          ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) / 4 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply div_le_div_of_nonneg_right _ (by linarith : (0 : ‚ĄĚ) ‚Č§ 4)
          exact mul_le_mul_of_nonneg_right hf_le hfactor_nn
      _ = (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / (4 * t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [one_mul]; field_simp

/-! ## Applications: heat-smoothed SQG quantities

Combining the heat smoothing bounds with SQG vorticity/strain structure.
-/

/-- **Heat-smoothed SQG vorticity ŠłĘňĘ bound.** The SQG vorticity after
heat smoothing, evaluated at `n ‚Č† 0`, satisfies

    `‚ÄĖheat(t,n) ¬∑ ŌČŐā(n) ¬∑ c‚ÄĖ¬≤ ‚Č§ exp(-1)/t ¬∑ ‚ÄĖc‚ÄĖ¬≤`

using vorticity identity `‚ÄĖŌČŐā(n)‚ÄĖ = ‚ÄĖn‚ÄĖ` and the k=1 parabolic smoothing.
This gives an L¬≤ bound on heat-smoothed vorticity independent of n's
frequency. -/
theorem heat_smoothed_vorticity_L2_mode {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * c‚ÄĖ ^ 2
    ‚Č§ Real.exp (-1) / t * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have : sqgVorticitySymbol 0 = 0 := by
      unfold sqgVorticitySymbol sqgGradSymbol derivSymbol rieszSymbol
      simp
    rw [this, mul_zero, zero_mul, norm_zero, sq, mul_zero]
    have : 0 ‚Č§ Real.exp (-1) / t * ‚ÄĖc‚ÄĖ ^ 2 := by
      apply mul_nonneg
      ¬∑ exact div_nonneg (Real.exp_pos _).le ht.le
      ¬∑ exact sq_nonneg _
    linarith
  ¬∑ -- Use the sqgVorticity_heat_smoothing_mode we already have
    rw [show ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * c
        = sqgVorticitySymbol n * ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c from by ring]
    exact sqgVorticity_heat_smoothing_mode ht hn c

/-- **Heat-smoothed SQG velocity ŠłĘňĘ ‚Č§ őł ŠłĘňĘ.** For the SQG velocity
`u = R_‚ä• őł` and its heat-smoothed version `e^{tőĒ} u`, combining Riesz
ŠłĘňĘ contractivity with heat ŠłĘňĘ contractivity gives:

    `‚ÄĖe^{tőĒ} u‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘňĘ}`

at every Sobolev level. Mode-level statement. -/
theorem heat_smoothed_sqg_velocity_mode (s : ‚ĄĚ) {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (n : Fin 2 ‚Üí ‚Ą§) (j : Fin 2) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 *
      ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) *
       (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) * c‚ÄĖ ^ 2
    ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  -- Combine Riesz contractivity with heat contractivity at mode level
  have hheat := heatSymbol_Hs_mode_bound ht s (c := c)
    (n := n)
  -- Step 1: ‚ÄĖheat ¬∑ riesz ¬∑ c‚ÄĖ¬≤ ‚Č§ ‚ÄĖriesz ¬∑ c‚ÄĖ¬≤ (heat contraction)
  -- Step 2: ŌÉ_s¬≤ ¬∑ ‚ÄĖriesz ¬∑ c‚ÄĖ¬≤ ‚Č§ ŌÉ_s¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤ (Riesz ŠłĘňĘ)
  have hcomb_expr : ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) *
      (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) * c
      = (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) *
        (((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c) := by ring
  rw [hcomb_expr]
  -- Now: ŌÉ_s¬≤ ¬∑ ‚ÄĖR ¬∑ (heat ¬∑ c)‚ÄĖ¬≤ ‚Č§ ŌÉ_s¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤
  -- Use: ŌÉ_s¬≤ ¬∑ ‚ÄĖR ¬∑ (heat ¬∑ c)‚ÄĖ¬≤ ‚Č§ ŌÉ_s¬≤ ¬∑ ‚ÄĖheat ¬∑ c‚ÄĖ¬≤ (Riesz contractive)
  --      ŌÉ_s¬≤ ¬∑ ‚ÄĖheat ¬∑ c‚ÄĖ¬≤ ‚Č§ ŌÉ_s¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤ (heat contractive)
  by_cases hn : n = 0
  ¬∑ subst hn
    by_cases hj : j = 0
    ¬∑ simp [hj, rieszSymbol_zero, fracDerivSymbol_zero]
    ¬∑ simp [hj, rieszSymbol_zero, fracDerivSymbol_zero]
  ¬∑ have hR_le : ‚ÄĖ(if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n)‚ÄĖ ^ 2 ‚Č§ 1 := by
      have hpyth := rieszSymbol_sum_sq hn
      simp only [Fin.sum_univ_two] at hpyth
      by_cases hj : j = 0
      ¬∑ simp [hj]; nlinarith [sq_nonneg ‚ÄĖrieszSymbol 0 n‚ÄĖ]
      ¬∑ simp [hj, norm_neg]; nlinarith [sq_nonneg ‚ÄĖrieszSymbol 1 n‚ÄĖ]
    have hR_Hs_bound : (fracDerivSymbol s n) ^ 2 *
        ‚ÄĖ(if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) *
          (((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c)‚ÄĖ ^ 2
        ‚Č§ (fracDerivSymbol s n) ^ 2 *
          ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2 := by
      rw [norm_mul, mul_pow]
      have hŌÉs_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
      have hhc_nn : 0 ‚Č§ ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2 := sq_nonneg _
      calc (fracDerivSymbol s n) ^ 2 *
            (‚ÄĖ(if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n)‚ÄĖ ^ 2
              * ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2)
          ‚Č§ (fracDerivSymbol s n) ^ 2 *
            (1 * ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2) :=
            mul_le_mul_of_nonneg_left
              (mul_le_mul_of_nonneg_right hR_le hhc_nn)
              hŌÉs_nn
        _ = (fracDerivSymbol s n) ^ 2 *
            ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2 := by ring
    exact le_trans hR_Hs_bound hheat

/-- **Heat-smoothed SQG velocity gradient L¬≤ bound.** Each gradient
component after heat smoothing:

    `‚ÄĖheat(t,n) ¬∑ ‚ąāŐā_i u_j(n) ¬∑ c‚ÄĖ¬≤ ‚Č§ exp(-1)/t ¬∑ ‚ÄĖc‚ÄĖ¬≤`

Proof: `‚ÄĖ‚ąāŐā_i u_j(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ`, so `‚ÄĖheat¬∑‚ąāu¬∑c‚ÄĖ¬≤ = heat¬≤¬∑‚ÄĖ‚ąāu‚ÄĖ¬≤¬∑‚ÄĖc‚ÄĖ¬≤ ‚Č§
heat¬∑(L¬≤¬∑heat)¬∑‚ÄĖc‚ÄĖ¬≤ ‚Č§ heat¬∑exp(-1)/t¬∑‚ÄĖc‚ÄĖ¬≤ ‚Č§ exp(-1)/t¬∑‚ÄĖc‚ÄĖ¬≤`. -/
theorem heat_smoothed_sqgGrad_L2_mode {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (i j : Fin 2) (c : ‚Ąā) :
    ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgGradSymbol i j n * c‚ÄĖ ^ 2
    ‚Č§ Real.exp (-1) / t * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have : sqgGradSymbol i j 0 = 0 := by
      unfold sqgGradSymbol derivSymbol rieszSymbol; simp
    rw [this, mul_zero, zero_mul, norm_zero, sq, mul_zero]
    have : 0 ‚Č§ Real.exp (-1) / t * ‚ÄĖc‚ÄĖ ^ 2 :=
      mul_nonneg (div_nonneg (Real.exp_pos _).le ht.le) (sq_nonneg _)
    linarith
  ¬∑ -- ‚ÄĖheat¬∑‚ąāu¬∑c‚ÄĖ¬≤ = heat¬≤¬∑‚ÄĖ‚ąāu‚ÄĖ¬≤¬∑‚ÄĖc‚ÄĖ¬≤
    rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
      Real.norm_of_nonneg (heatSymbol_nonneg t n)]
    have hgrad := sqgGrad_norm_le hn i j
    have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
    have hheat_le : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht.le n
    have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
    have hgrad_sq_le : ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
      sq_le_sq' (by linarith [norm_nonneg (sqgGradSymbol i j n)]) hgrad
    have hL_sq_heat := latticeNorm_sq_mul_heat_le ht n
    -- Goal: heat¬≤ ¬∑ ‚ÄĖ‚ąāu‚ÄĖ¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤ ‚Č§ exp(-1)/t ¬∑ ‚ÄĖc‚ÄĖ¬≤
    calc (heatSymbol t n) ^ 2 * ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
        ‚Č§ (heatSymbol t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply mul_le_mul_of_nonneg_left hgrad_sq_le (sq_nonneg _)
      _ = heatSymbol t n * ((latticeNorm n) ^ 2 * heatSymbol t n) * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [sq]; ring
      _ ‚Č§ heatSymbol t n * (Real.exp (-1) / t) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply mul_le_mul_of_nonneg_left hL_sq_heat hheat_nn
      _ ‚Č§ 1 * (Real.exp (-1) / t) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply mul_le_mul_of_nonneg_right hheat_le
          exact div_nonneg (Real.exp_pos _).le ht.le
      _ = Real.exp (-1) / t * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-- **Heat-smoothed SQG strain L¬≤ bound.** Analogous to the velocity
gradient bound. -/
theorem heat_smoothed_sqgStrain_L2_mode {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (i j : Fin 2) (c : ‚Ąā) :
    ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol i j n * c‚ÄĖ ^ 2
    ‚Č§ Real.exp (-1) / t * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have : sqgStrainSymbol i j 0 = 0 := by
      unfold sqgStrainSymbol sqgGradSymbol derivSymbol rieszSymbol; simp
    rw [this, mul_zero, zero_mul, norm_zero, sq, mul_zero]
    have : 0 ‚Č§ Real.exp (-1) / t * ‚ÄĖc‚ÄĖ ^ 2 :=
      mul_nonneg (div_nonneg (Real.exp_pos _).le ht.le) (sq_nonneg _)
    linarith
  ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
      Real.norm_of_nonneg (heatSymbol_nonneg t n)]
    have hstrain := sqgStrain_norm_le hn i j
    have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
    have hheat_le : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht.le n
    have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
    have hstrain_sq_le : ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
      sq_le_sq' (by linarith [norm_nonneg (sqgStrainSymbol i j n)]) hstrain
    have hL_sq_heat := latticeNorm_sq_mul_heat_le ht n
    calc (heatSymbol t n) ^ 2 * ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
        ‚Č§ (heatSymbol t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply mul_le_mul_of_nonneg_left hstrain_sq_le (sq_nonneg _)
      _ = heatSymbol t n * ((latticeNorm n) ^ 2 * heatSymbol t n) * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [sq]; ring
      _ ‚Č§ heatSymbol t n * (Real.exp (-1) / t) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply mul_le_mul_of_nonneg_left hL_sq_heat hheat_nn
      _ ‚Č§ 1 * (Real.exp (-1) / t) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply mul_le_mul_of_nonneg_right hheat_le
          exact div_nonneg (Real.exp_pos _).le ht.le
      _ = Real.exp (-1) / t * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-- **Heat-smoothed strain (0,0) ‚ÄĒ tight bound.** Using tight
`|S‚āÄ‚āÄ(n)|¬≤ ‚Č§ ‚ÄĖn‚ÄĖ¬≤/4`:

    `‚ÄĖheat(t,n)¬∑S‚āÄ‚āÄ(n)¬∑c‚ÄĖ¬≤ ‚Č§ exp(-1)/(4t) ¬∑ ‚ÄĖc‚ÄĖ¬≤`

This is 4√ó sharper than `heat_smoothed_sqgStrain_L2_mode`. -/
theorem heat_smoothed_sqgStrain_00_L2_mode_tight {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol 0 0 n * c‚ÄĖ ^ 2
    ‚Č§ Real.exp (-1) / (4 * t) * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have : sqgStrainSymbol 0 0 0 = 0 := by
      unfold sqgStrainSymbol sqgGradSymbol derivSymbol rieszSymbol; simp
    rw [this, mul_zero, zero_mul, norm_zero, sq, mul_zero]
    have : 0 ‚Č§ Real.exp (-1) / (4 * t) * ‚ÄĖc‚ÄĖ ^ 2 := by
      apply mul_nonneg
      ¬∑ apply div_nonneg (Real.exp_pos _).le; linarith
      ¬∑ exact sq_nonneg _
    linarith
  ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
      Real.norm_of_nonneg (heatSymbol_nonneg t n)]
    have hstrain_tight := sqgStrain_00_sq_le_quarter hn
    have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
    have hheat_le : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht.le n
    have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
    have hL_sq_heat := latticeNorm_sq_mul_heat_le ht n
    calc (heatSymbol t n) ^ 2 * ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
        ‚Č§ (heatSymbol t n) ^ 2 * ((latticeNorm n) ^ 2 / 4) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply mul_le_mul_of_nonneg_left hstrain_tight (sq_nonneg _)
      _ = heatSymbol t n * ((latticeNorm n) ^ 2 * heatSymbol t n) / 4 * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [sq]; ring
      _ ‚Č§ heatSymbol t n * (Real.exp (-1) / t) / 4 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply div_le_div_of_nonneg_right _ (by linarith : (0 : ‚ĄĚ) ‚Č§ 4)
          exact mul_le_mul_of_nonneg_left hL_sq_heat hheat_nn
      _ ‚Č§ 1 * (Real.exp (-1) / t) / 4 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply div_le_div_of_nonneg_right _ (by linarith : (0 : ‚ĄĚ) ‚Č§ 4)
          apply mul_le_mul_of_nonneg_right hheat_le
          exact div_nonneg (Real.exp_pos _).le ht.le
      _ = Real.exp (-1) / (4 * t) * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [one_mul]; field_simp

/-- **Heat-smoothed strain (0,1) ‚ÄĒ tight bound.** -/
theorem heat_smoothed_sqgStrain_01_L2_mode_tight {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol 0 1 n * c‚ÄĖ ^ 2
    ‚Č§ Real.exp (-1) / (4 * t) * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
