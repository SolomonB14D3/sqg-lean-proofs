    lp (fun _ : Fin 2 ‚Üí ‚Ą§ => ‚Ąā) 2 := by
  refine ‚ü®b, ?_‚ü©
  have hp : (0 : ‚ĄĚ) < (2 : ENNReal).toReal := by
    rw [ENNReal.toReal_ofNat]; norm_num
