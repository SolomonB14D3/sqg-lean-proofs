        ¬∑ have h_abs : |t - s| = s - t := by
            rw [abs_of_nonpos (sub_nonpos.mpr hts), neg_sub]
          rw [h_abs]
          have h_bound : ‚ąÄ ŌĄ ‚ąą Set.Ico t s,
              ‚ÄĖgalerkinRHS (sqgBox n)
                (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m‚ÄĖ
                ‚Č§ Real.sqrt K * fracDerivSymbol 2 m := by
            intro ŌĄ hŌĄ
