/-! ## Negative-order fractional derivative (őõ^{-s})

The multiplier `őõ^{-s}(n) = ‚ÄĖn‚ÄĖ^{-s}` for `n ‚Č† 0`, zero at `n = 0`.
This is the inverse of `őõ^s = (-őĒ)^{s/2}` on mean-zero functions.
Useful for Biot-Savart-like integrations and Sobolev embeddings.

We already have `fracDerivSymbol` which is `‚ÄĖn‚ÄĖ^s` for any real `s`.
For `s > 0` this is the positive-order; for `s < 0` it's the negative-order.
-/

/-- **Fractional Laplacian inverse symbol.** For `n ‚Č† 0`:

    `őõ^{-s}(n) = ‚ÄĖn‚ÄĖ^{-s} = 1/ŌÉ_s(n)`

and `0` at `n = 0`. This is `fracDerivSymbol (-s) n`. -/
lemma fracDerivSymbol_neg_inv {s : ‚ĄĚ} {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) (_hs : 0 < s) :
    fracDerivSymbol (-s) n * fracDerivSymbol s n = 1 := by
  rw [fracDerivSymbol_of_ne_zero _ hn, fracDerivSymbol_of_ne_zero _ hn]
  have hL_pos := latticeNorm_pos hn
  rw [‚Üź Real.rpow_add hL_pos]
  simp [Real.rpow_zero]

/-- **őõ^{-s} ¬∑ őõ^s = 1 at each nonzero mode (squared form).** -/
lemma fracDerivSymbol_sq_neg_inv {s : ‚ĄĚ} {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    (fracDerivSymbol (-s) n) ^ 2 * (fracDerivSymbol s n) ^ 2 = 1 := by
  rw [fracDerivSymbol_of_ne_zero _ hn, fracDerivSymbol_of_ne_zero _ hn]
  have hL_pos := latticeNorm_pos hn
  have hL_nn := latticeNorm_nonneg n
  rw [show ((latticeNorm n) ^ (-s)) ^ 2 * ((latticeNorm n) ^ s) ^ 2
      = ((latticeNorm n) ^ (-s) * (latticeNorm n) ^ s) ^ 2 from by ring]
  rw [‚Üź Real.rpow_add hL_pos, show (-s + s : ‚ĄĚ) = 0 from by ring, Real.rpow_zero]
  ring

/-- **Negative-order gain.** Applying `őõ^{-s}` to `c` gives a ŠłĘňĘ bound
by the `L¬≤` norm of `c` at each mode `n ‚Č† 0`:

    `ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖőõ^{-s}(n) ¬∑ c‚ÄĖ¬≤ = ‚ÄĖc‚ÄĖ¬≤`

i.e., the composition `őõ^s ‚ąė őõ^{-s}` is the identity. -/
theorem fracDerivSymbol_neg_Hs_equals_L2 {s : ‚ĄĚ} {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 *
      ‚ÄĖ((fracDerivSymbol (-s) n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    = ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (fracDerivSymbol_nonneg _ _)]
  rw [show (fracDerivSymbol s n) ^ 2 *
      ((fracDerivSymbol (-s) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ((fracDerivSymbol s n) ^ 2 * (fracDerivSymbol (-s) n) ^ 2) * ‚ÄĖc‚ÄĖ ^ 2 from by ring]
  rw [show (fracDerivSymbol s n) ^ 2 * (fracDerivSymbol (-s) n) ^ 2
      = (fracDerivSymbol (-s) n) ^ 2 * (fracDerivSymbol s n) ^ 2 from by ring]
  rw [fracDerivSymbol_sq_neg_inv hn, one_mul]

/-- **ŠłĘňĘ-to-L¬≤ mapping via őõ^{-s}.** For `s > 0`, the operator
`őõ^{-s}` maps `L¬≤` functions into `ŠłĘňĘ` (and vice versa). Mode-level
bound that the multiplier `őõ^{-s}` satisfies:

    `‚ÄĖőõ^{-s}(n)‚ÄĖ ‚Č§ 1`  for all `n ‚Č† 0`.

(i.e., `őõ^{-s}` is `L¬≤`-contractive on integer lattice with `s ‚Č• 0`.) -/
theorem fracDerivSymbol_neg_bound_on_lattice {s : ‚ĄĚ} (hs : 0 ‚Č§ s)
    {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    fracDerivSymbol (-s) n ‚Č§ 1 := by
  rw [fracDerivSymbol_of_ne_zero _ hn]
  have hL : 1 ‚Č§ latticeNorm n := latticeNorm_ge_one_of_ne_zero hn
  have hL_pos : 0 < latticeNorm n := latticeNorm_pos hn
  rw [show (latticeNorm n) ^ (-s) = 1 / (latticeNorm n) ^ s from by
    rw [Real.rpow_neg (le_of_lt hL_pos)]; field_simp]
  rw [div_le_one (Real.rpow_pos_of_pos hL_pos s)]
  calc (1 : ‚ĄĚ) = (1 : ‚ĄĚ) ^ s := by rw [Real.one_rpow]
    _ ‚Č§ (latticeNorm n) ^ s := Real.rpow_le_rpow (by norm_num) hL hs

/-! ## Poisson semigroup (őĪ=1/2 fractional heat)

The Poisson semigroup `e^{-t¬∑őõ}` (where `őõ = (-őĒ)^{1/2}`) has Fourier
multiplier `exp(-t¬∑‚ÄĖn‚ÄĖ)`. This corresponds to `őĪ=1/2` in the fractional
heat family. Useful for critical SQG analysis.
-/

/-- **Poisson semigroup symbol.** For `t ‚Č• 0`:

    `P_t(n) = exp(-t¬∑‚ÄĖn‚ÄĖ)`. -/
noncomputable def poissonSymbol {d : Type*} [Fintype d]
    (t : ‚ĄĚ) (n : d ‚Üí ‚Ą§) : ‚ĄĚ :=
  Real.exp (-t * latticeNorm n)

@[simp] lemma poissonSymbol_zero_mode {d : Type*} [Fintype d] (t : ‚ĄĚ) :
    poissonSymbol t (0 : d ‚Üí ‚Ą§) = 1 := by
  unfold poissonSymbol
  simp [latticeNorm]

lemma poissonSymbol_pos {d : Type*} [Fintype d] (t : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    0 < poissonSymbol t n := Real.exp_pos _

lemma poissonSymbol_nonneg {d : Type*} [Fintype d] (t : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    0 ‚Č§ poissonSymbol t n := (poissonSymbol_pos t n).le

@[simp] lemma poissonSymbol_zero_time {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    poissonSymbol 0 n = 1 := by
  unfold poissonSymbol
  simp

/-- **Poisson ‚Č§ 1 for t ‚Č• 0.** -/
lemma poissonSymbol_le_one {d : Type*} [Fintype d] {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (n : d ‚Üí ‚Ą§) : poissonSymbol t n ‚Č§ 1 := by
  unfold poissonSymbol
  rw [show (1 : ‚ĄĚ) = Real.exp 0 from Real.exp_zero.symm]
  apply Real.exp_le_exp.mpr
  have := latticeNorm_nonneg n
  nlinarith

/-- **Poisson semigroup: additive in time.** -/
lemma poissonSymbol_add {d : Type*} [Fintype d] (t‚āĀ t‚āā : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    poissonSymbol (t‚āĀ + t‚āā) n = poissonSymbol t‚āĀ n * poissonSymbol t‚āā n := by
  unfold poissonSymbol
  rw [‚Üź Real.exp_add]
  congr 1; ring

/-- **Poisson is őĪ=1/2 case of fracHeat.** -/
theorem fracHeatSymbol_half_eq_poisson (t : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§) :
    fracHeatSymbol (1/2) t n = poissonSymbol t n := by
  unfold fracHeatSymbol poissonSymbol
  congr 1
  have hL_nn : 0 ‚Č§ (latticeNorm n : ‚ĄĚ) := latticeNorm_nonneg n
  rw [show ((latticeNorm n : ‚ĄĚ) : ‚ĄĚ) ^ (2 * (1/2 : ‚ĄĚ)) = latticeNorm n from by
    rw [show (2 * (1/2) : ‚ĄĚ) = (1 : ‚ĄĚ) from by norm_num, Real.rpow_one]]

/-- **Poisson smoothing at gradient level.** For `t > 0`:

    `‚ÄĖn‚ÄĖ ¬∑ exp(-t¬∑‚ÄĖn‚ÄĖ) ‚Č§ exp(-1) / t`

Proof: set `y = t¬∑‚ÄĖn‚ÄĖ`, use the tangent-line inequality
`x ¬∑ exp(-x) ‚Č§ exp(-1)` with `x = y`. -/
theorem latticeNorm_mul_poisson_le {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm n : ‚ĄĚ) * poissonSymbol t n ‚Č§ Real.exp (-1) / t := by
  have h := latticeNorm_rpow_mul_fracHeat_le (őĪ := 1/2) (by norm_num : (0:‚ĄĚ) < 1/2) ht n
  rw [fracHeatSymbol_half_eq_poisson,
    show (2 * (1/2:‚ĄĚ)) = 1 from by norm_num, Real.rpow_one] at h
  exact h

/-- **Poisson smoothing for `ŌÉ_1(n) = ‚ÄĖn‚ÄĖ`.** -/
theorem fracDerivSymbol_1_mul_poisson_le {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    fracDerivSymbol 1 n * poissonSymbol t n ‚Č§ Real.exp (-1) / t := by
  by_cases hn : n = 0
  ¬∑ subst hn
    rw [fracDerivSymbol_zero]
    simp
    positivity
  ¬∑ rw [fracDerivSymbol_one_eq hn]
    exact latticeNorm_mul_poisson_le ht n

/-- **Poisson L¬≤-contractivity (mode-level).** For `t ‚Č• 0`:

    `‚ÄĖP_t(n) ¬∑ c‚ÄĖ¬≤ ‚Č§ ‚ÄĖc‚ÄĖ¬≤`. -/
theorem poissonSymbol_L2_mode_contract {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    ‚ÄĖ((poissonSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [‚Üź fracHeatSymbol_half_eq_poisson]
  exact fracHeatSymbol_L2_mode_contract (by norm_num : (0:‚ĄĚ) < 1/2) ht n c

/-- **Poisson semigroup rpow identity.** For `k > 0`, `t : ‚ĄĚ`:

    `poissonSymbol t n = (poissonSymbol (t/k) n)^k`. -/
theorem poissonSymbol_rpow_eq {t : ‚ĄĚ} (n : Fin 2 ‚Üí ‚Ą§) {k : ‚ĄĚ} (hk : 0 < k) :
    poissonSymbol t n = (poissonSymbol (t / k) n) ^ k := by
  unfold poissonSymbol
  rw [Real.rpow_def_of_pos (Real.exp_pos _), Real.log_exp]
  congr 1
  have hk_ne : k ‚Č† 0 := hk.ne'
  field_simp

/-- **General Poisson smoothing at real k > 0.** For `k > 0`, `t > 0`:

    `‚ÄĖn‚ÄĖ^k ¬∑ exp(-t¬∑‚ÄĖn‚ÄĖ) ‚Č§ k^k ¬∑ exp(-k) / t^k`

using `rpow`. -/
theorem latticeNorm_rpow_mul_poisson_le {k : ‚ĄĚ} (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm n) ^ k * poissonSymbol t n
    ‚Č§ k ^ k * Real.exp (-k) / t ^ k := by
  have h := latticeNorm_rpow_mul_fracHeat_le_general
    (by norm_num : (0:‚ĄĚ) < 1/2) hk ht n
  rw [fracHeatSymbol_half_eq_poisson,
    show (k / (2 * (1/2:‚ĄĚ))) = k from by field_simp] at h
  exact h

/-- **Poisson smoothing at fracDerivSymbol level.** For `k > 0`, `t > 0`:

    `ŌÉ_k(n) ¬∑ poisson(t, n) ‚Č§ k^k ¬∑ exp(-k) / t^k` -/
theorem fracDerivSymbol_mul_poisson_le_rpow {k : ‚ĄĚ} (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    fracDerivSymbol k n * poissonSymbol t n
    ‚Č§ k ^ k * Real.exp (-k) / t ^ k := by
  by_cases hn : n = 0
  ¬∑ subst hn
    rw [fracDerivSymbol_zero]
    simp
    have : 0 < k ^ k * Real.exp (-k) / t ^ k := by
      have hk_pos : 0 < k ^ k := Real.rpow_pos_of_pos hk k
      have ht_pos : 0 < t ^ k := Real.rpow_pos_of_pos ht k
      positivity
    linarith
  ¬∑ rw [fracDerivSymbol_of_ne_zero k hn]
    exact latticeNorm_rpow_mul_poisson_le hk ht n

/-- **Poisson ŠłĘŠĶŹ mode bound at real k > 0.** Using `‚ÄĖn‚ÄĖ^k¬∑poisson(t,n) ‚Č§
k^k¬∑exp(-k)/t^k` and `poisson ‚Č§ 1`:

    `ŌÉ_k(n) ¬∑ ‚ÄĖpoisson(t,n) ¬∑ c‚ÄĖ¬≤ ‚Č§ (k^k ¬∑ exp(-k) / t^k)^? ¬∑ ‚ÄĖc‚ÄĖ¬≤`

Wait, this bound has a different structure than heat because Poisson
scales with ŌÉ_k (not ŌÉ_{2k}). Let me state the correct bound:

    `ŌÉ_k(n)¬≤ ¬∑ ‚ÄĖpoisson(t,n) ¬∑ c‚ÄĖ¬≤ ‚Č§ ŌÉ_k(n) ¬∑ (k^k¬∑exp(-k)/t^k) ¬∑ ‚ÄĖc‚ÄĖ¬≤`

which uses `ŌÉ_k ¬∑ poisson¬≤ ‚Č§ ŌÉ_k ¬∑ poisson ‚Č§ k^k¬∑exp(-k)/t^k`. So:

    `ŌÉ_k(n)¬≤ ¬∑ ‚ÄĖpoisson(t,n) ¬∑ c‚ÄĖ¬≤ ‚Č§ ŌÉ_k(n) ¬∑ (k^k¬∑exp(-k)/t^k) ¬∑ ‚ÄĖc‚ÄĖ¬≤`

At each individual mode. -/
theorem poissonSymbol_Hk_mode_bound {k : ‚ĄĚ} (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    fracDerivSymbol k n * ‚ÄĖ((poissonSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ (k ^ k * Real.exp (-k) / t ^ k) * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (poissonSymbol_nonneg t n)]
  have hmain := fracDerivSymbol_mul_poisson_le_rpow hk ht n
  have hp_nn : 0 ‚Č§ poissonSymbol t n := poissonSymbol_nonneg t n
  have hp_le : poissonSymbol t n ‚Č§ 1 := poissonSymbol_le_one ht.le n
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hfactor_nn : 0 ‚Č§ k ^ k * Real.exp (-k) / t ^ k := by
    have hk_pos : 0 < k ^ k := Real.rpow_pos_of_pos hk k
    have ht_pos : 0 < t ^ k := Real.rpow_pos_of_pos ht k
    positivity
  calc fracDerivSymbol k n * ((poissonSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = (fracDerivSymbol k n * poissonSymbol t n)
        * (poissonSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) := by rw [sq]; ring
    _ ‚Č§ (k ^ k * Real.exp (-k) / t ^ k) * (poissonSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right hmain (mul_nonneg hp_nn hc_nn)
    _ ‚Č§ (k ^ k * Real.exp (-k) / t ^ k) * (1 * ‚ÄĖc‚ÄĖ ^ 2) := by
        apply mul_le_mul_of_nonneg_left _ hfactor_nn
        exact mul_le_mul_of_nonneg_right hp_le hc_nn
    _ = (k ^ k * Real.exp (-k) / t ^ k) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-! ## Integrated tight ŠłĘňĘ strain identity

Lifts the mode-level tight bound `|S‚āÄ‚āÄ(n)|¬≤ + |S‚āÄ‚āĀ(n)|¬≤ = ‚ÄĖn‚ÄĖ¬≤/4`
to integrated ŠłĘňĘ seminorms.
-/

/-- **Tight ŠłĘňĘ strain identity (integrated sum of S‚āÄ‚āÄ + S‚āÄ‚āĀ).**
For SQG with strain components `S‚āÄ‚āÄ, S‚āÄ‚āĀ` related to `őł` by Fourier
multipliers `sqgStrainSymbol 0 0, sqgStrainSymbol 0 1`:

    `‚ÄĖS‚āÄ‚āÄ‚ÄĖ¬≤_{ŠłĘňĘ} + ‚ÄĖS‚āÄ‚āĀ‚ÄĖ¬≤_{ŠłĘňĘ} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}} / 4`

This is an exact equality at every Sobolev level `s`. Uses the mode-level
tight identity `|S‚āÄ‚āÄ(n)|¬≤ + |S‚āÄ‚āĀ(n)|¬≤ = ‚ÄĖn‚ÄĖ¬≤/4`. -/
theorem sqgStrain_00_01_Hs_sum_eq
    (s : ‚ĄĚ)
    (őł S00 S01 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff0 : ‚ąÄ n, mFourierCoeff S00 n = sqgStrainSymbol 0 0 n * mFourierCoeff őł n)
    (hcoeff1 : ‚ąÄ n, mFourierCoeff S01 n = sqgStrainSymbol 0 1 n * mFourierCoeff őł n)
    (hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s S00 + hsSeminormSq s S01 = hsSeminormSq (s + 1) őł / 4 := by
  unfold hsSeminormSq
  -- Establish summabilities first
  have hsum0 : Summable (fun n ‚Ü¶ fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS00) n‚ÄĖ ^ 2) := by
    apply hsum.of_nonneg_of_le
    ¬∑ intro n; exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      by_cases hn : n = 0
      ¬∑ subst hn
        rw [hcoeff0 0]
        simp [sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol,
          fracDerivSymbol_zero]
      ¬∑ rw [hcoeff0 n, norm_mul, mul_pow]
        have h00 := sqgStrain_00_sq_le_quarter hn
        have hŌÉs_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
        have hc_nn : 0 ‚Č§ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := sq_nonneg _
        have hfrac := fracDerivSymbol_add_sq s 1 n
        have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
          rw [fracDerivSymbol_one_eq hn]
        calc (fracDerivSymbol s n) ^ 2 *
              (‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
            = ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 *
              ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by ring
          _ ‚Č§ ((latticeNorm n) ^ 2 / 4) *
              ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
              mul_le_mul_of_nonneg_right h00 (mul_nonneg hŌÉs_nn hc_nn)
          _ ‚Č§ (latticeNorm n) ^ 2 *
              ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
              apply mul_le_mul_of_nonneg_right _ (mul_nonneg hŌÉs_nn hc_nn)
              have : 0 ‚Č§ (latticeNorm n) ^ 2 := sq_nonneg _; linarith
          _ = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
              rw [hfrac, hfrac1]; ring
  have hsum1 : Summable (fun n ‚Ü¶ fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS01) n‚ÄĖ ^ 2) := by
    apply hsum.of_nonneg_of_le
    ¬∑ intro n; exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      by_cases hn : n = 0
      ¬∑ subst hn
        rw [hcoeff1 0]
        simp [sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol,
          fracDerivSymbol_zero]
      ¬∑ rw [hcoeff1 n, norm_mul, mul_pow]
        have h01 := sqgStrain_01_sq_le_quarter hn
        have hŌÉs_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
        have hc_nn : 0 ‚Č§ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := sq_nonneg _
        have hfrac := fracDerivSymbol_add_sq s 1 n
        have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
          rw [fracDerivSymbol_one_eq hn]
        calc (fracDerivSymbol s n) ^ 2 *
              (‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
            = ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 *
              ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by ring
          _ ‚Č§ ((latticeNorm n) ^ 2 / 4) *
              ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
              mul_le_mul_of_nonneg_right h01 (mul_nonneg hŌÉs_nn hc_nn)
          _ ‚Č§ (latticeNorm n) ^ 2 *
              ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
              apply mul_le_mul_of_nonneg_right _ (mul_nonneg hŌÉs_nn hc_nn)
              have : 0 ‚Č§ (latticeNorm n) ^ 2 := sq_nonneg _; linarith
          _ = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
              rw [hfrac, hfrac1]; ring
  -- Establish the pointwise identity
  have hpt : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS00) n‚ÄĖ ^ 2
        + fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS01) n‚ÄĖ ^ 2
      = fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 / 4 := by
    intro n
    rw [hcoeff0 n, hcoeff1 n]
    by_cases hn : n = 0
    ¬∑ subst hn
      simp [sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol,
        fracDerivSymbol_zero]
    ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow]
      have htight := sqgStrain_eigenvalue_tight hn
      have hfrac := fracDerivSymbol_add_sq s 1 n
      have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
        rw [fracDerivSymbol_one_eq hn]
      rw [show fracDerivSymbol s n ^ 2 *
          (‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
          + fracDerivSymbol s n ^ 2 *
          (‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
          = fracDerivSymbol s n ^ 2 *
            ((‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2) *
             ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2) from by ring]
      rw [htight, hfrac, hfrac1]; ring
  -- Now the sum identity follows by tsum_add and tsum_div_const
  have hsum_add : Summable (fun n ‚Ü¶
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS00) n‚ÄĖ ^ 2
      + fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS01) n‚ÄĖ ^ 2) :=
    hsum0.add hsum1
  have step1 : (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), fracDerivSymbol s n ^ 2 *
      ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS00) n‚ÄĖ ^ 2) +
      (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), fracDerivSymbol s n ^ 2 *
        ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS01) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
          (fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS00) n‚ÄĖ ^ 2
            + fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS01) n‚ÄĖ ^ 2) :=
    (hsum0.tsum_add hsum1).symm
  rw [step1]
  rw [show (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), fracDerivSymbol (s + 1) n ^ 2 *
            ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2) / 4
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), fracDerivSymbol (s + 1) n ^ 2 *
            ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 / 4 from by rw [tsum_div_const]]
  exact tsum_congr hpt

/-- **L¬≤ strain tight identity (from ŠłĘ‚Āį specialization).**

    `‚ÄĖS‚āÄ‚āÄ‚ÄĖ¬≤_{ŠłĘ‚Āį} + ‚ÄĖS‚āÄ‚āĀ‚ÄĖ¬≤_{ŠłĘ‚Āį} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ} / 4`

At mean-zero functions, ŠłĘ‚Āį = L¬≤ so this is the L¬≤-level strain tight
identity. -/
theorem sqgStrain_00_01_L2_tight_eq
    (őł S00 S01 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff0 : ‚ąÄ n, mFourierCoeff S00 n = sqgStrainSymbol 0 0 n * mFourierCoeff őł n)
    (hcoeff1 : ‚ąÄ n, mFourierCoeff S01 n = sqgStrainSymbol 0 1 n * mFourierCoeff őł n)
    (hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq 0 S00 + hsSeminormSq 0 S01 = hsSeminormSq 1 őł / 4 := by
  have h := sqgStrain_00_01_Hs_sum_eq 0 őł S00 S01 hcoeff0 hcoeff1
    (by simpa using hsum)
  simpa using h

/-! ## Poisson semigroup: integrated contractivity -/

/-- **Poisson L¬≤ contractivity (integrated).** For `t ‚Č• 0`:

    `‚ÄĖP_t f‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}`

where `P_t f` has Fourier coefficients `poissonSymbol(t,n) ¬∑ fŐā(n)`. -/
theorem poissonSymbol_L2_contractivity {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((poissonSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hf_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) (‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2))
    (hu_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2) (‚ąę x, ‚ÄĖu x‚ÄĖ ^ 2))
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    (‚ąę x, ‚ÄĖu x‚ÄĖ ^ 2) ‚Č§ (‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2) := by
  apply fracHeatSymbol_L2_contractivity (by norm_num : (0:‚ĄĚ) < 1/2) ht f u _
    hf_parseval hu_parseval hsum
  intro n; rw [hcoeff n, ‚Üź fracHeatSymbol_half_eq_poisson]

/-- **Poisson ŠłĘňĘ contractivity (integrated).** For `t ‚Č• 0`, any `s`:

    `‚ÄĖP_t f‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}` -/
theorem poissonSymbol_Hs_contractivity {s : ‚ĄĚ} {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((poissonSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hsum : Summable (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq s f := by
  apply fracHeatSymbol_Hs_contractivity (by norm_num : (0:‚ĄĚ) < 1/2) ht f u _ hsum
  intro n; rw [hcoeff n, ‚Üź fracHeatSymbol_half_eq_poisson]

/-- **Heat-smoothed SQG vorticity integrated L¬≤ bound.** For `t > 0`:

    `‚ÄĖe^{tőĒ} ŌČ‚ÄĖ¬≤_{L¬≤} ‚Č§ exp(-1)/t ¬∑ ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}`

where `ŌČ` is the SQG vorticity (so `ŌČŐā = sqgVorticitySymbol ¬∑ őłŐā`).
The heat smoothing at `t > 0` converts the ŠłĘ¬Ļ-level vorticity into an
L¬≤-level quantity with parabolic decay `exp(-1)/t`. -/
theorem heat_smoothed_vorticity_L2_integrated {t : ‚ĄĚ} (ht : 0 < t)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * mFourierCoeff őł n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
    ‚Č§ Real.exp (-1) / t * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
  rw [show Real.exp (-1) / t *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        Real.exp (-1) / t * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 from
    (tsum_mul_left).symm]
  -- Establish the mode-level bound first
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * mFourierCoeff őł n‚ÄĖ ^ 2
      ‚Č§ Real.exp (-1) / t * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
    intro n
    by_cases hn : n = 0
    ¬∑ subst hn
      have hŌČ0 : sqgVorticitySymbol 0 = 0 := by
        unfold sqgVorticitySymbol sqgGradSymbol derivSymbol rieszSymbol; simp
      rw [hŌČ0, mul_zero, zero_mul, norm_zero, sq, mul_zero]
      exact mul_nonneg (div_nonneg (Real.exp_pos _).le ht.le) (sq_nonneg _)
    ¬∑ rw [show ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * mFourierCoeff őł n
          = sqgVorticitySymbol n * ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff őł n from by ring]
      exact sqgVorticity_heat_smoothing_mode ht hn (mFourierCoeff őł n)
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶ ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
  ¬∑ intro n; rw [hcoeff n]; exact hmode n
  ¬∑ apply (hsum.mul_left (Real.exp (-1) / t)).of_nonneg_of_le
    ¬∑ intro n; positivity
    ¬∑ intro n; rw [hcoeff n]; exact hmode n
  ¬∑ exact hsum.mul_left _

/-- **Heat-smoothed SQG gradient integrated L¬≤ bound.** For `t > 0`:

    `‚ÄĖe^{tőĒ} ‚ąā_i u_j‚ÄĖ¬≤_{L¬≤} ‚Č§ exp(-1)/t ¬∑ ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}` -/
theorem heat_smoothed_sqgGrad_L2_integrated {t : ‚ĄĚ} (ht : 0 < t)
    (i j : Fin 2)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgGradSymbol i j n * mFourierCoeff őł n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
    ‚Č§ Real.exp (-1) / t * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
  rw [show Real.exp (-1) / t *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        Real.exp (-1) / t * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 from
    (tsum_mul_left).symm]
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶ ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
  ¬∑ intro n
    rw [hcoeff n]
    exact heat_smoothed_sqgGrad_L2_mode ht n i j (mFourierCoeff őł n)
  ¬∑ apply (hsum.mul_left (Real.exp (-1) / t)).of_nonneg_of_le
    ¬∑ intro n; exact sq_nonneg _
    ¬∑ intro n
      rw [hcoeff n]
      exact heat_smoothed_sqgGrad_L2_mode ht n i j (mFourierCoeff őł n)
  ¬∑ exact hsum.mul_left _

/-- **Heat-smoothed SQG strain integrated L¬≤ bound.** For `t > 0`:

    `‚ÄĖe^{tőĒ} S_{ij}‚ÄĖ¬≤_{L¬≤} ‚Č§ exp(-1)/t ¬∑ ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}` -/
theorem heat_smoothed_sqgStrain_L2_integrated {t : ‚ĄĚ} (ht : 0 < t)
    (i j : Fin 2)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
