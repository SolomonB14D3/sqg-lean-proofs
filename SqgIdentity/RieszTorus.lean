    hsSeminormSq s u ‚Č§ hsSeminormSq (s + 1) őł / 4 := by
  unfold hsSeminormSq
  rw [show (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2) / 4
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 / 4 from by
    rw [‚Üź tsum_div_const]]
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2
      ‚Č§ fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 / 4 := by
    intro n
    rw [hcoeff n]
    by_cases hn : n = 0
    ¬∑ subst hn
      have hs0 : sqgStrainSymbol 0 0 0 = 0 := by
        unfold sqgStrainSymbol sqgGradSymbol derivSymbol rieszSymbol; simp
      rw [hs0, mul_zero, zero_mul, norm_zero]
