def HasThermostatBound.of_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (_hőł : ‚ąÄ t, őł t = 0) :
    HasThermostatBound őł where
