attribute [local irreducible] sqgBox

set_option maxHeartbeats 400000 in
/-- **Raw Route B `l2Conservation`.**  Uses
`tendsto_hsSeminormSq_of_tendsto_L2sub_torus` to get
`Tendsto (hsSeminormSq 0 вҲҳ f_k) вҶ’ hsSeminormSq 0 g` at both t and 0,
then `Tendsto.congr` against `hLevel` + `tendsto_nhds_unique`. -/
theorem l2Conservation_of_aubinLions_raw
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (nsub : в„• вҶ’ в„•)
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ))
    (Оё_lim : в„қ вҶ’ Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (tendsto_L2_proof : вҲҖ t : в„қ, 0 вүӨ t вҶ’
      Filter.Tendsto
        (fun k : в„• =>
          вҲ« x, вҖ–galerkinToLp (sqgBox (nsub k)) (Оұ (nsub k) t) x
                - Оё_lim t xвҖ– ^ 2)
        Filter.atTop (nhds 0))
    (hLevel : вҲҖ n t, 0 вүӨ t вҶ’
      hsSeminormSq 0 (galerkinToLp (sqgBox n) (Оұ n t))
        = hsSeminormSq 0 (galerkinToLp (sqgBox n) (Оұ n 0)))
    (hZero : вҲҖ t, 0 вүӨ t вҶ’
      mFourierCoeff (Оё_lim t) (0 : Fin 2 вҶ’ в„Ө) = 0) :
    вҲҖ t, 0 вүӨ t вҶ’
      hsSeminormSq 0 (Оё_lim t) = hsSeminormSq 0 (Оё_lim 0) := by
  intro t ht
  -- Name the Galerkin sequences at times t and 0 so Lean treats them
  -- as atomic terms (avoids repeated HOU / instance resolution on the
  -- full `galerkinToLp (sqgBox (nsub k)) (Оұ (nsub k) _)` expression).
  let Ft : в„• вҶ’ Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
    fun k => galerkinToLp (sqgBox (nsub k)) (Оұ (nsub k) t)
  let F0 : в„• вҶ’ Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
    fun k => galerkinToLp (sqgBox (nsub k)) (Оұ (nsub k) 0)
  have h_zero_Ft : вҲҖ k : в„•, mFourierCoeff (Ft k) (0 : Fin 2 вҶ’ в„Ө) = 0 := by
    intro k
    -- `convert` bridges DecidableEq instance mismatch (helper auto-synthesizes
    -- `Fintype.decidablePiFintype`, raw's `[DecidableEq]` is `instвңқ`; both are
    -- subsingleton-equal but not defeq under irreducible sqgBox).
    convert mFourierCoeff_galerkin_sqgBox_zero_any (nsub k) (Оұ (nsub k) t)
  have h_zero_F0 : вҲҖ k : в„•, mFourierCoeff (F0 k) (0 : Fin 2 вҶ’ в„Ө) = 0 := by
    intro k
    convert mFourierCoeff_galerkin_sqgBox_zero_any (nsub k) (Оұ (nsub k) 0)
  have h_L2_t : Filter.Tendsto
      (fun k : в„• => вҲ« x, вҖ–Ft k x - Оё_lim t xвҖ– ^ 2)
      Filter.atTop (nhds 0) := tendsto_L2_proof t ht
  have h_L2_0 : Filter.Tendsto
      (fun k : в„• => вҲ« x, вҖ–F0 k x - Оё_lim 0 xвҖ– ^ 2)
      Filter.atTop (nhds 0) := tendsto_L2_proof 0 le_rfl
  -- Strong-LВІ вҶ’ hsSeminormSq Tendsto at both t and 0.
  have h_lim_t : Filter.Tendsto (fun k : в„• => hsSeminormSq 0 (Ft k))
      Filter.atTop (nhds (hsSeminormSq 0 (Оё_lim t))) :=
    tendsto_hsSeminormSq_of_tendsto_L2sub_torus h_L2_t h_zero_Ft (hZero t ht)
  have h_lim_0 : Filter.Tendsto (fun k : в„• => hsSeminormSq 0 (F0 k))
      Filter.atTop (nhds (hsSeminormSq 0 (Оё_lim 0))) :=
    tendsto_hsSeminormSq_of_tendsto_L2sub_torus h_L2_0 h_zero_F0 (hZero 0 le_rfl)
  -- Per-k equality `hsSeminormSq 0 (Ft k) = hsSeminormSq 0 (F0 k)` from hLevel.
  have h_pointwise : вҲҖ k : в„•,
      hsSeminormSq 0 (Ft k) = hsSeminormSq 0 (F0 k) :=
    fun k => hLevel (nsub k) t ht
  -- Transport h_lim_t's sequence via hLevel.
  have h_lim_t' : Filter.Tendsto (fun k : в„• => hsSeminormSq 0 (F0 k))
      Filter.atTop (nhds (hsSeminormSq 0 (Оё_lim t))) :=
    h_lim_t.congr h_pointwise
  -- Limit uniqueness.
  exact tendsto_nhds_unique h_lim_t' h_lim_0

set_option maxHeartbeats 400000 in
/-- **Route B `l2Conservation` from AubinвҖ“Lions (bundled wrapper).**
Thin wrapper around `l2Conservation_of_aubinLions_raw` вҖ” projects
`HasAubinLionsExtraction` at the single call site below. -/
theorem l2Conservation_of_aubinLions
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {Оё : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (ext : HasAubinLionsExtraction Оё Оұ)
