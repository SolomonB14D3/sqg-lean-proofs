/-! ### ¬ß10.1 Material derivative scaffolding

This subsection is the foundation for the SQG PDE at the level we can
state without a full material-derivative operator. Two tiers:

1. **Fourier-level velocity multiplier** (`sqgVelocitySymbol`) ‚ÄĒ pure
   algebraic content, fully proved.
2. **`SqgEvolutionAxioms` structure** ‚ÄĒ bundles expected consequences
   of the PDE as predicates on `őł`. The `l2Conservation` field is a
   real statement any SQG solution satisfies; the other two fields are
   placeholders pending material-derivative infrastructure
   (DiPerna‚ÄďLions / Ambrosio-level flow theory, not in mathlib).

`SqgEvolutionAxioms` is consumed by `SqgSolution.solvesSqgEvolution`
in ¬ß10.2, upgrading that field from `True` to real propositional
content.
-/

/-- **SQG velocity Fourier multiplier.** For `őł` with Fourier
coefficients `őłŐā`, the SQG velocity `u = (R‚āĀőł, -R‚āÄőł)` has components
with Fourier multipliers:

  * `sqgVelocitySymbol 0 n = rieszSymbol 1 n` (i.e. `m‚āĀ(n)` ‚ÄĒ the
    `R‚āĀ` multiplier, recovering `u‚āÄ = R‚āĀőł`),
  * `sqgVelocitySymbol 1 n = -rieszSymbol 0 n` (i.e. `-m‚āÄ(n)` ‚ÄĒ
    recovering `u‚āĀ = -R‚āÄőł`).

This is the mode-level analogue of the velocity operator; defining the
actual velocity field `u : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (...)` as a composite of
time-dependent Riesz transforms requires `FracSobolevCalculus` at
operator level. -/
noncomputable def sqgVelocitySymbol (j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n

/-- **SQG velocity multiplier is bounded by 1 pointwise.** Riesz
contractivity per-mode per-component. -/
theorem sqgVelocitySymbol_norm_le_one (j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖsqgVelocitySymbol j n‚ÄĖ ‚Č§ 1 := by
  unfold sqgVelocitySymbol
  split_ifs
  ¬∑ exact rieszSymbol_norm_le_one 1 n
  ¬∑ rw [norm_neg]; exact rieszSymbol_norm_le_one 0 n

/-- **SQG velocity multiplier has unit squared-sum at nonzero modes.**
`‚ÄĖu‚āÄ(n)‚ÄĖ¬≤ + ‚ÄĖu‚āĀ(n)‚ÄĖ¬≤ = 1` for `n ‚Č† 0` ‚ÄĒ the per-mode kinetic-energy
identity that sources the global L¬≤-isometry `‚ÄĖu‚ÄĖ¬≤ = ‚ÄĖőł‚ÄĖ¬≤`. -/
theorem sqgVelocitySymbol_sum_sq {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgVelocitySymbol 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgVelocitySymbol 1 n‚ÄĖ ^ 2 = 1 := by
  unfold sqgVelocitySymbol
  simp only [Fin.isValue, if_true]
  have h := rieszSymbol_sum_sq (n := n) hn
  simpa [Fin.sum_univ_two, add_comm] using h

/-- **SQG velocity multiplier vanishes at the zero mode.** The constant
component of the velocity is zero (u has zero mean, inherited from őł's
zero-mean assumption in Riesz transforms). -/
theorem sqgVelocitySymbol_zero (j : Fin 2) :
    sqgVelocitySymbol j (0 : Fin 2 ‚Üí ‚Ą§) = 0 := by
  unfold sqgVelocitySymbol
  split_ifs
  ¬∑ exact rieszSymbol_zero 1
  ¬∑ rw [rieszSymbol_zero 0, neg_zero]

/-- **SQG velocity multiplier is divergence-free.** Per-mode statement:
`n ¬∑ u(n) = 0` for any `n ‚ąą ‚Ą§¬≤`. This is the symbol-level form of
`div u = 0`. Restates `sqg_velocity_divergence_free_symbol` using the
bundled `sqgVelocitySymbol`. -/
theorem sqgVelocitySymbol_divergence_free (n : Fin 2 ‚Üí ‚Ą§) (z : ‚Ąā) :
    ((n 0 : ‚ĄĚ) : ‚Ąā) * (sqgVelocitySymbol 0 n * z)
      + ((n 1 : ‚ĄĚ) : ‚Ąā) * (sqgVelocitySymbol 1 n * z) = 0 := by
  unfold sqgVelocitySymbol
  simp only [Fin.isValue, if_true]
  exact sqg_velocity_divergence_free_symbol n z

/-- **"Is-SQG-velocity-component" predicate.** A purely specificational
predicate asserting that the `L¬≤` function `u_j` is the `j`-th
component of the SQG velocity of `őł`. Matches every Fourier mode.

This replaces a direct `sqgVelocity_fromFourier` operator definition,
which would require `HilbertBasis.repr` machinery to construct `u_j`
from its Fourier coefficients. The predicate form sidesteps the
construction while still letting us state what a "correct" velocity
component is, so existence can be axiomatized separately or discharged
case-by-case when needed. -/
def IsSqgVelocityComponent
    (őł u_j : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (j : Fin 2) : Prop :=
  ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
    mFourierCoeff u_j n = sqgVelocitySymbol j n * mFourierCoeff őł n

/-- **Fourier coefficients of the zero Lp function vanish.**

For every dimension `d` and every mode `n : Fin d ‚Üí ‚Ą§`,
`mFourierCoeff (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) n = 0`.

Proof: Parseval gives `‚ąĎ' m, ‚ÄĖmFourierCoeff 0 m‚ÄĖ¬≤ = ‚ąę ‚ÄĖ0‚ÄĖ¬≤ = 0`,
so each term of a summable non-negative series with zero total is
individually zero.

Extracted from the previously-inline proof in
`IsSqgVelocityComponent.of_zero` so that downstream constructors
(notably `IsSqgWeakSolutionTimeTest.zero` in ¬ß10.16 and
`sqgNonlinearFlux_zero_theta`) can reuse it without re-deriving the
Parseval argument. -/
theorem mFourierCoeff_zero
    {d : ‚Ąē}
    (n : Fin d ‚Üí ‚Ą§) :
    mFourierCoeff
        (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) n = 0 := by
  have hP := hasSum_sq_mFourierCoeff
    (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d))))
  have hi : (‚ąę t,
        ‚ÄĖ((0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) : _ ‚Üí ‚Ąā) t‚ÄĖ ^ 2)
        = 0 := by simp
  rw [hi] at hP
  have hle :
      ‚ÄĖmFourierCoeff
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) n‚ÄĖ ^ 2
        ‚Č§ ‚ąĎ' m, ‚ÄĖmFourierCoeff
            (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) m‚ÄĖ ^ 2 :=
    hP.summable.le_tsum n (fun _ _ => sq_nonneg _)
  rw [hP.tsum_eq] at hle
  have h_sq :
      ‚ÄĖmFourierCoeff
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) n‚ÄĖ ^ 2 = 0 :=
    le_antisymm hle (sq_nonneg _)
  have h_norm :
      ‚ÄĖmFourierCoeff
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) n‚ÄĖ = 0 := by
    have hmul :
        ‚ÄĖmFourierCoeff
            (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) n‚ÄĖ
          * ‚ÄĖmFourierCoeff
              (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) n‚ÄĖ
            = 0 := by
      nlinarith [h_sq,
        norm_nonneg (mFourierCoeff
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin d)))) n)]
    exact mul_self_eq_zero.mp hmul
  exact norm_eq_zero.mp h_norm

/-- **The zero function is an SQG-velocity-component of the zero scalar.**
If `őł = 0`, then `u_j = 0` satisfies every Fourier-mode condition
trivially (both sides are zero). A minimal existence example.

Proof now a three-liner after factoring `mFourierCoeff_zero` into
a public lemma (the 30+-line inline Parseval argument has moved
there). -/
theorem IsSqgVelocityComponent.of_zero (j : Fin 2) :
    IsSqgVelocityComponent (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
      (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) j := by
  intro n
  rw [mFourierCoeff_zero]
  simp

/-- **SQG evolution axioms.** Encodes "`őł` solves SQG" at the level we
can state without a full material-derivative operator.

Three fields, all with real mathematical content (no `True`
placeholders remain):

* `l2Conservation`: `L¬≤` norm is constant in time ‚ÄĒ a direct
  consequence of `‚ąę őł ¬∑ div(uőł) dx = 0` plus `div u = 0`.
* `meanConservation`: the spatial mean `‚ąę őł dx` (equivalently the
  zeroth Fourier coefficient) is preserved along the flow ‚ÄĒ the
  zero-mode reading of `‚ąā‚āúőł + div(uőł) = 0`.
* `velocityIsRieszTransform`: for each axis `j`, an `L¬≤`-valued
  time-indexed velocity component exists which realizes the SQG
  relation `u_j(t) = (¬ĪR_{1-j}) őł(t)` mode-by-mode via
  `IsSqgVelocityComponent`.

The three fields together are sufficient to define `SqgSolution` with
real PDE content, to run the ¬ß10.5 `L¬≤` bound argument, and to feed
the ¬ß10.8 s=2 bootstrap discharge of `BKMCriterionS2` once the energy
estimate is formalized. The full weak form of `‚ąā‚āúőł + u¬∑‚ąáőł = 0`
paired against smooth test functions is a strictly stronger refinement
that would consume a distributional / material-derivative
infrastructure not yet built here.

Used as the `solvesSqgEvolution` field of `SqgSolution` in ¬ß10.2. -/
structure SqgEvolutionAxioms
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop where
  /-- `L¬≤` norm squared is conserved along the flow: consequence of
  incompressibility plus `‚ąę őł (u¬∑‚ąáőł) = 0`. -/
  l2Conservation :
    ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq 0 (őł t) = hsSeminormSq 0 (őł 0)
  /-- Spatial-mean conservation (zero-mode form of `‚ąā‚āúőł + div(uőł) = 0`):
  the zeroth Fourier coefficient is preserved for all forward time.
  Equivalent to `‚ąę őł(t) dx = ‚ąę őł(0) dx` on `ūĚēč¬≤`. -/
  meanConservation :
    ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
      mFourierCoeff (őł t) (0 : Fin 2 ‚Üí ‚Ą§)
        = mFourierCoeff (őł 0) (0 : Fin 2 ‚Üí ‚Ą§)
  /-- For each axis `j`, a time-indexed `L¬≤` velocity component
  `u_j : ‚ĄĚ ‚Üí Lp ‚Ąā 2` exists satisfying the SQG velocity relation
  `u_j(t) = (sgnj ¬∑ R_{1-j}) őł(t)` mode-by-mode (as encoded by
  `IsSqgVelocityComponent`). -/
  velocityIsRieszTransform :
    ‚ąÄ j : Fin 2,
      ‚ąÉ u_j : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))),
        ‚ąÄ t : ‚ĄĚ, IsSqgVelocityComponent (őł t) (u_j t) j

/-- **SQG evolution axioms hold for the identically-zero solution.**
A minimal sanity check: `őł ‚Č° 0` trivially satisfies the real content
(`l2Conservation`) since both sides of the equation are `0`. -/
theorem SqgEvolutionAxioms.of_identically_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł : ‚ąÄ t, őł t = 0) :
    SqgEvolutionAxioms őł where
  l2Conservation := fun t _ => by rw [hőł t, hőł 0]
  meanConservation := fun t _ => by rw [hőł t, hőł 0]
  velocityIsRieszTransform := fun j =>
    ‚ü®fun _ => 0, fun t => by
      rw [hőł t]
      exact IsSqgVelocityComponent.of_zero j‚ü©

/-! ### ¬ß10.2 `SqgSolution` wrapper

The Sobolev-bound conclusion of `sqg_regularity_conditional` is stated
about a bare time-indexed family `őł : ‚ĄĚ ‚Üí L¬≤(ūĚēč¬≤)`. For compositional
proofs it is cleaner to package a solution with its defining data.

`SqgSolution` bundles three things:

1. The time-evolution family `őł`.
2. The `smoothInitialData` predicate: `őł 0` has finite ŠłĘňĘ seminorm for
   some `s > 2` (the standard well-posedness regularity class for
   SQG ‚ÄĒ one order above the scaling-critical level `s = 1`).
3. The `solvesSqgEvolution` predicate: a `SqgEvolutionAxioms őł` proof.
   Real content (`l2Conservation`) plus two placeholders for the
   full PDE statement.

`SqgSolution.regularity_conditional` then restates
`sqg_regularity_conditional` in the structured form.
-/

/-- **SQG solution.** Bundles a time-evolution `őł`, a smooth-initial-data
predicate, and an `SqgEvolutionAxioms őł` proof. -/
structure SqgSolution where
  /-- The time-evolution of the active scalar on `ūĚēč¬≤`. -/
  őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))
  /-- Initial data has finite ŠłĘňĘ seminorm at some subcritical
  regularity `s > 2` ‚ÄĒ the standard SQG well-posedness class. -/
  smoothInitialData :
    ‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
      Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (őł 0) n‚ÄĖ ^ 2)
  /-- `őł` satisfies the SQG evolution axioms ‚ÄĒ real content for
  `l2Conservation`, placeholders for the full PDE. -/
  solvesSqgEvolution : SqgEvolutionAxioms őł

namespace SqgSolution

variable (S : SqgSolution)

/-- **Sobolev bounds conclusion.** Uniform ŠłĘňĘ bounds at every order,
for all forward time ‚ÄĒ the conclusion of conditional Theorem 3 stated
on an `SqgSolution`. -/
def SobolevBounds : Prop :=
  ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí
    ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (S.őł t) ‚Č§ M

/-- **Conditional Theorem 3 (structured form).**

Any `SqgSolution` satisfying the three analytic hypotheses
‚ÄĒ `MaterialMaxPrinciple`, `BKMCriterion`, `FracSobolevCalculus` ‚ÄĒ has
uniform Sobolev bounds at every order.

Proof is direct delegation to `sqg_regularity_conditional`. The
`smoothInitialData` and `solvesSqgEvolution` fields of `S` are not
yet consumed by the proof, because the three analytic hypotheses
currently supply (via `hOnePropagation` and `hsPropagation`) the
content those fields will eventually establish from first principles. -/
theorem regularity_conditional
    (hMMP : MaterialMaxPrinciple S.őł)
    (hBKM : BKMCriterion S.őł)
    (hFSC : FracSobolevCalculus S.őł) :
    S.SobolevBounds :=
  sqg_regularity_conditional S.őł hMMP hBKM hFSC

end SqgSolution

/-! ### ¬ß10.3 Trivial-case discharges

The stationary zero solution `őł ‚Č° 0` is trivially regular: every
Sobolev norm vanishes at every time. We prove this discharges both
refined hypotheses (`MaterialMaxPrinciple.hOnePropagation` and
`BKMCriterion.hsPropagation`) unconditionally in that case.

These aren't mathematically deep, but they demonstrate the structural
point: the hypotheses *can* be discharged to real proofs, not just
axiomatized. Future PRs strengthen from "discharges in the trivial
case" to "discharges under increasingly general hypotheses." -/

/-- **ŠłĘňĘ seminorm of the zero function is zero.** -/
theorem hsSeminormSq_of_zero {d : Type*} [Fintype d] (s : ‚ĄĚ) :
    hsSeminormSq s (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) = 0 := by
  -- Each mode's coefficient is zero, so each summand is zero.
  unfold hsSeminormSq
  -- Parseval: ‚ąĎ' ‚ÄĖmFourierCoeff 0 n‚ÄĖ¬≤ = ‚ąę ‚ÄĖ(0 : Lp) t‚ÄĖ¬≤ = 0
  have hParseval := hasSum_sq_mFourierCoeff
    (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
  have h_int : (‚ąę t, ‚ÄĖ((0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) : _ ‚Üí ‚Ąā) t‚ÄĖ ^ 2)
        = 0 := by simp
  rw [h_int] at hParseval
  -- From HasSum (‚ÄĖ¬∑Őā‚ÄĖ¬≤) 0 with non-neg summands, each is zero
  have h_each : ‚ąÄ n : d ‚Üí ‚Ą§,
      ‚ÄĖmFourierCoeff (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) n‚ÄĖ ^ 2 = 0 := by
    intro n
    have hnn : ‚ąÄ m, 0 ‚Č§ ‚ÄĖmFourierCoeff
        (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) m‚ÄĖ ^ 2 := fun _ => sq_nonneg _
    have hle : ‚ÄĖmFourierCoeff
        (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) n‚ÄĖ ^ 2
          ‚Č§ ‚ąĎ' m, ‚ÄĖmFourierCoeff
            (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) m‚ÄĖ ^ 2 :=
      hParseval.summable.le_tsum n (fun m _ => hnn m)
    rw [hParseval.tsum_eq] at hle
    exact le_antisymm hle (sq_nonneg _)
  -- Now each weighted term is zero, so the tsum is zero.
  have h_term_zero : ‚ąÄ n : d ‚Üí ‚Ą§,
      (fracDerivSymbol s n) ^ 2
        * ‚ÄĖmFourierCoeff (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) n‚ÄĖ ^ 2 = 0 := by
    intro n
    rw [h_each n, mul_zero]
  calc (‚ąĎ' n : d ‚Üí ‚Ą§, (fracDerivSymbol s n) ^ 2
          * ‚ÄĖmFourierCoeff (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) n‚ÄĖ ^ 2)
      = ‚ąĎ' _ : d ‚Üí ‚Ą§, (0 : ‚ĄĚ) := tsum_congr h_term_zero
    _ = 0 := tsum_zero

/-- **MaterialMaxPrinciple holds for the identically-zero evolution.** -/
theorem MaterialMaxPrinciple.of_identically_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł : ‚ąÄ t, őł t = 0) :
    MaterialMaxPrinciple őł where
  hOnePropagation := ‚ü®0, fun t _ => by
    rw [hőł t, hsSeminormSq_of_zero]‚ü©
  hOneSummability := fun t _ => by
    -- For őł t = 0, each mode coefficient is 0, so each term is 0.
    -- Summable of constant 0 sequence is trivial.
    have h_each : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
        (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff (őł t) n‚ÄĖ ^ 2 = 0 := by
      intro n
      rw [hőł t]
      -- mFourierCoeff (0 : Lp) n = 0 by IsSqgVelocityComponent.of_zero's helper argument
      have hP := hasSum_sq_mFourierCoeff
        (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
      have hi : (‚ąę t, ‚ÄĖ((0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : _ ‚Üí ‚Ąā) t‚ÄĖ ^ 2)
            = 0 := by simp
      rw [hi] at hP
      have hle : ‚ÄĖmFourierCoeff
            (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) n‚ÄĖ ^ 2
            ‚Č§ ‚ąĎ' m, ‚ÄĖmFourierCoeff
              (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) m‚ÄĖ ^ 2 :=
        hP.summable.le_tsum n (fun _ _ => sq_nonneg _)
      rw [hP.tsum_eq] at hle
      have h_sq : ‚ÄĖmFourierCoeff
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) n‚ÄĖ ^ 2 = 0 :=
        le_antisymm hle (sq_nonneg _)
      rw [h_sq, mul_zero]
    have : (fun n : Fin 2 ‚Üí ‚Ą§ =>
          (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff (őł t) n‚ÄĖ ^ 2)
          = fun _ => 0 := by
      ext n; exact h_each n
    rw [this]
    exact summable_zero
  freeDerivativeAtKappaMax := trivial
  materialSegmentExpansion := trivial
  farFieldBoundary := trivial

/-- **BKMCriterion holds for the identically-zero evolution.** -/
theorem BKMCriterion.of_identically_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł : ‚ąÄ t, őł t = 0) :
    BKMCriterion őł where
  hsPropagation := fun _ s _ => ‚ü®0, fun t _ => by
    rw [hőł t, hsSeminormSq_of_zero]‚ü©
  boundedGradIntegralImpliesSmooth := trivial

/-! ### ¬ß10.4 Well-posedness hypothesis + packaged regularity

`SqgWellPosedness` axiomatizes the local-in-time well-posedness of
SQG: any smooth initial data gives rise to *some* `SqgSolution`
matching it at `t = 0`. This is the standard existence theorem for
ŠłĘňĘ data with `s > 2`, and is the last missing link between "regularity
of a given solution" and "regularity for given smooth data."

`sqg_regularity_for_smooth_data` combines well-posedness with the
three analytic hypotheses (assumed to hold for every solution) and
concludes: every smooth initial datum evolves into a solution with
uniform Sobolev bounds at every order. -/

/-- **Well-posedness hypothesis for SQG (placeholder).**

The standard local-in-time existence statement: smooth initial data
yields *some* `SqgSolution` with matching initial condition. The
missing analytic content is ŠłĘňĘ well-posedness of SQG for `s > 2`
(Constantin‚ÄďMajda‚ÄďTabak et al.). -/
structure SqgWellPosedness : Prop where
  /-- Existence of a solution matching prescribed smooth initial data. -/
  existsSolution :
    ‚ąÄ őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))),
      (‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
        Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
          (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2)) ‚Üí
      ‚ąÉ S : SqgSolution, S.őł 0 = őł‚āÄ

/-- **Conditional Theorem 3 for smooth initial data.**

Combines well-posedness with the three analytic hypotheses (required
to hold for every solution) and concludes: every smooth initial datum
`őł‚āÄ` evolves into a solution with uniform Sobolev bounds at every order.

This is the "user-facing" form of Theorem 3: it takes initial data,
not a pre-baked solution. -/
theorem sqg_regularity_for_smooth_data
    (hWP : SqgWellPosedness)
    (hMMPAll : ‚ąÄ S : SqgSolution, MaterialMaxPrinciple S.őł)
    (hBKMAll : ‚ąÄ S : SqgSolution, BKMCriterion S.őł)
    (hFSCAll : ‚ąÄ S : SqgSolution, FracSobolevCalculus S.őł)
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hsmooth : ‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
      Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2)) :
    ‚ąÉ S : SqgSolution, S.őł 0 = őł‚āÄ ‚ąß S.SobolevBounds := by
  obtain ‚ü®S, hS0‚ü© := hWP.existsSolution őł‚āÄ hsmooth
  exact ‚ü®S, hS0, S.regularity_conditional (hMMPAll S) (hBKMAll S) (hFSCAll S)‚ü©

/-! ### ¬ß10.5 L¬≤ conservation ‚üĻ uniform L¬≤ bound (s=0 degenerate subcase)

A concrete payoff of ¬ß10.1's `SqgEvolutionAxioms` integration: we can
discharge the "s=0 degenerate subcase" of `MaterialMaxPrinciple.hOnePropagation`
directly. Given only `l2Conservation`, the `L¬≤` norm is bounded for
all time by its initial value.

This is **not** enough to discharge `hOnePropagation` itself (which is
about `s=1`, i.e. `ŠłĘ¬Ļ`) ‚ÄĒ L¬≤ conservation doesn't control gradients.
But it does demonstrate that once the SQG PDE content is real (as
`SqgEvolutionAxioms.l2Conservation`, `meanConservation`, and
`velocityIsRieszTransform` now are, via `SqgSolution`), a genuine
chain of reasoning produces genuine regularity output. This is the
pattern the full `hOnePropagation` discharge will follow once the
integer-order energy estimate formalized in ¬ß10.8 is carried out in
detail: PDE property ‚Üí conserved quantity ‚Üí uniform bound.
-/

/-- **Uniform L¬≤ bound from L¬≤ conservation.** The "s=0 degenerate
subcase" of `MaterialMaxPrinciple.hOnePropagation`.

This is a real theorem ‚ÄĒ takes the `l2Conservation` field of
`SqgEvolutionAxioms` and produces a uniform-in-time `hsSeminormSq 0`
bound with `M = hsSeminormSq 0 (őł 0)`.

It does not discharge `hOnePropagation` (which needs `ŠłĘ¬Ļ`, not `ŠłĘ‚Āį`),
but it demonstrates the pattern: once PDE content is real, genuine
regularity output follows. -/
theorem uniform_l2Bound_of_l2Conservation
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hE : SqgEvolutionAxioms őł) :
    ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq 0 (őł t) ‚Č§ M :=
  ‚ü®hsSeminormSq 0 (őł 0), fun t ht => le_of_eq (hE.l2Conservation t ht)‚ü©

/-- **Uniform L¬≤ bound for any `SqgSolution`.** Specializes
`uniform_l2Bound_of_l2Conservation` to the structured form. -/
theorem SqgSolution.uniform_l2Bound (S : SqgSolution) :
    ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq 0 (S.őł t) ‚Č§ M :=
  uniform_l2Bound_of_l2Conservation S.őł S.solvesSqgEvolution

/-! ### ¬ß10.6 Interpolation reduction of BKM scope

`BKMCriterion.hsPropagation` currently axiomatizes the bootstrap
`uniform ŠłĘ¬Ļ ‚Üí uniform ŠłĘňĘ` for every `s ‚Č• 0`. But **interpolation
handles `s ‚ąą [0, 1]` for free**: on the integer lattice, `‚ÄĖn‚ÄĖ ‚Č• 1` at
every nonzero mode, so `‚ÄĖn‚ÄĖ^{2s} ‚Č§ ‚ÄĖn‚ÄĖ¬≤` for `s ‚Č§ 1`, giving
`hsSeminormSq s őł ‚Č§ hsSeminormSq 1 őł` directly (this is
`hsSeminormSq_mono_of_le`).

So we can replace the "all `s ‚Č• 0`" bootstrap by one that only covers
`s > 1`, without weakening Theorem 3. This subsection:

* Introduces `BKMCriterionHighFreq`, the refined hypothesis covering
  only `s > 1`.
* Shows the original `BKMCriterion` implies it, so every previous
  discharge auto-promotes.
* Gives a trivial-case discharge for the weaker form.
* Proves `sqg_regularity_via_interpolation`: the combined theorem,
  which uses interpolation for the `s ‚ąą [0, 1]` branch and the
  `BKMCriterionHighFreq` hypothesis for `s > 1`.

Net effect: BKM's axiomatic footprint is reduced by the full
`s ‚ąą [0, 1]` range ‚ÄĒ a factor-of-2 shrink in the Sobolev scale BKM
is responsible for.
-/

/-- **Refined BKM criterion (high-frequency only).** The bootstrap
from uniform ŠłĘ¬Ļ bound to uniform ŠłĘňĘ bound for `s > 1` ‚ÄĒ the range
where interpolation no longer suffices.

This is strictly weaker than `BKMCriterion.hsPropagation`
(`BKMCriterion.toHighFreq` below), and is all that the combined
regularity theorem actually needs once `SqgEvolutionAxioms` supplies
the L¬≤ bound and interpolation handles `s ‚ąą [0, 1]`. -/
structure BKMCriterionHighFreq
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop where
  /-- Uniform ŠłĘ¬Ļ bound propagates to uniform ŠłĘňĘ bound for every `s > 1`. -/
  hsPropagationHighFreq :
    (‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq 1 (őł t) ‚Č§ M) ‚Üí
      ‚ąÄ s : ‚ĄĚ, 1 < s ‚Üí
        ‚ąÉ M' : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (őł t) ‚Č§ M'

/-- **Original `BKMCriterion` implies the refined high-frequency form.**
Every existing discharge of `BKMCriterion` automatically gives the
weaker `BKMCriterionHighFreq`. -/
theorem BKMCriterion.toHighFreq
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hBKM : BKMCriterion őł) : BKMCriterionHighFreq őł where
  hsPropagationHighFreq :=
    fun h‚āĀ s _ => hBKM.hsPropagation h‚āĀ s (by linarith)

/-- **Refined BKM holds for the identically-zero evolution.** Direct
discharge via `BKMCriterion.of_identically_zero + toHighFreq`. -/
theorem BKMCriterionHighFreq.of_identically_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł : ‚ąÄ t, őł t = 0) : BKMCriterionHighFreq őł :=
  (BKMCriterion.of_identically_zero őł hőł).toHighFreq

/-- **Interpolation reduction: Theorem 3 from weakened BKM.**

Discharges the full Sobolev-scale regularity conclusion using the
reduced axiomatic footprint:

* `MaterialMaxPrinciple` ‚Üí uniform ŠłĘ¬Ļ bound + ŠłĘ¬Ļ summability
* `SqgEvolutionAxioms.l2Conservation` ‚Üí uniform L¬≤ bound
* `BKMCriterionHighFreq` ‚Üí ŠłĘ¬Ļ ‚Üí ŠłĘňĘ bootstrap for `s > 1` only

For `s ‚ąą [0, 1]`, interpolation delivers the bound from MMP directly
(no BKM needed; summability comes from `hMMP.hOneSummability`). For
`s > 1`, the refined BKM supplies it.

This makes the axiomatic content of Theorem 3 more precise: BKM is
only needed for `s > 1`, not the full `s ‚Č• 0` range. -/
theorem sqg_regularity_via_interpolation
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hMMP : MaterialMaxPrinciple őł)
    (hBKM : BKMCriterionHighFreq őł)
    (_hE : SqgEvolutionAxioms őł) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (őł t) ‚Č§ M := by
  intro s hs
  -- Get the ŠłĘ¬Ļ bound once; we'll reuse it.
  obtain ‚ü®M‚āĀ, hM‚āĀ‚ü© := hMMP.hOnePropagation
  by_cases hs1 : s ‚Č§ 1
  ¬∑ -- s ‚ąą [0, 1]: interpolation via hsSeminormSq_mono_of_le, summability from MMP
    refine ‚ü®M‚āĀ, fun t ht => ?_‚ü©
    calc hsSeminormSq s (őł t)
        ‚Č§ hsSeminormSq 1 (őł t) :=
          hsSeminormSq_mono_of_le hs1 (őł t) (hMMP.hOneSummability t ht)
      _ ‚Č§ M‚āĀ := hM‚āĀ t ht
  ¬∑ -- s > 1: invoke BKMCriterionHighFreq
    push Not at hs1
    exact hBKM.hsPropagationHighFreq ‚ü®M‚āĀ, hM‚āĀ‚ü© s hs1

/-- **Structured-form interpolation reduction.** Specializes
`sqg_regularity_via_interpolation` to an `SqgSolution`, consuming
`S.solvesSqgEvolution` for the L¬≤ bound automatically. -/
theorem SqgSolution.regularity_via_interpolation (S : SqgSolution)
    (hMMP : MaterialMaxPrinciple S.őł)
    (hBKM : BKMCriterionHighFreq S.őł) :
    S.SobolevBounds :=
  sqg_regularity_via_interpolation S.őł hMMP hBKM S.solvesSqgEvolution

/-! ### ¬ß10.7 MMP alone covers the intermediate Sobolev range

Consequence of the internalized `hOneSummability` in
`MaterialMaxPrinciple`: the intermediate range `s ‚ąą [0, 1]` is fully
discharged by MMP without any BKM hypothesis. This is the cleanest
statement of the interpolation reduction ‚ÄĒ it says MMP's "uniform
ŠłĘ¬Ļ bound + summability" is a self-contained piece of content
sufficient for a substantial fragment of Theorem 3 on its own.
-/

/-- **MMP alone ‚üĻ uniform ŠłĘňĘ bound for `s ‚ąą [0, 1]`.**

No BKM, no well-posedness, no L¬≤ conservation ‚ÄĒ just MMP's ŠłĘ¬Ļ bound
and summability internalized into the structure. The uniform bound
at any `s ‚ąą [0, 1]` is achieved with `M = M‚āĀ` from `hOnePropagation`
(the same constant across the whole intermediate range).

This is a real (non-trivial, non-circular) theorem showing that
MMP is a self-contained piece of the Theorem 3 puzzle ‚ÄĒ it handles
a 50% sub-range of Sobolev indices entirely. -/
theorem MaterialMaxPrinciple.uniform_hs_intermediate
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hMMP : MaterialMaxPrinciple őł) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 1 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (őł t) ‚Č§ M := by
  intro s _ hs1
  obtain ‚ü®M‚āĀ, hM‚āĀ‚ü© := hMMP.hOnePropagation
  exact ‚ü®M‚āĀ, fun t ht => le_trans
    (hsSeminormSq_mono_of_le hs1 (őł t) (hMMP.hOneSummability t ht))
    (hM‚āĀ t ht)‚ü©

/-- **`SqgSolution` form of the intermediate-range theorem.** -/
theorem SqgSolution.uniform_hs_intermediate (S : SqgSolution)
    (hMMP : MaterialMaxPrinciple S.őł) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 1 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (S.őł t) ‚Č§ M :=
  hMMP.uniform_hs_intermediate

/-! ### ¬ß10.8 s=2 bootstrap: integer-order BKM refinement

The `BKMCriterionHighFreq` axiom of ¬ß10.6 covers the ŠłĘňĘ bootstrap for
every `s > 1`, which on `ūĚēč¬≤` involves fractional-calculus
machinery (Kato‚ÄďPonce-type product and commutator estimates) that is
not yet available in this development's dependency chain.

**The integer case `s = 2` avoids fractional calculus entirely.** The
Fourier multiplier `|n|¬≤` is polynomial, and at `s = 2` the BKM
energy estimate uses only the classical commutator

  `[őĒ, u¬∑‚ąá] = 2 ‚ąáu ¬∑ ‚ąá¬≤ + (őĒu) ¬∑ ‚ąá`,

which is a *differential* operator ‚ÄĒ its bounds are pointwise,
handled by the real-valued calculus already in Mathlib, with no
Littlewood‚ÄďPaley decomposition required.

This subsection introduces `BKMCriterionS2`, a strict weakening of
`BKMCriterionHighFreq` that only covers `s ‚ąą (1, 2]`. Combined with
the ¬ß10.6 / ¬ß10.7 interpolation from `MaterialMaxPrinciple` on
`s ‚ąą [0, 1]`, it delivers **a conditional Theorem 3 on the full
Sobolev range `[0, 2]` from an axiomatic footprint that targets only
integer-order regularity**.

Significance: `BKMCriterionS2` is the most restricted BKM-type
hypothesis against which the conditional Theorem 3 can still cover
a non-trivial Sobolev range above the critical index `s = 1`. A
future discharge via a genuine ŠłĘ¬≤ energy estimate ‚ÄĒ integer-order,
no fractional calculus ‚ÄĒ would make Theorem 3 unconditional on
`s ‚ąą [0, 2]`. The `s > 2` tail remains an explicit open axiom.

Provided here:

* `BKMCriterionS2`: refined hypothesis covering `s ‚ąą (1, 2]`.
* `BKMCriterionHighFreq.toS2`: the HighFreq axiom (and therefore the
  original `BKMCriterion`) implies the S2 form. Every previous
  discharge auto-promotes.
* `BKMCriterionS2.of_identically_zero`: trivial-case discharge.
* `sqg_regularity_via_s2_bootstrap`: combined theorem for
  `s ‚ąą [0, 2]`.
* `SqgSolution.regularity_via_s2_bootstrap`: structured form.
-/

/-- **S2 BKM criterion.** Uniform ŠłĘ¬Ļ bound propagates to uniform ŠłĘňĘ
bound for every `s ‚ąą (1, 2]` ‚ÄĒ the integer-order range where the BKM
bootstrap uses only classical (differential) commutators, no
fractional Sobolev calculus.

This is strictly weaker than `BKMCriterionHighFreq`
(`BKMCriterionHighFreq.toS2` below). Exactly what the combined
conditional Theorem 3 on `s ‚ąą [0, 2]` requires. -/
structure BKMCriterionS2
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop where
  /-- Uniform ŠłĘ¬Ļ bound propagates to uniform ŠłĘňĘ bound for every
  `s ‚ąą (1, 2]`. Integer-order: no fractional calculus required. -/
  hsPropagationS2 :
    (‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq 1 (őł t) ‚Č§ M) ‚Üí
      ‚ąÄ s : ‚ĄĚ, 1 < s ‚Üí s ‚Č§ 2 ‚Üí
        ‚ąÉ M' : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (őł t) ‚Č§ M'

/-- **High-frequency BKM implies S2 BKM.** Every existing discharge of
`BKMCriterionHighFreq` auto-promotes to `BKMCriterionS2` ‚ÄĒ the
restriction `s ‚Č§ 2` is harmless. -/
theorem BKMCriterionHighFreq.toS2
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hBKM : BKMCriterionHighFreq őł) : BKMCriterionS2 őł where
  hsPropagationS2 := fun h‚āĀ s hs1 _ => hBKM.hsPropagationHighFreq h‚āĀ s hs1

/-- **Original BKM criterion implies S2 BKM.** Chain through
`BKMCriterion.toHighFreq` and `BKMCriterionHighFreq.toS2`. -/
theorem BKMCriterion.toS2
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hBKM : BKMCriterion őł) : BKMCriterionS2 őł :=
  hBKM.toHighFreq.toS2

/-- **S2 BKM holds for the identically-zero evolution.** Discharge
via `BKMCriterion.of_identically_zero + toS2`. -/
theorem BKMCriterionS2.of_identically_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł : ‚ąÄ t, őł t = 0) : BKMCriterionS2 őł :=
  (BKMCriterion.of_identically_zero őł hőł).toS2

/-- **s=2 bootstrap reduction: Theorem 3 on `s ‚ąą [0, 2]`.**

Discharges the conditional regularity conclusion on the range `[0, 2]`
from a strictly weaker axiomatic footprint than
`sqg_regularity_via_interpolation`:

* `MaterialMaxPrinciple` ‚Üí uniform ŠłĘ¬Ļ bound + ŠłĘ¬Ļ summability
* `BKMCriterionS2` ‚Üí ŠłĘ¬Ļ ‚Üí ŠłĘňĘ bootstrap for `s ‚ąą (1, 2]` only ‚ÄĒ
  the integer-order subrange

For `s ‚ąą [0, 1]`, MMP summability + monotonicity delivers the bound
directly (same argument as ¬ß10.6 / ¬ß10.7). For `s ‚ąą (1, 2]`,
`BKMCriterionS2` supplies it.

**The top of the range, `s > 2`, is not covered.** That is the
explicit remaining open axiom. This is the honest partial-win: the
conditional Theorem 3 now holds over `[0, 2]` from an axiomatic
footprint that targets only integer-order Sobolev regularity. -/
theorem sqg_regularity_via_s2_bootstrap
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hMMP : MaterialMaxPrinciple őł)
    (hBKM : BKMCriterionS2 őł) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (őł t) ‚Č§ M := by
  intro s _ hs2
  obtain ‚ü®M‚āĀ, hM‚āĀ‚ü© := hMMP.hOnePropagation
  by_cases hs1 : s ‚Č§ 1
  ¬∑ -- s ‚ąą [0, 1]: interpolation via hsSeminormSq_mono_of_le, summability from MMP
    refine ‚ü®M‚āĀ, fun t ht => ?_‚ü©
    calc hsSeminormSq s (őł t)
        ‚Č§ hsSeminormSq 1 (őł t) :=
          hsSeminormSq_mono_of_le hs1 (őł t) (hMMP.hOneSummability t ht)
      _ ‚Č§ M‚āĀ := hM‚āĀ t ht
  ¬∑ -- s ‚ąą (1, 2]: invoke BKMCriterionS2
    push Not at hs1
    exact hBKM.hsPropagationS2 ‚ü®M‚āĀ, hM‚āĀ‚ü© s hs1 hs2

/-- **Structured-form s=2 bootstrap reduction.** Specializes
`sqg_regularity_via_s2_bootstrap` to an `SqgSolution`, covering the
integer-order range `[0, 2]` of `S.SobolevBounds`. -/
theorem SqgSolution.regularity_via_s2_bootstrap (S : SqgSolution)
    (hMMP : MaterialMaxPrinciple S.őł)
    (hBKM : BKMCriterionS2 S.őł) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (S.őł t) ‚Č§ M :=
  sqg_regularity_via_s2_bootstrap S.őł hMMP hBKM

/-! ### ¬ß10.9 Fourier convolution scaffolding

Statement of the SQG evolution at full per-mode Fourier resolution ‚ÄĒ
i.e., the Duhamel identity

  `őłŐā(m, t) ‚ąí őłŐā(m, 0) = ‚ąí ‚ąę‚āÄŠĶó (u¬∑‚ąáőł)Őā(m, ŌĄ) dŌĄ`

‚ÄĒ expresses the nonlinear flux `(u¬∑‚ąáőł)Őā(m)` as a **convolution of
Fourier coefficient sequences**:

  `(u_j ‚ąā_j őł)Őā(m) = ‚ąĎ ‚Ąď, √Ľ_j(m ‚ąí ‚Ąď) ¬∑ (i¬∑‚Ąď_j) ¬∑ őłŐā(‚Ąď)`.

This section introduces `fourierConvolution` as an abstract operator
on coefficient sequences `őĻ ‚Üí ‚Ąā` over any additive commutative group
`őĻ`, together with the **pointwise convolution bound**
`convolution_bounded_by_product` ‚ÄĒ the single analytic lemma that
powers the Bochner integrability step when the per-mode flux is later
integrated in time to state the Duhamel identity.

Lemmas provided:

* `fourierConvolution` ‚ÄĒ the raw bilinear convolution on `őĻ ‚Üí ‚Ąā`.
* `fourierConvolution_zero_left` / `_zero_right` ‚ÄĒ convolution with
  zero is zero (used by the zero-solution discharges).
* `tsum_sq_norm_shift_left` ‚ÄĒ shift invariance of the ‚Ąď¬≤ norm:
  `‚ąĎ ‚Ąď, ‚ÄĖg(m ‚ąí ‚Ąď)‚ÄĖ¬≤ = ‚ąĎ ‚Ąď, ‚ÄĖg(‚Ąď)‚ÄĖ¬≤`.
* `summable_sq_norm_shift_left` ‚ÄĒ its summability companion.
* `convolution_bounded_by_product` ‚ÄĒ the Young + triangle uniform
  bound `‚ÄĖ(f * g)(m)‚ÄĖ ‚Č§ (‚ÄĖf‚ÄĖ¬≤_‚Ąď¬≤ + ‚ÄĖg‚ÄĖ¬≤_‚Ąď¬≤)/2`.
* `SqgFourierData.fourierConvolution` ‚ÄĒ thin bundle-level wrapper
  that exposes the operation on two `SqgFourierData` bundles.

The Young-form bound is weaker than full Cauchy‚ÄďSchwarz
(`‚ąö(‚ÄĖf‚ÄĖ¬≤)¬∑‚ąö(‚ÄĖg‚ÄĖ¬≤)`) but equivalent up to a constant, and sufficient
for the uniform-in-time boundedness that Bochner integrability of the
per-mode flux requires. -/

/-- **Fourier convolution of two coefficient sequences on an additive
commutative group.** Defined by

  `(f * g)(m) := ‚ąĎ' ‚Ąď, f(‚Ąď) ¬∑ g(m ‚ąí ‚Ąď)`

(with the usual `tsum` convention: returns `0` if the sum diverges).

On the integer lattice `Fin d ‚Üí ‚Ą§`, this is the Fourier-side of
pointwise multiplication: if `f = fŐāŠĶ§` and `g = ńĚŠĶ•` are Fourier
coefficient sequences of `L¬≤(ūĚēč^d)` functions `u`, `v`, then
`fourierConvolution f g` equals the Fourier coefficient sequence of
the pointwise product `u ¬∑ v` (modulo the usual `2ŌÄ` normalization
factor absorbed into `mFourierCoeff`). -/
noncomputable def fourierConvolution {őĻ : Type*} [AddCommGroup őĻ]
    (f g : őĻ ‚Üí ‚Ąā) (m : őĻ) : ‚Ąā :=
  ‚ąĎ' ‚Ąď : őĻ, f ‚Ąď * g (m - ‚Ąď)

/-- **Convolution with the zero sequence on the left is zero.** -/
theorem fourierConvolution_zero_left {őĻ : Type*} [AddCommGroup őĻ]
    (g : őĻ ‚Üí ‚Ąā) (m : őĻ) :
    fourierConvolution (fun _ => (0 : ‚Ąā)) g m = 0 := by
  unfold fourierConvolution
  simp

/-- **Convolution with the zero sequence on the right is zero.** -/
theorem fourierConvolution_zero_right {őĻ : Type*} [AddCommGroup őĻ]
    (f : őĻ ‚Üí ‚Ąā) (m : őĻ) :
    fourierConvolution f (fun _ => (0 : ‚Ąā)) m = 0 := by
  unfold fourierConvolution
  simp

/-- **Reindexing involution `‚Ąď ‚Ü¶ m ‚ąí ‚Ąď`.** An `Equiv őĻ őĻ` whose
inverse is itself; used to transfer summability and `tsum` identities
across the shift. -/
noncomputable def subLeftEquiv {őĻ : Type*} [AddCommGroup őĻ]
    (m : őĻ) : őĻ ‚ČÉ őĻ where
  toFun ‚Ąď := m - ‚Ąď
  invFun ‚Ąď := m - ‚Ąď
  left_inv ‚Ąď := sub_sub_self m ‚Ąď
  right_inv ‚Ąď := sub_sub_self m ‚Ąď

/-- **Shift invariance of the ‚Ąď¬≤ norm (tsum form).**
`‚ąĎ' ‚Ąď, ‚ÄĖg(m ‚ąí ‚Ąď)‚ÄĖ¬≤ = ‚ąĎ' ‚Ąď, ‚ÄĖg(‚Ąď)‚ÄĖ¬≤`. -/
theorem tsum_sq_norm_shift_left {őĻ : Type*} [AddCommGroup őĻ]
    (g : őĻ ‚Üí ‚Ąā) (m : őĻ) :
    (‚ąĎ' ‚Ąď : őĻ, ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) = ‚ąĎ' ‚Ąď : őĻ, ‚ÄĖg ‚Ąď‚ÄĖ ^ 2 :=
  (subLeftEquiv m).tsum_eq (fun ‚Ąď => ‚ÄĖg ‚Ąď‚ÄĖ ^ 2)

/-- **Shift invariance of ‚Ąď¬≤ summability.** If `‚ąĎ' ‚Ąď, ‚ÄĖg(‚Ąď)‚ÄĖ¬≤` is
summable, so is `‚ąĎ' ‚Ąď, ‚ÄĖg(m ‚ąí ‚Ąď)‚ÄĖ¬≤`. -/
theorem summable_sq_norm_shift_left {őĻ : Type*} [AddCommGroup őĻ]
    (g : őĻ ‚Üí ‚Ąā) (m : őĻ)
    (hg : Summable (fun ‚Ąď => ‚ÄĖg ‚Ąď‚ÄĖ ^ 2)) :
    Summable (fun ‚Ąď => ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) :=
  (subLeftEquiv m).summable_iff.mpr hg

/-- **Pointwise convolution bound (Young + triangle form).**

For ‚Ąď¬≤-summable `f`, `g : őĻ ‚Üí ‚Ąā`, the convolution at every mode `m`
satisfies the **uniform-in-`m`** bound

  `‚ÄĖ(f * g)(m)‚ÄĖ ‚Č§ (‚ÄĖf‚ÄĖ¬≤_‚Ąď¬≤ + ‚ÄĖg‚ÄĖ¬≤_‚Ąď¬≤) / 2`.

Proof: Young's inequality `2ab ‚Č§ a¬≤ + b¬≤` at every `‚Ąď` gives
termwise `‚ÄĖf(‚Ąď)‚ÄĖ¬∑‚ÄĖg(m ‚ąí ‚Ąď)‚ÄĖ ‚Č§ (‚ÄĖf(‚Ąď)‚ÄĖ¬≤ + ‚ÄĖg(m ‚ąí ‚Ąď)‚ÄĖ¬≤)/2`. Summing,
combined with shift invariance `‚ąĎ ‚Ąď, ‚ÄĖg(m ‚ąí ‚Ąď)‚ÄĖ¬≤ = ‚ąĎ ‚Ąď, ‚ÄĖg(‚Ąď)‚ÄĖ¬≤` and
the triangle inequality for `tsum`, yields the stated bound.

Weaker than the Cauchy‚ÄďSchwarz form `‚ąö(‚ÄĖf‚ÄĖ¬≤) ¬∑ ‚ąö(‚ÄĖg‚ÄĖ¬≤)` but
equivalent up to a constant factor. It is the form the ¬ß11 Bochner
step will consume: once the ‚Ąď¬≤ norms of the per-mode sequences are
uniformly bounded in time, the per-mode flux is uniformly bounded,
hence Bochner-integrable on any finite time interval. -/
theorem convolution_bounded_by_product
    {őĻ : Type*} [AddCommGroup őĻ]
    (f g : őĻ ‚Üí ‚Ąā)
    (hf : Summable (fun ‚Ąď => ‚ÄĖf ‚Ąď‚ÄĖ ^ 2))
    (hg : Summable (fun ‚Ąď => ‚ÄĖg ‚Ąď‚ÄĖ ^ 2))
    (m : őĻ) :
    ‚ÄĖfourierConvolution f g m‚ÄĖ
      ‚Č§ ((‚ąĎ' ‚Ąď, ‚ÄĖf ‚Ąď‚ÄĖ ^ 2) + (‚ąĎ' ‚Ąď, ‚ÄĖg ‚Ąď‚ÄĖ ^ 2)) / 2 := by
  -- Shift invariance of the ‚Ąď¬≤ norm of `g`.
  have hg_shift_sum : Summable (fun ‚Ąď => ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) :=
    summable_sq_norm_shift_left g m hg
  have hg_shift_eq : (‚ąĎ' ‚Ąď, ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) = ‚ąĎ' ‚Ąď, ‚ÄĖg ‚Ąď‚ÄĖ ^ 2 :=
    tsum_sq_norm_shift_left g m
  -- Young termwise: `‚ÄĖf(‚Ąď)‚ÄĖ¬∑‚ÄĖg(m ‚ąí ‚Ąď)‚ÄĖ ‚Č§ (‚ÄĖf(‚Ąď)‚ÄĖ¬≤ + ‚ÄĖg(m ‚ąí ‚Ąď)‚ÄĖ¬≤)/2`.
  have hyoung : ‚ąÄ ‚Ąď, ‚ÄĖf ‚Ąď‚ÄĖ * ‚ÄĖg (m - ‚Ąď)‚ÄĖ
      ‚Č§ (‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) / 2 := by
    intro ‚Ąď
    have h := two_mul_le_add_sq ‚ÄĖf ‚Ąď‚ÄĖ ‚ÄĖg (m - ‚Ąď)‚ÄĖ
    linarith
  -- Summability of the upper-bound sequence.
  have hbound_sum : Summable (fun ‚Ąď => (‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) / 2) := by
    have hadd : Summable (fun ‚Ąď => ‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) :=
      hf.add hg_shift_sum
    simpa [div_eq_mul_inv] using hadd.mul_right ((1 : ‚ĄĚ) / 2)
  -- Summability of the product sequence via domination by the Young bound.
  have hprod_nn : ‚ąÄ ‚Ąď, 0 ‚Č§ ‚ÄĖf ‚Ąď‚ÄĖ * ‚ÄĖg (m - ‚Ąď)‚ÄĖ := fun _ =>
    mul_nonneg (norm_nonneg _) (norm_nonneg _)
  have hprod_sum : Summable (fun ‚Ąď => ‚ÄĖf ‚Ąď‚ÄĖ * ‚ÄĖg (m - ‚Ąď)‚ÄĖ) :=
    Summable.of_nonneg_of_le hprod_nn hyoung hbound_sum
  -- Triangle inequality for `tsum` (via `norm_mul` on each term).
  have hnorm_eq : (fun ‚Ąď => ‚ÄĖf ‚Ąď * g (m - ‚Ąď)‚ÄĖ)
      = (fun ‚Ąď => ‚ÄĖf ‚Ąď‚ÄĖ * ‚ÄĖg (m - ‚Ąď)‚ÄĖ) := by
    funext ‚Ąď; exact norm_mul _ _
  have htri_sum : Summable (fun ‚Ąď => ‚ÄĖf ‚Ąď * g (m - ‚Ąď)‚ÄĖ) := by
    rw [hnorm_eq]; exact hprod_sum
  have htriangle : ‚ÄĖfourierConvolution f g m‚ÄĖ
      ‚Č§ ‚ąĎ' ‚Ąď, ‚ÄĖf ‚Ąď * g (m - ‚Ąď)‚ÄĖ := by
    unfold fourierConvolution
    exact norm_tsum_le_tsum_norm htri_sum
  -- tsum comparison (HasSum-form, avoids depending on `tsum_le_tsum`'s exact name)
  have hprod_le_bound :
      (‚ąĎ' ‚Ąď, ‚ÄĖf ‚Ąď‚ÄĖ * ‚ÄĖg (m - ‚Ąď)‚ÄĖ) ‚Č§ ‚ąĎ' ‚Ąď, (‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) / 2 :=
    hasSum_le hyoung hprod_sum.hasSum hbound_sum.hasSum
  -- `‚ąĎ' (a + b) = ‚ąĎ' a + ‚ąĎ' b` via `HasSum.add`.
  have hadd_eq :
      (‚ąĎ' ‚Ąď, (‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2))
        = (‚ąĎ' ‚Ąď, ‚ÄĖf ‚Ąď‚ÄĖ ^ 2) + (‚ąĎ' ‚Ąď, ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) :=
    (hf.hasSum.add hg_shift_sum.hasSum).tsum_eq
  -- Pull out the `/2` factor via `tsum_mul_right` on `* (1/2)`.
  have hdiv_eq :
      (‚ąĎ' ‚Ąď, (‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) / 2)
        = (‚ąĎ' ‚Ąď, (‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2)) / 2 := by
    simp [div_eq_mul_inv, tsum_mul_right]
  -- Assemble the final chain.
  calc ‚ÄĖfourierConvolution f g m‚ÄĖ
      ‚Č§ ‚ąĎ' ‚Ąď, ‚ÄĖf ‚Ąď * g (m - ‚Ąď)‚ÄĖ := htriangle
    _ = ‚ąĎ' ‚Ąď, ‚ÄĖf ‚Ąď‚ÄĖ * ‚ÄĖg (m - ‚Ąď)‚ÄĖ := by rw [hnorm_eq]
    _ ‚Č§ ‚ąĎ' ‚Ąď, (‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2) / 2 := hprod_le_bound
    _ = (‚ąĎ' ‚Ąď, (‚ÄĖf ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2)) / 2 := hdiv_eq
    _ = ((‚ąĎ' ‚Ąď, ‚ÄĖf ‚Ąď‚ÄĖ ^ 2) + (‚ąĎ' ‚Ąď, ‚ÄĖg (m - ‚Ąď)‚ÄĖ ^ 2)) / 2 := by rw [hadd_eq]
    _ = ((‚ąĎ' ‚Ąď, ‚ÄĖf ‚Ąď‚ÄĖ ^ 2) + (‚ąĎ' ‚Ąď, ‚ÄĖg ‚Ąď‚ÄĖ ^ 2)) / 2 := by rw [hg_shift_eq]

namespace SqgFourierData

/-- **Bundle-level convolution wrapper.** Forwards the raw
`fourierConvolution` on the `őł` fields of two `SqgFourierData`
bundles. Convenience for statements that already carry a
`SqgFourierData` structure ‚ÄĒ reuses all of the `w`, `w_norm_le`,
`ell2_bound` machinery from the Fourier-mode packaging section. -/
noncomputable def fourierConvolution {őĻ : Type*} [AddCommGroup őĻ]
    (D‚āĀ D‚āā : SqgFourierData őĻ) : őĻ ‚Üí ‚Ąā :=
  _root_.SqgIdentity.fourierConvolution D‚āĀ.őł D‚āā.őł

/-- **Bundle-level convolution bound.** Immediate consequence of
`convolution_bounded_by_product`: if both bundles' `őł`-sequences are
‚Ąď¬≤-summable, the bundle convolution is pointwise bounded by
`(‚ÄĖD‚āĀ.őł‚ÄĖ¬≤_‚Ąď¬≤ + ‚ÄĖD‚āā.őł‚ÄĖ¬≤_‚Ąď¬≤)/2`. -/
theorem fourierConvolution_bounded_by_product
    {őĻ : Type*} [AddCommGroup őĻ]
    (D‚āĀ D‚āā : SqgFourierData őĻ)
    (h‚āĀ : Summable (fun ‚Ąď => ‚ÄĖD‚āĀ.őł ‚Ąď‚ÄĖ ^ 2))
    (h‚āā : Summable (fun ‚Ąď => ‚ÄĖD‚āā.őł ‚Ąď‚ÄĖ ^ 2))
    (m : őĻ) :
    ‚ÄĖD‚āĀ.fourierConvolution D‚āā m‚ÄĖ
      ‚Č§ ((‚ąĎ' ‚Ąď, ‚ÄĖD‚āĀ.őł ‚Ąď‚ÄĖ ^ 2) + (‚ąĎ' ‚Ąď, ‚ÄĖD‚āā.őł ‚Ąď‚ÄĖ ^ 2)) / 2 :=
  convolution_bounded_by_product D‚āĀ.őł D‚āā.őł h‚āĀ h‚āā m

end SqgFourierData

/-! ### ¬ß10.10 Mode-Lipschitz upgrade to `SqgEvolutionAxioms`

The `meanConservation` field introduced in ¬ß10.8 is the `m = 0`
consequence of the SQG evolution: the spatial mean is exactly
preserved. At `m ‚Č† 0` the Fourier coefficient is *not* conserved ‚ÄĒ
it evolves via the per-mode flux `(u¬∑‚ąáőł)Őā(m, ŌĄ)`, which by
`convolution_bounded_by_product` is uniformly bounded in `ŌĄ`
(provided `u` and `őł` are ‚Ąď¬≤-summable uniformly in time). The
consequence is a **mode-level Lipschitz-in-time bound**:

  `‚ÄĖőłŐā(m, t‚āā) ‚ąí őłŐā(m, t‚āĀ)‚ÄĖ ‚Č§ (t‚āā ‚ąí t‚āĀ) ¬∑ C_m`

for some `C_m ‚Č• 0` that depends on the mode.

This is the differential form of the Duhamel identity ‚ÄĒ strictly
stronger than `meanConservation` (which is the `C_0 = 0` case at
mode 0) and strictly weaker than the full integral Duhamel (which
would also specify `C_m` as an explicit convolution quantity and
state the identity as an equality with a Bochner integral).

At this level the structure carries enough content to feed the ¬ß10.8
s=2 bootstrap once the Bochner integration infrastructure is in
place: the Lipschitz constants `C_m` are exactly the `‚ÄĖ¬∑‚ÄĖ‚ąě` bounds
on the time-integrand of the per-mode Duhamel identity.

This subsection:

* Introduces `ModeLipschitz őł` ‚ÄĒ a Prop predicate capturing the
  mode-by-mode Lipschitz-in-time bound.
* Shows `ModeLipschitz.of_identically_zero`: the zero solution
  satisfies it trivially with `C_m = 0`.
* States `SqgEvolutionAxioms_strong` ‚ÄĒ a strengthened version of
  `SqgEvolutionAxioms` that additionally requires `ModeLipschitz`.
  The original `SqgEvolutionAxioms` is kept for backward
  compatibility; `SqgEvolutionAxioms_strong.toWeak` forgets the
  extra content.
* Provides the zero-solution discharge
  `SqgEvolutionAxioms_strong.of_identically_zero`.
-/

/-- **Mode-Lipschitz-in-time property.** Every Fourier coefficient
of `őł(t)` is Lipschitz-in-time, with a mode-specific constant.

This is the differential form of the per-mode Duhamel identity:
the full identity says `őłŐā(m, t) ‚ąí őłŐā(m, s) = ‚ąí‚ąę‚āõŠĶó F(m, ŌĄ) dŌĄ` where
`F` is the convolution flux; bounding `F` uniformly in `ŌĄ` (by
`convolution_bounded_by_product`) yields the stated Lipschitz
bound with `C m = sup_ŌĄ ‚ÄĖF(m, ŌĄ)‚ÄĖ`. -/
def ModeLipschitz
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop :=
  ‚ąÄ m : Fin 2 ‚Üí ‚Ą§,
    ‚ąÉ C : ‚ĄĚ, 0 ‚Č§ C ‚ąß
      ‚ąÄ s t : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
        ‚ÄĖmFourierCoeff (őł t) m - mFourierCoeff (őł s) m‚ÄĖ
          ‚Č§ (t - s) * C

/-- **Mode-Lipschitz holds trivially for the identically-zero
evolution.** Every Fourier coefficient difference is zero, and any
non-negative constant (take `C = 0`) satisfies the bound. -/
theorem ModeLipschitz.of_identically_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł : ‚ąÄ t, őł t = 0) :
    ModeLipschitz őł := by
  intro m
  refine ‚ü®0, le_refl 0, fun s t _ _ => ?_‚ü©
  rw [hőł t, hőł s, sub_self]
  simp

/-- **Strengthened `SqgEvolutionAxioms`.** Bundles the original axioms
with the mode-Lipschitz predicate ‚ÄĒ the ¬ß10.10 keystone content
established in this section. -/
structure SqgEvolutionAxioms_strong
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop where
  /-- All of the original `SqgEvolutionAxioms` content. -/
  weak : SqgEvolutionAxioms őł
  /-- Per-mode Lipschitz-in-time bound ‚ÄĒ the ¬ß10.10 upgrade. -/
  modeLipschitz : ModeLipschitz őł

namespace SqgEvolutionAxioms_strong

/-- **Forgetful projection.** A strong evolution axiom-set implies
the original one. -/
theorem toWeak {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (h : SqgEvolutionAxioms_strong őł) : SqgEvolutionAxioms őł :=
  h.weak

/-- **Zero-solution discharge for the strengthened structure.** -/
theorem of_identically_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł : ‚ąÄ t, őł t = 0) :
    SqgEvolutionAxioms_strong őł where
  weak := SqgEvolutionAxioms.of_identically_zero őł hőł
  modeLipschitz := ModeLipschitz.of_identically_zero őł hőł

end SqgEvolutionAxioms_strong

/-! ### ¬ß10.11 SQG-specific Bochner wiring: `DuhamelFlux ‚áí ModeLipschitz`

¬ß10.9 gives the pointwise convolution bound
`convolution_bounded_by_product`. ¬ß10.10 states the Lipschitz-in-time
target `ModeLipschitz`. This subsection wires them together via the
Bochner-integral chain

  `‚ÄĖ‚ąę_s^t F(m, ŌĄ) dŌĄ‚ÄĖ ‚Č§ ‚ąę_s^t ‚ÄĖF(m, ŌĄ)‚ÄĖ dŌĄ ‚Č§ (t ‚ąí s) ¬∑ sup_ŌĄ ‚ÄĖF(m, ŌĄ)‚ÄĖ`.

Concretely: the `DuhamelFlux` predicate bundles

  (i)  A per-mode flux function `F : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ ‚Üí ‚Ąā`.
  (ii) A uniform-in-`ŌĄ` bound `sup_ŌĄ ‚ÄĖF(m, ŌĄ)‚ÄĖ ‚Č§ K m` (this is the
       precise shape that `convolution_bounded_by_product` delivers).
  (iii) The per-mode Duhamel integral identity
       `őłŐā(m, t) ‚ąí őłŐā(m, s) = ‚ąí ‚ąę_s^t F(m, ŌĄ) dŌĄ`.

`DuhamelFlux.modeLipschitz` then discharges `ModeLipschitz` via a
one-shot application of `MeasureTheory.norm_setIntegral_le_of_norm_le_const`
combined with `Real.volume_Icc` for the interval-length identity.

**This is the SQG-specific wiring** the ¬ß10.9 / ¬ß10.10 scaffolding
was built for: given a real SQG solution supplying `DuhamelFlux`
(with flux witnessed by a sum of `fourierConvolution`s and the bound
witnessed by `convolution_bounded_by_product` on the velocity/gradient
coefficient sequences), `SqgEvolutionAxioms_strong` follows
immediately. No intermediate integrability argument is needed ‚ÄĒ the
mathlib lemma packages it inside. -/

/-- **Duhamel-flux representation of an SQG-type evolution.**

Witnesses a per-mode Fourier-side Duhamel identity for `őł`:

  `őłŐā(m, t) ‚ąí őłŐā(m, s) = ‚ąí‚ąę_s^t F(m, ŌĄ) dŌĄ`  for  `0 ‚Č§ s ‚Č§ t`,

together with a uniform-in-`ŌĄ` bound `‚ÄĖF(m, ŌĄ)‚ÄĖ ‚Č§ K m` on each mode's
flux ‚ÄĒ the precise shape that `convolution_bounded_by_product`
delivers when `F(m, ŌĄ)` is realized as a sum of
`fourierConvolution`s of ‚Ąď¬≤-summable sequences. -/
def DuhamelFlux
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop :=
  ‚ąÉ F : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ ‚Üí ‚Ąā,
    (‚ąÄ m, ‚ąÉ K : ‚ĄĚ, 0 ‚Č§ K ‚ąß ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖF m ŌĄ‚ÄĖ ‚Č§ K) ‚ąß
    (‚ąÄ m (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
      mFourierCoeff (őł t) m - mFourierCoeff (őł s) m
        = -‚ąę ŌĄ in Set.Icc s t, F m ŌĄ)

/-- **Zero-solution discharge of `DuhamelFlux`.** Take the identically-
zero flux; both sides of the Duhamel identity vanish. -/
theorem DuhamelFlux.of_identically_zero
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł : ‚ąÄ t, őł t = 0) :
    DuhamelFlux őł := by
  refine ‚ü®fun _ _ => (0 : ‚Ąā), ?_, ?_‚ü©
  ¬∑ intro m
    refine ‚ü®0, le_refl 0, fun ŌĄ _ => ?_‚ü©
    simp
  ¬∑ intro m s t hs hst
    -- LHS: mFourierCoeff (őł t) m - mFourierCoeff (őł s) m = 0 since őł ‚Č° 0.
    -- RHS: -‚ąę ŌĄ in Icc s t, 0 = 0.
    rw [hőł t, hőł s, sub_self]
    simp

/-- **SQG-specific Bochner wiring: `DuhamelFlux ‚áí ModeLipschitz`.**

The single analytic fact between the ¬ß10.9/¬ß10.10 scaffolding and a
real-solution discharge of `SqgEvolutionAxioms_strong`. Given a
Duhamel-flux witness with per-mode bound `K_m`, every Fourier
coefficient is Lipschitz-in-time with constant `K_m`:

  `‚ÄĖőłŐā(m, t) ‚ąí őłŐā(m, s)‚ÄĖ ‚Č§ (t ‚ąí s) ¬∑ K_m`.

Proof is a one-shot application of
`MeasureTheory.norm_setIntegral_le_of_norm_le_const` on `Set.Icc s t`
under the `volume` measure, combined with `Real.volume_Icc` to
evaluate `volume.real (Icc s t) = t ‚ąí s` for `s ‚Č§ t`. -/
theorem DuhamelFlux.modeLipschitz
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (h : DuhamelFlux őł) : ModeLipschitz őł := by
  intro m
  obtain ‚ü®F, hbound, hduhamel‚ü© := h
  obtain ‚ü®K, hK_nn, hK‚ü© := hbound m
  refine ‚ü®K, hK_nn, fun s t hs hst => ?_‚ü©
  -- Rewrite via Duhamel, drop the leading minus sign.
  rw [hduhamel m s t hs hst, norm_neg]
  -- `Icc s t` has finite `volume`.
  have hvol_lt_top : (volume : Measure ‚ĄĚ) (Set.Icc s t) < ‚ä§ := by
    rw [Real.volume_Icc]
    exact ENNReal.ofReal_lt_top
  -- Per-point bound on the flux over `Icc s t`. For ŌĄ ‚ąą Icc s t,
  -- hs : 0 ‚Č§ s and hŌĄ.1 : s ‚Č§ ŌĄ give 0 ‚Č§ ŌĄ, so the weakened K-bound applies.
  have hbound_on : ‚ąÄ ŌĄ ‚ąą Set.Icc s t, ‚ÄĖF m ŌĄ‚ÄĖ ‚Č§ K :=
    fun ŌĄ hŌĄ => hK ŌĄ (le_trans hs hŌĄ.1)
  -- Apply the mathlib Bochner lemma.
  have hbochner :
      ‚ÄĖ‚ąę ŌĄ in Set.Icc s t, F m ŌĄ‚ÄĖ
        ‚Č§ K * ((volume : Measure ‚ĄĚ).real (Set.Icc s t)) :=
    MeasureTheory.norm_setIntegral_le_of_norm_le_const hvol_lt_top hbound_on
  -- Evaluate the interval length.
  have hvol_real : ((volume : Measure ‚ĄĚ).real (Set.Icc s t)) = t - s := by
    simp [MeasureTheory.measureReal_def, Real.volume_Icc,
          ENNReal.toReal_ofReal (show (0 : ‚ĄĚ) ‚Č§ t - s by linarith)]
  -- Combine.
  calc ‚ÄĖ‚ąę ŌĄ in Set.Icc s t, F m ŌĄ‚ÄĖ
      ‚Č§ K * ((volume : Measure ‚ĄĚ).real (Set.Icc s t)) := hbochner
    _ = K * (t - s) := by rw [hvol_real]
    _ = (t - s) * K := by ring

/-- **Structured-form: `DuhamelFlux` promotes `SqgEvolutionAxioms`
to `SqgEvolutionAxioms_strong`.** The single remaining step
between "real SQG solution with Duhamel representation" and the
¬ß10.10 keystone structure. -/
theorem SqgEvolutionAxioms.strengthen_of_duhamel
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hE : SqgEvolutionAxioms őł)
    (hD : DuhamelFlux őł) :
    SqgEvolutionAxioms_strong őł where
  weak := hE
  modeLipschitz := hD.modeLipschitz

/-! ### ¬ß10.12 Concrete SQG nonlinear flux + PDE-identity promotion

Duhamel keystone: realize the per-mode nonlinear flux `(u ¬∑ ‚ąáőł)Őā(m)`
as a **concrete Lean expression** ‚ÄĒ a sum over the two velocity
components of `fourierConvolution`s between the velocity Fourier
coefficients and the gradient Fourier coefficients. Bound it via
`convolution_bounded_by_product` on each component. Discharge
`SqgEvolutionAxioms_strong` from a **PDE-level integral identity**
against this specific flux, under two natural ‚Ąď¬≤ control
hypotheses (uniform ‚Ąď¬≤ bound on velocity coefficients and on
gradient coefficients in time).

After ¬ß10.12, the remaining open content of conditional Theorem 3 on
`s ‚ąą [0, 2]` collapses to:

* `MaterialMaxPrinciple.hOnePropagation` ‚ÄĒ the ¬ß9 of the paper geometric
  argument (unchanged).
* `BKMCriterionS2.hsPropagationS2` ‚ÄĒ integer-order ŠłĘ¬≤ bootstrap
  (unchanged).
* **A single weak-form PDE identity** at the Fourier level, stated
  cleanly as `őłŐā(m, t) ‚ąí őłŐā(m, s) = ‚ąí ‚ąę_s^t (sqgNonlinearFlux)(m, ŌĄ) dŌĄ`.
  This is the PDE existence / regularity content; the flux and its
  bound are no longer part of the open axiomatic footprint.

Provided here:

* `sqgNonlinearFlux őł u m` ‚ÄĒ the concrete flux definition.
* `sqgNonlinearFlux_bounded` ‚ÄĒ the per-mode pointwise bound derived
  from `convolution_bounded_by_product` on each component.
* `SqgEvolutionAxioms_strong.of_sqgDuhamelIdentity` ‚ÄĒ the PDE-to-
  `SqgEvolutionAxioms_strong` promotion theorem.
-/

/-- **Concrete SQG nonlinear flux at a fixed mode.** The Fourier-side
realization of `(u ¬∑ ‚ąáőł)Őā(m)` as a sum of convolutions:

  `sqgNonlinearFlux őł u m = ‚ąĎ‚Īľ (√Ľ_j * (i ¬∑ ¬∑_j ¬∑ őłŐā))(m)`

where `derivSymbol j ‚Ąď = i ¬∑ ‚Ąď_j` is the Fourier multiplier of
`‚ąā_j` (from the Riesz library) and `fourierConvolution` is the
¬ß10.9 coefficient-sequence convolution. -/
noncomputable def sqgNonlinearFlux
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (u : Fin 2 ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (m : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  ‚ąĎ j : Fin 2, fourierConvolution
    (fun ‚Ąď => mFourierCoeff (u j) ‚Ąď)
    (fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff őł ‚Ąď) m

/-- **Per-mode bound on `sqgNonlinearFlux`.**

Given ‚Ąď¬≤-summability of (i) the velocity Fourier coefficients of each
`u j` and (ii) the gradient Fourier coefficients `derivSymbol j ¬∑ őłŐā`,
the nonlinear flux at every mode satisfies a Young-type bound inherited
from `convolution_bounded_by_product` on each component, summed over
the two velocity directions via the triangle inequality. -/
theorem sqgNonlinearFlux_bounded
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (u : Fin 2 ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hu_sum : ‚ąÄ j, Summable (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => ‚ÄĖmFourierCoeff (u j) ‚Ąď‚ÄĖ ^ 2))
    (hgrad_sum : ‚ąÄ j, Summable
      (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff őł ‚Ąď‚ÄĖ ^ 2))
    (m : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖsqgNonlinearFlux őł u m‚ÄĖ
      ‚Č§ ‚ąĎ j : Fin 2,
          ((‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (u j) ‚Ąď‚ÄĖ ^ 2)
            + (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff őł ‚Ąď‚ÄĖ ^ 2)) / 2 := by
  unfold sqgNonlinearFlux
  calc
    ‚ÄĖ‚ąĎ j : Fin 2, fourierConvolution (fun ‚Ąď => mFourierCoeff (u j) ‚Ąď)
        (fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff őł ‚Ąď) m‚ÄĖ
      ‚Č§ ‚ąĎ j : Fin 2, ‚ÄĖfourierConvolution (fun ‚Ąď => mFourierCoeff (u j) ‚Ąď)
          (fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff őł ‚Ąď) m‚ÄĖ :=
          norm_sum_le _ _
    _ ‚Č§ ‚ąĎ j : Fin 2,
          ((‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (u j) ‚Ąď‚ÄĖ ^ 2)
            + (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff őł ‚Ąď‚ÄĖ ^ 2)) / 2 := by
        apply Finset.sum_le_sum
        intro j _
        exact convolution_bounded_by_product _ _ (hu_sum j) (hgrad_sum j) m

/-- **PDE-identity promotion to `SqgEvolutionAxioms_strong`.**

The ¬ß10.12 keystone. Given:

* `SqgEvolutionAxioms őł` (from the existing scaffold),
* a concrete velocity field `u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp` witnessing the
  Riesz-transform relation for `őł` at every time,
* uniform ‚Ąď¬≤-summability and uniform-in-`ŌĄ` tsum bounds on the
  velocity and gradient Fourier coefficients (supplied by the caller
  ‚ÄĒ a one-line consequence of Parseval + Riesz L¬≤-isometry + MMP's
  ŠłĘ¬Ļ summability, but deferred here),
* **the PDE integral identity** at the Fourier level against
  `sqgNonlinearFlux`,

this theorem concludes `SqgEvolutionAxioms_strong őł` ‚ÄĒ the ¬ß10.10
keystone structure.

**Only PDE-specific input:** the integral identity `hDuhamel`. The
flux is a concrete Lean expression (`sqgNonlinearFlux`), the bound is
derived (`sqgNonlinearFlux_bounded`), and the Bochner wiring is
already in ¬ß10.11 (`DuhamelFlux.modeLipschitz`). -/
theorem SqgEvolutionAxioms_strong.of_sqgDuhamelIdentity
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hE : SqgEvolutionAxioms őł)
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (_hu_velocity : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), IsSqgVelocityComponent (őł ŌĄ) (u j ŌĄ) j)
    (Mu : ‚ĄĚ) (hMu : 0 ‚Č§ Mu)
    (hu_sum : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí
      Summable (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => ‚ÄĖmFourierCoeff (u j ŌĄ) ‚Ąď‚ÄĖ ^ 2))
    (hu_bdd : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí
      (‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (u j ŌĄ) ‚Ąď‚ÄĖ ^ 2) ‚Č§ Mu)
    (Mg : ‚ĄĚ) (hMg : 0 ‚Č§ Mg)
    (hgrad_sum : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí
      Summable (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2))
    (hgrad_bdd : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí
      (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2) ‚Č§ Mg)
    (hDuhamel : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
      mFourierCoeff (őł t) m - mFourierCoeff (őł s) m
        = -‚ąę ŌĄ in Set.Icc s t, sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m) :
    SqgEvolutionAxioms_strong őł := by
  -- Build the `DuhamelFlux` witness with flux = sqgNonlinearFlux and K = Mu + Mg.
  have hDF : DuhamelFlux őł := by
    refine ‚ü®fun m ŌĄ => sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m, ?_, ?_‚ü©
    ¬∑ -- Uniform per-mode bound (applies at ŌĄ ‚Č• 0).
      intro m
      refine ‚ü®Mu + Mg, by linarith, fun ŌĄ hŌĄ => ?_‚ü©
      have hFlux :=
        sqgNonlinearFlux_bounded (őł ŌĄ) (fun j => u j ŌĄ)
          (fun j => hu_sum j ŌĄ hŌĄ) (fun j => hgrad_sum j ŌĄ hŌĄ) m
      -- Each summand is at most (Mu + Mg)/2; `Fin 2` has two terms.
      have hterm : ‚ąÄ j : Fin 2,
          ((‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (u j ŌĄ) ‚Ąď‚ÄĖ ^ 2)
            + (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2)) / 2
          ‚Č§ (Mu + Mg) / 2 := by
        intro j
        have h1 := hu_bdd j ŌĄ hŌĄ
        have h2 := hgrad_bdd j ŌĄ hŌĄ
        linarith
      have hsum_le :
          ‚ąĎ j : Fin 2,
              ((‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (u j ŌĄ) ‚Ąď‚ÄĖ ^ 2)
                + (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2)) / 2
            ‚Č§ Mu + Mg := by
        calc
          ‚ąĎ j : Fin 2,
              ((‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (u j ŌĄ) ‚Ąď‚ÄĖ ^ 2)
                + (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2)) / 2
            ‚Č§ ‚ąĎ _j : Fin 2, (Mu + Mg) / 2 :=
                Finset.sum_le_sum (fun j _ => hterm j)
          _ = (Mu + Mg) / 2 + (Mu + Mg) / 2 := Fin.sum_univ_two _
          _ = Mu + Mg := by ring
      linarith
    ¬∑ -- Duhamel identity.
      intro m s t hs hst
      exact hDuhamel m s t hs hst
  exact hE.strengthen_of_duhamel hDF

/-! ### ¬ß10.13 ‚Ąď¬≤-control helpers for `sqgNonlinearFlux_bounded`

¬ß10.12's `of_sqgDuhamelIdentity` takes four ‚Ąď¬≤-control hypotheses.
Three of the four are one-line consequences of data the repo already
provides:

* Velocity Fourier summability at fixed `ŌĄ`: automatic from
  `hasSum_sq_mFourierCoeff` applied to `u j ŌĄ : Lp`.
* Gradient Fourier summability: ‚Ąď¬≤ domination by the
  `(fracDerivSymbol 1)`-weighted series, whose summability comes
  from `MaterialMaxPrinciple.hOneSummability`.
* Velocity Fourier ‚Ąď¬≤ tsum bound: per-mode `‚ÄĖsqgVelocitySymbol‚ÄĖ ‚Č§ 1`
  combined with `IsSqgVelocityComponent` gives
  `‚ÄĖu_j‚ÄĖ¬≤_‚Ąď¬≤ ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_‚Ąď¬≤` directly.

This subsection formalizes those three lines as named helpers.
Callers of `of_sqgDuhamelIdentity` can use them to derive the four
control hypotheses from `SqgEvolutionAxioms` + `MaterialMaxPrinciple`
+ the `IsSqgVelocityComponent` witness alone (plus one external
`‚ąę |őł|¬≤` bound ‚ÄĒ the one piece that requires combining
`l2Conservation` with `meanConservation`, deferred). -/

/-- **Single-coordinate derivative symbol bound.** At every lattice
point, `‚ÄĖderivSymbol j n‚ÄĖ¬≤ ‚Č§ (fracDerivSymbol 1 n)¬≤`. At `n ‚Č† 0` this
is `|n_j|¬≤ ‚Č§ ‚ÄĖn‚ÄĖ¬≤`; at `n = 0` both sides vanish. -/
lemma norm_derivSymbol_sq_le_fracDerivSymbol_one_sq
    (j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 ‚Č§ (fracDerivSymbol 1 n) ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    simp [derivSymbol]
  ¬∑ rw [norm_derivSymbol_sq, fracDerivSymbol_one_eq hn]
    exact sq_le_latticeNorm_sq n j

/-- **Gradient Fourier summability from ŠłĘ¬Ļ summability.** -/
lemma gradient_fourier_summable_of_hOneSummability
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (j : Fin 2)
    (hőł_sum : Summable
      (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => (fracDerivSymbol 1 ‚Ąď) ^ 2 * ‚ÄĖmFourierCoeff őł ‚Ąď‚ÄĖ ^ 2)) :
    Summable
      (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff őł ‚Ąď‚ÄĖ ^ 2) := by
  refine Summable.of_nonneg_of_le (fun _ => sq_nonneg _) ?_ hőł_sum
  intro ‚Ąď
  rw [norm_mul, mul_pow]
  exact mul_le_mul_of_nonneg_right
    (norm_derivSymbol_sq_le_fracDerivSymbol_one_sq j ‚Ąď) (sq_nonneg _)

/-- **Gradient Fourier ‚Ąď¬≤ tsum bound by ŠłĘ¬Ļ seminorm.** -/
lemma gradient_fourier_tsum_le_hsSeminormSq_one
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (j : Fin 2)
    (hőł_sum : Summable
      (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => (fracDerivSymbol 1 ‚Ąď) ^ 2 * ‚ÄĖmFourierCoeff őł ‚Ąď‚ÄĖ ^ 2)) :
    (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff őł ‚Ąď‚ÄĖ ^ 2) ‚Č§ hsSeminormSq 1 őł := by
  unfold hsSeminormSq
  refine hasSum_le ?_
    (gradient_fourier_summable_of_hOneSummability őł j hőł_sum).hasSum
    hőł_sum.hasSum
  intro ‚Ąď
  rw [norm_mul, mul_pow]
  exact mul_le_mul_of_nonneg_right
    (norm_derivSymbol_sq_le_fracDerivSymbol_one_sq j ‚Ąď) (sq_nonneg _)

/-- **Velocity Fourier summability** ‚ÄĒ automatic from Parseval on
`u_j : Lp`. -/
lemma velocity_fourier_summable
    (u_j : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Summable (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => ‚ÄĖmFourierCoeff u_j ‚Ąď‚ÄĖ ^ 2) :=
  (hasSum_sq_mFourierCoeff u_j).summable

/-- **Velocity Fourier ‚Ąď¬≤ tsum bound from `IsSqgVelocityComponent`.**
Per-mode `‚ÄĖsqgVelocitySymbol‚ÄĖ ‚Č§ 1` gives `‚ÄĖu_j‚ÄĖ¬≤_‚Ąď¬≤ ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_‚Ąď¬≤`. -/
lemma velocity_fourier_tsum_le_of_IsSqgVelocityComponent
    (őł u_j : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (j : Fin 2)
    (hvel : IsSqgVelocityComponent őł u_j j) :
    (‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff u_j ‚Ąď‚ÄĖ ^ 2)
      ‚Č§ ‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff őł ‚Ąď‚ÄĖ ^ 2 := by
  refine hasSum_le ?_
    (hasSum_sq_mFourierCoeff u_j).summable.hasSum
    (hasSum_sq_mFourierCoeff őł).summable.hasSum
  intro ‚Ąď
  rw [hvel ‚Ąď, norm_mul, mul_pow]
  have h1 : ‚ÄĖsqgVelocitySymbol j ‚Ąď‚ÄĖ ^ 2 ‚Č§ 1 := by
    have h := sqgVelocitySymbol_norm_le_one j ‚Ąď
    have hnn := norm_nonneg (sqgVelocitySymbol j ‚Ąď)
    nlinarith
  calc ‚ÄĖsqgVelocitySymbol j ‚Ąď‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł ‚Ąď‚ÄĖ ^ 2
      ‚Č§ 1 * ‚ÄĖmFourierCoeff őł ‚Ąď‚ÄĖ ^ 2 :=
        mul_le_mul_of_nonneg_right h1 (sq_nonneg _)
    _ = ‚ÄĖmFourierCoeff őł ‚Ąď‚ÄĖ ^ 2 := one_mul _

/-! ### ¬ß10.14 Full L¬≤ conservation + MMP-keyed promotion

The last external hypothesis in ¬ß10.12's `of_sqgDuhamelIdentity` is
`Mu` ‚ÄĒ a uniform ‚Ąď¬≤ tsum bound on the velocity Fourier coefficients.
Combining `l2Conservation` (which controls the non-zero modes) with
`meanConservation` (which controls the zero mode) gives **full L¬≤
conservation** of `őł`; by Parseval this translates to conservation
of `‚ąĎ' n, ‚ÄĖőłŐā(ŌĄ) n‚ÄĖ¬≤`, closing the loop.

This subsection ships:

* `l2_integral_eq_fourier_zero_sq_plus_hsSeminormSq_zero` ‚ÄĒ the
  Parseval "split-at-zero-mode" identity, writing the full ‚Ąď¬≤ tsum
  as the zero-mode contribution plus `hsSeminormSq 0`.
* `theta_fourier_tsum_conserved` ‚ÄĒ given `SqgEvolutionAxioms őł`,
  `‚ąĎ' n, ‚ÄĖőłŐā(ŌĄ) n‚ÄĖ¬≤ = ‚ąĎ' n, ‚ÄĖőłŐā(0) n‚ÄĖ¬≤` for every forward time.
* `SqgEvolutionAxioms_strong.of_sqgDuhamelIdentity_via_MMP` ‚ÄĒ the
  fully-internalized promotion theorem. Consumes **only**
  `SqgEvolutionAxioms + MaterialMaxPrinciple + velocity witness +
  the PDE integral identity**.

**The headline reading of the repo after ¬ß10.14:**

> "Give me a solution satisfying `SqgEvolutionAxioms` (which already
> requires mean + L¬≤ conservation + Riesz-transform velocity),
> `MaterialMaxPrinciple` (uniform ŠłĘ¬Ļ bound), and the integral form
> of the SQG PDE against `sqgNonlinearFlux` ‚ÄĒ and I will hand you
> uniform ŠłĘňĘ bounds for every `s ‚ąą [0, 2]`."
-/

/-- **Parseval split at the zero mode.** For any `f : L¬≤(ūĚēč¬≤)`,

  `‚ąę ‚ÄĖf‚ÄĖ¬≤ = ‚ÄĖfŐā(0)‚ÄĖ¬≤ + hsSeminormSq 0 f`.

Since `fracDerivSymbol 0` vanishes at `n = 0` and equals `1` at every
other mode, `hsSeminormSq 0 f` sums the squared Fourier coefficients
over `n ‚Č† 0`, leaving the zero-mode contribution separated. -/
lemma l2_integral_eq_fourier_zero_sq_plus_hsSeminormSq_zero
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    (‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2) = ‚ÄĖmFourierCoeff f (0 : Fin 2 ‚Üí ‚Ą§)‚ÄĖ ^ 2 + hsSeminormSq 0 f := by
  classical
  have hP : HasSum
      (fun n : Fin 2 ‚Üí ‚Ą§ => ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) (‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2) :=
    hasSum_sq_mFourierCoeff f
  have hsum := hP.summable
  have h1 :
      (‚ąĎ' n : Fin 2 ‚Üí ‚Ą§, ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
        = ‚ÄĖmFourierCoeff f (0 : Fin 2 ‚Üí ‚Ą§)‚ÄĖ ^ 2
          + ‚ąĎ' n : Fin 2 ‚Üí ‚Ą§, ite (n = 0) 0 (‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
    hsum.tsum_eq_add_tsum_ite 0
  rw [hP.tsum_eq] at h1
  rw [h1]
  congr 1
  -- Show the residual tsum equals `hsSeminormSq 0 f`.
  unfold hsSeminormSq
  apply tsum_congr
  intro n
  by_cases hn : n = 0
  ¬∑ subst hn; simp [fracDerivSymbol_zero]
  ¬∑ rw [if_neg hn, fracDerivSymbol_of_ne_zero 0 hn, Real.rpow_zero]
    ring

/-- **Full Fourier ‚Ąď¬≤ tsum conservation for SQG solutions.**

Given `SqgEvolutionAxioms őł`, for every forward time `ŌĄ ‚Č• 0`,

  `‚ąĎ' n, ‚ÄĖőłŐā(ŌĄ) n‚ÄĖ¬≤ = ‚ąĎ' n, ‚ÄĖőłŐā(0) n‚ÄĖ¬≤`.

Proof: Parseval's "split at the zero mode" identity writes both sides
as `‚ÄĖőłŐā(¬∑) 0‚ÄĖ¬≤ + hsSeminormSq 0 (őł ¬∑)`. The first term is conserved
by `meanConservation`; the second by `l2Conservation`. -/
lemma theta_fourier_tsum_conserved
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hE : SqgEvolutionAxioms őł)
    {ŌĄ : ‚ĄĚ} (hŌĄ : 0 ‚Č§ ŌĄ) :
    (‚ąĎ' n, ‚ÄĖmFourierCoeff (őł ŌĄ) n‚ÄĖ ^ 2)
      = ‚ąĎ' n, ‚ÄĖmFourierCoeff (őł 0) n‚ÄĖ ^ 2 := by
  rw [(hasSum_sq_mFourierCoeff (őł ŌĄ)).tsum_eq,
      (hasSum_sq_mFourierCoeff (őł 0)).tsum_eq,
      l2_integral_eq_fourier_zero_sq_plus_hsSeminormSq_zero (őł ŌĄ),
      l2_integral_eq_fourier_zero_sq_plus_hsSeminormSq_zero (őł 0),
      hE.meanConservation ŌĄ hŌĄ, hE.l2Conservation ŌĄ hŌĄ]

/-- **MMP-keyed promotion to `SqgEvolutionAxioms_strong`.** The clean
form the ¬ß10.9‚Äď¬ß10.13 machinery was built for.

Consumes:
* `SqgEvolutionAxioms őł`
* `MaterialMaxPrinciple őł`
* velocity field `u` + `IsSqgVelocityComponent` witness
* the PDE integral identity at the Fourier level against
  `sqgNonlinearFlux`

Concludes `SqgEvolutionAxioms_strong őł`. All four ‚Ąď¬≤ control
hypotheses of `of_sqgDuhamelIdentity` are discharged internally:

* Velocity summability: `velocity_fourier_summable` (Parseval on
  `u j ŌĄ : Lp`).
* Velocity tsum bound: `velocity_fourier_tsum_le_of_IsSqgVelocityComponent`
  combined with `theta_fourier_tsum_conserved` gives a constant
  `Mu := ‚ąĎ' n, ‚ÄĖőłŐā(0) n‚ÄĖ¬≤`.
* Gradient summability: `gradient_fourier_summable_of_hOneSummability`
  against `MMP.hOneSummability`.
* Gradient tsum bound: `gradient_fourier_tsum_le_hsSeminormSq_one`
  combined with `MMP.hOnePropagation` gives `Mg := M‚āĀ`. -/
theorem SqgEvolutionAxioms_strong.of_sqgDuhamelIdentity_via_MMP
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hE : SqgEvolutionAxioms őł)
    (hMMP : MaterialMaxPrinciple őł)
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hu_velocity : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), IsSqgVelocityComponent (őł ŌĄ) (u j ŌĄ) j)
    (hDuhamel : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
      mFourierCoeff (őł t) m - mFourierCoeff (őł s) m
        = -‚ąę ŌĄ in Set.Icc s t, sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m) :
    SqgEvolutionAxioms_strong őł := by
  -- Velocity tsum bound Mu := ‚ąĎ' n, ‚ÄĖőłŐā(0) n‚ÄĖ¬≤, constant across forward time
  -- by `theta_fourier_tsum_conserved`.
  set Mu : ‚ĄĚ := ‚ąĎ' n : Fin 2 ‚Üí ‚Ą§, ‚ÄĖmFourierCoeff (őł 0) n‚ÄĖ ^ 2 with hMu_def
  have hMu_nn : 0 ‚Č§ Mu := tsum_nonneg (fun _ => sq_nonneg _)
  have hu_sum : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí
      Summable (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => ‚ÄĖmFourierCoeff (u j ŌĄ) ‚Ąď‚ÄĖ ^ 2) :=
    fun j ŌĄ _ => velocity_fourier_summable (u j ŌĄ)
  have hu_bdd : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí
      (‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (u j ŌĄ) ‚Ąď‚ÄĖ ^ 2) ‚Č§ Mu := by
    intro j ŌĄ hŌĄ
    calc (‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (u j ŌĄ) ‚Ąď‚ÄĖ ^ 2)
        ‚Č§ ‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2 :=
          velocity_fourier_tsum_le_of_IsSqgVelocityComponent
            (őł ŌĄ) (u j ŌĄ) j (hu_velocity j ŌĄ)
      _ = Mu := theta_fourier_tsum_conserved hE hŌĄ
  -- Gradient tsum bound Mg := M‚āĀ from MMP.hOnePropagation.
  obtain ‚ü®M‚āĀ, hM‚āĀ‚ü© := hMMP.hOnePropagation
  set Mg : ‚ĄĚ := M‚āĀ with hMg_def
  have hMg_nn : 0 ‚Č§ Mg := by
    have hbd := hM‚āĀ 0 (le_refl 0)
    have hnn : 0 ‚Č§ hsSeminormSq 1 (őł 0) := hsSeminormSq_nonneg 1 (őł 0)
    linarith
  have hgrad_sum : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí
      Summable (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ =>
        ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2) :=
    fun j ŌĄ hŌĄ =>
      gradient_fourier_summable_of_hOneSummability (őł ŌĄ) j
        (hMMP.hOneSummability ŌĄ hŌĄ)
  have hgrad_bdd : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí
      (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2) ‚Č§ Mg := by
    intro j ŌĄ hŌĄ
    calc (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (őł ŌĄ) ‚Ąď‚ÄĖ ^ 2)
        ‚Č§ hsSeminormSq 1 (őł ŌĄ) :=
          gradient_fourier_tsum_le_hsSeminormSq_one (őł ŌĄ) j
            (hMMP.hOneSummability ŌĄ hŌĄ)
      _ ‚Č§ Mg := hM‚āĀ ŌĄ hŌĄ
  -- Chain through of_sqgDuhamelIdentity.
  exact SqgEvolutionAxioms_strong.of_sqgDuhamelIdentity
    hE u hu_velocity Mu hMu_nn hu_sum hu_bdd Mg hMg_nn
    hgrad_sum hgrad_bdd hDuhamel

/-! ### ¬ß10.15 Weak-solution predicate `IsSqgWeakSolution`

¬ß10.14's `of_sqgDuhamelIdentity_via_MMP` takes `hDuhamel`, the mode-wise
integral identity, as a raw ‚ąÄ-proposition. This section wraps that
hypothesis in a named predicate `IsSqgWeakSolution őł u` so that callers
can pass "őł is a weak SQG solution driven by velocity `u`" as a single
structural witness.

**Connection to the classical test-function weak form.** The standard
distributional weak form of `‚ąā_t őł + u ¬∑ ‚ąáőł = 0` on `ūĚēč¬≤ √ó [0, T]` reads:
for every smooth test function `ŌÜ : ūĚēč¬≤ √ó ‚ĄĚ ‚Üí ‚ĄĚ` with compact time
support in `(0, T)`,

  `‚ąę‚āÄ^T ‚ü®őł(ŌĄ), ‚ąā_ŌĄ ŌÜ(¬∑, ŌĄ)‚ü©_{L¬≤(ūĚēč¬≤)} dŌĄ`
  `  + ‚ąę‚āÄ^T ‚ü®őł(ŌĄ) ¬∑ u(ŌĄ), ‚ąá_x ŌÜ(¬∑, ŌĄ)‚ü©_{L¬≤(ūĚēč¬≤)} dŌĄ = 0`.

Specialising to separated test functions `ŌÜ(x, ŌĄ) = Ōą(ŌĄ) ¬∑ e_m(x)`
where `e_m` is the Fourier character of mode `m` and `Ōą` is a smooth
bump on `[s, t]`, Parseval gives

  `‚ąę‚āÄ^T Ōą'(ŌĄ) ¬∑ őłŐā(m, ŌĄ) dŌĄ`
  `  + ‚ąę‚āÄ^T Ōą(ŌĄ) ¬∑ ((u ¬∑ ‚ąáőł)Őā(m, ŌĄ)) dŌĄ = 0`.

Taking `Ōą ‚Üí ūĚüô_{[s, t]}` (bump-to-indicator limit) and recognising
`(u ¬∑ ‚ąáőł)Őā(m, ŌĄ) = sqgNonlinearFlux (őł ŌĄ) (u ŌĄ) m` produces the
mode-wise Duhamel identity carried below. The forward direction
"distributional weak form ‚Üí mode-wise identity" therefore hinges on:

* density of separated Fourier characters in the test-function space
  on `ūĚēč¬≤ √ó [0, T]`,
* the bump-to-indicator limit for `Ōą`, valid because
  `sqgNonlinearFlux (őł ŌĄ) (u ŌĄ) m` is uniformly bounded in `ŌĄ` by
  `sqgNonlinearFlux_bounded` (¬ß10.12) and so the integrand on
  `[s, t]` is Bochner-integrable,
* identification `(u ¬∑ ‚ąáőł)Őā(m) = ‚ąĎ‚Īľ (√Ľ_j ‚čÜ (i¬∑‚Ąď_j ¬∑ őłŐā))(m)`, which
  is the very definition of `sqgNonlinearFlux`.

None of those three steps needs the DNS solution's regularity beyond
what `SqgEvolutionAxioms + MaterialMaxPrinciple` already give; they
are genuine Fourier-analysis facts on `ūĚēč¬≤`. Formalising them in
mathlib is the multi-step tactical goal whose first layer this
section names.

**Why wrap at all.** The predicate's sole field is the Duhamel
identity itself, so `.duhamel` is a trivial projection. But:

1. Downstream consumers (`of_IsSqgWeakSolution_via_MMP`) take one
   structural witness instead of a five-argument ‚ąÄ-proposition.
2. When the test-function weak form is later formalised, this is
   exactly the predicate that will receive a second constructor
   `IsSqgWeakSolution.of_testFormWeakSolution`.
3. Documentation of the intended semantics (the docstring above)
   attaches to the named predicate rather than to a raw hypothesis
   repeated verbatim at every call site. -/

/-- **SQG weak-solution predicate (Fourier-mode form).**

`IsSqgWeakSolution őł u` says that `őł` is a weak solution of the SQG
equation `‚ąā_t őł + u ¬∑ ‚ąáőł = 0` driven by velocity field `u`, expressed
at the Fourier-mode level: for every mode `m` and every forward time
interval `[s, t]`,

  `őłŐā(m, t) ‚ąí őłŐā(m, s) = ‚ąí ‚ąę_s^t sqgNonlinearFlux(őł ŌĄ)(u ŌĄ)(m) dŌĄ`.

This is the direct consumer of `of_sqgDuhamelIdentity_via_MMP`. See
the section-level comment above for the classical distributional
weak form it specialises and the Fourier-analysis steps that would
link them. -/
structure IsSqgWeakSolution
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    : Prop where
  /-- Mode-wise Duhamel identity for the SQG PDE. -/
  duhamel : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
    mFourierCoeff (őł t) m - mFourierCoeff (őł s) m
      = -‚ąę ŌĄ in Set.Icc s t, sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m

/-- **MMP-keyed promotion from `IsSqgWeakSolution`.** The one-line
wrapper over `of_sqgDuhamelIdentity_via_MMP` that consumes the
structural weak-solution witness. This is the entry point the repo's
final conditional Theorem 3 layer is meant to sit on: any analytic
construction that delivers `IsSqgWeakSolution` plus `MMP` plus the
velocity-component witness closes the full `[0, 2]` bootstrap. -/
theorem SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hE : SqgEvolutionAxioms őł)
    (hMMP : MaterialMaxPrinciple őł)
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hu_velocity : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), IsSqgVelocityComponent (őł ŌĄ) (u j ŌĄ) j)
    (hweak : IsSqgWeakSolution őł u) :
    SqgEvolutionAxioms_strong őł :=
  SqgEvolutionAxioms_strong.of_sqgDuhamelIdentity_via_MMP
    hE hMMP u hu_velocity hweak.duhamel

/-! ### ¬ß10.16 Test-function weak-form predicate `IsSqgWeakSolutionTimeTest`

¬ß10.15's `IsSqgWeakSolution őł u` carries the mode-wise Duhamel identity
as a named structural witness for
`of_IsSqgWeakSolution_via_MMP`. This section opens the next tactical
layer: a **test-function weak-form predicate**, stated at a
granularity fine enough to couple with time integration but coarse
enough to avoid a full distributional-calculus apparatus on `ūĚēč¬≤ √ó ‚ĄĚ`.

**Simplification of scope.** The classical distributional weak form
of `‚ąā_t őł + u ¬∑ ‚ąáőł = 0` pairs against smooth test functions
`ŌÜ : ūĚēč¬≤ √ó ‚ĄĚ ‚Üí ‚Ąā` with compact time support and reads:

  `‚ąę‚āÄ^T ‚ü®őł(ŌĄ), ‚ąā_ŌĄŌÜ(¬∑, ŌĄ) + u(ŌĄ) ¬∑ ‚ąá_x ŌÜ(¬∑, ŌĄ)‚ü©_{L¬≤(ūĚēč¬≤)} dŌĄ = 0`.

Two independent analytical steps separate this from the mode-wise
Duhamel identity carried by `IsSqgWeakSolution`:

(A) **Spatial Fourier-character specialization** ‚ÄĒ pair against
    separated test functions `ŌÜ(x, ŌĄ) = Ōą(ŌĄ) ¬∑ e_m(x)` and identify
    `‚ü®őł(ŌĄ), e_m ¬∑ u(ŌĄ) ¬∑ ‚ąá_x e_m'‚ü©` with
    `sqgNonlinearFlux (őł ŌĄ) (u ŌĄ) m` via Parseval + the convolution-of-
    Fourier-coefficients structure already proved in ¬ß10.9/¬ß10.12.

(B) **Bump-to-indicator limit in time** ‚ÄĒ take a smooth bump
    `Ōą_n ‚Üí ūĚüô_{[s, t]}` and use dominated convergence (legitimate
    because `sqgNonlinearFlux_bounded` gives a uniform flux bound) to
    recover
    `őłŐā(m, t) ‚ąí őłŐā(m, s) = ‚ąí ‚ąę_s^t sqgNonlinearFlux(őł ŌĄ)(u ŌĄ)(m) dŌĄ`.

¬ß10.16 **pre-executes step (A)** by formulating the test-function
weak form directly at the Fourier-mode level ‚ÄĒ one time test function
`Ōą : ‚ĄĚ ‚Üí ‚Ąā` per mode. What remains for `IsSqgWeakSolution` is step
(B) alone: a clean bump-to-indicator limit argument using the bounded
flux.

The advantage is modularity: step (A) becomes a property *of the
predicate's formulation*, not a theorem that needs proof; step (B)
stands alone as the next formalization target and lives entirely in
time integration, not space-time Bochner. -/

/-- **Time test functions.** A `C¬Ļ` function `Ōą : ‚ĄĚ ‚Üí ‚Ąā` with compact
support. We use `C¬Ļ` rather than `C^‚ąě` because ¬ß10's bump-to-indicator
argument needs only one derivative: pair against the derivative of a
mollified indicator, dominated by the bounded flux. -/
def IsSqgTimeTestFunction (Ōą : ‚ĄĚ ‚Üí ‚Ąā) : Prop :=
  ContDiff ‚ĄĚ 1 Ōą ‚ąß HasCompactSupport Ōą

/-- **Mode-wise time-weak form of SQG.**

For every time test function `Ōą` and every Fourier mode `m`,

  `‚ąę ŌĄ, (deriv Ōą ŌĄ) ¬∑ őłŐā(m, ŌĄ) dŌĄ`
  `  = ‚ąę ŌĄ, Ōą ŌĄ ¬∑ sqgNonlinearFlux(őł ŌĄ)(u ŌĄ)(m) dŌĄ`.

The SQG Fourier-mode ODE is `‚ąā_ŌĄ őłŐā(m, ŌĄ) = ‚ąísqgNonlinearFlux(őł ŌĄ)(u ŌĄ)(m)`.
Pairing both sides with `Ōą` and integrating by parts in time (boundary
terms vanish since `Ōą` is compactly supported) gives

  `‚ąę ŌĄ, (‚ąā_ŌĄ Ōą)(ŌĄ) ¬∑ őłŐā(m, ŌĄ) dŌĄ = ‚ąę ŌĄ, Ōą(ŌĄ) ¬∑ (u ¬∑ ‚ąáőł)Őā(m, ŌĄ) dŌĄ`

with `(u ¬∑ ‚ąáőł)Őā(m, ŌĄ)` identified with
`sqgNonlinearFlux(őł ŌĄ)(u ŌĄ)(m)` by the convolution structure of
¬ß10.9/¬ß10.12. This is step (A) of the reduction in the ¬ß10.16 header.

Strictly stronger than `IsSqgWeakSolution`: any of the Duhamel-
identity witnesses that were in ¬ß10.15's scope must in particular
satisfy this pairing (multiply the Duhamel identity on both sides by
`deriv Ōą ŌĄ`, integrate, and use the compact support of `Ōą` to
integrate by parts). Strictly weaker than a full space-time
distributional weak form: we have already projected onto Fourier
characters in space. -/
def IsSqgWeakSolutionTimeTest
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    : Prop :=
  ‚ąÄ (Ōą : ‚ĄĚ ‚Üí ‚Ąā), IsSqgTimeTestFunction Ōą ‚Üí
  ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§),
    (‚ąę ŌĄ, (deriv Ōą ŌĄ) * mFourierCoeff (őł ŌĄ) m)
      = ‚ąę ŌĄ, Ōą ŌĄ * sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m

/-- **Nonlinear flux of the zero scalar field vanishes.**

`sqgNonlinearFlux 0 u m = 0` for every velocity field `u` and mode
`m`. Each component convolution's right factor is
`fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff 0 ‚Ąď`, which is pointwise
zero by `mFourierCoeff_zero`. The convolution with the zero sequence
on the right is then zero by `fourierConvolution_zero_right`. -/
theorem sqgNonlinearFlux_zero_theta
    (u : Fin 2 ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (m : Fin 2 ‚Üí ‚Ą§) :
    sqgNonlinearFlux
        (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) u m = 0 := by
  unfold sqgNonlinearFlux
  apply Finset.sum_eq_zero
  intro j _
  have h :
      (fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) ‚Ąď)
        = fun _ => (0 : ‚Ąā) := by
    funext ‚Ąď
    rw [mFourierCoeff_zero]
    ring
  rw [h]
  exact fourierConvolution_zero_right _ m

/-- **The zero scalar field is a trivial time-weak solution.**

Both integrands vanish pointwise:
* `mFourierCoeff (fun _ => 0) ŌĄ m = mFourierCoeff (0 : Lp) m = 0`
  by `mFourierCoeff_zero`.
* `sqgNonlinearFlux (fun _ => 0) ŌĄ u m = sqgNonlinearFlux 0 (u ŌĄ) m = 0`
  by `sqgNonlinearFlux_zero_theta`.

So each integral is zero and the weak-form identity reads `0 = 0`.
This is the ¬ß10.16 counterpart of `IsSqgVelocityComponent.of_zero`. -/
theorem IsSqgWeakSolutionTimeTest.zero
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    IsSqgWeakSolutionTimeTest
      (fun _ => (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) u := by
  intro Ōą _ m
  have h1 : (fun ŌĄ : ‚ĄĚ => deriv Ōą ŌĄ
      * mFourierCoeff ((fun _ : ‚ĄĚ =>
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) ŌĄ) m)
        = fun _ => (0 : ‚Ąā) := by
    funext ŌĄ
    rw [mFourierCoeff_zero]
    ring
  have h2 : (fun ŌĄ : ‚ĄĚ => Ōą ŌĄ
      * sqgNonlinearFlux ((fun _ : ‚ĄĚ =>
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) ŌĄ)
            (fun j => u j ŌĄ) m)
        = fun _ => (0 : ‚Ąā) := by
    funext ŌĄ
    rw [sqgNonlinearFlux_zero_theta]
    ring
  rw [h1, h2]

/-! ### ¬ß10.17 Fourier-coefficient time regularity

The bump-to-indicator bridge (step (B) of ¬ß10.16) from
`IsSqgWeakSolutionTimeTest` to `IsSqgWeakSolution` needs a time-
regularity witness: on mollified indicators `Ōą_n ‚Üí ūĚüô_{[s, t]}`, the
left-hand pairing `‚ąę (deriv Ōą_n)¬∑őłŐā(m)` tends to a boundary evaluation
`őłŐā(m, t) ‚ąí őłŐā(m, s)`, and that limit is pointwise only if
`ŌĄ ‚Ü¶ őłŐā(m, ŌĄ)` is continuous at `s` and `t`.

This section names the minimal continuity predicate needed.
`SqgEvolutionAxioms` alone does NOT supply it: mean + L¬≤
conservation + Riesz-transform velocity are constants of the motion,
not pointwise regularity. A real SQG solution constructed from
smooth initial data and the material-derivative flow delivers
Fourier-coefficient continuity as a property of the construction;
this predicate abstracts that property so the bridge can consume it
without reference to any specific construction.

Contents:
* `SqgFourierContinuous őł` ‚ÄĒ every mode coefficient `ŌĄ ‚Ü¶ őłŐā(m, ŌĄ)`
  is continuous in `ŌĄ`.
* `SqgFourierContinuous.zero` ‚ÄĒ the zero scalar field satisfies it
  trivially (every coefficient is the zero constant).
* `SqgFourierContinuous.const` ‚ÄĒ any constant-in-time field does
  too (every coefficient is a real constant). -/

/-- **Fourier-coefficient continuity in time.**

For every Fourier mode `m`, the map `ŌĄ ‚Ü¶ mFourierCoeff (őł ŌĄ) m` is
continuous. This is strictly weaker than requiring `ŌĄ ‚Ü¶ őł ŌĄ` to be
continuous in `Lp ‚Ąā 2` (which by boundedness of `mFourierCoeff`
would imply Fourier-coefficient continuity uniformly across modes),
but is exactly what the bump-to-indicator limit needs for a fixed
mode at fixed endpoints `(s, t)`. -/
def SqgFourierContinuous
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop :=
  ‚ąÄ m : Fin 2 ‚Üí ‚Ą§, Continuous (fun ŌĄ => mFourierCoeff (őł ŌĄ) m)

/-- **Zero scalar field is Fourier-continuous.** Every coefficient
is the zero constant (by `mFourierCoeff_zero`), hence continuous. -/
theorem SqgFourierContinuous.zero :
    SqgFourierContinuous
      (fun _ => (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) := by
  intro m
  have h : (fun ŌĄ : ‚ĄĚ => mFourierCoeff ((fun _ : ‚ĄĚ =>
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) ŌĄ) m)
        = fun _ => (0 : ‚Ąā) := by
    funext ŌĄ
    exact mFourierCoeff_zero m
  rw [h]
  exact continuous_const

/-- **Constant-in-time scalar field is Fourier-continuous.** Every
coefficient `mFourierCoeff őł‚āÄ m` is a time-independent complex
number. -/
theorem SqgFourierContinuous.const
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    SqgFourierContinuous (fun _ => őł‚āÄ) := by
  intro _
  exact continuous_const

/-! ### ¬ß10.18 Mollifier construction for the bump-to-indicator bridge

Phase 2.2 of the bridge: name the concrete mollifier family that
Phase 2.3's limit argument will instantiate.

**Primitive.** Mathlib's `ContDiffBump` delivers, for any center `c`
in a finite-dimensional inner-product space and any `0 < rIn < rOut`,
a `C^‚ąě` function ‚ĄĚ-valued on that space with the properties:
* equals `1` on `closedBall c rIn`,
* supported in `closedBall c rOut`,
* values in `[0, 1]` everywhere.

On ‚ĄĚ, `closedBall c r = [c ‚ąí r, c + r]`. Picking
`c := (s + t) / 2`, `rIn := (t ‚ąí s) / 2`, `rOut := (t ‚ąí s) / 2 + őĶ`
yields a bump that is `1` on exactly `[s, t]` and supported in
`[s ‚ąí őĶ, t + őĶ]` ‚ÄĒ exactly the Friedrichs-mollifier shape.

`HasContDiffBump ‚ĄĚ` is automatic via
`hasContDiffBump_of_innerProductSpace`. `FiniteDimensional ‚ĄĚ ‚ĄĚ` is
automatic (‚ĄĚ as a module over itself is 1-dimensional), so
`ContDiffBump.hasCompactSupport` applies. -/

/-- **Mollifier-data bump for `[s, t]` widened by `őĶ` on each side.**

Centered at the midpoint with inner radius half the interval width
and outer radius half the interval width plus `őĶ`. The hypotheses
`s < t` and `0 < őĶ` make `0 < rIn < rOut`. -/
noncomputable def sqgMollifierBump (őĶ s t : ‚ĄĚ) (hst : s < t) (hőĶ : 0 < őĶ) :
    ContDiffBump ((s + t) / 2 : ‚ĄĚ) where
  rIn := (t - s) / 2
  rOut := (t - s) / 2 + őĶ
  rIn_pos := by linarith
  rIn_lt_rOut := by linarith

/-- **Complex-valued mollifier function.**

The underlying bump `sqgMollifierBump őĶ s t hst hőĶ : ‚ĄĚ ‚Üí ‚ĄĚ`
composed with the `Complex.ofReal` coercion so it fits the
`IsSqgTimeTestFunction` signature `‚ĄĚ ‚Üí ‚Ąā`. -/
noncomputable def sqgMollifier (őĶ s t : ‚ĄĚ) (hst : s < t) (hőĶ : 0 < őĶ) :
    ‚ĄĚ ‚Üí ‚Ąā :=
  fun ŌĄ => ((sqgMollifierBump őĶ s t hst hőĶ) ŌĄ : ‚Ąā)

/-- **Mollifier is `C¬Ļ` (in fact `C^‚ąě`, but `C¬Ļ` is what we need).**
Composition of `Complex.ofRealCLM` (infinitely smooth linear map)
with the bump (`C^‚ąě` by `ContDiffBump.contDiff`). We target
`ContDiff ‚ĄĚ 1` directly because:
* `ContDiffBump.contDiff` provides `ContDiff ‚ĄĚ (‚ÜĎn) f` for
  `n : ‚Ąē‚ąě`, whose max value `‚ąě` lifts to `(‚ąě : WithTop ‚Ąē‚ąě)` ‚ÄĒ it
  cannot reach `(‚ä§ : WithTop ‚Ąē‚ąě)` (the analytic level).
* `IsSqgTimeTestFunction` only needs `C¬Ļ`. -/
theorem sqgMollifier_contDiff (őĶ s t : ‚ĄĚ) (hst : s < t) (hőĶ : 0 < őĶ) :
    ContDiff ‚ĄĚ 1 (sqgMollifier őĶ s t hst hőĶ) := by
  unfold sqgMollifier
  exact Complex.ofRealCLM.contDiff.comp
    (sqgMollifierBump őĶ s t hst hőĶ).contDiff

/-- **Mollifier has compact support.** The underlying bump has
compact support (`ContDiffBump.hasCompactSupport`, using
`FiniteDimensional ‚ĄĚ ‚ĄĚ`), and composition with `Complex.ofReal`
preserves that because `Complex.ofReal 0 = 0`. -/
theorem sqgMollifier_hasCompactSupport
    (őĶ s t : ‚ĄĚ) (hst : s < t) (hőĶ : 0 < őĶ) :
    HasCompactSupport (sqgMollifier őĶ s t hst hőĶ) := by
  unfold sqgMollifier
  exact (sqgMollifierBump őĶ s t hst hőĶ).hasCompactSupport.comp_left
    Complex.ofReal_zero

/-- **Mollifier is a time test function.**

Bundles `sqgMollifier_contDiff` (at level `1`) with
`sqgMollifier_hasCompactSupport` to match `IsSqgTimeTestFunction`. -/
theorem sqgMollifier_isSqgTimeTestFunction
    (őĶ s t : ‚ĄĚ) (hst : s < t) (hőĶ : 0 < őĶ) :
    IsSqgTimeTestFunction (sqgMollifier őĶ s t hst hőĶ) :=
  ‚ü®sqgMollifier_contDiff őĶ s t hst hőĶ,
   sqgMollifier_hasCompactSupport őĶ s t hst hőĶ‚ü©

/-- **Mollifier equals `1` on `[s, t]`.** On the core interval the
inner bump evaluates to `1` (by `ContDiffBump.one_of_mem_closedBall`,
since `[s, t] = closedBall ((s + t) / 2) ((t ‚ąí s) / 2)`), and
`Complex.ofReal` maps `1` to `1`. -/
theorem sqgMollifier_eq_one_of_mem_Icc
    (őĶ s t : ‚ĄĚ) (hst : s < t) (hőĶ : 0 < őĶ)
    (ŌĄ : ‚ĄĚ) (hŌĄ : ŌĄ ‚ąą Set.Icc s t) :
    sqgMollifier őĶ s t hst hőĶ ŌĄ = 1 := by
  obtain ‚ü®h1, h2‚ü© := hŌĄ
  have hbump : (sqgMollifierBump őĶ s t hst hőĶ) ŌĄ = 1 := by
    apply ContDiffBump.one_of_mem_closedBall
    change ŌĄ ‚ąą Metric.closedBall ((s + t) / 2) ((t - s) / 2)
    rw [Metric.mem_closedBall, Real.dist_eq, abs_le]
    refine ‚ü®?_, ?_‚ü© <;> linarith
  unfold sqgMollifier
  rw [hbump]
  norm_cast

/-! ### ¬ß10.19 Mollifier-specialized weak-form identity (Phase 2.3.a)

Instantiating `IsSqgWeakSolutionTimeTest` at the mollifier gives an
algebraic starting point for the bump-to-indicator limit: the full
weak-form identity `‚ąę(deriv Ōą_őĶ)¬∑őłŐā + ‚ąęŌą_őĶ¬∑F = 0` is the sum of two
integrals; rearranged it says

  `‚ąę(deriv Ōą_őĶ)¬∑őłŐā(m) = ‚ąí‚ąęŌą_őĶ¬∑F(m)`.

That rearrangement is what the final limit argument will take in
both directions ‚ÄĒ the LHS tends to `őłŐā(m, s) ‚ąí őłŐā(m, t)` (by
`SqgFourierContinuous őł`), the RHS tends to `‚ąí‚ąę_s^t F(m)` (by
dominated convergence against `sqgNonlinearFlux_bounded`).

This section delivers only the rearrangement. The two limits are
Phase 2.3.b and 2.3.c. -/

/-- **Weak-form identity specialised at the mollifier.**

For every `s < t`, `őĶ > 0`, and mode `m`, if `őł` weakly solves SQG
at the mode level (`IsSqgWeakSolutionTimeTest őł u`) then

  `‚ąę ŌĄ, (deriv (sqgMollifier őĶ s t hst hőĶ) ŌĄ) ¬∑ mFourierCoeff (őł ŌĄ) m`
  `  = ‚ąę ŌĄ, (sqgMollifier őĶ s t hst hőĶ ŌĄ) ¬∑ sqgNonlinearFlux (őł ŌĄ) (u ŌĄ) m`.

Proof: apply the predicate to the mollifier (a valid time test
function by `sqgMollifier_isSqgTimeTestFunction`). -/
theorem IsSqgWeakSolutionTimeTest.mollifier_identity
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hweak : IsSqgWeakSolutionTimeTest őł u)
    (őĶ s t : ‚ĄĚ) (hst : s < t) (hőĶ : 0 < őĶ) (m : Fin 2 ‚Üí ‚Ą§) :
    (‚ąę ŌĄ, (deriv (sqgMollifier őĶ s t hst hőĶ) ŌĄ) * mFourierCoeff (őł ŌĄ) m)
      = ‚ąę ŌĄ, (sqgMollifier őĶ s t hst hőĶ ŌĄ)
          * sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m :=
  hweak (sqgMollifier őĶ s t hst hőĶ)
    (sqgMollifier_isSqgTimeTestFunction őĶ s t hst hőĶ) m

/-! ### ¬ß10.20 Concrete mollifier and bump-to-indicator limit

The abstract `sqgMollifier` of ¬ß10.18 (built from `ContDiffBump` via
`Classical.choice`) is adequate for the mollifier_identity, but its
abstract API prevents deriving derivative sign information on the
collars ‚ÄĒ a key ingredient for Phase 2.3.b (LHS collar limit).

This section constructs `sqgConcreteMollifier` directly from
`Real.smoothTransition`, with an explicit product formula:

  `sqgConcreteMollifier őĶ s t ŌĄ`
  `  = smoothTransition((ŌĄ ‚ąí s + őĶ)/őĶ) ¬∑ smoothTransition((t ‚ąí ŌĄ + őĶ)/őĶ)`

Since `Real.smoothTransition` is monotone and C^‚ąě, the concrete
mollifier inherits these properties.  Its collar behavior is exact:

* **Left collar** `[s ‚ąí őĶ, s]`: second factor = 1 (argument ‚Č• 1 when
  ŌĄ ‚Č§ s < t), so the mollifier is the monotone rising function
  `smoothTransition((ŌĄ ‚ąí s + őĶ)/őĶ)`, going from 0 at ŌĄ = s ‚ąí őĶ to
  1 at ŌĄ = s.
* **Flat region** `[s, t]`: both arguments are ‚Č• 1, so both factors = 1.
* **Right collar** `[t, t + őĶ]`: first factor = 1 (argument ‚Č• 1 when
  s < t ‚Č§ ŌĄ), so the mollifier is the antitone falling function
  `smoothTransition((t ‚ąí ŌĄ + őĶ)/őĶ)`, going from 1 at ŌĄ = t to 0 at
  ŌĄ = t + őĶ.
* **Outside** `[s ‚ąí őĶ, t + őĶ]`: one factor has argument ‚Č§ 0, so = 0.

Crucially, `sqgConcreteMollifier őĶ s t ŌĄ = 1` for **every** ŌĄ ‚ąą (s, t)
and every őĶ > 0 (not just eventually).  This makes the Phase 2.3.c
proof (RHS DCT limit) especially clean: the integrand already equals
`G ŌĄ` on `(s, t)` for all positive őĶ. -/

/-- **Concrete mollifier** for the bump-to-indicator bridge, built
directly from `Real.smoothTransition` to expose its monotonicity.

  `sqgConcreteMollifier őĶ s t ŌĄ`
  `  = smoothTransition((ŌĄ ‚ąí s + őĶ)/őĶ) ¬∑ smoothTransition((t ‚ąí ŌĄ + őĶ)/őĶ)`.

When `őĶ = 0`, division by őĶ gives `(¬∑)/0 = 0` in Lean's real-number
convention, so both factors collapse to `smoothTransition 0 = 0`; the
function is identically 0 (not a bump).  All positivity hypotheses
`hőĶ : 0 < őĶ` are therefore reserved for the property lemmas, not the
definition. -/
noncomputable def sqgConcreteMollifier (őĶ s t : ‚ĄĚ) : ‚ĄĚ ‚Üí ‚ĄĚ :=
  fun ŌĄ => Real.smoothTransition ((ŌĄ - s + őĶ) / őĶ) *
           Real.smoothTransition ((t - ŌĄ + őĶ) / őĶ)

/-- `sqgConcreteMollifier` is non-negative everywhere: product of two
non-negative `smoothTransition` values. -/
theorem sqgConcreteMollifier_nonneg (őĶ s t ŌĄ : ‚ĄĚ) :
    0 ‚Č§ sqgConcreteMollifier őĶ s t ŌĄ :=
  mul_nonneg (Real.smoothTransition.nonneg _) (Real.smoothTransition.nonneg _)

/-- `sqgConcreteMollifier` is at most 1 everywhere: product of two
values each ‚Č§ 1, and the product of non-negatives ‚Č§ 1 that multiply
to ‚Č§ 1. Since `0 ‚Č§ a ‚Č§ 1` and `0 ‚Č§ b ‚Č§ 1`, we have `a * b ‚Č§ 1 * 1 = 1`. -/
theorem sqgConcreteMollifier_le_one (őĶ s t ŌĄ : ‚ĄĚ) :
    sqgConcreteMollifier őĶ s t ŌĄ ‚Č§ 1 := by
  unfold sqgConcreteMollifier
  exact mul_le_one‚āÄ (Real.smoothTransition.le_one _)
         (Real.smoothTransition.nonneg _) (Real.smoothTransition.le_one _)

/-- For `ŌĄ ‚ąą (s, t)` (open interval), both `smoothTransition` arguments
are strictly greater than 1, so both factors equal 1 and the concrete
mollifier equals 1.  In contrast to the abstract bump approach, this
holds for **every** `őĶ > 0`, not just eventually. -/
theorem sqgConcreteMollifier_eq_one_of_mem_Ioo {s t ŌĄ : ‚ĄĚ} (hŌĄ : ŌĄ ‚ąą Set.Ioo s t)
    {őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ) : sqgConcreteMollifier őĶ s t ŌĄ = 1 := by
  unfold sqgConcreteMollifier
  have hŌĄs : s < ŌĄ := hŌĄ.1
  have hŌĄt : ŌĄ < t := hŌĄ.2
  rw [Real.smoothTransition.one_of_one_le, Real.smoothTransition.one_of_one_le, mul_one]
  ¬∑ rw [le_div_iff‚āÄ hőĶ]; linarith
  ¬∑ rw [le_div_iff‚āÄ hőĶ]; linarith

/-- Same as `sqgConcreteMollifier_eq_one_of_mem_Ioo` for the closed interval `Icc`.
Both factors are 1 on `[s, t]`. -/
theorem sqgConcreteMollifier_eq_one_of_mem_Icc {s t ŌĄ : ‚ĄĚ} (hŌĄ : ŌĄ ‚ąą Set.Icc s t)
    {őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ) : sqgConcreteMollifier őĶ s t ŌĄ = 1 := by
  unfold sqgConcreteMollifier
  have hŌĄs : s ‚Č§ ŌĄ := hŌĄ.1
  have hŌĄt : ŌĄ ‚Č§ t := hŌĄ.2
  rw [Real.smoothTransition.one_of_one_le, Real.smoothTransition.one_of_one_le, mul_one]
  ¬∑ rw [le_div_iff‚āÄ hőĶ]; linarith
  ¬∑ rw [le_div_iff‚āÄ hőĶ]; linarith

/-- Left factor only: when `ŌĄ ‚Č§ t`, the second `smoothTransition` factor
equals 1 (its argument `(t ‚ąí ŌĄ + őĶ)/őĶ ‚Č• 1` iff `t ‚ąí ŌĄ ‚Č• 0`). -/
theorem sqgConcreteMollifier_eq_left_factor {s t ŌĄ : ‚ĄĚ} (hŌĄt : ŌĄ ‚Č§ t) {őĶ : ‚ĄĚ}
    (hőĶ : 0 < őĶ) :
    sqgConcreteMollifier őĶ s t ŌĄ =
      Real.smoothTransition ((ŌĄ - s + őĶ) / őĶ) := by
  unfold sqgConcreteMollifier
  have h2 : Real.smoothTransition ((t - ŌĄ + őĶ) / őĶ) = 1 :=
    Real.smoothTransition.one_of_one_le (by rw [le_div_iff‚āÄ hőĶ]; linarith)
  rw [h2, mul_one]

/-- The concrete mollifier vanishes for `ŌĄ ‚Č§ s ‚ąí őĶ`: the left factor's
argument is `(ŌĄ ‚ąí s + őĶ)/őĶ ‚Č§ 0` when `ŌĄ ‚Č§ s ‚ąí őĶ`. -/
theorem sqgConcreteMollifier_zero_of_le_left {s t ŌĄ őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hŌĄ : ŌĄ ‚Č§ s - őĶ) : sqgConcreteMollifier őĶ s t ŌĄ = 0 := by
  unfold sqgConcreteMollifier
  have harg : (ŌĄ - s + őĶ) / őĶ ‚Č§ 0 := by
    apply div_nonpos_of_nonpos_of_nonneg _ hőĶ.le; linarith
  rw [Real.smoothTransition.zero_of_nonpos harg, zero_mul]

/-- The concrete mollifier vanishes for `ŌĄ ‚Č• t + őĶ`: the right factor's
argument is `(t ‚ąí ŌĄ + őĶ)/őĶ ‚Č§ 0` when `ŌĄ ‚Č• t + őĶ`. -/
theorem sqgConcreteMollifier_zero_of_ge_right {s t ŌĄ őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hŌĄ : t + őĶ ‚Č§ ŌĄ) : sqgConcreteMollifier őĶ s t ŌĄ = 0 := by
  unfold sqgConcreteMollifier
  have harg : (t - ŌĄ + őĶ) / őĶ ‚Č§ 0 := by
    apply div_nonpos_of_nonpos_of_nonneg _ hőĶ.le; linarith
  rw [Real.smoothTransition.zero_of_nonpos harg, mul_zero]

/-- The concrete mollifier is `ContDiff ‚ĄĚ 1`: it is a product of two
`C^‚ąě` compositions of `Real.smoothTransition` with affine functions. -/
theorem sqgConcreteMollifier_contDiff (őĶ s t : ‚ĄĚ) :
    ContDiff ‚ĄĚ 1 (sqgConcreteMollifier őĶ s t) := by
  unfold sqgConcreteMollifier
  apply ContDiff.mul
  ¬∑ exact Real.smoothTransition.contDiff.comp
      (((contDiff_id.sub contDiff_const).add contDiff_const).div_const őĶ)
  ¬∑ exact Real.smoothTransition.contDiff.comp
      (((contDiff_const.sub contDiff_id).add contDiff_const).div_const őĶ)

/-- The concrete mollifier has compact support: it vanishes outside the
closed interval `[s ‚ąí őĶ, t + őĶ]`, hence `tsupport ‚äÜ [s ‚ąí őĶ, t + őĶ]`. -/
theorem sqgConcreteMollifier_hasCompactSupport {őĶ s t : ‚ĄĚ} (hőĶ : 0 < őĶ) :
    HasCompactSupport (sqgConcreteMollifier őĶ s t) := by
  apply HasCompactSupport.of_support_subset_isCompact (K := Set.Icc (s - őĶ) (t + őĶ))
    isCompact_Icc
  intro ŌĄ hŌĄ
  simp only [Function.mem_support] at hŌĄ
  simp only [Set.mem_Icc]
  by_contra h
  simp only [not_and_or, not_le] at h
  rcases h with h | h
  ¬∑ exact hŌĄ (sqgConcreteMollifier_zero_of_le_left hőĶ h.le)
  ¬∑ exact hŌĄ (sqgConcreteMollifier_zero_of_ge_right hőĶ h.le)

/-- The complex-valued concrete mollifier `(sqgConcreteMollifier őĶ s t ¬∑ : ‚ĄĚ ‚Üí ‚Ąā)`
(coerced via `‚ÜĎ`) is a valid time test function: `C¬Ļ` and compactly supported. -/
theorem sqgConcreteMollifier_isSqgTimeTestFunction {őĶ s t : ‚ĄĚ} (hőĶ : 0 < őĶ) :
    IsSqgTimeTestFunction (fun ŌĄ => (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā)) := by
  constructor
  ¬∑ exact ofRealCLM.contDiff.comp (sqgConcreteMollifier_contDiff őĶ s t)
  ¬∑ show HasCompactSupport (Complex.ofReal ‚ąė sqgConcreteMollifier őĶ s t)
    exact (sqgConcreteMollifier_hasCompactSupport hőĶ).comp_left Complex.ofReal_zero

/-! #### Phase 2.3.c ‚ÄĒ RHS mollifier integral converges to interval integral

As `őĶ ‚Üí 0‚Āļ`, `‚ąę (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā) * G ŌĄ dŌĄ ‚Üí ‚ąę_{[s,t]} G ŌĄ dŌĄ`.

Proof: Dominated Convergence Theorem.

**Bound.** For `őĶ ‚Č§ 1`, the mollifier is supported in `[s ‚ąí 1, t + 1]`
(compact), and `‚ÄĖmollifier ¬∑ G‚ÄĖ ‚Č§ 1 ¬∑ K = K` since the mollifier is in
`[0, 1]` and `‚ÄĖG ŌĄ‚ÄĖ ‚Č§ K` by hypothesis.  The dominating function
`K ¬∑ ūĚüô_{[s ‚ąí 1, t + 1]}` is integrable.

**Pointwise.** For a.e. ŌĄ:
* ŌĄ ‚ąą (s, t): both smoothTransition arguments are > 1 for ALL őĶ > 0, so
  mollifier = 1 for all őĶ > 0 ‚Üí integrand = G ŌĄ a.e. ‚úď
* ŌĄ < s: argument `(ŌĄ ‚ąí s + őĶ)/őĶ ‚Üí ‚ąí‚ąě` as őĶ ‚Üí 0‚Āļ ‚Üí smoothTransition ‚Üí 0
  (in fact = 0 for őĶ < s ‚ąí ŌĄ) ‚Üí integrand = 0 ‚úď
* ŌĄ > t: symmetric ‚Üí integrand = 0 ‚úď

Limit identification: `‚ąę ūĚüô_{[s,t]} G = ‚ąę_{[s,t]} G` by
`MeasureTheory.integral_indicator`. -/

/-- **Phase 2.3.c**: The RHS mollifier integral tends to the interval
integral as `őĶ ‚Üí 0‚Āļ`.

Hypotheses:
* `hK_nn`: the flux bound `K` is non-negative.
* `hG_bound`: `‚ÄĖG ŌĄ‚ÄĖ ‚Č§ K` for all ŌĄ (uniform bound).
* `hG_meas`: `G` is measurable (needed for DCT and the set integral).
* `hst`: `s < t`. -/
theorem sqgConcreteMollifier_rhs_tendsto {s t : ‚ĄĚ} (hst : s < t)
    {G : ‚ĄĚ ‚Üí ‚Ąā} {K : ‚ĄĚ} (hK_nn : 0 ‚Č§ K)
    (hG_bound : ‚ąÄ ŌĄ, ‚ÄĖG ŌĄ‚ÄĖ ‚Č§ K)
    (hG_meas : AEStronglyMeasurable G volume) :
    Filter.Tendsto
      (fun őĶ => ‚ąę ŌĄ, (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā) * G ŌĄ)
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds (‚ąę ŌĄ in Set.Icc s t, G ŌĄ)) := by
  -- Rewrite the target as ‚ąę ūĚüô_{[s,t]} G (for the DCT limit identification)
  rw [‚Üź MeasureTheory.integral_indicator measurableSet_Icc]
  -- Apply DCT for filters (nhdsWithin 0 Ioi 0 is countably generated as a sub-nhds of ‚ĄĚ)
  apply MeasureTheory.tendsto_integral_filter_of_dominated_convergence
    (fun ŌĄ => K * (Set.Icc (s - 1) (t + 1)).indicator (fun _ => (1 : ‚ĄĚ)) ŌĄ)
  ¬∑ -- Measurability: for each őĶ, the integrand is measurable
    apply Filter.Eventually.of_forall
    intro őĶ
    apply AEStronglyMeasurable.mul _ hG_meas
    exact (Complex.continuous_ofReal.comp
      ((sqgConcreteMollifier_contDiff őĶ s t).continuous)).aestronglyMeasurable
  ¬∑ -- Domination: for őĶ ‚ąą (0, 1], the integrand is bounded by K ¬∑ ūĚüô_{[s-1,t+1]}
    apply Filter.eventually_of_mem (Ioc_mem_nhdsGT (by norm_num : (0 : ‚ĄĚ) < 1))
    intro őĶ ‚ü®hőĶ_pos, hőĶ_le‚ü©
    apply Filter.Eventually.of_forall
    intro ŌĄ
    simp only [Set.indicator, Set.mem_Icc]
    split_ifs with hmem
    ¬∑ -- ŌĄ ‚ąą [s-1, t+1]
      rw [mul_one]
      calc ‚ÄĖ(sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā) * G ŌĄ‚ÄĖ
          = ‚ÄĖ(sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā)‚ÄĖ * ‚ÄĖG ŌĄ‚ÄĖ := norm_mul _ _
        _ ‚Č§ 1 * K := by
            apply mul_le_mul _ (hG_bound ŌĄ) (norm_nonneg _) zero_le_one
            rw [Complex.norm_real, Real.norm_eq_abs,
                abs_of_nonneg (sqgConcreteMollifier_nonneg őĶ s t ŌĄ)]
            exact sqgConcreteMollifier_le_one őĶ s t ŌĄ
        _ = K := one_mul K
    ¬∑ -- ŌĄ ‚ąČ [s-1, t+1], so mollifier = 0 (support ‚äÜ [s-őĶ, t+őĶ] ‚äÜ [s-1, t+1] for őĶ ‚Č§ 1)
      rw [mul_zero]
      -- mollifier is 0 outside [s-1, t+1] when őĶ ‚Č§ 1
      have hmoll : sqgConcreteMollifier őĶ s t ŌĄ = 0 := by
        simp only [not_and_or, not_le] at hmem
        rcases hmem with h | h
        ¬∑ exact sqgConcreteMollifier_zero_of_le_left hőĶ_pos (by linarith)
        ¬∑ exact sqgConcreteMollifier_zero_of_ge_right hőĶ_pos (by linarith)
      simp [hmoll]
  ¬∑ -- Integrability of the dominating function K ¬∑ ūĚüô_{[s-1, t+1]}
    apply Integrable.const_mul _ K
    apply IntegrableOn.integrable_indicator _ measurableSet_Icc
    exact integrableOn_const
        (hs := by rw [Real.volume_Icc]; exact ENNReal.ofReal_ne_top)
        (hC := enorm_ne_top)
  ¬∑ -- Pointwise a.e. convergence
    apply Filter.Eventually.of_forall
    intro ŌĄ
    by_cases hŌĄ : ŌĄ ‚ąą Set.Icc s t
    ¬∑ -- ŌĄ ‚ąą [s, t]: indicator = G ŌĄ; mollifier = 1 for all őĶ > 0
      rw [Set.indicator_of_mem hŌĄ]
      apply Filter.Tendsto.congr' _ tendsto_const_nhds
      apply Filter.eventually_of_mem self_mem_nhdsWithin
      intro őĶ hőĶ
      show G ŌĄ = (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā) * G ŌĄ
      rw [sqgConcreteMollifier_eq_one_of_mem_Icc hŌĄ (Set.mem_Ioi.mp hőĶ)]
      push_cast; ring
    ¬∑ -- ŌĄ ‚ąČ [s, t]: indicator = 0; mollifier eventually zero near 0‚Āļ
      rw [Set.indicator_of_notMem hŌĄ]
      apply Filter.Tendsto.congr' _ tendsto_const_nhds
      -- Show (fun _ => (0:‚Ąā)) =Š∂†[nhdsWithin 0 (Ioi 0)] (fun őĶ => (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā) * G ŌĄ)
      simp only [Set.mem_Icc, not_and_or, not_le] at hŌĄ
      rcases hŌĄ with hŌĄs | hŌĄt
      ¬∑ -- ŌĄ < s: mollifier = 0 for all őĶ ‚ąą (0, s ‚ąí ŌĄ)
        apply Filter.eventually_of_mem (Ioc_mem_nhdsGT (by linarith : (0 : ‚ĄĚ) < s - ŌĄ))
        intro őĶ ‚ü®hőĶ_pos, hőĶ_le‚ü©
        show (0 : ‚Ąā) = (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā) * G ŌĄ
        rw [sqgConcreteMollifier_zero_of_le_left hőĶ_pos (by linarith)]
        push_cast; ring
      ¬∑ -- ŌĄ > t: mollifier = 0 for all őĶ ‚ąą (0, ŌĄ ‚ąí t)
        apply Filter.eventually_of_mem (Ioc_mem_nhdsGT (by linarith : (0 : ‚ĄĚ) < ŌĄ - t))
        intro őĶ ‚ü®hőĶ_pos, hőĶ_le‚ü©
        show (0 : ‚Ąā) = (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā) * G ŌĄ
        rw [sqgConcreteMollifier_zero_of_ge_right hőĶ_pos (by linarith)]
        push_cast; ring

/-! ### ¬ß10.21 Phase 2.3.d ‚ÄĒ Bridge from time-test weak form to Duhamel

Combines Phase 2.3.a (`IsSqgWeakSolutionTimeTest.mollifier_identity`,
¬ß10.19) with Phase 2.3.c (`sqgConcreteMollifier_rhs_tendsto`, ¬ß10.20)
and an abstract Phase 2.3.b predicate to prove the bridge theorem
`IsSqgWeakSolution.of_IsSqgWeakSolutionTimeTest`.

**Phase 2.3.b ‚ÄĒ open item.** `IsSqgCollarLhsCondition őł` asserts that
for each mode `m` and interval `[s, t]` with `0 ‚Č§ s ‚Č§ t`, the LHS
mollifier integral
`‚ąę ŌĄ, deriv(Ōą_őĶ ŌĄ) ¬∑ őłŐā(m, ŌĄ) dŌĄ` ‚Üí `őłŐā(m, s) ‚ąí őłŐā(m, t)` as `őĶ ‚Üí 0‚Āļ`,
where `Ōą_őĶ ŌĄ = sqgConcreteMollifier őĶ s t ŌĄ` coerced to `‚Ąā`.

The proof of `IsSqgCollarLhsCondition őł` from `SqgFourierContinuous őł`
proceeds by FTC on each collar:

* **Left collar** `[s ‚ąí őĶ, s]`: `‚ąę_{s‚ąíőĶ}^s deriv(Ōą_őĶ) = Ōą_őĶ(s) ‚ąí Ōą_őĶ(s ‚ąí őĶ) = 1`
  by `intervalIntegral.integral_eq_sub_of_hasDerivAt` applied to the
  C¬Ļ function `sqgConcreteMollifier`; non-negativity of the derivative
  on this collar (`Monotone.deriv_nonneg`, since the left factor is
  monotone rising) then gives `‚ÄĖcollar integral ‚ąí őłŐā(s)‚ÄĖ ‚Č§ osc_{[s‚ąíőĶ,s]}(őłŐā) ‚Üí 0`.
* **Right collar** symmetric.

This FTC + continuity argument will be fully formalised in ¬ß10.22 once
`HasDerivAt` boilerplate for `sqgConcreteMollifier` is in place. -/

/-- **Phase 2.3.b predicate**: for every mode `m` and interval `[s, t]`
(with `0 ‚Č§ s ‚Č§ t`), the LHS mollifier integral
`‚ąę ŌĄ, deriv(Ōą_őĶ ŌĄ) ¬∑ őłŐā(m, ŌĄ) dŌĄ` tends to `őłŐā(m, s) ‚ąí őłŐā(m, t)` as
`őĶ ‚Üí 0‚Āļ`, where `Ōą_őĶ` is `sqgConcreteMollifier őĶ s t` coerced to `‚Ąā`.

This is the Phase 2.3.b component of the bump-to-indicator bridge.
Once proved from `SqgFourierContinuous őł` (¬ß10.22), it can be dropped
as a hypothesis of `IsSqgWeakSolution.of_IsSqgWeakSolutionTimeTest`. -/
def IsSqgCollarLhsCondition
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop :=
  ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
    Filter.Tendsto
      (fun őĶ => ‚ąę ŌĄ,
        deriv (fun ŌĄ => (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā)) ŌĄ
          * mFourierCoeff (őł ŌĄ) m)
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds (mFourierCoeff (őł s) m - mFourierCoeff (őł t) m))

/-- **Phase 2.3.d ‚ÄĒ Bridge theorem**: `IsSqgWeakSolutionTimeTest őł u`
together with the collar-limit condition `IsSqgCollarLhsCondition őł`
and uniform flux bounds implies `IsSqgWeakSolution őł u`.

**Proof sketch.**
1. For every `őĶ > 0`, Phase 2.3.a gives
   `‚ąę deriv(Ōą_őĶ)¬∑őłŐā(m) = ‚ąę Ōą_őĶ¬∑G(m)`.
2. Phase 2.3.b (`h_collar`): the LHS ‚Üí `őłŐā(m, s) ‚ąí őłŐā(m, t)`.
3. Phase 2.3.c (`sqgConcreteMollifier_rhs_tendsto`): the RHS ‚Üí
   `‚ąę_{[s,t]} G(m)`.
4. Uniqueness of limits (`tendsto_nhds_unique`): `őłŐā(m, s) ‚ąí őłŐā(m, t) =
   ‚ąę_{[s,t]} G(m)`, hence `őłŐā(m, t) ‚ąí őłŐā(m, s) = ‚ąí‚ąę_{[s,t]} G(m)`. -/
theorem IsSqgWeakSolution.of_IsSqgWeakSolutionTimeTest
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hweak : IsSqgWeakSolutionTimeTest őł u)
    (h_collar : IsSqgCollarLhsCondition őł)
    {K : ‚ĄĚ} (hK_nn : 0 ‚Č§ K)
    (hG_bound : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (ŌĄ : ‚ĄĚ),
        ‚ÄĖsqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m‚ÄĖ ‚Č§ K)
    (hG_meas : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§),
        AEStronglyMeasurable
          (fun ŌĄ => sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m)
          volume) :
    IsSqgWeakSolution őł u := by
  constructor
  intro m s t hs hst
  -- s = t: both sides vanish
  rcases eq_or_lt_of_le hst with rfl | hst_lt
  ¬∑ simp [sub_self]
  -- Main case: s < t
  -- Phase 2.3.a: weak-form identity at the concrete mollifier for every őĶ > 0
  have eq_eps : ‚ąÄ őĶ > 0,
      ‚ąę ŌĄ, deriv (fun ŌĄ => (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā)) ŌĄ
               * mFourierCoeff (őł ŌĄ) m =
      ‚ąę ŌĄ, (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā)
               * sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m :=
    fun őĶ hőĶ => hweak (fun ŌĄ => (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā))
                      (sqgConcreteMollifier_isSqgTimeTestFunction hőĶ) m
  -- Phase 2.3.b: LHS ‚Üí őłŐā(s) ‚ąí őłŐā(t)
  have lhs_lim := h_collar m s t hs hst_lt.le
  -- Phase 2.3.c: RHS ‚Üí ‚ąę_{[s,t]} G
  have rhs_lim := sqgConcreteMollifier_rhs_tendsto hst_lt hK_nn
      (hG_bound m) (hG_meas m)
  -- Rewrite rhs_lim using eq_eps: the LHS also tends to ‚ąę_{[s,t]} G
  have lhs_lim' : Filter.Tendsto
      (fun őĶ => ‚ąę ŌĄ, deriv (fun ŌĄ => (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā)) ŌĄ
                       * mFourierCoeff (őł ŌĄ) m)
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds (‚ąę ŌĄ in Set.Icc s t,
               sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m)) :=
    rhs_lim.congr' (Filter.eventually_of_mem self_mem_nhdsWithin
                     (fun őĶ hőĶ => (eq_eps őĶ (Set.mem_Ioi.mp hőĶ)).symm))
  -- Uniqueness of limits (nhdsWithin 0 (Ioi 0) is NeBot on ‚ĄĚ)
  haveI : Filter.NeBot (nhdsWithin (0 : ‚ĄĚ) (Set.Ioi 0)) := inferInstance
  have heq : mFourierCoeff (őł s) m - mFourierCoeff (őł t) m =
      ‚ąę ŌĄ in Set.Icc s t, sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m :=
    tendsto_nhds_unique lhs_lim lhs_lim'
  -- őłŐā(t) ‚ąí őłŐā(s) = ‚ąí‚ąę_{[s,t]} G
  linear_combination -heq

/-! ### ¬ß10.22 Phase 2.3.b ‚ÄĒ collar FTC: `SqgFourierContinuous ‚Üí IsSqgCollarLhsCondition`

This section executes the proof roadmap documented in ¬ß10.21. The mollifier
`Ōą_őĶ = sqgConcreteMollifier őĶ s t` is piecewise constant (= 0 outside
`[s ‚ąí őĶ, t + őĶ]`, = 1 on `[s, t]`), so its derivative is supported on the two
**collars** `[s ‚ąí őĶ, s]` and `[t, t + őĶ]`. On the left collar the mollifier
reduces to `Real.smoothTransition ((ŌĄ ‚ąí s + őĶ)/őĶ)` (right factor = 1); on the
right collar it reduces to `Real.smoothTransition ((t ‚ąí ŌĄ + őĶ)/őĶ)` (left
factor = 1). Each factor is monotone in the scaled variable, so:

* **Tier 1 ‚ÄĒ monotonicity.** `sqgConcreteMollifier` is `MonotoneOn` the left
  collar and `AntitoneOn` the right collar. This is the substrate all sign
  statements below rest on.
* **Tier 2 ‚ÄĒ derivative sign / vanishing.** On `Ioo s t` the function is
  locally constant ‚áí `deriv = 0`. Outside `[s ‚ąí őĶ, t + őĶ]` the same holds.
  On the interior of each collar the local monotone representative makes
  `deriv` non-negative (left) or non-positive (right).

Tiers 3‚Äď6 (FTC mass identities, integral split, collar squeeze, final
assembly) are the subsequent commits in this plan. -/

/-- **Right-factor collapse.** Symmetric companion to
`sqgConcreteMollifier_eq_left_factor`: when `s ‚Č§ ŌĄ`, the left factor
`smoothTransition ((ŌĄ ‚ąí s + őĶ)/őĶ)` equals 1 (its argument is `‚Č• 1`), so the
mollifier reduces to the right factor. Needed for the right-collar monotone
representation in Tier 1. -/
theorem sqgConcreteMollifier_eq_right_factor {s t ŌĄ : ‚ĄĚ} (hŌĄs : s ‚Č§ ŌĄ) {őĶ : ‚ĄĚ}
    (hőĶ : 0 < őĶ) :
    sqgConcreteMollifier őĶ s t ŌĄ =
      Real.smoothTransition ((t - ŌĄ + őĶ) / őĶ) := by
  unfold sqgConcreteMollifier
  have h1 : Real.smoothTransition ((ŌĄ - s + őĶ) / őĶ) = 1 :=
    Real.smoothTransition.one_of_one_le (by rw [le_div_iff‚āÄ hőĶ]; linarith)
  rw [h1, one_mul]

/-! #### Tier 1 ‚ÄĒ monotonicity on the two collars -/

/-- **Tier 1a ‚ÄĒ MonotoneOn left collar.** On `[s ‚ąí őĶ, s]`, the mollifier
equals `Real.smoothTransition ((ŌĄ ‚ąí s + őĶ)/őĶ)` (right factor is 1 because
`ŌĄ ‚Č§ s ‚Č§ t`). Precomposition of a monotone function with an affine
increasing map is monotone. -/
theorem sqgConcreteMollifier_monotoneOn_left_collar {s t őĶ : ‚ĄĚ}
    (hőĶ : 0 < őĶ) (hst : s ‚Č§ t) :
    MonotoneOn (sqgConcreteMollifier őĶ s t) (Set.Icc (s - őĶ) s) := by
  intro a ha b hb hab
  have ha_t : a ‚Č§ t := ha.2.trans hst
  have hb_t : b ‚Č§ t := hb.2.trans hst
  rw [sqgConcreteMollifier_eq_left_factor ha_t hőĶ,
      sqgConcreteMollifier_eq_left_factor hb_t hőĶ]
  apply Real.smoothTransition.monotone
  exact (div_le_div_iff_of_pos_right hőĶ).mpr (by linarith)

/-- **Tier 1b ‚ÄĒ AntitoneOn right collar.** On `[t, t + őĶ]`, the mollifier
equals `Real.smoothTransition ((t ‚ąí ŌĄ + őĶ)/őĶ)` (left factor is 1 because
`s ‚Č§ t ‚Č§ ŌĄ`). The argument `(t ‚ąí ŌĄ + őĶ)/őĶ` is *decreasing* in `ŌĄ`, so after
composition with the monotone `smoothTransition` the mollifier is antitone. -/
theorem sqgConcreteMollifier_antitoneOn_right_collar {s t őĶ : ‚ĄĚ}
    (hőĶ : 0 < őĶ) (hst : s ‚Č§ t) :
    AntitoneOn (sqgConcreteMollifier őĶ s t) (Set.Icc t (t + őĶ)) := by
  intro a ha b hb hab
  have ha_s : s ‚Č§ a := hst.trans ha.1
  have hb_s : s ‚Č§ b := hst.trans hb.1
  rw [sqgConcreteMollifier_eq_right_factor ha_s hőĶ,
      sqgConcreteMollifier_eq_right_factor hb_s hőĶ]
  apply Real.smoothTransition.monotone
  exact (div_le_div_iff_of_pos_right hőĶ).mpr (by linarith)

/-! #### Tier 2 ‚ÄĒ derivative sign and vanishing zones -/

/-- **Tier 2a ‚ÄĒ derivative vanishes on the mid-interval `Ioo s t`.** On the
open interval `(s, t)` the mollifier is constantly 1, hence locally constant
in a neighborhood of any `ŌĄ ‚ąą Ioo s t`, so `deriv = 0` by
`Filter.EventuallyEq.deriv_eq`. -/
theorem sqgConcreteMollifier_deriv_zero_of_mem_Ioo {s t ŌĄ őĶ : ‚ĄĚ}
    (hŌĄ : ŌĄ ‚ąą Set.Ioo s t) (hőĶ : 0 < őĶ) :
    deriv (sqgConcreteMollifier őĶ s t) ŌĄ = 0 := by
  have h : (sqgConcreteMollifier őĶ s t) =Š∂†[nhds ŌĄ] (fun _ : ‚ĄĚ => (1 : ‚ĄĚ)) := by
    filter_upwards [Ioo_mem_nhds hŌĄ.1 hŌĄ.2] with x hx
    exact sqgConcreteMollifier_eq_one_of_mem_Ioo hx hőĶ
  rw [h.deriv_eq]; exact deriv_const ŌĄ 1

/-- **Tier 2b ‚ÄĒ derivative vanishes strictly below `s ‚ąí őĶ`.** Below the
support's left edge the mollifier is identically 0, so `deriv = 0`. -/
theorem sqgConcreteMollifier_deriv_zero_of_lt_left {s t ŌĄ őĶ : ‚ĄĚ}
    (hŌĄ : ŌĄ < s - őĶ) (hőĶ : 0 < őĶ) :
    deriv (sqgConcreteMollifier őĶ s t) ŌĄ = 0 := by
  have h : (sqgConcreteMollifier őĶ s t) =Š∂†[nhds ŌĄ] (fun _ : ‚ĄĚ => (0 : ‚ĄĚ)) := by
    filter_upwards [Iio_mem_nhds hŌĄ] with x hx
    exact sqgConcreteMollifier_zero_of_le_left hőĶ hx.le
  rw [h.deriv_eq]; exact deriv_const ŌĄ 0

/-- **Tier 2c ‚ÄĒ derivative vanishes strictly above `t + őĶ`.** Symmetric to
Tier 2b. -/
theorem sqgConcreteMollifier_deriv_zero_of_gt_right {s t ŌĄ őĶ : ‚ĄĚ}
    (hŌĄ : t + őĶ < ŌĄ) (hőĶ : 0 < őĶ) :
    deriv (sqgConcreteMollifier őĶ s t) ŌĄ = 0 := by
  have h : (sqgConcreteMollifier őĶ s t) =Š∂†[nhds ŌĄ] (fun _ : ‚ĄĚ => (0 : ‚ĄĚ)) := by
    filter_upwards [Ioi_mem_nhds hŌĄ] with x hx
    exact sqgConcreteMollifier_zero_of_ge_right hőĶ hx.le
  rw [h.deriv_eq]; exact deriv_const ŌĄ 0

/-- **Tier 2d ‚ÄĒ derivative is non-negative on the interior of the left
collar.** In a neighborhood of `ŌĄ ‚ąą Ioo (s ‚ąí őĶ) s` (specifically, any nbhd
contained in `Iic t`), the mollifier equals the monotone representative
`x ‚Ü¶ smoothTransition ((x ‚ąí s + őĶ)/őĶ)`. By `Filter.EventuallyEq.deriv_eq`
the derivative at `ŌĄ` matches, and the representative's derivative is
non-negative by `Monotone.deriv_nonneg`. -/
theorem sqgConcreteMollifier_deriv_nonneg_of_mem_left_collar
    {s t ŌĄ őĶ : ‚ĄĚ} (hŌĄ : ŌĄ ‚ąą Set.Ioo (s - őĶ) s) (hőĶ : 0 < őĶ) (hst : s ‚Č§ t) :
    0 ‚Č§ deriv (sqgConcreteMollifier őĶ s t) ŌĄ := by
  set f : ‚ĄĚ ‚Üí ‚ĄĚ := fun x => Real.smoothTransition ((x - s + őĶ) / őĶ) with hf_def
  have h_nhds : (sqgConcreteMollifier őĶ s t) =Š∂†[nhds ŌĄ] f := by
    filter_upwards [Iic_mem_nhds (lt_of_lt_of_le hŌĄ.2 hst)] with x hx
    exact sqgConcreteMollifier_eq_left_factor hx hőĶ
  rw [h_nhds.deriv_eq]
  have hf_mono : Monotone f := fun a b hab => by
    apply Real.smoothTransition.monotone
    exact (div_le_div_iff_of_pos_right hőĶ).mpr (by linarith)
  exact hf_mono.deriv_nonneg

/-- **Tier 2e ‚ÄĒ derivative is non-positive on the interior of the right
collar.** Symmetric to Tier 2d: local representative is
`x ‚Ü¶ smoothTransition ((t ‚ąí x + őĶ)/őĶ)`, which is antitone, so
`deriv ‚Č§ 0` by `Antitone.deriv_nonpos`. -/
theorem sqgConcreteMollifier_deriv_nonpos_of_mem_right_collar
    {s t ŌĄ őĶ : ‚ĄĚ} (hŌĄ : ŌĄ ‚ąą Set.Ioo t (t + őĶ)) (hőĶ : 0 < őĶ) (hst : s ‚Č§ t) :
    deriv (sqgConcreteMollifier őĶ s t) ŌĄ ‚Č§ 0 := by
  set f : ‚ĄĚ ‚Üí ‚ĄĚ := fun x => Real.smoothTransition ((t - x + őĶ) / őĶ) with hf_def
  have h_nhds : (sqgConcreteMollifier őĶ s t) =Š∂†[nhds ŌĄ] f := by
    filter_upwards [Ioi_mem_nhds (lt_of_le_of_lt hst hŌĄ.1)] with x hx
    exact sqgConcreteMollifier_eq_right_factor hx.le hőĶ
  rw [h_nhds.deriv_eq]
  have hf_anti : Antitone f := fun a b hab => by
    apply Real.smoothTransition.monotone
    exact (div_le_div_iff_of_pos_right hőĶ).mpr (by linarith)
  exact hf_anti.deriv_nonpos

/-! #### Tier 3 ‚ÄĒ FTC mass identities on each collar -/

/-- **Plumbing ‚ÄĒ pointwise `HasDerivAt` from `ContDiff 1`.** Needed to feed
`intervalIntegral.integral_eq_sub_of_hasDerivAt` on every collar. -/
theorem sqgConcreteMollifier_hasDerivAt (őĶ s t x : ‚ĄĚ) :
    HasDerivAt (sqgConcreteMollifier őĶ s t)
      (deriv (sqgConcreteMollifier őĶ s t) x) x := by
  have hd : Differentiable ‚ĄĚ (sqgConcreteMollifier őĶ s t) :=
    (sqgConcreteMollifier_contDiff őĶ s t).differentiable one_ne_zero
  exact (hd x).hasDerivAt

/-- **Plumbing ‚ÄĒ derivative is globally interval-integrable.** `sqgConcreteMollifier`
is `C¬Ļ`, so `deriv` is continuous and hence interval-integrable on any `[a, b]`. -/
theorem sqgConcreteMollifier_deriv_intervalIntegrable (őĶ s t a b : ‚ĄĚ) :
    IntervalIntegrable (deriv (sqgConcreteMollifier őĶ s t)) volume a b :=
  ((sqgConcreteMollifier_contDiff őĶ s t).continuous_deriv_one).intervalIntegrable a b

/-- **Tier 3a ‚ÄĒ Left-collar FTC mass identity.**
`‚ąę_{s‚ąíőĶ}^{s} deriv Ōą_őĶ = Ōą_őĶ(s) ‚ąí Ōą_őĶ(s ‚ąí őĶ) = 1 ‚ąí 0 = 1`. -/
theorem sqgConcreteMollifier_integral_deriv_left_collar {őĶ s t : ‚ĄĚ}
    (hőĶ : 0 < őĶ) (hst : s ‚Č§ t) :
    ‚ąę ŌĄ in (s - őĶ)..s, deriv (sqgConcreteMollifier őĶ s t) ŌĄ = 1 := by
  rw [intervalIntegral.integral_eq_sub_of_hasDerivAt
        (fun x _ => sqgConcreteMollifier_hasDerivAt őĶ s t x)
        (sqgConcreteMollifier_deriv_intervalIntegrable őĶ s t _ _),
      sqgConcreteMollifier_eq_one_of_mem_Icc ‚ü®le_refl s, hst‚ü© hőĶ,
      sqgConcreteMollifier_zero_of_le_left hőĶ (le_refl _)]
  ring

/-- **Tier 3b ‚ÄĒ Right-collar FTC mass identity.**
`‚ąę_{t}^{t+őĶ} deriv Ōą_őĶ = Ōą_őĶ(t + őĶ) ‚ąí Ōą_őĶ(t) = 0 ‚ąí 1 = ‚ąí1`. -/
theorem sqgConcreteMollifier_integral_deriv_right_collar {őĶ s t : ‚ĄĚ}
    (hőĶ : 0 < őĶ) (hst : s ‚Č§ t) :
    ‚ąę ŌĄ in t..(t + őĶ), deriv (sqgConcreteMollifier őĶ s t) ŌĄ = -1 := by
  rw [intervalIntegral.integral_eq_sub_of_hasDerivAt
        (fun x _ => sqgConcreteMollifier_hasDerivAt őĶ s t x)
        (sqgConcreteMollifier_deriv_intervalIntegrable őĶ s t _ _),
      sqgConcreteMollifier_zero_of_ge_right hőĶ (le_refl _),
      sqgConcreteMollifier_eq_one_of_mem_Icc ‚ü®hst, le_refl t‚ü© hőĶ]
  ring

/-! #### Tier 4 ‚ÄĒ split the full real integral into two collar interval integrals -/

/-- **Tier 4 plumbing ‚ÄĒ complex derivative via real derivative coercion.**
`deriv (ŌĄ ‚Ü¶ ‚ÜĎ(Ōą_őĶ ŌĄ)) = ‚ÜĎ(deriv Ōą_őĶ ŌĄ)` because coercion `‚ĄĚ ‚Üí ‚Ąā` is `‚ĄĚ`-linear
and `Ōą_őĶ` is real-differentiable at every point. -/
theorem sqgConcreteMollifier_deriv_complex (őĶ s t x : ‚ĄĚ) :
    deriv (fun ŌĄ => (sqgConcreteMollifier őĶ s t ŌĄ : ‚Ąā)) x =
      ((deriv (sqgConcreteMollifier őĶ s t) x : ‚ĄĚ) : ‚Ąā) :=
  ((sqgConcreteMollifier_hasDerivAt őĶ s t x).ofReal_comp).deriv

/-- **Tier 4 plumbing ‚ÄĒ `deriv Ōą_őĶ` is zero at the left edge of the left
collar, `ŌĄ = s ‚ąí őĶ`.** The derivative is continuous (by `ContDiff 1`) and
identically zero on the open half-line `(‚ąí‚ąě, s ‚ąí őĶ)`; uniqueness of the
one-sided limit from the left then pins down the boundary value. -/
theorem sqgConcreteMollifier_deriv_zero_at_s_minus_őĶ {s t őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ) :
    deriv (sqgConcreteMollifier őĶ s t) (s - őĶ) = 0 := by
  have hcont : Continuous (deriv (sqgConcreteMollifier őĶ s t)) :=
    (sqgConcreteMollifier_contDiff őĶ s t).continuous_deriv_one
  have h_left_lim : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s t))
      (nhdsWithin (s - őĶ) (Set.Iio (s - őĶ))) (nhds 0) := by
    apply Filter.Tendsto.congr' _ tendsto_const_nhds
    filter_upwards [self_mem_nhdsWithin] with x hx
    rw [sqgConcreteMollifier_deriv_zero_of_lt_left hx hőĶ]
  have h_full_tendsto : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s t))
      (nhdsWithin (s - őĶ) (Set.Iio (s - őĶ)))
      (nhds (deriv (sqgConcreteMollifier őĶ s t) (s - őĶ))) :=
    hcont.continuousAt.mono_left nhdsWithin_le_nhds
  exact tendsto_nhds_unique h_full_tendsto h_left_lim

/-- **Tier 4 plumbing ‚ÄĒ `deriv Ōą_őĶ` is zero at the right edge, `ŌĄ = t + őĶ`.**
Symmetric to `_deriv_zero_at_s_minus_őĶ`. -/
theorem sqgConcreteMollifier_deriv_zero_at_t_plus_őĶ {s t őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ) :
    deriv (sqgConcreteMollifier őĶ s t) (t + őĶ) = 0 := by
  have hcont : Continuous (deriv (sqgConcreteMollifier őĶ s t)) :=
    (sqgConcreteMollifier_contDiff őĶ s t).continuous_deriv_one
  have h_right_lim : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s t))
      (nhdsWithin (t + őĶ) (Set.Ioi (t + őĶ))) (nhds 0) := by
    apply Filter.Tendsto.congr' _ tendsto_const_nhds
    filter_upwards [self_mem_nhdsWithin] with x hx
    rw [sqgConcreteMollifier_deriv_zero_of_gt_right hx hőĶ]
  have h_full_tendsto : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s t))
      (nhdsWithin (t + őĶ) (Set.Ioi (t + őĶ)))
      (nhds (deriv (sqgConcreteMollifier őĶ s t) (t + őĶ))) :=
    hcont.continuousAt.mono_left nhdsWithin_le_nhds
  exact tendsto_nhds_unique h_full_tendsto h_right_lim

/-- **Tier 4 plumbing ‚ÄĒ `deriv Ōą_őĶ` vanishes on the closed mid-interval
`[s, t]`.** On `Ioo s t` it is zero by Tier 2a; at the endpoints `s` and
`t` (with `s < t`) the one-sided limit of the continuous `deriv` equals zero
by approaching from the inside, pinning the value down. When `s = t` we use
the boundary-edge vanishing at `s = t` directly, approached from outside the
collars on the other side. -/
theorem sqgConcreteMollifier_deriv_zero_on_mid_Icc {s t ŌĄ őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hst : s ‚Č§ t) (hŌĄ : ŌĄ ‚ąą Set.Icc s t) :
    deriv (sqgConcreteMollifier őĶ s t) ŌĄ = 0 := by
  rcases eq_or_lt_of_le hst with rfl | hst_lt
  ¬∑ -- s = t case. From hŌĄ : ŌĄ ‚ąą Icc s s, get ŌĄ = s. Then use squeeze:
    -- deriv ‚Č• 0 from the left-collar limit, ‚Č§ 0 from the right-collar limit.
    have hŌĄ_eq : ŌĄ = s := le_antisymm hŌĄ.2 hŌĄ.1
    rw [hŌĄ_eq]
    have hcont : Continuous (deriv (sqgConcreteMollifier őĶ s s)) :=
      (sqgConcreteMollifier_contDiff őĶ s s).continuous_deriv_one
    have hlb : 0 ‚Č§ deriv (sqgConcreteMollifier őĶ s s) s := by
      have h_tend : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s s))
          (nhdsWithin s (Set.Iio s))
          (nhds (deriv (sqgConcreteMollifier őĶ s s) s)) :=
        hcont.continuousAt.mono_left nhdsWithin_le_nhds
      apply ge_of_tendsto h_tend
      filter_upwards [Ioo_mem_nhdsLT (show s - őĶ < s by linarith)] with x hx
      exact sqgConcreteMollifier_deriv_nonneg_of_mem_left_collar hx hőĶ le_rfl
    have hub : deriv (sqgConcreteMollifier őĶ s s) s ‚Č§ 0 := by
      have h_tend : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s s))
          (nhdsWithin s (Set.Ioi s))
          (nhds (deriv (sqgConcreteMollifier őĶ s s) s)) :=
        hcont.continuousAt.mono_left nhdsWithin_le_nhds
      apply le_of_tendsto h_tend
      filter_upwards [Ioo_mem_nhdsGT (show s < s + őĶ by linarith)] with x hx
      exact sqgConcreteMollifier_deriv_nonpos_of_mem_right_collar hx hőĶ le_rfl
    linarith
  ¬∑ rcases eq_or_lt_of_le hŌĄ.1 with heq_s | hŌĄ_gt_s
    ¬∑ -- ŌĄ = s: deriv from right is 0 (deriv = 0 on Ioo s t)
      rw [‚Üź heq_s]
      have hcont : Continuous (deriv (sqgConcreteMollifier őĶ s t)) :=
        (sqgConcreteMollifier_contDiff őĶ s t).continuous_deriv_one
      have h_right_lim : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s t))
          (nhdsWithin s (Set.Ioi s)) (nhds 0) := by
        apply Filter.Tendsto.congr' _ tendsto_const_nhds
        filter_upwards [Ioo_mem_nhdsGT hst_lt] with x hx
        rw [sqgConcreteMollifier_deriv_zero_of_mem_Ioo hx hőĶ]
      have h_full_tendsto : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s t))
          (nhdsWithin s (Set.Ioi s))
          (nhds (deriv (sqgConcreteMollifier őĶ s t) s)) :=
        hcont.continuousAt.mono_left nhdsWithin_le_nhds
      exact tendsto_nhds_unique h_full_tendsto h_right_lim
    ¬∑ rcases eq_or_lt_of_le hŌĄ.2 with heq_t | hŌĄ_lt_t
      ¬∑ -- ŌĄ = t: deriv from left is 0
        rw [heq_t]
        have hcont : Continuous (deriv (sqgConcreteMollifier őĶ s t)) :=
          (sqgConcreteMollifier_contDiff őĶ s t).continuous_deriv_one
        have h_left_lim : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s t))
            (nhdsWithin t (Set.Iio t)) (nhds 0) := by
          apply Filter.Tendsto.congr' _ tendsto_const_nhds
          filter_upwards [Ioo_mem_nhdsLT hst_lt] with x hx
          rw [sqgConcreteMollifier_deriv_zero_of_mem_Ioo hx hőĶ]
        have h_full_tendsto : Filter.Tendsto (deriv (sqgConcreteMollifier őĶ s t))
            (nhdsWithin t (Set.Iio t))
            (nhds (deriv (sqgConcreteMollifier őĶ s t) t)) :=
          hcont.continuousAt.mono_left nhdsWithin_le_nhds
        exact tendsto_nhds_unique h_full_tendsto h_left_lim
      ¬∑ exact sqgConcreteMollifier_deriv_zero_of_mem_Ioo ‚ü®hŌĄ_gt_s, hŌĄ_lt_t‚ü© hőĶ

/-- **Tier 4 ‚ÄĒ derivative (complex-valued) vanishes outside the two open
collars (extended to include their separating boundaries).** -/
theorem sqgConcreteMollifier_deriv_complex_zero_off_collars
    {őĶ s t ŌĄ : ‚ĄĚ} (hőĶ : 0 < őĶ) (hst : s ‚Č§ t)
    (hŌĄ : ŌĄ ‚Č§ s - őĶ ‚ą® ŌĄ ‚ąą Set.Icc s t ‚ą® t + őĶ ‚Č§ ŌĄ) :
    deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ = 0 := by
  rw [sqgConcreteMollifier_deriv_complex]
  rcases hŌĄ with h | h | h
  ¬∑ rcases eq_or_lt_of_le h with rfl | h
    ¬∑ rw [sqgConcreteMollifier_deriv_zero_at_s_minus_őĶ hőĶ]; simp
    ¬∑ rw [sqgConcreteMollifier_deriv_zero_of_lt_left h hőĶ]; simp
  ¬∑ rw [sqgConcreteMollifier_deriv_zero_on_mid_Icc hőĶ hst h]; simp
  ¬∑ rcases eq_or_lt_of_le h with rfl | h
    ¬∑ rw [sqgConcreteMollifier_deriv_zero_at_t_plus_őĶ hőĶ]; simp
    ¬∑ rw [sqgConcreteMollifier_deriv_zero_of_gt_right h hőĶ]; simp

/-- **Tier 4 plumbing ‚ÄĒ interval integrability of the product integrand.** -/
theorem sqgConcreteMollifier_product_intervalIntegrable
    (őĶ s t : ‚ĄĚ) {F : ‚ĄĚ ‚Üí ‚Ąā} (hF : Continuous F) (a b : ‚ĄĚ) :
    IntervalIntegrable
      (fun ŌĄ => deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ)
      volume a b := by
  apply Continuous.intervalIntegrable
  apply Continuous.mul _ hF
  have h_eq : deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) =
              fun ŌĄ => ((deriv (sqgConcreteMollifier őĶ s t) ŌĄ : ‚ĄĚ) : ‚Ąā) := by
    funext ŌĄ; exact sqgConcreteMollifier_deriv_complex őĶ s t ŌĄ
  rw [h_eq]
  exact Complex.continuous_ofReal.comp
    ((sqgConcreteMollifier_contDiff őĶ s t).continuous_deriv_one)

/-- **Tier 4 ‚ÄĒ the full real integral equals the buffered interval integral.** -/
theorem sqgConcreteMollifier_integral_eq_buffered
    {őĶ s t : ‚ĄĚ} (hőĶ : 0 < őĶ) (hst : s ‚Č§ t) (F : ‚ĄĚ ‚Üí ‚Ąā) :
    ‚ąę ŌĄ, deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ
      = ‚ąę ŌĄ in (s - őĶ - 1)..(t + őĶ + 1),
          deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ := by
  symm
  apply intervalIntegral.integral_eq_integral_of_support_subset
  intro ŌĄ hŌĄ
  refine ‚ü®?_, ?_‚ü©
  ¬∑ by_contra h
    push Not at h
    apply hŌĄ
    have hŌĄ_le : ŌĄ ‚Č§ s - őĶ := by linarith
    show deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ = 0
    rw [sqgConcreteMollifier_deriv_complex_zero_off_collars hőĶ hst (Or.inl hŌĄ_le)]
    ring
  ¬∑ by_contra h
    push Not at h
    apply hŌĄ
    have hŌĄ_ge : t + őĶ ‚Č§ ŌĄ := by linarith
    show deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ = 0
    rw [sqgConcreteMollifier_deriv_complex_zero_off_collars hőĶ hst
          (Or.inr (Or.inr hŌĄ_ge))]
    ring

/-- **Tier 4 ‚ÄĒ full real integral decomposed as a sum over the two collars.** -/
theorem sqgConcreteMollifier_integral_collar_split
    {őĶ s t : ‚ĄĚ} (hőĶ : 0 < őĶ) (hst : s ‚Č§ t) {F : ‚ĄĚ ‚Üí ‚Ąā} (hF : Continuous F) :
    ‚ąę ŌĄ, deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ
      = (‚ąę ŌĄ in (s - őĶ)..s,
          deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ)
      + (‚ąę ŌĄ in t..(t + őĶ),
          deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ) := by
  set G : ‚ĄĚ ‚Üí ‚Ąā := fun ŌĄ =>
    deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ with hG_def
  have hII : ‚ąÄ a b : ‚ĄĚ, IntervalIntegrable G volume a b :=
    fun a b => sqgConcreteMollifier_product_intervalIntegrable őĶ s t hF a b
  rw [sqgConcreteMollifier_integral_eq_buffered hőĶ hst F]
  rw [‚Üź intervalIntegral.integral_add_adjacent_intervals
        (hII (s - őĶ - 1) (s - őĶ)) (hII (s - őĶ) _),
      ‚Üź intervalIntegral.integral_add_adjacent_intervals (hII (s - őĶ) s) (hII s _),
      ‚Üź intervalIntegral.integral_add_adjacent_intervals (hII s t) (hII t _),
      ‚Üź intervalIntegral.integral_add_adjacent_intervals (hII t (t + őĶ)) (hII (t + őĶ) _)]
  have h_outer_left : ‚ąę ŌĄ in (s - őĶ - 1)..(s - őĶ), G ŌĄ = 0 := by
    rw [show (‚ąę ŌĄ in (s - őĶ - 1)..(s - őĶ), G ŌĄ)
          = ‚ąę ŌĄ in (s - őĶ - 1)..(s - őĶ), (0 : ‚Ąā) from ?_,
        intervalIntegral.integral_zero]
    apply intervalIntegral.integral_congr
    intro ŌĄ hŌĄ
    rw [Set.uIcc_of_le (by linarith : s - őĶ - 1 ‚Č§ s - őĶ)] at hŌĄ
    show deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ = 0
    rw [sqgConcreteMollifier_deriv_complex_zero_off_collars hőĶ hst
          (Or.inl hŌĄ.2)]
    ring
  have h_mid : ‚ąę ŌĄ in s..t, G ŌĄ = 0 := by
    rw [show (‚ąę ŌĄ in s..t, G ŌĄ) = ‚ąę ŌĄ in s..t, (0 : ‚Ąā) from ?_,
        intervalIntegral.integral_zero]
    apply intervalIntegral.integral_congr
    intro ŌĄ hŌĄ
    rw [Set.uIcc_of_le hst] at hŌĄ
    show deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ = 0
    rw [sqgConcreteMollifier_deriv_complex_zero_off_collars hőĶ hst
          (Or.inr (Or.inl hŌĄ))]
    ring
  have h_outer_right : ‚ąę ŌĄ in (t + őĶ)..(t + őĶ + 1), G ŌĄ = 0 := by
    rw [show (‚ąę ŌĄ in (t + őĶ)..(t + őĶ + 1), G ŌĄ)
          = ‚ąę ŌĄ in (t + őĶ)..(t + őĶ + 1), (0 : ‚Ąā) from ?_,
        intervalIntegral.integral_zero]
    apply intervalIntegral.integral_congr
    intro ŌĄ hŌĄ
    rw [Set.uIcc_of_le (by linarith : t + őĶ ‚Č§ t + őĶ + 1)] at hŌĄ
    show deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ = 0
    rw [sqgConcreteMollifier_deriv_complex_zero_off_collars hőĶ hst
          (Or.inr (Or.inr hŌĄ.1))]
    ring
  simp only [h_outer_left, h_outer_right, h_mid, zero_add, add_zero]

/-! #### Tier 5 ‚ÄĒ collar squeeze: each collar integral tends to the endpoint value -/

/-- **Tier 5 ‚ÄĒ Left-collar squeeze.** As `őĶ ‚Üí 0‚Āļ`, the left-collar integral
of `deriv Ōą_őĶ ¬∑ F` tends to `F(s)`, when `F` is continuous.

Proof sketch: `‚ąę (s-őĶ)..s, deriv Ōą_őĶ ¬∑ F ‚ąí F(s) = ‚ąę (s-őĶ)..s, deriv Ōą_őĶ ¬∑ (F ‚ąí F(s))`
using the Tier 3 mass identity `‚ąę deriv Ōą_őĶ = 1`. The remainder is bounded by
`sup_{ŌĄ ‚ąą [s‚ąíőĶ, s]} ‚ÄĖF(ŌĄ) ‚ąí F(s)‚ÄĖ ¬∑ 1`, which tends to 0 by continuity of F. -/
theorem sqgConcreteMollifier_left_collar_tendsto
    {s t : ‚ĄĚ} (hst : s ‚Č§ t) {F : ‚ĄĚ ‚Üí ‚Ąā} (hF : Continuous F) :
    Filter.Tendsto
      (fun őĶ => ‚ąę ŌĄ in (s - őĶ)..s,
          deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (F s)) := by
  rw [Metric.tendsto_nhdsWithin_nhds]
  intro őī hőī
  have hFc : ContinuousAt F s := hF.continuousAt
  rcases Metric.continuousAt_iff.mp hFc (őī / 2) (by linarith) with ‚ü®ő∑, hő∑_pos, hő∑‚ü©
  refine ‚ü®ő∑, hő∑_pos, ?_‚ü©
  intro őĶ hőĶ hőĶ_dist
  have hőĶ_pos : (0 : ‚ĄĚ) < őĶ := hőĶ
  have hőĶ_lt_ő∑ : őĶ < ő∑ := by
    rw [Real.dist_eq, sub_zero, abs_of_pos hőĶ_pos] at hőĶ_dist
    exact hőĶ_dist
  have hab : s - őĶ ‚Č§ s := by linarith
  -- Pointwise continuity bound on [s - őĶ, s]
  have hF_bound : ‚ąÄ ŌĄ ‚ąą Set.Icc (s - őĶ) s, ‚ÄĖF ŌĄ - F s‚ÄĖ ‚Č§ őī / 2 := by
    intro ŌĄ hŌĄ
    have hdŌĄ : dist ŌĄ s < ő∑ := by
      rw [Real.dist_eq]
      have h1 : ŌĄ - s ‚Č§ 0 := by linarith [hŌĄ.2]
      have h2 : s - ŌĄ ‚Č§ őĶ := by linarith [hŌĄ.1]
      rw [abs_of_nonpos h1]; linarith
    have := hő∑ hdŌĄ
    rw [dist_eq_norm] at this
    exact this.le
  -- Abbreviations
  set ŌąC : ‚ĄĚ ‚Üí ‚Ąā := fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā) with hŌąC
  have hderivC : ‚ąÄ x, deriv ŌąC x = ((deriv (sqgConcreteMollifier őĶ s t) x : ‚ĄĚ) : ‚Ąā) :=
    sqgConcreteMollifier_deriv_complex őĶ s t
  have hderivC_fun : deriv ŌąC = fun x => ((deriv (sqgConcreteMollifier őĶ s t) x : ‚ĄĚ) : ‚Ąā) :=
    funext hderivC
  -- Tier 3 mass identities, lifted to ‚Ąā
  have hmass_R : ‚ąę ŌĄ in (s - őĶ)..s, deriv (sqgConcreteMollifier őĶ s t) ŌĄ = 1 :=
    sqgConcreteMollifier_integral_deriv_left_collar hőĶ_pos hst
  have hmass_C : ‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ = (1 : ‚Ąā) := by
    rw [hderivC_fun, intervalIntegral.integral_ofReal, hmass_R, Complex.ofReal_one]
  -- Integrability of key integrands
  have hII_deriv : IntervalIntegrable (deriv ŌąC) volume (s - őĶ) s := by
    rw [hderivC_fun]
    exact (Complex.continuous_ofReal.comp
      ((sqgConcreteMollifier_contDiff őĶ s t).continuous_deriv_one)).intervalIntegrable _ _
  have hII_prod : IntervalIntegrable (fun ŌĄ => deriv ŌąC ŌĄ * F ŌĄ) volume (s - őĶ) s :=
    sqgConcreteMollifier_product_intervalIntegrable őĶ s t hF _ _
  have hII_prodFs : IntervalIntegrable (fun ŌĄ => deriv ŌąC ŌĄ * F s) volume (s - őĶ) s :=
    hII_deriv.mul_const _
  -- Rewrite the difference
  have hőĒ : (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * F ŌĄ) - F s
      = ‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * (F ŌĄ - F s) := by
    have h1 : (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * F ŌĄ)
              - (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * F s)
              = ‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * (F ŌĄ - F s) := by
      rw [‚Üź intervalIntegral.integral_sub hII_prod hII_prodFs]
      congr 1; funext ŌĄ; ring
    have h2 : (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * F s) = F s := by
      calc (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * F s)
          = (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ) * F s :=
              intervalIntegral.integral_mul_const (F s) (deriv ŌąC)
        _ = 1 * F s := by rw [hmass_C]
        _ = F s := one_mul _
    calc (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * F ŌĄ) - F s
        = (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * F ŌĄ)
            - (‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * F s) := by rw [h2]
      _ = ‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * (F ŌĄ - F s) := h1
  -- Dominating function g ŌĄ = deriv Ōą_R ŌĄ * (őī/2)
  set g : ‚ĄĚ ‚Üí ‚ĄĚ := fun ŌĄ => deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (őī / 2) with hg
  have hII_g : IntervalIntegrable g volume (s - őĶ) s := by
    have := (sqgConcreteMollifier_deriv_intervalIntegrable őĶ s t (s - őĶ) s)
    exact this.mul_const _
  have h_norm_bound : ‚ąÄŠĶź ŌĄ ‚ąāvolume, ŌĄ ‚ąą Set.Ioc (s - őĶ) s ‚Üí
      ‚ÄĖderiv ŌąC ŌĄ * (F ŌĄ - F s)‚ÄĖ ‚Č§ g ŌĄ := by
    refine Filter.Eventually.of_forall (fun ŌĄ hŌĄ => ?_)
    have hŌĄ_Icc : ŌĄ ‚ąą Set.Icc (s - őĶ) s := ‚ü®hŌĄ.1.le, hŌĄ.2‚ü©
    rw [norm_mul, hderivC ŌĄ, Complex.norm_real, Real.norm_eq_abs]
    have h_nonneg : 0 ‚Č§ deriv (sqgConcreteMollifier őĶ s t) ŌĄ := by
      rcases eq_or_lt_of_le hŌĄ.2 with heq | hlt
      ¬∑ rw [heq]
        exact le_of_eq (sqgConcreteMollifier_deriv_zero_on_mid_Icc
                         hőĶ_pos hst ‚ü®le_refl _, hst‚ü©).symm
      ¬∑ exact sqgConcreteMollifier_deriv_nonneg_of_mem_left_collar
                ‚ü®hŌĄ.1, hlt‚ü© hőĶ_pos hst
    rw [abs_of_nonneg h_nonneg]
    show deriv (sqgConcreteMollifier őĶ s t) ŌĄ * ‚ÄĖF ŌĄ - F s‚ÄĖ
        ‚Č§ deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (őī / 2)
    exact mul_le_mul_of_nonneg_left (hF_bound ŌĄ hŌĄ_Icc) h_nonneg
  have h_int_bound :
      ‚ÄĖ‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * (F ŌĄ - F s)‚ÄĖ
        ‚Č§ ‚ąę ŌĄ in (s - őĶ)..s, g ŌĄ :=
    intervalIntegral.norm_integral_le_of_norm_le hab h_norm_bound hII_g
  have h_g_int : (‚ąę ŌĄ in (s - őĶ)..s, g ŌĄ) = őī / 2 := by
    show (‚ąę ŌĄ in (s - őĶ)..s,
            deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (őī / 2)) = őī / 2
    calc (‚ąę ŌĄ in (s - őĶ)..s,
            deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (őī / 2))
        = (‚ąę ŌĄ in (s - őĶ)..s,
              deriv (sqgConcreteMollifier őĶ s t) ŌĄ) * (őī / 2) :=
              intervalIntegral.integral_mul_const (őī / 2)
                (deriv (sqgConcreteMollifier őĶ s t))
      _ = 1 * (őī / 2) := by rw [hmass_R]
      _ = őī / 2 := one_mul _
  -- Finish
  rw [dist_eq_norm, hőĒ]
  calc ‚ÄĖ‚ąę ŌĄ in (s - őĶ)..s, deriv ŌąC ŌĄ * (F ŌĄ - F s)‚ÄĖ
      ‚Č§ ‚ąę ŌĄ in (s - őĶ)..s, g ŌĄ := h_int_bound
    _ = őī / 2 := h_g_int
    _ < őī := by linarith

/-- **Tier 5 ‚ÄĒ Right-collar squeeze.** As `őĶ ‚Üí 0‚Āļ`, the right-collar integral
of `deriv Ōą_őĶ ¬∑ F` tends to `‚ąíF(t)`. Symmetric to the left collar; derivative
is non-positive and mass identity is `‚ąí1` instead of `1`. -/
theorem sqgConcreteMollifier_right_collar_tendsto
    {s t : ‚ĄĚ} (hst : s ‚Č§ t) {F : ‚ĄĚ ‚Üí ‚Ąā} (hF : Continuous F) :
    Filter.Tendsto
      (fun őĶ => ‚ąę ŌĄ in t..(t + őĶ),
          deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * F ŌĄ)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (- F t)) := by
  rw [Metric.tendsto_nhdsWithin_nhds]
  intro őī hőī
  have hFc : ContinuousAt F t := hF.continuousAt
  rcases Metric.continuousAt_iff.mp hFc (őī / 2) (by linarith) with ‚ü®ő∑, hő∑_pos, hő∑‚ü©
  refine ‚ü®ő∑, hő∑_pos, ?_‚ü©
  intro őĶ hőĶ hőĶ_dist
  have hőĶ_pos : (0 : ‚ĄĚ) < őĶ := hőĶ
  have hőĶ_lt_ő∑ : őĶ < ő∑ := by
    rw [Real.dist_eq, sub_zero, abs_of_pos hőĶ_pos] at hőĶ_dist
    exact hőĶ_dist
  have hab : t ‚Č§ t + őĶ := by linarith
  have hF_bound : ‚ąÄ ŌĄ ‚ąą Set.Icc t (t + őĶ), ‚ÄĖF ŌĄ - F t‚ÄĖ ‚Č§ őī / 2 := by
    intro ŌĄ hŌĄ
    have hdŌĄ : dist ŌĄ t < ő∑ := by
      rw [Real.dist_eq]
      have h1 : 0 ‚Č§ ŌĄ - t := by linarith [hŌĄ.1]
      have h2 : ŌĄ - t ‚Č§ őĶ := by linarith [hŌĄ.2]
      rw [abs_of_nonneg h1]; linarith
    have := hő∑ hdŌĄ
    rw [dist_eq_norm] at this
    exact this.le
  set ŌąC : ‚ĄĚ ‚Üí ‚Ąā := fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā) with hŌąC
  have hderivC : ‚ąÄ x, deriv ŌąC x = ((deriv (sqgConcreteMollifier őĶ s t) x : ‚ĄĚ) : ‚Ąā) :=
    sqgConcreteMollifier_deriv_complex őĶ s t
  have hderivC_fun : deriv ŌąC = fun x => ((deriv (sqgConcreteMollifier őĶ s t) x : ‚ĄĚ) : ‚Ąā) :=
    funext hderivC
  have hmass_R : ‚ąę ŌĄ in t..(t + őĶ), deriv (sqgConcreteMollifier őĶ s t) ŌĄ = -1 :=
    sqgConcreteMollifier_integral_deriv_right_collar hőĶ_pos hst
  have hmass_C : ‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ = (-1 : ‚Ąā) := by
    rw [hderivC_fun, intervalIntegral.integral_ofReal, hmass_R]
    push_cast; ring
  have hII_deriv : IntervalIntegrable (deriv ŌąC) volume t (t + őĶ) := by
    rw [hderivC_fun]
    exact (Complex.continuous_ofReal.comp
      ((sqgConcreteMollifier_contDiff őĶ s t).continuous_deriv_one)).intervalIntegrable _ _
  have hII_prod : IntervalIntegrable (fun ŌĄ => deriv ŌąC ŌĄ * F ŌĄ) volume t (t + őĶ) :=
    sqgConcreteMollifier_product_intervalIntegrable őĶ s t hF _ _
  have hII_prodFt : IntervalIntegrable (fun ŌĄ => deriv ŌąC ŌĄ * F t) volume t (t + őĶ) :=
    hII_deriv.mul_const _
  -- Difference: ‚ąę deriv Ōą ¬∑ F - (-F t) = ‚ąę deriv Ōą ¬∑ F + F t
  --           = ‚ąę deriv Ōą ¬∑ F - F t ¬∑ ‚ąę deriv Ōą       [using ‚ąę deriv Ōą = -1]
  --           = ‚ąę deriv Ōą ¬∑ (F - F t)
  have hőĒ : (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * F ŌĄ) - (- F t)
      = ‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * (F ŌĄ - F t) := by
    have h1 : (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * F ŌĄ)
              - (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * F t)
              = ‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * (F ŌĄ - F t) := by
      rw [‚Üź intervalIntegral.integral_sub hII_prod hII_prodFt]
      congr 1; funext ŌĄ; ring
    have h2 : (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * F t) = - F t := by
      calc (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * F t)
          = (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ) * F t :=
              intervalIntegral.integral_mul_const (F t) (deriv ŌąC)
        _ = (-1 : ‚Ąā) * F t := by rw [hmass_C]
        _ = - F t := by ring
    calc (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * F ŌĄ) - (- F t)
        = (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * F ŌĄ)
            - (‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * F t) := by rw [h2]
      _ = ‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * (F ŌĄ - F t) := h1
  set g : ‚ĄĚ ‚Üí ‚ĄĚ := fun ŌĄ => - deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (őī / 2) with hg
  have hII_g : IntervalIntegrable g volume t (t + őĶ) := by
    have := (sqgConcreteMollifier_deriv_intervalIntegrable őĶ s t t (t + őĶ))
    exact this.neg.mul_const _
  have h_norm_bound : ‚ąÄŠĶź ŌĄ ‚ąāvolume, ŌĄ ‚ąą Set.Ioc t (t + őĶ) ‚Üí
      ‚ÄĖderiv ŌąC ŌĄ * (F ŌĄ - F t)‚ÄĖ ‚Č§ g ŌĄ := by
    refine Filter.Eventually.of_forall (fun ŌĄ hŌĄ => ?_)
    have hŌĄ_Icc : ŌĄ ‚ąą Set.Icc t (t + őĶ) := ‚ü®hŌĄ.1.le, hŌĄ.2‚ü©
    rw [norm_mul, hderivC ŌĄ, Complex.norm_real, Real.norm_eq_abs]
    have h_nonpos : deriv (sqgConcreteMollifier őĶ s t) ŌĄ ‚Č§ 0 := by
      rcases eq_or_lt_of_le hŌĄ.2 with heq | hlt
      ¬∑ rw [heq]
        exact le_of_eq (sqgConcreteMollifier_deriv_zero_at_t_plus_őĶ hőĶ_pos)
      ¬∑ exact sqgConcreteMollifier_deriv_nonpos_of_mem_right_collar
                ‚ü®hŌĄ.1, hlt‚ü© hőĶ_pos hst
    rw [abs_of_nonpos h_nonpos]
    have hneg_nonneg : 0 ‚Č§ - deriv (sqgConcreteMollifier őĶ s t) ŌĄ := by linarith
    show - deriv (sqgConcreteMollifier őĶ s t) ŌĄ * ‚ÄĖF ŌĄ - F t‚ÄĖ
        ‚Č§ - deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (őī / 2)
    exact mul_le_mul_of_nonneg_left (hF_bound ŌĄ hŌĄ_Icc) hneg_nonneg
  have h_int_bound :
      ‚ÄĖ‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * (F ŌĄ - F t)‚ÄĖ
        ‚Č§ ‚ąę ŌĄ in t..(t + őĶ), g ŌĄ :=
    intervalIntegral.norm_integral_le_of_norm_le hab h_norm_bound hII_g
  have h_g_int : (‚ąę ŌĄ in t..(t + őĶ), g ŌĄ) = őī / 2 := by
    show (‚ąę ŌĄ in t..(t + őĶ),
            - deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (őī / 2)) = őī / 2
    have h_swap : (‚ąę ŌĄ in t..(t + őĶ),
            - deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (őī / 2))
            = (‚ąę ŌĄ in t..(t + őĶ),
                deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (-(őī / 2))) := by
      congr 1; funext ŌĄ; ring
    rw [h_swap]
    calc (‚ąę ŌĄ in t..(t + őĶ),
            deriv (sqgConcreteMollifier őĶ s t) ŌĄ * (-(őī / 2)))
        = (‚ąę ŌĄ in t..(t + őĶ),
              deriv (sqgConcreteMollifier őĶ s t) ŌĄ) * (-(őī / 2)) :=
              intervalIntegral.integral_mul_const (-(őī / 2))
                (deriv (sqgConcreteMollifier őĶ s t))
      _ = (-1 : ‚ĄĚ) * (-(őī / 2)) := by rw [hmass_R]
      _ = őī / 2 := by ring
  rw [dist_eq_norm, hőĒ]
  calc ‚ÄĖ‚ąę ŌĄ in t..(t + őĶ), deriv ŌąC ŌĄ * (F ŌĄ - F t)‚ÄĖ
      ‚Č§ ‚ąę ŌĄ in t..(t + őĶ), g ŌĄ := h_int_bound
    _ = őī / 2 := h_g_int
    _ < őī := by linarith

/-! #### Tier 6 ‚ÄĒ final assembly: `SqgFourierContinuous ‚Üí IsSqgCollarLhsCondition` -/

/-- **Tier 6 (main theorem of ¬ß10.22) ‚ÄĒ `SqgFourierContinuous` implies
`IsSqgCollarLhsCondition`.** Combines Tier 4's integral-split with Tier 5's
two collar-squeeze results to deliver the Phase 2.3.b bridge needed by
`IsSqgWeakSolution.of_IsSqgWeakSolutionTimeTest`. -/
theorem SqgFourierContinuous.toCollarLhsCondition
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hőł : SqgFourierContinuous őł) :
    IsSqgCollarLhsCondition őł := by
  intro m s t _hs hst
  have hF : Continuous (fun ŌĄ => mFourierCoeff (őł ŌĄ) m) := hőł m
  have h_split : ‚ąÄ őĶ > 0,
      (‚ąę ŌĄ, deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ
              * mFourierCoeff (őł ŌĄ) m)
        = (‚ąę ŌĄ in (s - őĶ)..s,
            deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ
              * mFourierCoeff (őł ŌĄ) m)
        + (‚ąę ŌĄ in t..(t + őĶ),
            deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ
              * mFourierCoeff (őł ŌĄ) m) :=
    fun őĶ hőĶ => sqgConcreteMollifier_integral_collar_split hőĶ hst hF
  have h_eq : (fun őĶ => ‚ąę ŌĄ,
      deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * mFourierCoeff (őł ŌĄ) m)
      =Š∂†[nhdsWithin 0 (Set.Ioi 0)]
      (fun őĶ => (‚ąę ŌĄ in (s - őĶ)..s,
          deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ * mFourierCoeff (őł ŌĄ) m)
        + (‚ąę ŌĄ in t..(t + őĶ),
            deriv (fun x => (sqgConcreteMollifier őĶ s t x : ‚Ąā)) ŌĄ
              * mFourierCoeff (őł ŌĄ) m)) := by
    filter_upwards [self_mem_nhdsWithin] with őĶ hőĶ
    exact h_split őĶ (Set.mem_Ioi.mp hőĶ)
  rw [show mFourierCoeff (őł s) m - mFourierCoeff (őł t) m
        = mFourierCoeff (őł s) m + (- mFourierCoeff (őł t) m) from by ring]
  exact (Filter.Tendsto.congr' h_eq.symm
          ((sqgConcreteMollifier_left_collar_tendsto hst hF).add
            (sqgConcreteMollifier_right_collar_tendsto hst hF)))

/-! ### ¬ß10.23 Duhamel witness + BKMCriterionS2 discharge for constant-in-time

This section delivers two building blocks and a capstone:

1. **Duhamel witness.** `IsSqgWeakSolution.const_zero_u`: the constant-in-time
   scalar field `őł(ŌĄ) = őł‚āÄ` paired with the zero velocity `u ‚Č° 0` satisfies
   the mode-wise Duhamel identity directly. Both sides vanish: LHS by
   `mFourierCoeff őł‚āÄ m ‚ąí mFourierCoeff őł‚āÄ m = 0`, RHS by
   `sqgNonlinearFlux őł‚āÄ 0 m = 0` (zero velocity kills every convolution
   component).

2. **BKMCriterionS2 discharge.** `BKMCriterionS2.of_const`: for a constant
   `őł‚āÄ`, every ŠłĘňĘ seminorm stays fixed at `hsSeminormSq s őł‚āÄ`, so the
   propagation hypothesis is discharged by `le_refl`.

3. **Capstone.** `sqg_regularity_const`: combines `MaterialMaxPrinciple.of_const`
   (contingent on `őł‚āÄ`'s ŠłĘ¬Ļ summability) with `BKMCriterionS2.of_const` and
   `sqg_regularity_via_s2_bootstrap` to certify that any constant-in-time
   `őł‚āÄ` with `Summable (fun n => (fracDerivSymbol 1 n)¬≤ * ‚ÄĖőłŐā‚āÄ(n)‚ÄĖ¬≤)`
   enjoys uniform ŠłĘňĘ bounds for every `s ‚ąą [0, 2]`.

Together these give the first **non-zero** concrete SQG solution class that
the conditional Theorem 3 chain certifies unconditionally. -/

/-- **Nonlinear flux with zero velocity vanishes.**

`sqgNonlinearFlux őł 0 m = 0` for every scalar `őł` and mode `m`. Each
component convolution has left factor `mFourierCoeff 0 ‚Ąď = 0`; the
convolution with the zero sequence on the left is zero by
`fourierConvolution_zero_left`. -/
theorem sqgNonlinearFlux_zero_u
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (m : Fin 2 ‚Üí ‚Ą§) :
    sqgNonlinearFlux őł
        (fun _ : Fin 2 =>
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) m = 0 := by
  unfold sqgNonlinearFlux
  apply Finset.sum_eq_zero
  intro j _
  have h :
      (fun ‚Ąď => mFourierCoeff
          ((fun _ : Fin 2 =>
            (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) j) ‚Ąď)
        = fun _ => (0 : ‚Ąā) := by
    funext ‚Ąď
    exact mFourierCoeff_zero ‚Ąď
  rw [h]
  exact fourierConvolution_zero_left _ m

/-- **Duhamel witness ‚ÄĒ constant-in-time őł, zero velocity is a weak solution.**
Both sides of the mode-wise Duhamel identity vanish: LHS by `sub_self`,
RHS because `sqgNonlinearFlux őł‚āÄ 0 m = 0` (from `sqgNonlinearFlux_zero_u`),
so the set integral is zero. -/
theorem IsSqgWeakSolution.const_zero_u
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    IsSqgWeakSolution
        (fun _ : ‚ĄĚ => őł‚āÄ)
        (fun _ : Fin 2 => fun _ : ‚ĄĚ =>
          (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) where
  duhamel := fun m s t _ _ => by
    -- Rewrite the integrand pointwise to 0 via `sqgNonlinearFlux_zero_u`.
    have h_integrand :
        (fun ŌĄ : ‚ĄĚ => sqgNonlinearFlux ((fun _ : ‚ĄĚ => őł‚āÄ) ŌĄ)
          (fun j => (fun _ : Fin 2 => fun _ : ‚ĄĚ =>
            (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) j ŌĄ) m)
        = fun _ => (0 : ‚Ąā) := by
      funext ŌĄ
      exact sqgNonlinearFlux_zero_u őł‚āÄ m
    rw [h_integrand]
    simp

/-- **MaterialMaxPrinciple for a constant-in-time scalar field.**
`őł(ŌĄ) = őł‚āÄ` with ŠłĘ¬Ļ-summable `őł‚āÄ` satisfies the ŠłĘ¬Ļ-propagation principle
with `M = hsSeminormSq 1 őł‚āÄ` (bound by itself). -/
theorem MaterialMaxPrinciple.of_const
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2)) :
    MaterialMaxPrinciple (fun _ : ‚ĄĚ => őł‚āÄ) where
  hOnePropagation := ‚ü®hsSeminormSq 1 őł‚āÄ, fun _ _ => le_refl _‚ü©
  hOneSummability := fun _ _ => hSumm
  freeDerivativeAtKappaMax := trivial
  materialSegmentExpansion := trivial
  farFieldBoundary := trivial

/-- **BKMCriterionS2 discharge for a constant-in-time scalar field.**
For a constant `őł‚āÄ`, `hsSeminormSq s (őł t) = hsSeminormSq s őł‚āÄ` for every
`t`, so the propagation hypothesis is closed by `le_refl`. No fractional
calculus needed. -/
theorem BKMCriterionS2.of_const
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    BKMCriterionS2 (fun _ : ‚ĄĚ => őł‚āÄ) where
  hsPropagationS2 := fun _ s _ _ =>
    ‚ü®hsSeminormSq s őł‚āÄ, fun _ _ => le_refl _‚ü©

/-- **Capstone ‚ÄĒ constant-in-time SQG solution is regular on `[0, 2]`.**

For any `őł‚āÄ ‚ąą Lp ‚Ąā 2 ūĚēč¬≤` with ŠłĘ¬Ļ summability, the constant-in-time
evolution `őł(ŌĄ) = őł‚āÄ` (paired with the zero velocity) enjoys uniform
ŠłĘňĘ bounds for every `s ‚ąą [0, 2]`. This is the first non-trivial
concrete discharge of conditional Theorem 3, layered over ¬ß10.22. -/
theorem sqg_regularity_const
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2)) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s ((fun _ : ‚ĄĚ => őł‚āÄ) t) ‚Č§ M :=
  sqg_regularity_via_s2_bootstrap
    (fun _ : ‚ĄĚ => őł‚āÄ)
    (MaterialMaxPrinciple.of_const őł‚āÄ hSumm)
    (BKMCriterionS2.of_const őł‚āÄ)

/-! ### ¬ß10.24 Scaled time-varying witness class

This section delivers the **first time-varying** discharge of the conditional
Theorem 3 chain. ¬ß10.23 closed the constant case `őł(ŌĄ) = őł‚āÄ`; here we allow

  `őł(ŌĄ) = c(ŌĄ) ‚ÄĘ őł‚āÄ`

with `c : ‚ĄĚ ‚Üí ‚Ąā` such that `‚ÄĖc(ŌĄ)‚ÄĖ ‚Č§ 1` for `ŌĄ ‚Č• 0`. This admits decay,
oscillation, and slow growth bounded by 1. It is *genuinely* time-varying:
no two distinct values of `c(ŌĄ)¬∑őł‚āÄ` agree as `Lp` elements when `őł‚āÄ ‚Č† 0`.

The mechanism is purely algebraic: scaling by `c(ŌĄ)` multiplies every Sobolev
seminorm by `‚ÄĖc(ŌĄ)‚ÄĖ¬≤ ‚Č§ 1`, so `MaterialMaxPrinciple` and `BKMCriterionS2`
are discharged by Sobolev-norm dominance against the initial-data bound.
The ŠłĘ¬Ļ-summability hypothesis on `őł‚āÄ` transfers across the scaling via
`Summable.mul_left`.

This class does *not* satisfy the SQG PDE in general ‚ÄĒ for that one needs
the velocity to be the Riesz transform of `őł`, which constrains the dynamics.
But `sqg_regularity_via_s2_bootstrap` is keyed only on `MaterialMaxPrinciple`
and `BKMCriterionS2`, both of which this class discharges abstractly. So
the regularity *conclusion* ‚ÄĒ uniform ŠłĘňĘ bounds for every `s ‚ąą [0, 2]` ‚ÄĒ
holds for the scaled class without invoking the Duhamel identity. -/

/-- **Fourier coefficient under scalar multiplication.** For `c : ‚Ąā` and
`f : Lp ‚Ąā 2 (ūĚēčŠĶą)`, scalar multiplication factors through `mFourierCoeff`:

  `mFourierCoeff (c ‚ÄĘ f) n = c * mFourierCoeff f n`.

Proof: rewrite the integrand using `Lp.coeFn_smul` (which gives the a.e.
equality `(c ‚ÄĘ f) t = c * f t`), then pull `c` out of the Bochner integral
via `integral_smul`. -/
theorem mFourierCoeff_const_smul
    {d : Type*} [Fintype d]
    (c : ‚Ąā) (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (n : d ‚Üí ‚Ą§) :
    mFourierCoeff (c ‚ÄĘ f : Lp ‚Ąā 2 _) n = c * mFourierCoeff f n := by
  unfold mFourierCoeff
  have h_ae :
      (fun t => mFourier (-n) t ‚ÄĘ ((c ‚ÄĘ f : Lp ‚Ąā 2 _) : UnitAddTorus d ‚Üí ‚Ąā) t)
        =ŠĶź[volume]
      (fun t => c ‚ÄĘ (mFourier (-n) t ‚ÄĘ (f : UnitAddTorus d ‚Üí ‚Ąā) t)) := by
    filter_upwards [Lp.coeFn_smul c f] with t ht
    simp only [ht, Pi.smul_apply, smul_eq_mul]
    ring
  rw [integral_congr_ae h_ae, integral_smul, smul_eq_mul]

/-- **ŠłĘňĘ seminorm under scalar multiplication.** Scalar multiplication
factors through every `hsSeminormSq` as `‚ÄĖc‚ÄĖ¬≤`:

  `hsSeminormSq s (c ‚ÄĘ f) = ‚ÄĖc‚ÄĖ¬≤ ¬∑ hsSeminormSq s f`.

Proof: per-mode, `‚ÄĖmFourierCoeff (c ‚ÄĘ f) n‚ÄĖ¬≤ = ‚ÄĖc‚ÄĖ¬≤ ¬∑ ‚ÄĖmFourierCoeff f n‚ÄĖ¬≤`
by `mFourierCoeff_const_smul` and `norm_mul`. Pull `‚ÄĖc‚ÄĖ¬≤` out of the `tsum`
via `tsum_mul_left`. -/
theorem hsSeminormSq_const_smul
    {d : Type*} [Fintype d] (s : ‚ĄĚ) (c : ‚Ąā)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) :
    hsSeminormSq s (c ‚ÄĘ f : Lp ‚Ąā 2 _) = ‚ÄĖc‚ÄĖ ^ 2 * hsSeminormSq s f := by
  unfold hsSeminormSq
  rw [‚Üź tsum_mul_left]
  apply tsum_congr
  intro n
  rw [mFourierCoeff_const_smul, norm_mul]
  ring

/-- **MaterialMaxPrinciple for the scaled class.** With `‚ÄĖc(ŌĄ)‚ÄĖ ‚Č§ 1` for
`ŌĄ ‚Č• 0` and ŠłĘ¬Ļ-summable `őł‚āÄ`, the family `őł(ŌĄ) := c(ŌĄ) ‚ÄĘ őł‚āÄ` satisfies
`MaterialMaxPrinciple` with the bound `M = hsSeminormSq 1 őł‚āÄ` (the initial
ŠłĘ¬Ļ seminorm).

The bound comes from `hsSeminormSq_const_smul` plus `‚ÄĖc(ŌĄ)‚ÄĖ¬≤ ‚Č§ 1`. The
ŠłĘ¬Ļ-summability hypothesis transfers via `Summable.mul_left ‚ÄĖc ŌĄ‚ÄĖ¬≤`. -/
theorem MaterialMaxPrinciple.of_scaled
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (c : ‚ĄĚ ‚Üí ‚Ąā)
    (hc : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖc ŌĄ‚ÄĖ ‚Č§ 1)
    (hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2)) :
    MaterialMaxPrinciple (fun ŌĄ : ‚ĄĚ => (c ŌĄ ‚ÄĘ őł‚āÄ : Lp ‚Ąā 2 _)) where
  hOnePropagation := by
    refine ‚ü®hsSeminormSq 1 őł‚āÄ, fun ŌĄ hŌĄ => ?_‚ü©
    rw [hsSeminormSq_const_smul]
    have h_norm_le_one : ‚ÄĖc ŌĄ‚ÄĖ ‚Č§ 1 := hc ŌĄ hŌĄ
    have h_norm_sq_le_one : ‚ÄĖc ŌĄ‚ÄĖ ^ 2 ‚Č§ 1 := by
      have h_nn : 0 ‚Č§ ‚ÄĖc ŌĄ‚ÄĖ := norm_nonneg _
      nlinarith [h_norm_le_one, h_nn]
    have h_sem_nn : 0 ‚Č§ hsSeminormSq 1 őł‚āÄ := by
      unfold hsSeminormSq
      exact tsum_nonneg (fun n => mul_nonneg (sq_nonneg _) (sq_nonneg _))
    calc ‚ÄĖc ŌĄ‚ÄĖ ^ 2 * hsSeminormSq 1 őł‚āÄ
        ‚Č§ 1 * hsSeminormSq 1 őł‚āÄ :=
            mul_le_mul_of_nonneg_right h_norm_sq_le_one h_sem_nn
      _ = hsSeminormSq 1 őł‚āÄ := one_mul _
  hOneSummability := fun ŌĄ _ => by
    have hcoeff : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
        (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff (c ŌĄ ‚ÄĘ őł‚āÄ : Lp ‚Ąā 2 _) n‚ÄĖ ^ 2
        = ‚ÄĖc ŌĄ‚ÄĖ ^ 2
            * ((fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2) := by
      intro n
      rw [mFourierCoeff_const_smul, norm_mul]
      ring
    have heq :
        (fun n : Fin 2 ‚Üí ‚Ą§ =>
          (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff (c ŌĄ ‚ÄĘ őł‚āÄ : Lp ‚Ąā 2 _) n‚ÄĖ ^ 2)
        = (fun n =>
            ‚ÄĖc ŌĄ‚ÄĖ ^ 2
              * ((fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2)) :=
      funext hcoeff
    rw [heq]
    exact hSumm.mul_left _
  freeDerivativeAtKappaMax := trivial
  materialSegmentExpansion := trivial
  farFieldBoundary := trivial

/-- **BKMCriterionS2 discharge for the scaled class.** With `‚ÄĖc(ŌĄ)‚ÄĖ ‚Č§ 1`
for `ŌĄ ‚Č• 0`, every ŠłĘňĘ seminorm of `őł(ŌĄ) = c(ŌĄ) ‚ÄĘ őł‚āÄ` is bounded by the
corresponding seminorm of `őł‚āÄ` via `hsSeminormSq_const_smul` and `‚ÄĖc(ŌĄ)‚ÄĖ¬≤ ‚Č§ 1`.
No fractional calculus needed ‚ÄĒ the bound passes through algebraic scaling. -/
theorem BKMCriterionS2.of_scaled
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (c : ‚ĄĚ ‚Üí ‚Ąā)
    (hc : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖc ŌĄ‚ÄĖ ‚Č§ 1) :
    BKMCriterionS2 (fun ŌĄ : ‚ĄĚ => (c ŌĄ ‚ÄĘ őł‚āÄ : Lp ‚Ąā 2 _)) where
  hsPropagationS2 := fun _M s _hs0 _hs2 => by
    refine ‚ü®hsSeminormSq s őł‚āÄ, fun ŌĄ hŌĄ => ?_‚ü©
    rw [hsSeminormSq_const_smul]
    have h_norm_le_one : ‚ÄĖc ŌĄ‚ÄĖ ‚Č§ 1 := hc ŌĄ hŌĄ
    have h_norm_sq_le_one : ‚ÄĖc ŌĄ‚ÄĖ ^ 2 ‚Č§ 1 := by
      have h_nn : 0 ‚Č§ ‚ÄĖc ŌĄ‚ÄĖ := norm_nonneg _
      nlinarith [h_norm_le_one, h_nn]
    have h_sem_nn : 0 ‚Č§ hsSeminormSq s őł‚āÄ := by
      unfold hsSeminormSq
      exact tsum_nonneg (fun n => mul_nonneg (sq_nonneg _) (sq_nonneg _))
    calc ‚ÄĖc ŌĄ‚ÄĖ ^ 2 * hsSeminormSq s őł‚āÄ
        ‚Č§ 1 * hsSeminormSq s őł‚āÄ :=
            mul_le_mul_of_nonneg_right h_norm_sq_le_one h_sem_nn
      _ = hsSeminormSq s őł‚āÄ := one_mul _

/-- **Capstone ‚ÄĒ scaled time-varying SQG family is regular on `[0, 2]`.**

For any `őł‚āÄ ‚ąą Lp ‚Ąā 2 (ūĚēč¬≤)` with ŠłĘ¬Ļ-summable Fourier data and any
`c : ‚ĄĚ ‚Üí ‚Ąā` with `‚ÄĖc(ŌĄ)‚ÄĖ ‚Č§ 1` for `ŌĄ ‚Č• 0`, the time-varying family

  `őł(ŌĄ) = c(ŌĄ) ‚ÄĘ őł‚āÄ`

enjoys uniform ŠłĘňĘ bounds for every `s ‚ąą [0, 2]`. This is the **first
time-evolving** concrete discharge of conditional Theorem 3 along the
`sqg_regularity_via_s2_bootstrap` chain.

Specializations:
- `c ‚Č° 1` recovers `sqg_regularity_const`.
- `c ŌĄ = exp(-őĽŌĄ)` for `őĽ ‚Č• 0` gives the decaying class.
- `c ŌĄ = exp(iŌČŌĄ)` for `ŌČ ‚ąą ‚ĄĚ` gives the unitary-rotation class
  (energy-conserving phase rotation in time). -/
theorem sqg_regularity_scaled
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (c : ‚ĄĚ ‚Üí ‚Ąā)
    (hc : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖc ŌĄ‚ÄĖ ‚Č§ 1)
    (hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2)) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
        hsSeminormSq s ((fun ŌĄ : ‚ĄĚ => (c ŌĄ ‚ÄĘ őł‚āÄ : Lp ‚Ąā 2 _)) t) ‚Č§ M :=
  sqg_regularity_via_s2_bootstrap
    (fun ŌĄ : ‚ĄĚ => (c ŌĄ ‚ÄĘ őł‚āÄ : Lp ‚Ąā 2 _))
    (MaterialMaxPrinciple.of_scaled őł‚āÄ c hc hSumm)
    (BKMCriterionS2.of_scaled őł‚āÄ c hc)

/-! ### ¬ß10.25 Finite-Fourier-support automatic summability

¬ß10.24 left the ŠłĘ¬Ļ-summability hypothesis on the user. This section
discharges it automatically whenever `őł‚āÄ` has **finite Fourier support**
‚ÄĒ i.e. its Fourier coefficients vanish outside some finite set
`S ‚äÜ ‚Ą§¬≤`. Trigonometric polynomials, single Fourier modes, and any
finite linear combination of `mFourierLp 2 n` fall in this class.

The mechanism: a function `f : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ` that vanishes outside
finite `S` is automatically summable (`summable_of_ne_finset_zero`).
For `őł‚āÄ` with `Fourier-supp őł‚āÄ ‚äÜ S`, the Sobolev seminorm series
`(fracDerivSymbol s n)¬≤ ¬∑ ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ¬≤` vanishes outside `S`
because `‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ¬≤ = 0` when `mFourierCoeff őł‚āÄ n = 0`.

This collapses the user-facing API of `sqg_regularity_scaled` to just:
the finite Fourier-support set `S`, the witness `hS` that coefficients
vanish outside `S`, the scalar `c`, and the boundedness hypothesis on
`c`. No summability assumption needed. -/

/-- **Finite Fourier support implies Sobolev seminorm summability.**
For any `s ‚Č• 0` (in fact any `s : ‚ĄĚ`) and any `őł‚āÄ : Lp ‚Ąā 2 (ūĚēč¬≤)` whose
Fourier coefficients vanish outside a finite set `S`, the series

  `(fracDerivSymbol s n)¬≤ ¬∑ ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ¬≤`

is summable. Proof: outside `S` the term is zero
(`‚ÄĖ0‚ÄĖ¬≤ ¬∑ anything = 0`), so `summable_of_ne_finset_zero` applies. -/
theorem hsSeminormSq_summable_of_finite_support
    (s : ‚ĄĚ)
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hS : ‚ąÄ n ‚ąČ S, mFourierCoeff őł‚āÄ n = 0) :
    Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł‚āÄ n‚ÄĖ ^ 2) := by
  apply summable_of_ne_finset_zero (s := S)
  intro n hn
  rw [hS n hn, norm_zero]
  ring

/-- **Capstone ‚ÄĒ scaled trig-polynomial class is regular on `[0, 2]`,
no summability hypothesis needed.**

For any `őł‚āÄ` with finite Fourier support `S ‚äÜ ‚Ą§¬≤` and any `c : ‚ĄĚ ‚Üí ‚Ąā`
with `‚ÄĖc(ŌĄ)‚ÄĖ ‚Č§ 1` for `ŌĄ ‚Č• 0`, the time-varying family

  `őł(ŌĄ) = c(ŌĄ) ‚ÄĘ őł‚āÄ`

enjoys uniform ŠłĘňĘ bounds for every `s ‚ąą [0, 2]` ‚ÄĒ *unconditionally*
in `őł‚āÄ`'s coefficients (no summability axiom remains). The ŠłĘ¬Ļ
summability hypothesis of `sqg_regularity_scaled` is discharged by
`hsSeminormSq_summable_of_finite_support`.

Concrete witness classes covered:
- Single Fourier mode: `őł‚āÄ = a ‚ÄĘ mFourierLp 2 m‚āÄ`, `S = {m‚āÄ}`.
- Finite Fourier sum: `őł‚āÄ = ‚ąĎ n ‚ąą S, a n ‚ÄĘ mFourierLp 2 n` for any
  finite `S` and complex coefficients `a`.
- Combined with any `c` of unit-bounded modulus (constant, decaying,
  oscillating, slowly growing). -/
theorem sqg_regularity_scaled_finiteSupport
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hS : ‚ąÄ n ‚ąČ S, mFourierCoeff őł‚āÄ n = 0)
    (c : ‚ĄĚ ‚Üí ‚Ąā)
    (hc : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖc ŌĄ‚ÄĖ ‚Č§ 1) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
        hsSeminormSq s ((fun ŌĄ : ‚ĄĚ => (c ŌĄ ‚ÄĘ őł‚āÄ : Lp ‚Ąā 2 _)) t) ‚Č§ M :=
  sqg_regularity_scaled őł‚āÄ c hc
    (hsSeminormSq_summable_of_finite_support 1 őł‚āÄ S hS)

/-! ### ¬ß10.26 Concrete trigonometric polynomial witness class

The earlier attempt at a general Finset-sum trigPoly result hit Lean's
auto-coercion elaborator: `Lp.coeFn_add` is only `=ŠĶź[őľ]`, not `rfl`,
so `‚ÜĎ‚ÜĎ(f + g)` and `‚ÜĎ‚ÜĎf + ‚ÜĎ‚ÜĎg` are propositionally distinct as
functions even though `mFourierCoeff` reads them identically (via
`integral_congr_ae`). Pattern-rewriting `mFourierCoeff_add` on the
post-`Finset.sum_insert` goal failed because Lean had distributed the
coercion inward.

The clean fix: promote `mFourierCoeff` (at a fixed mode `m`) to a
`LinearMap : Lp ‚Ąā 2 _ ‚Üí‚āó[‚Ąā] ‚Ąā`. Once we have this, `_root_.map_sum`,
`_root_.map_add`, and `_root_.map_zero` apply automatically without any
coercion friction. Building blocks:

- `mFourierCoeffLM m` ‚ÄĒ the `LinearMap` form. Linearity proved through
  `mFourierBasis.repr` (additive) and `mFourierCoeff_const_smul`.
- `mFourierCoeff_finset_sum` ‚ÄĒ corollary of `_root_.map_sum`.
- `mFourierCoeff_mFourierLp` ‚ÄĒ single basis element gives a Kronecker
  delta via `HilbertBasis.repr_self`.
- `singleMode m‚āÄ a := a ‚ÄĘ mFourierLp 2 m‚āÄ` ‚ÄĒ single Fourier mode.
- `trigPoly S a := ‚ąĎ n ‚ąą S, a n ‚ÄĘ mFourierLp 2 n` ‚ÄĒ concrete trig
  polynomial on `ūĚēč¬≤`.
- Closed-form Fourier coefficient identities for both, derived without
  relying on `Lp` coercion gymnastics. -/

/-- **Fourier coefficient at fixed mode is linear in the function.**
Linear-map form of `mFourierCoeff`, eligible for `_root_.map_sum`,
`_root_.map_add`, and `_root_.map_zero` automatically. -/
noncomputable def mFourierCoeffLM
    {d : Type*} [Fintype d] (m : d ‚Üí ‚Ą§) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)) ‚Üí‚āó[‚Ąā] ‚Ąā where
  toFun f := mFourierCoeff f m
  map_add' f g := by
    have h_fg : mFourierCoeff (f + g) m = mFourierBasis.repr (f + g) m :=
      (mFourierBasis_repr _ _).symm
    have h_f : mFourierCoeff f m = mFourierBasis.repr f m :=
      (mFourierBasis_repr _ _).symm
    have h_g : mFourierCoeff g m = mFourierBasis.repr g m :=
      (mFourierBasis_repr _ _).symm
    show mFourierCoeff (f + g) m = mFourierCoeff f m + mFourierCoeff g m
    rw [h_fg, h_f, h_g, map_add]
    rfl
  map_smul' c f := by
    show mFourierCoeff (c ‚ÄĘ f) m = c ‚ÄĘ mFourierCoeff f m
    rw [mFourierCoeff_const_smul, smul_eq_mul]

@[simp]
theorem mFourierCoeffLM_apply
    {d : Type*} [Fintype d] (m : d ‚Üí ‚Ą§)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) :
    mFourierCoeffLM m f = mFourierCoeff f m := rfl

/-- **Fourier coefficient of a finite sum is the finite sum of Fourier
coefficients.** Direct corollary of `_root_.map_sum` on
`mFourierCoeffLM`. The explicit `Lp` type annotation on the sum is
load-bearing: it forces Lean to elaborate the sum at `Lp` level (so
the coercion appears outside the sum, matching what
`mFourierCoeffLM`'s map_sum produces). Without it, Lean defaults to
distributing the coercion inside, and the patterns mismatch. -/
theorem mFourierCoeff_finset_sum
    {d : Type*} [Fintype d]
    {őĻ : Type*}
    (S : Finset őĻ)
    (f : őĻ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : d ‚Üí ‚Ą§) :
    mFourierCoeff
        ((‚ąĎ n ‚ąą S, f n :
          Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))) m
      = ‚ąĎ n ‚ąą S, mFourierCoeff (f n) m := by
  have h := _root_.map_sum (mFourierCoeffLM (d := d) m) f S
  simp only [mFourierCoeffLM_apply] at h
  exact h

/-- **Single basis element gives a Kronecker delta.**
`mFourierCoeff (mFourierLp 2 n) m = if m = n then 1 else 0`.

Proof: `mFourierBasis.repr (mFourierBasis n) = lp.single 2 n 1` by
`HilbertBasis.repr_self`. `coe_mFourierBasis` identifies
`mFourierBasis n` with `mFourierLp 2 n`. Evaluating the `lp.single`
at `m` returns the `Pi.single` Kronecker delta. -/
theorem mFourierCoeff_mFourierLp
    {d : Type*} [Fintype d] [DecidableEq (d ‚Üí ‚Ą§)]
    (n m : d ‚Üí ‚Ą§) :
    mFourierCoeff (mFourierLp 2 n :
        Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) m
      = if m = n then 1 else 0 := by
  rw [‚Üź mFourierBasis_repr,
      show (mFourierLp 2 n :
              Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
            = mFourierBasis (d := d) n from
        congrFun coe_mFourierBasis.symm n,
      HilbertBasis.repr_self, lp.single_apply, Pi.single_apply]

/-- **Single Fourier mode** with amplitude `a` at mode `m‚āÄ`. -/
noncomputable def singleMode (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  a ‚ÄĘ (mFourierLp 2 m‚āÄ : Lp ‚Ąā 2 _)

/-- **Closed-form Fourier coefficients of a single Fourier mode.** -/
theorem mFourierCoeff_singleMode
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (singleMode m‚āÄ a) m = if m = m‚āÄ then a else 0 := by
  unfold singleMode
  rw [mFourierCoeff_const_smul, mFourierCoeff_mFourierLp]
  split_ifs with h
  ¬∑ rw [mul_one]
  ¬∑ rw [mul_zero]

/-- **Single Fourier mode vanishes outside `{m‚āÄ}`.** -/
theorem mFourierCoeff_singleMode_eq_zero_of_ne
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚Č† m‚āÄ) :
    mFourierCoeff (singleMode m‚āÄ a) m = 0 := by
  rw [mFourierCoeff_singleMode, if_neg hm]

/-- **Capstone ‚ÄĒ scaled single-mode family is regular on `[0, 2]`,
no user verification needed.**

For any mode `m‚āÄ ‚ąą ‚Ą§¬≤`, amplitude `a : ‚Ąā`, and `c : ‚ĄĚ ‚Üí ‚Ąā` with
`‚ÄĖc(ŌĄ)‚ÄĖ ‚Č§ 1` for `ŌĄ ‚Č• 0`, the family `őł(ŌĄ) = c(ŌĄ) ‚ÄĘ singleMode m‚āÄ a`
enjoys uniform ŠłĘňĘ bounds for every `s ‚ąą [0, 2]`. The Fourier-support
hypothesis of `sqg_regularity_scaled_finiteSupport` is discharged by
`mFourierCoeff_singleMode_eq_zero_of_ne`.

Plug-and-play form: users supply only `m‚āÄ`, `a`, `c`, and `hc`. -/
theorem sqg_regularity_singleMode
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā)
    (c : ‚ĄĚ ‚Üí ‚Ąā)
    (hc : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖc ŌĄ‚ÄĖ ‚Č§ 1) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
        hsSeminormSq s ((fun ŌĄ : ‚ĄĚ =>
          (c ŌĄ ‚ÄĘ singleMode m‚āÄ a : Lp ‚Ąā 2 _)) t) ‚Č§ M :=
  sqg_regularity_scaled_finiteSupport (singleMode m‚āÄ a) {m‚āÄ}
    (fun n hn => by
      rw [Finset.notMem_singleton] at hn
      exact mFourierCoeff_singleMode_eq_zero_of_ne m‚āÄ a hn)
    c hc

/-- **Trigonometric polynomial on `ūĚēč¬≤` from finite Fourier data.**
`trigPoly S a := ‚ąĎ n ‚ąą S, a n ‚ÄĘ mFourierLp 2 n`. Concrete `Lp ‚Ąā 2`
element with prescribed Fourier coefficients on `S` and zero elsewhere. -/
noncomputable def trigPoly
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  ‚ąĎ n ‚ąą S, a n ‚ÄĘ (mFourierLp 2 n : Lp ‚Ąā 2 _)

/-- **Closed-form Fourier coefficients of a trigonometric polynomial.**
`mFourierCoeff (trigPoly S a) m = if m ‚ąą S then a m else 0`.

Proof: `mFourierCoeff_finset_sum` (via `_root_.map_sum` on the linear
form `mFourierCoeffLM`) reduces the LHS to a finite sum of scaled
Kronecker deltas, then `Finset.sum_ite_eq` collapses to the closed
form. -/
theorem mFourierCoeff_trigPoly
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (trigPoly S a) m = if m ‚ąą S then a m else 0 := by
  unfold trigPoly
  rw [mFourierCoeff_finset_sum]
  have h_terms : ‚ąÄ n ‚ąą S,
      mFourierCoeff (a n ‚ÄĘ (mFourierLp 2 n :
          Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) m
        = if m = n then a n else 0 := by
    intro n _
    rw [mFourierCoeff_const_smul, mFourierCoeff_mFourierLp]
    split_ifs with h
    ¬∑ rw [mul_one]
    ¬∑ rw [mul_zero]
  rw [Finset.sum_congr rfl h_terms]
  exact Finset.sum_ite_eq S m a

/-- **Trigonometric polynomial vanishes outside its support set.** -/
theorem mFourierCoeff_trigPoly_eq_zero_of_not_mem
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚ąČ S) :
    mFourierCoeff (trigPoly S a) m = 0 := by
  rw [mFourierCoeff_trigPoly, if_neg hm]

/-- **Capstone ‚ÄĒ scaled trig-polynomial class is regular on `[0, 2]`,
plug-and-play form.**

For any finite Fourier support `S ‚äÜ ‚Ą§¬≤`, any complex coefficients
`a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā`, and any `c : ‚ĄĚ ‚Üí ‚Ąā` with `‚ÄĖc(ŌĄ)‚ÄĖ ‚Č§ 1` for
`ŌĄ ‚Č• 0`, the family `őł(ŌĄ) = c(ŌĄ) ‚ÄĘ trigPoly S a` enjoys uniform ŠłĘňĘ
bounds for every `s ‚ąą [0, 2]`. The Fourier-support hypothesis is
automatic via `mFourierCoeff_trigPoly_eq_zero_of_not_mem`. -/
theorem sqg_regularity_trigPoly
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (c : ‚ĄĚ ‚Üí ‚Ąā)
    (hc : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖc ŌĄ‚ÄĖ ‚Č§ 1) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
        hsSeminormSq s ((fun ŌĄ : ‚ĄĚ =>
          (c ŌĄ ‚ÄĘ trigPoly S a : Lp ‚Ąā 2 _)) t) ‚Č§ M :=
  sqg_regularity_scaled_finiteSupport (trigPoly S a) S
    (fun n hn => mFourierCoeff_trigPoly_eq_zero_of_not_mem S a hn)
    c hc

/-! ### ¬ß10.27 Single-mode stationary SQG witness

First **non-trivial discharge** of `IsSqgWeakSolution` AND
`IsSqgVelocityComponent` simultaneously. Activates the Duhamel route
`SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP` for the first
time as a real instance, not just a theorem with no users.

**Construction.** For any nonzero mode `m‚āÄ : Fin 2 ‚Üí ‚Ą§` and amplitude
`a : ‚Ąā`:
- `őł(ŌĄ) = singleMode m‚āÄ a` (constant in time).
- `u_j(ŌĄ) = singleModeVelocity m‚āÄ a j := (sqgVelocitySymbol j m‚āÄ * a) ‚ÄĘ
  mFourierLp 2 m‚āÄ` ‚ÄĒ the j-th component of the Riesz-transform velocity
  at this mode.

**Why it is a stationary SQG solution.** Both őł and u_j are supported
at the single Fourier mode `m‚āÄ`. The convolution structure of
`sqgNonlinearFlux` then concentrates at mode `2m‚āÄ`, where the inner sum
`‚ąĎ‚Īľ sqgVelocitySymbol j m‚āÄ ¬∑ derivSymbol j m‚āÄ` vanishes by the
divergence-free identity `n ¬∑ u(n) = 0`. So the nonlinear flux is zero
**at every mode** ‚ÄĒ both the trivial-support modes and the
algebraic-cancellation mode.

**Discharges.** Constant-in-time SQG with the Riesz velocity at a
single Fourier mode satisfies:
- `IsSqgVelocityComponent` (Fourier-side definition matches by
  construction).
- `IsSqgWeakSolution` (Duhamel = ‚ąę 0 = 0 since flux ‚Č° 0).
- `MaterialMaxPrinciple` and `BKMCriterionS2` (constant in time +
  finite Fourier support, via ¬ß10.25).

The full chain via `sqg_regularity_via_s2_bootstrap` then concludes
uniform ŠłĘňĘ bounds on `[0, 2]`. -/

/-- **Riesz-transform velocity component for a single Fourier mode.**
The j-th component of the SQG velocity associated with
`singleMode m‚āÄ a`. Sits at the same Fourier mode `m‚āÄ` with amplitude
scaled by the velocity-symbol multiplier `sqgVelocitySymbol j m‚āÄ`. -/
noncomputable def singleModeVelocity (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) (j : Fin 2) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  (sqgVelocitySymbol j m‚āÄ * a) ‚ÄĘ (mFourierLp 2 m‚āÄ : Lp ‚Ąā 2 _)

/-- **Closed-form Fourier coefficients of the single-mode velocity.** -/
theorem mFourierCoeff_singleModeVelocity
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) (j : Fin 2) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (singleModeVelocity m‚āÄ a j) m
      = if m = m‚āÄ then sqgVelocitySymbol j m‚āÄ * a else 0 := by
  unfold singleModeVelocity
  rw [mFourierCoeff_const_smul, mFourierCoeff_mFourierLp]
  split_ifs with h
  ¬∑ rw [mul_one]
  ¬∑ rw [mul_zero]

/-- **Single-mode velocity satisfies `IsSqgVelocityComponent`.** -/
theorem isSqgVelocityComponent_singleMode
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) (j : Fin 2) :
    IsSqgVelocityComponent (singleMode m‚āÄ a) (singleModeVelocity m‚āÄ a j) j := by
  intro n
  rw [mFourierCoeff_singleModeVelocity, mFourierCoeff_singleMode]
  by_cases h : n = m‚āÄ
  ¬∑ rw [h, if_pos rfl, if_pos rfl]
  ¬∑ rw [if_neg h, if_neg h, mul_zero]

/-- **Divergence-free identity at a single mode.** Sum over coordinate
directions of `sqgVelocitySymbol j m‚āÄ ¬∑ derivSymbol j m‚āÄ` vanishes,
recovered from `sqgVelocitySymbol_divergence_free` with `z = 1`. -/
theorem sqgVelocitySymbol_mul_derivSymbol_sum_zero (m‚āÄ : Fin 2 ‚Üí ‚Ą§) :
    ‚ąĎ j : Fin 2, sqgVelocitySymbol j m‚āÄ * derivSymbol j m‚āÄ = 0 := by
  unfold derivSymbol
  rw [Fin.sum_univ_two]
  have h := sqgVelocitySymbol_divergence_free m‚āÄ 1
  simp only [mul_one] at h
  linear_combination Complex.I * h

/-- **Nonlinear flux of single-mode SQG vanishes everywhere.**

For `m ‚Č† 2 m‚āÄ`: the convolution support requires `‚Ąď = m‚āÄ` (from `√Ľ_j`)
and `m - ‚Ąď = m‚āÄ` (from `őłŐā`), forcing `m = 2 m‚āÄ`; otherwise the term
is zero. For `m = 2 m‚āÄ`: the inner sum over `j` reduces to
`a¬≤ ¬∑ ‚ąĎ‚Īľ sqgVelocitySymbol j m‚āÄ ¬∑ derivSymbol j m‚āÄ = 0` by the
divergence-free identity. -/
theorem sqgNonlinearFlux_singleMode_eq_zero
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    sqgNonlinearFlux (singleMode m‚āÄ a) (singleModeVelocity m‚āÄ a) m = 0 := by
  unfold sqgNonlinearFlux
  by_cases hm : m - m‚āÄ = m‚āÄ
  ¬∑ -- m - m‚āÄ = m‚āÄ: each convolution simplifies; sum over j vanishes by div-free.
    have h_inner : ‚ąÄ j : Fin 2,
        fourierConvolution
            (fun ‚Ąď => mFourierCoeff (singleModeVelocity m‚āÄ a j) ‚Ąď)
            (fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff (singleMode m‚āÄ a) ‚Ąď) m
          = (sqgVelocitySymbol j m‚āÄ * a) * (derivSymbol j m‚āÄ * a) := by
      intro j
      unfold fourierConvolution
      rw [tsum_eq_single m‚āÄ]
      ¬∑ simp [mFourierCoeff_singleModeVelocity, mFourierCoeff_singleMode, hm]
      ¬∑ intro ‚Ąď h‚Ąď
        simp [mFourierCoeff_singleModeVelocity, h‚Ąď]
    rw [Finset.sum_congr rfl (fun j _ => h_inner j)]
    have h_factor : ‚ąÄ j : Fin 2,
        (sqgVelocitySymbol j m‚āÄ * a) * (derivSymbol j m‚āÄ * a)
          = a * a * (sqgVelocitySymbol j m‚āÄ * derivSymbol j m‚āÄ) :=
      fun j => by ring
    rw [Finset.sum_congr rfl (fun j _ => h_factor j),
        ‚Üź Finset.mul_sum, sqgVelocitySymbol_mul_derivSymbol_sum_zero, mul_zero]
  ¬∑ -- m - m‚āÄ ‚Č† m‚āÄ: each convolution is zero (őłŐā(m - m‚āÄ) = 0).
    apply Finset.sum_eq_zero
    intro j _
    unfold fourierConvolution
    rw [tsum_eq_single m‚āÄ]
    ¬∑ simp [mFourierCoeff_singleModeVelocity, mFourierCoeff_singleMode, hm]
    ¬∑ intro ‚Ąď h‚Ąď
      simp [mFourierCoeff_singleModeVelocity, h‚Ąď]

/-- **`IsSqgWeakSolution` for the constant-in-time single-mode SQG.**
Duhamel reduces to `0 = ‚ąę 0 = 0`: LHS by `sub_self` (őł constant), RHS
by `sqgNonlinearFlux_singleMode_eq_zero`. -/
theorem isSqgWeakSolution_singleMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) :
    IsSqgWeakSolution
        (fun _ : ‚ĄĚ => singleMode m‚āÄ a)
        (fun (j : Fin 2) (_ : ‚ĄĚ) => singleModeVelocity m‚āÄ a j) where
  duhamel := fun m s t _ _ => by
    have h_integrand :
        (fun ŌĄ : ‚ĄĚ => sqgNonlinearFlux ((fun _ : ‚ĄĚ => singleMode m‚āÄ a) ŌĄ)
            (fun j : Fin 2 =>
              (fun (j : Fin 2) (_ : ‚ĄĚ) => singleModeVelocity m‚āÄ a j) j ŌĄ) m)
        = fun _ => (0 : ‚Ąā) := by
      funext ŌĄ
      exact sqgNonlinearFlux_singleMode_eq_zero m‚āÄ a m
    rw [h_integrand]
    simp

/-- **`SqgEvolutionAxioms` for constant-in-time single-mode SQG.**
- `l2Conservation`: trivial since őł is time-constant.
- `meanConservation`: trivial since őł is time-constant.
- `velocityIsRieszTransform`: discharged by `singleModeVelocity` and
  `isSqgVelocityComponent_singleMode`. -/
theorem sqgEvolutionAxioms_singleMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) :
    SqgEvolutionAxioms (fun _ : ‚ĄĚ => singleMode m‚āÄ a) where
  l2Conservation := fun _ _ => rfl
  meanConservation := fun _ _ => rfl
  velocityIsRieszTransform := fun j =>
    ‚ü®fun _ : ‚ĄĚ => singleModeVelocity m‚āÄ a j,
     fun _ : ‚ĄĚ => isSqgVelocityComponent_singleMode m‚āÄ a j‚ü©

/-! ### ¬ß10.28 `SqgEvolutionAxioms_strong` for constant-in-time single-mode SQG

Bundle the ¬ß10.27 witness into a named discharge of
`SqgEvolutionAxioms_strong` via `of_IsSqgWeakSolution_via_MMP`. This is
the first real instance of the route that consumes the four-tier
analytic stack `SqgEvolutionAxioms + MaterialMaxPrinciple + velocity
witness + IsSqgWeakSolution` and concludes the strengthened axioms.

Ingredients assembled:
- `sqgEvolutionAxioms_singleMode_const` ‚ÄĒ `SqgEvolutionAxioms`.
- `MaterialMaxPrinciple.of_const` ‚ÄĒ MMP holds pointwise for
  constant-in-time őł; the ŠłĘ¬Ļ summability hypothesis is discharged by
  `hsSeminormSq_summable_of_finite_support` (finite Fourier support).
- `singleModeVelocity` ‚ÄĒ the Riesz-transform velocity carrier.
- `isSqgVelocityComponent_singleMode` ‚ÄĒ velocity witness at every mode.
- `isSqgWeakSolution_singleMode_const` ‚ÄĒ the Duhamel identity from
  ¬ß10.27.

Routing these through `of_IsSqgWeakSolution_via_MMP` closes the
strengthened axioms with zero new content. This theorem is the
"single-mode capstone" for downstream regularity consumers. -/

theorem SqgEvolutionAxioms_strong.singleMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a : ‚Ąā) :
    SqgEvolutionAxioms_strong (fun _ : ‚ĄĚ => singleMode m‚āÄ a) := by
  have hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff (singleMode m‚āÄ a) n‚ÄĖ ^ 2) :=
    hsSeminormSq_summable_of_finite_support 1 (singleMode m‚āÄ a) {m‚āÄ}
      (fun n hn => by
        have hne : n ‚Č† m‚āÄ := fun h => hn (by simp [h])
        exact mFourierCoeff_singleMode_eq_zero_of_ne m‚āÄ a hne)
  exact SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP
    (sqgEvolutionAxioms_singleMode_const m‚āÄ a)
    (MaterialMaxPrinciple.of_const (singleMode m‚āÄ a) hSumm)
    (fun j _ => singleModeVelocity m‚āÄ a j)
    (fun j _ => isSqgVelocityComponent_singleMode m‚āÄ a j)
    (isSqgWeakSolution_singleMode_const m‚āÄ a)

/-! ### ¬ß10.29 Odd-symmetry helpers for antipodal constructions

Helper lemmas used by the antipodal-pair stationary SQG witness (¬ß10.30):
the basic symbols are **odd** in their lattice argument. These are
immediate consequences of the defining formulas but are worth carving
out as named identities for use in algebraic rewrites inside the
nonlinear-flux computation. -/

/-- **Lattice norm is even.** `latticeNorm (-n) = latticeNorm n` via
`(-n j)¬≤ = (n j)¬≤`. -/
lemma latticeNorm_neg {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    latticeNorm (-n) = latticeNorm n := by
  unfold latticeNorm
  congr 1
  refine Finset.sum_congr rfl (fun j _ => ?_)
  have : ((-n) j : ‚ĄĚ) = -((n j : ‚ĄĚ)) := by push_cast [Pi.neg_apply]; ring
  rw [this, neg_pow, show ((-1 : ‚ĄĚ)^2) = 1 from by norm_num, one_mul]

/-- **Riesz symbol is odd.** `rieszSymbol j (-n) = -rieszSymbol j n`. -/
lemma rieszSymbol_neg {d : Type*} [Fintype d] (j : d) (n : d ‚Üí ‚Ą§) :
    rieszSymbol j (-n) = -rieszSymbol j n := by
  by_cases hn : n = 0
  ¬∑ simp [rieszSymbol, hn]
  ¬∑ have hne : (-n) ‚Č† 0 := fun h => hn (neg_eq_zero.mp h)
    unfold rieszSymbol
    rw [if_neg hn, if_neg hne, latticeNorm_neg]
    have h1 : ((-n) j : ‚ĄĚ) = -((n j : ‚ĄĚ)) := by push_cast [Pi.neg_apply]; ring
    rw [h1]
    push_cast
    ring

/-- **SQG velocity symbol is odd.** -/
lemma sqgVelocitySymbol_neg (j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) :
    sqgVelocitySymbol j (-n) = -sqgVelocitySymbol j n := by
  unfold sqgVelocitySymbol
  split_ifs
  ¬∑ exact rieszSymbol_neg 1 n
  ¬∑ rw [rieszSymbol_neg 0 n, neg_neg]

/-- **Derivative symbol is odd.** -/
lemma derivSymbol_neg {d : Type*} [Fintype d] (j : d) (n : d ‚Üí ‚Ą§) :
    derivSymbol j (-n) = -derivSymbol j n := by
  unfold derivSymbol
  rw [Pi.neg_apply]
  push_cast
  ring

/-! ### ¬ß10.30 Antipodal-pair stationary SQG witness

First **multi-mode** stationary SQG solution. Takes a pair of antipodal
modes `{m‚āÄ, -m‚āÄ}` (requiring `m‚āÄ ‚Č† 0` to be genuinely two-mode) and
arbitrary complex amplitudes `a‚āĀ, a‚āā : ‚Ąā`:

- `őł = antipodalMode m‚āÄ a‚āĀ a‚āā := singleMode m‚āÄ a‚āĀ + singleMode (-m‚āÄ) a‚āā`
- `u_j = antipodalVelocity m‚āÄ a‚āĀ a‚āā j :=
    singleModeVelocity m‚āÄ a‚āĀ j + singleModeVelocity (-m‚āÄ) a‚āā j`

**Why stationary.** The nonlinear flux `‚ąĎ_j (√Ľ_j ‚ėÖ (‚ąā_j őłŐā))(m)`
concentrates only at `m ‚ąą {2m‚āÄ, 0, -2m‚āÄ}`. At each, the sum over j
vanishes by the divergence-free identity `‚ąĎ_j sqgVelocitySymbol j m‚āÄ ¬∑
derivSymbol j m‚āÄ = 0`, using odd-symmetry of `derivSymbol` and
`sqgVelocitySymbol` to reduce every algebraic case to that one sum.
Elsewhere, both `√Ľ_j` and `őłŐā(m ‚ąí ‚Ąď)` lack joint support, so every term
vanishes.

**Scope.** This is the first non-trivial Lean formalization of a
genuine multi-mode stationary SQG solution. It admits e.g. the
real-valued cosine mode (`a‚āā = conj a‚āĀ`) and sine mode (`a‚āā =
‚ąíconj a‚āĀ`) as special cases, plus any complex superposition. -/

/-- **Antipodal Fourier pair** `a‚āĀ ‚ÄĘ e_{m‚āÄ} + a‚āā ‚ÄĘ e_{‚ąím‚āÄ}`. -/
noncomputable def antipodalMode (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a‚āĀ a‚āā : ‚Ąā) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  singleMode m‚āÄ a‚āĀ + singleMode (-m‚āÄ) a‚āā

/-- From `m‚āÄ ‚Č† 0`, the antipodes differ: `m‚āÄ ‚Č† -m‚āÄ`. -/
lemma neg_ne_self_of_ne_zero {d : Type*} [Fintype d]
    {m‚āÄ : d ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) : m‚āÄ ‚Č† -m‚āÄ := by
  intro h
  apply hm‚āÄ
  funext i
  have hi : m‚āÄ i = -m‚āÄ i := congrFun h i
  have : 2 * m‚āÄ i = 0 := by linarith
  have : m‚āÄ i = 0 := by linarith
  simpa using this

/-- **Closed-form Fourier coefficients of the antipodal pair** (requires
`m‚āÄ ‚Č† 0` so that `m‚āÄ ‚Č† -m‚āÄ`). -/
theorem mFourierCoeff_antipodalMode
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) m
      = if m = m‚āÄ then a‚āĀ else if m = -m‚āÄ then a‚āā else 0 := by
  have h_ne : m‚āÄ ‚Č† -m‚āÄ := neg_ne_self_of_ne_zero hm‚āÄ
  have h_add : mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) m
      = mFourierCoeff (singleMode m‚āÄ a‚āĀ) m + mFourierCoeff (singleMode (-m‚āÄ) a‚āā) m := by
    unfold antipodalMode
    exact (mFourierCoeffLM m).map_add (singleMode m‚āÄ a‚āĀ) (singleMode (-m‚āÄ) a‚āā)
  rw [h_add, mFourierCoeff_singleMode, mFourierCoeff_singleMode]
  have h_ne' : (-m‚āÄ) ‚Č† m‚āÄ := fun h => h_ne h.symm
  by_cases h1 : m = m‚āÄ
  ¬∑ have h2 : m ‚Č† -m‚āÄ := fun hc => h_ne (h1.symm.trans hc)
    simp [h1, h2, h_ne]
  ¬∑ by_cases h2 : m = -m‚āÄ
    ¬∑ simp [h1, h2, h_ne']
    ¬∑ simp [h1, h2]

/-- **Antipodal pair vanishes outside `{m‚āÄ, -m‚āÄ}`.** -/
theorem mFourierCoeff_antipodalMode_eq_zero_of_not_mem
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā)
    {m : Fin 2 ‚Üí ‚Ą§} (h1 : m ‚Č† m‚āÄ) (h2 : m ‚Č† -m‚āÄ) :
    mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) m = 0 := by
  rw [mFourierCoeff_antipodalMode hm‚āÄ, if_neg h1, if_neg h2]

/-- **Riesz-transform velocity for the antipodal pair.** -/
noncomputable def antipodalVelocity
    (m‚āÄ : Fin 2 ‚Üí ‚Ą§) (a‚āĀ a‚āā : ‚Ąā) (j : Fin 2) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  singleModeVelocity m‚āÄ a‚āĀ j + singleModeVelocity (-m‚āÄ) a‚āā j

/-- **Closed-form Fourier coefficients of the antipodal velocity.** -/
theorem mFourierCoeff_antipodalVelocity
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā) (j : Fin 2) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (antipodalVelocity m‚āÄ a‚āĀ a‚āā j) m
      = if m = m‚āÄ then sqgVelocitySymbol j m‚āÄ * a‚āĀ
        else if m = -m‚āÄ then sqgVelocitySymbol j (-m‚āÄ) * a‚āā else 0 := by
  have h_ne : m‚āÄ ‚Č† -m‚āÄ := neg_ne_self_of_ne_zero hm‚āÄ
  have h_add : mFourierCoeff (antipodalVelocity m‚āÄ a‚āĀ a‚āā j) m
      = mFourierCoeff (singleModeVelocity m‚āÄ a‚āĀ j) m
        + mFourierCoeff (singleModeVelocity (-m‚āÄ) a‚āā j) m := by
    unfold antipodalVelocity
    exact (mFourierCoeffLM m).map_add
      (singleModeVelocity m‚āÄ a‚āĀ j) (singleModeVelocity (-m‚āÄ) a‚āā j)
  rw [h_add, mFourierCoeff_singleModeVelocity, mFourierCoeff_singleModeVelocity]
  have h_ne' : (-m‚āÄ) ‚Č† m‚āÄ := fun h => h_ne h.symm
  by_cases h1 : m = m‚āÄ
  ¬∑ have h2 : m ‚Č† -m‚āÄ := fun hc => h_ne (h1.symm.trans hc)
    simp [h1, h2, h_ne]
  ¬∑ by_cases h2 : m = -m‚āÄ
    ¬∑ simp [h1, h2, h_ne']
    ¬∑ simp [h1, h2]

/-- **Antipodal velocity satisfies `IsSqgVelocityComponent`.** -/
theorem isSqgVelocityComponent_antipodalMode
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā) (j : Fin 2) :
    IsSqgVelocityComponent
      (antipodalMode m‚āÄ a‚āĀ a‚āā) (antipodalVelocity m‚āÄ a‚āĀ a‚āā j) j := by
  intro n
  have h_ne' : (-m‚āÄ) ‚Č† m‚āÄ := fun h => neg_ne_self_of_ne_zero hm‚āÄ h.symm
  rw [mFourierCoeff_antipodalVelocity hm‚āÄ, mFourierCoeff_antipodalMode hm‚āÄ]
  by_cases h1 : n = m‚āÄ
  ¬∑ simp [h1]
  ¬∑ by_cases h2 : n = -m‚āÄ
    ¬∑ simp [h2, h_ne']
    ¬∑ simp [h1, h2]

/-- **Divergence-free at the antipodal mode.** A corollary of
`sqgVelocitySymbol_mul_derivSymbol_sum_zero` applied at `-m‚āÄ`, useful
for the `m = -2m‚āÄ` algebraic case. -/
lemma sqgVelocitySymbol_mul_derivSymbol_sum_zero_neg (m‚āÄ : Fin 2 ‚Üí ‚Ą§) :
    ‚ąĎ j : Fin 2, sqgVelocitySymbol j (-m‚āÄ) * derivSymbol j (-m‚āÄ) = 0 := by
  simp_rw [sqgVelocitySymbol_neg, derivSymbol_neg]
  have := sqgVelocitySymbol_mul_derivSymbol_sum_zero m‚āÄ
  calc ‚ąĎ j : Fin 2, -sqgVelocitySymbol j m‚āÄ * -derivSymbol j m‚āÄ
      = ‚ąĎ j : Fin 2, sqgVelocitySymbol j m‚āÄ * derivSymbol j m‚āÄ := by
        refine Finset.sum_congr rfl ?_; intro j _; ring
    _ = 0 := this

/-- **Cross div-free identity (őł mode flipped).**
`‚ąĎ_j sqgVelocitySymbol j m‚āÄ ¬∑ derivSymbol j (-m‚āÄ) = 0` via odd-symmetry
of `derivSymbol` and the base div-free identity. -/
lemma sqgVelocitySymbol_mul_derivSymbol_sum_zero_cross‚āĀ (m‚āÄ : Fin 2 ‚Üí ‚Ą§) :
    ‚ąĎ j : Fin 2, sqgVelocitySymbol j m‚āÄ * derivSymbol j (-m‚āÄ) = 0 := by
  have h := sqgVelocitySymbol_mul_derivSymbol_sum_zero m‚āÄ
  rw [Fin.sum_univ_two] at h ‚äĘ
  simp only [derivSymbol_neg] at *
  linear_combination -h

/-- **Cross div-free identity (u mode flipped).**
`‚ąĎ_j sqgVelocitySymbol j (-m‚āÄ) ¬∑ derivSymbol j m‚āÄ = 0` via odd-symmetry
of `sqgVelocitySymbol` and the base div-free identity. -/
lemma sqgVelocitySymbol_mul_derivSymbol_sum_zero_cross‚āā (m‚āÄ : Fin 2 ‚Üí ‚Ą§) :
    ‚ąĎ j : Fin 2, sqgVelocitySymbol j (-m‚āÄ) * derivSymbol j m‚āÄ = 0 := by
  have h := sqgVelocitySymbol_mul_derivSymbol_sum_zero m‚āÄ
  rw [Fin.sum_univ_two] at h ‚äĘ
  simp only [sqgVelocitySymbol_neg] at *
  linear_combination -h

/-- **Unified antipodal div-free identity.** For any pair
`(‚Ąď, k) ‚ąą {m‚āÄ, -m‚āÄ} √ó {m‚āÄ, -m‚āÄ}`, the j-sum
`‚ąĎ_j sqgVelocitySymbol j ‚Ąď ¬∑ derivSymbol j k` vanishes. Combines the
four specific identities above via 2√ó2 case split. -/
lemma sqgVelocitySymbol_mul_derivSymbol_sum_zero_antipodal_pair
    (m‚āÄ ‚Ąď k : Fin 2 ‚Üí ‚Ą§)
    (h‚Ąď : ‚Ąď = m‚āÄ ‚ą® ‚Ąď = -m‚āÄ) (hk : k = m‚āÄ ‚ą® k = -m‚āÄ) :
    ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k = 0 := by
  rcases h‚Ąď with h1 | h1
  ¬∑ rcases hk with h2 | h2
    ¬∑ rw [h1, h2]; exact sqgVelocitySymbol_mul_derivSymbol_sum_zero m‚āÄ
    ¬∑ rw [h1, h2]; exact sqgVelocitySymbol_mul_derivSymbol_sum_zero_cross‚āĀ m‚āÄ
  ¬∑ rcases hk with h2 | h2
    ¬∑ rw [h1, h2]; exact sqgVelocitySymbol_mul_derivSymbol_sum_zero_cross‚āā m‚āÄ
    ¬∑ rw [h1, h2]; exact sqgVelocitySymbol_mul_derivSymbol_sum_zero_neg m‚āÄ

/-- **Per-‚Ąď cancellation for the antipodal flux.** For each
‚Ąď ‚ąą {m‚āÄ, -m‚āÄ} and any target `m`, the sum over `j` of
`√Ľ_j(‚Ąď) ¬∑ derivSymbol j (m-‚Ąď) ¬∑ őłŐā(m-‚Ąď)` vanishes.

Mechanism: by `isSqgVelocityComponent_antipodalMode`, `√Ľ_j(‚Ąď) =
sqgVelocitySymbol j ‚Ąď ¬∑ őłŐā(‚Ąď)`. Each summand factors as `őłŐā(‚Ąď) ¬∑ őłŐā(m-‚Ąď)
¬∑ (sqgVelocitySymbol j ‚Ąď ¬∑ derivSymbol j (m-‚Ąď))`. Pull the `j`-
independent factor `őłŐā(‚Ąď) ¬∑ őłŐā(m-‚Ąď)` out of the sum. Then either
`m-‚Ąď ‚ąą {m‚āÄ, -m‚āÄ}` (kill via the unified antipodal div-free helper) or
`m-‚Ąď ‚ąČ {m‚āÄ, -m‚āÄ}` (kill via `őłŐā(m-‚Ąď) = 0`). -/
lemma antipodal_inner_sum_zero
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§)
    {‚Ąď : Fin 2 ‚Üí ‚Ą§} (h‚Ąď : ‚Ąď = m‚āÄ ‚ą® ‚Ąď = -m‚āÄ) :
    (‚ąĎ j : Fin 2,
        mFourierCoeff (antipodalVelocity m‚āÄ a‚āĀ a‚āā j) ‚Ąď
        * (derivSymbol j (m - ‚Ąď)
            * mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) (m - ‚Ąď))) = 0 := by
  -- Step 1: rewrite √Ľ_j(‚Ąď) = sqgVelocitySymbol j ‚Ąď ¬∑ őłŐā(‚Ąď) per j, then
  -- factor out the őłŐā scalars from the j-sum.
  have h_rewrite : ‚ąÄ j : Fin 2,
      mFourierCoeff (antipodalVelocity m‚āÄ a‚āĀ a‚āā j) ‚Ąď
        * (derivSymbol j (m - ‚Ąď)
            * mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) (m - ‚Ąď))
      = mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) ‚Ąď
        * mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) (m - ‚Ąď)
        * (sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
    intro j
    rw [isSqgVelocityComponent_antipodalMode hm‚āÄ a‚āĀ a‚āā j ‚Ąď]
    ring
  rw [Finset.sum_congr rfl (fun j _ => h_rewrite j), ‚Üź Finset.mul_sum]
  -- Step 2: case on whether m - ‚Ąď ‚ąą {m‚āÄ, -m‚āÄ}.
  by_cases hm‚Ąď : m - ‚Ąď = m‚āÄ ‚ą® m - ‚Ąď = -m‚āÄ
  ¬∑ -- Inner j-sum vanishes by the unified div-free helper.
    rw [sqgVelocitySymbol_mul_derivSymbol_sum_zero_antipodal_pair m‚āÄ ‚Ąď (m - ‚Ąď) h‚Ąď hm‚Ąď]
    ring
  ¬∑ -- őłŐā(m - ‚Ąď) = 0.
    push Not at hm‚Ąď
    rw [mFourierCoeff_antipodalMode_eq_zero_of_not_mem hm‚āÄ a‚āĀ a‚āā hm‚Ąď.1 hm‚Ąď.2]
    ring

/-- **Nonlinear flux of the antipodal-pair SQG vanishes everywhere.**

Reduce `‚ąĎ_j (√Ľ_j ‚ėÖ (‚ąā_j őłŐā))(m)` to a double sum: per `j`, the tsum
over ‚Ąď collapses to a finset sum on `{m‚āÄ, -m‚āÄ}` (support of `√Ľ_j`);
swap via `Finset.sum_comm`; each ‚Ąď-slice is zero by
`antipodal_inner_sum_zero`. -/
theorem sqgNonlinearFlux_antipodalMode_eq_zero
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    sqgNonlinearFlux (antipodalMode m‚āÄ a‚āĀ a‚āā)
      (antipodalVelocity m‚āÄ a‚āĀ a‚āā ¬∑) m = 0 := by
  unfold sqgNonlinearFlux
  have h_ne : m‚āÄ ‚Č† -m‚āÄ := neg_ne_self_of_ne_zero hm‚āÄ
  -- Step 1: reduce each inner tsum to a Finset.sum on {m‚āÄ, -m‚āÄ}.
  have h_tsum_eq_sum : ‚ąÄ j : Fin 2,
      fourierConvolution
          (fun ‚Ąď => mFourierCoeff (antipodalVelocity m‚āÄ a‚āĀ a‚āā j) ‚Ąď)
          (fun ‚Ąď => derivSymbol j ‚Ąď *
            mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) ‚Ąď) m
        = ‚ąĎ ‚Ąď ‚ąą ({m‚āÄ, -m‚āÄ} : Finset (Fin 2 ‚Üí ‚Ą§)),
            mFourierCoeff (antipodalVelocity m‚āÄ a‚āĀ a‚āā j) ‚Ąď
            * (derivSymbol j (m - ‚Ąď) *
               mFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) (m - ‚Ąď)) := by
    intro j
    unfold fourierConvolution
    apply tsum_eq_sum
    intro ‚Ąď h‚Ąď
    have h1 : ‚Ąď ‚Č† m‚āÄ := fun h => h‚Ąď (by simp [h])
    have h2 : ‚Ąď ‚Č† -m‚āÄ := fun h => h‚Ąď (by simp [h])
    simp only [mFourierCoeff_antipodalVelocity hm‚āÄ, if_neg h1, if_neg h2, zero_mul]
  rw [Finset.sum_congr rfl (fun j _ => h_tsum_eq_sum j)]
  -- Step 2: swap ‚ąĎ_j and ‚ąĎ_‚Ąď.
  rw [Finset.sum_comm]
  -- Step 3: each ‚Ąď-slice is zero.
  apply Finset.sum_eq_zero
  intro ‚Ąď h‚Ąď_mem
  have h‚Ąď : ‚Ąď = m‚āÄ ‚ą® ‚Ąď = -m‚āÄ := by
    rcases Finset.mem_insert.mp h‚Ąď_mem with h | h
    ¬∑ exact Or.inl h
    ¬∑ rw [Finset.mem_singleton] at h; exact Or.inr h
  exact antipodal_inner_sum_zero hm‚āÄ a‚āĀ a‚āā m h‚Ąď

/-! ### ¬ß10.31 Antipodal-pair stationary SQG weak-solution witness

With the flux theorem in hand, bundle the antipodal pair into:
- `IsSqgWeakSolution`: Duhamel = ‚ąę 0 = 0 (flux ‚Č° 0).
- `SqgEvolutionAxioms`: constant-in-time, Riesz velocity.
- `SqgEvolutionAxioms_strong.antipodalMode_const`: route through
  `of_IsSqgWeakSolution_via_MMP` ‚ÄĒ first **multi-mode** named
  discharge of the strong axioms. -/

/-- **IsSqgWeakSolution for the antipodal-pair stationary SQG.** -/
theorem isSqgWeakSolution_antipodalMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā) :
    IsSqgWeakSolution
        (fun _ : ‚ĄĚ => antipodalMode m‚āÄ a‚āĀ a‚āā)
        (fun (j : Fin 2) (_ : ‚ĄĚ) => antipodalVelocity m‚āÄ a‚āĀ a‚āā j) where
  duhamel := fun m s t _ _ => by
    have h_integrand :
        (fun ŌĄ : ‚ĄĚ => sqgNonlinearFlux
            ((fun _ : ‚ĄĚ => antipodalMode m‚āÄ a‚āĀ a‚āā) ŌĄ)
            (fun j : Fin 2 =>
              (fun (j : Fin 2) (_ : ‚ĄĚ) =>
                antipodalVelocity m‚āÄ a‚āĀ a‚āā j) j ŌĄ) m)
        = fun _ => (0 : ‚Ąā) := by
      funext ŌĄ
      exact sqgNonlinearFlux_antipodalMode_eq_zero hm‚āÄ a‚āĀ a‚āā m
    rw [h_integrand]
    simp

/-- **SqgEvolutionAxioms for the antipodal-pair stationary SQG.**
Constant-in-time trivialises l¬≤/mean conservation; velocity witness
via `isSqgVelocityComponent_antipodalMode`. -/
theorem sqgEvolutionAxioms_antipodalMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā) :
    SqgEvolutionAxioms (fun _ : ‚ĄĚ => antipodalMode m‚āÄ a‚āĀ a‚āā) where
  l2Conservation := fun _ _ => rfl
  meanConservation := fun _ _ => rfl
  velocityIsRieszTransform := fun j =>
    ‚ü®fun _ : ‚ĄĚ => antipodalVelocity m‚āÄ a‚āĀ a‚āā j,
     fun _ : ‚ĄĚ => isSqgVelocityComponent_antipodalMode hm‚āÄ a‚āĀ a‚āā j‚ü©

/-- **`SqgEvolutionAxioms_strong` for the antipodal pair.** First
**multi-mode** named discharge of the strong axioms. Routes the
antipodal-pair witness through `of_IsSqgWeakSolution_via_MMP`, with
MMP discharged by `MaterialMaxPrinciple.of_const` keyed on finite
Fourier support `{m‚āÄ, -m‚āÄ}`. -/
theorem SqgEvolutionAxioms_strong.antipodalMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {m‚āÄ : Fin 2 ‚Üí ‚Ą§} (hm‚āÄ : m‚āÄ ‚Č† 0) (a‚āĀ a‚āā : ‚Ąā) :
    SqgEvolutionAxioms_strong (fun _ : ‚ĄĚ => antipodalMode m‚āÄ a‚āĀ a‚āā) := by
  have hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 *
        ‚ÄĖmFourierCoeff (antipodalMode m‚āÄ a‚āĀ a‚āā) n‚ÄĖ ^ 2) :=
    hsSeminormSq_summable_of_finite_support 1 (antipodalMode m‚āÄ a‚āĀ a‚āā)
      {m‚āÄ, -m‚āÄ}
      (fun n hn => by
        have h1 : n ‚Č† m‚āÄ := fun h => hn (by simp [h])
        have h2 : n ‚Č† -m‚āÄ := fun h => hn (by simp [h])
        exact mFourierCoeff_antipodalMode_eq_zero_of_not_mem hm‚āÄ a‚āĀ a‚āā h1 h2)
  exact SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP
    (sqgEvolutionAxioms_antipodalMode_const hm‚āÄ a‚āĀ a‚āā)
    (MaterialMaxPrinciple.of_const (antipodalMode m‚āÄ a‚āĀ a‚āā) hSumm)
    (fun j _ => antipodalVelocity m‚āÄ a‚āĀ a‚āā j)
    (fun j _ => isSqgVelocityComponent_antipodalMode hm‚āÄ a‚āĀ a‚āā j)
    (isSqgWeakSolution_antipodalMode_const hm‚āÄ a‚āĀ a‚āā)

/-! ### ¬ß10.32 Radial-shell pair-sum cross div-free identity

Generalises the four div-free identities used in ¬ß10.30 (`{m‚āÄ, ¬Īm‚āÄ}`
√ó  `{m‚āÄ, ¬Īm‚āÄ}`) to any pair `(‚Ąď, k)` on a common radial shell
`latticeNorm ‚Ąď = latticeNorm k`. The per-pair identity
`C(‚Ąď, k) + C(k, ‚Ąď) = 0` (where `C(p, q) := ‚ąĎ_j sqgVelocitySymbol j p *
derivSymbol j q`) is the core algebraic fact behind the radial-shell
stationary SQG witness built in ¬ß10.33‚Äď¬ß10.34.

**Mechanism.** For `‚Ąď, k ‚Č† 0` in `‚Ą§¬≤`:
`C(‚Ąď, k) = (‚Ąď‚āĀk‚āÄ ‚ąí ‚Ąď‚āÄk‚āĀ) / |‚Ąď|` (2D cross product, after `-I¬∑I = 1`).
Symmetrically `C(k, ‚Ąď) = (k‚āĀ‚Ąď‚āÄ ‚ąí k‚āÄ‚Ąď‚āĀ) / |k| = ‚ąí(‚Ąď‚āĀk‚āÄ ‚ąí ‚Ąď‚āÄk‚āĀ) / |k|`.
Sum: `(‚Ąď‚āĀk‚āÄ ‚ąí ‚Ąď‚āÄk‚āĀ) ¬∑ (1/|‚Ąď| ‚ąí 1/|k|) = 0` when `|‚Ąď| = |k|`. The `‚Ąď = 0`
or `k = 0` case is trivial because either `sqgVelocitySymbol` or
`derivSymbol` vanishes at `0`. -/

/-- **Per-‚Ąď closed form of the inner j-sum** (‚Ąď ‚Č† 0). For any `k`, the
sum `‚ąĎ_j sqgVelocitySymbol j ‚Ąď ¬∑ derivSymbol j k` equals
`((‚Ąď‚āĀk‚āÄ ‚ąí ‚Ąď‚āÄk‚āĀ : ‚ĄĚ) : ‚Ąā) / ((latticeNorm ‚Ąď : ‚ĄĚ) : ‚Ąā)`.

Immediate computation: unfold the two symbols via
`rieszSymbol_of_ne_zero`, use `-I¬∑I = 1` and `I¬∑I = -1` for the two
j-values, factor out `1/|‚Ąď|`. -/
lemma sum_sqgVelocitySymbol_mul_derivSymbol_of_ne_zero
    (‚Ąď k : Fin 2 ‚Üí ‚Ą§) (h‚Ąď : ‚Ąď ‚Č† 0) :
    (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k)
      = (((‚Ąď 1 : ‚ĄĚ) * (k 0 : ‚ĄĚ) - (‚Ąď 0 : ‚ĄĚ) * (k 1 : ‚ĄĚ) : ‚ĄĚ) : ‚Ąā)
        / ((latticeNorm ‚Ąď : ‚ĄĚ) : ‚Ąā) := by
  have hLne : ((latticeNorm ‚Ąď : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    have := latticeNorm_pos h‚Ąď
    exact_mod_cast ne_of_gt this
  have hI : Complex.I * Complex.I = -1 := by
    rw [‚Üź sq]; exact Complex.I_sq
  rw [Fin.sum_univ_two]
  -- Unfold sqgVelocitySymbol at 0 and 1.
  have hsv0 : sqgVelocitySymbol 0 ‚Ąď = rieszSymbol 1 ‚Ąď := by
    unfold sqgVelocitySymbol; simp
  have h10 : (1 : Fin 2) ‚Č† 0 := by decide
  have hsv1 : sqgVelocitySymbol 1 ‚Ąď = -rieszSymbol 0 ‚Ąď := by
    unfold sqgVelocitySymbol; rw [if_neg h10]
  rw [hsv0, hsv1]
  rw [rieszSymbol_of_ne_zero h‚Ąď (j := 1),
      rieszSymbol_of_ne_zero h‚Ąď (j := 0)]
  unfold derivSymbol
  field_simp
  push_cast
  linear_combination
    ((‚Ąď 0 : ‚Ąā) * (k 1 : ‚Ąā) - (‚Ąď 1 : ‚Ąā) * (k 0 : ‚Ąā)) * hI

/-- **Pair-sum cross div-free identity on a common radial shell.**
For any ‚Ąď, k ‚ąą ‚Ą§¬≤ with `latticeNorm ‚Ąď = latticeNorm k`:
`(‚ąĎ_j sqgVel j ‚Ąď ¬∑ ‚ąā_j k) + (‚ąĎ_j sqgVel j k ¬∑ ‚ąā_j ‚Ąď) = 0`.

Base case `‚Ąď = k` gives `2 ¬∑ sqgVelocitySymbol_mul_derivSymbol_sum_zero`,
but the same algebraic identity holds for *any* pair on the shell.
Proof: reduce each sum to the closed form via
`sum_sqgVelocitySymbol_mul_derivSymbol_of_ne_zero`, match denominators
using `|‚Ąď| = |k|`, then observe the numerators are anti-symmetric:
`(‚Ąď‚āĀk‚āÄ ‚ąí ‚Ąď‚āÄk‚āĀ) + (k‚āĀ‚Ąď‚āÄ ‚ąí k‚āÄ‚Ąď‚āĀ) = 0`. -/
lemma sqgVelocitySymbol_mul_derivSymbol_pair_sum_zero_of_latticeNorm_eq
    (‚Ąď k : Fin 2 ‚Üí ‚Ą§) (hnorm : latticeNorm ‚Ąď = latticeNorm k) :
    (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k)
      + (‚ąĎ j : Fin 2, sqgVelocitySymbol j k * derivSymbol j ‚Ąď) = 0 := by
  by_cases h‚Ąď : ‚Ąď = 0
  ¬∑ subst h‚Ąď
    have hk : k = 0 := by
      have h0 : latticeNorm (0 : Fin 2 ‚Üí ‚Ą§) = 0 := by
        rw [(latticeNorm_eq_zero_iff _).mpr rfl]
      rw [h0] at hnorm
      exact (latticeNorm_eq_zero_iff k).mp hnorm.symm
    subst hk
    simp [sqgVelocitySymbol_zero, derivSymbol_zero]
  by_cases hk : k = 0
  ¬∑ subst hk
    simp [sqgVelocitySymbol_zero, derivSymbol_zero]
  -- Both ‚Ąď, k ‚Č† 0, and |‚Ąď| = |k|.
  rw [sum_sqgVelocitySymbol_mul_derivSymbol_of_ne_zero _ _ h‚Ąď,
      sum_sqgVelocitySymbol_mul_derivSymbol_of_ne_zero _ _ hk]
  have hnormC : ((latticeNorm ‚Ąď : ‚ĄĚ) : ‚Ąā) = ((latticeNorm k : ‚ĄĚ) : ‚Ąā) := by
    exact_mod_cast hnorm
  have hLne : ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    have := latticeNorm_pos hk
    exact_mod_cast ne_of_gt this
  rw [hnormC]
  field_simp
  push_cast
  ring

/-! ### ¬ß10.33 Radial-shell stationary SQG witness

Generalises ¬ß10.30's antipodal-pair construction `S = {m‚āÄ, -m‚āÄ}` to
any finite `S ‚äÜ ‚Ą§¬≤ \ {0}` with constant `latticeNorm` ("radial
shell"). The witness chain:

* `shellMode S a := trigPoly S a` ‚ÄĒ shell-supported őł.
* `shellVelocity S a j := trigPoly S (sqgVelocitySymbol j ¬∑ a)` ‚ÄĒ
  Riesz-transform velocity at the shell.
* `isSqgVelocityComponent_shellMode` ‚ÄĒ mode-by-mode velocity witness.
* `sqgNonlinearFlux_shellMode_eq_zero` ‚ÄĒ flux vanishes everywhere.

**Cancellation mechanism (for the flux).**
Reduce `‚ąĎ_j ‚ąĎ'_‚Ąď √Ľ_j(‚Ąď) ¬∑ ‚ąā_j(m-‚Ąď) ¬∑ őłŐā(m-‚Ąď)` to a finite sum over
`{‚Ąď ‚ąą S : m - ‚Ąď ‚ąą S}` (both `√Ľ_j` and `őłŐā(m-‚Ąď)` force ‚Ąď and m-‚Ąď in S).
Factor each ‚Ąď-slice through `IsSqgVelocityComponent`:
`a(‚Ąď) ¬∑ a(m-‚Ąď) ¬∑ C(‚Ąď, m-‚Ąď)`. Apply `Finset.sum_involution` with
`ŌÉ(‚Ąď) := m - ‚Ąď`:
* Fixed point (m = 2‚Ąď): `a(‚Ąď)¬≤ ¬∑ C(‚Ąď, ‚Ąď) = 0` via base div-free.
* Paired: `a(‚Ąď)¬∑a(m-‚Ąď) ¬∑ [C(‚Ąď, m-‚Ąď) + C(m-‚Ąď, ‚Ąď)] = 0` via ¬ß10.32's
  `sqgVelocitySymbol_mul_derivSymbol_pair_sum_zero_of_latticeNorm_eq`,
  with `|‚Ąď| = |m-‚Ąď|` from the radial-shell hypothesis. -/

/-- **Radial-shell predicate.** All modes in `S` are nonzero and share
a common `latticeNorm`. Equivalently, `S` lies on one integer-lattice
Euclidean sphere. -/
def IsRadialShell (S : Finset (Fin 2 ‚Üí ‚Ą§)) : Prop :=
  (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S ‚ąß
    ‚ąÄ m ‚ąą S, ‚ąÄ n ‚ąą S, latticeNorm m = latticeNorm n

/-- **Shell-mode őł from finite radial support.** A rename of
`trigPoly` for downstream clarity. -/
noncomputable def shellMode
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  trigPoly S a

/-- **Shell-velocity u_j from finite radial support.** `trigPoly` with
each Fourier amplitude weighted by `sqgVelocitySymbol j n`. -/
noncomputable def shellVelocity
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (j : Fin 2) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  trigPoly S (fun n => sqgVelocitySymbol j n * a n)

/-- Closed-form Fourier coefficients of `shellMode`. -/
theorem mFourierCoeff_shellMode
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (shellMode S a) m = if m ‚ąą S then a m else 0 :=
  mFourierCoeff_trigPoly S a m

/-- Closed-form Fourier coefficients of `shellVelocity`. -/
theorem mFourierCoeff_shellVelocity
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (j : Fin 2) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (shellVelocity S a j) m
      = if m ‚ąą S then sqgVelocitySymbol j m * a m else 0 :=
  mFourierCoeff_trigPoly S _ m

/-- `shellMode` vanishes outside its Fourier support. -/
theorem mFourierCoeff_shellMode_eq_zero_of_not_mem
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚ąČ S) :
    mFourierCoeff (shellMode S a) m = 0 := by
  rw [mFourierCoeff_shellMode, if_neg hm]

/-- `shellVelocity` realises the SQG Riesz-transform velocity of
`shellMode`: at every mode, its Fourier coefficient is
`sqgVelocitySymbol j n * mFourierCoeff (shellMode S a) n`. -/
theorem isSqgVelocityComponent_shellMode
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (j : Fin 2) :
    IsSqgVelocityComponent (shellMode S a) (shellVelocity S a j) j := by
  intro n
  rw [mFourierCoeff_shellVelocity, mFourierCoeff_shellMode]
  by_cases hn : n ‚ąą S
  ¬∑ rw [if_pos hn, if_pos hn]
  ¬∑ rw [if_neg hn, if_neg hn, mul_zero]

/-- **Radial-shell nonlinear flux vanishes everywhere.** This is the
core stationarity of `shellMode` paired with its Riesz velocity. -/
theorem sqgNonlinearFlux_shellMode_eq_zero
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    sqgNonlinearFlux (shellMode S a) (shellVelocity S a ¬∑) m = 0 := by
  unfold sqgNonlinearFlux
  -- Step 1: reduce each inner tsum to a Finset.sum on S.
  have h_tsum_eq : ‚ąÄ j : Fin 2,
      fourierConvolution
          (fun ‚Ąď => mFourierCoeff (shellVelocity S a j) ‚Ąď)
          (fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff (shellMode S a) ‚Ąď) m
        = ‚ąĎ ‚Ąď ‚ąą S,
            mFourierCoeff (shellVelocity S a j) ‚Ąď
              * (derivSymbol j (m - ‚Ąď)
                 * mFourierCoeff (shellMode S a) (m - ‚Ąď)) := by
    intro j
    unfold fourierConvolution
    apply tsum_eq_sum
    intro ‚Ąď h‚Ąď
    simp only [mFourierCoeff_shellVelocity, if_neg h‚Ąď, zero_mul]
  rw [Finset.sum_congr rfl (fun j _ => h_tsum_eq j)]
  -- Step 2: swap the j and ‚Ąď sums.
  rw [Finset.sum_comm]
  -- Step 3: factor each ‚Ąď-slice through IsSqgVelocityComponent.
  have h_factor : ‚ąÄ ‚Ąď ‚ąą S,
      (‚ąĎ j : Fin 2,
        mFourierCoeff (shellVelocity S a j) ‚Ąď
          * (derivSymbol j (m - ‚Ąď) * mFourierCoeff (shellMode S a) (m - ‚Ąď)))
        = a ‚Ąď * mFourierCoeff (shellMode S a) (m - ‚Ąď)
            * (‚ąĎ j : Fin 2,
                sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
    intros ‚Ąď h‚Ąď
    have h_each : ‚ąÄ j : Fin 2,
        mFourierCoeff (shellVelocity S a j) ‚Ąď
          * (derivSymbol j (m - ‚Ąď) * mFourierCoeff (shellMode S a) (m - ‚Ąď))
          = a ‚Ąď * mFourierCoeff (shellMode S a) (m - ‚Ąď)
              * (sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
      intro j
      rw [mFourierCoeff_shellVelocity, if_pos h‚Ąď]
      ring
    rw [Finset.sum_congr rfl (fun j _ => h_each j), ‚Üź Finset.mul_sum]
  rw [Finset.sum_congr rfl h_factor]
  -- Step 4: rewrite each summand with `mFourierCoeff_shellMode` explicit,
  -- then collapse to the filter `T := {‚Ąď ‚ąą S : m - ‚Ąď ‚ąą S}` via
  -- `Finset.sum_filter`.
  have h_rewrite : ‚ąÄ ‚Ąď ‚ąą S,
      a ‚Ąď * mFourierCoeff (shellMode S a) (m - ‚Ąď)
        * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
        = if m - ‚Ąď ‚ąą S then
            a ‚Ąď * a (m - ‚Ąď)
              * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
          else 0 := by
    intros ‚Ąď _
    rw [mFourierCoeff_shellMode]
    split_ifs with h
    ¬∑ rfl
    ¬∑ rw [mul_zero, zero_mul]
  rw [Finset.sum_congr rfl h_rewrite]
  rw [‚Üź Finset.sum_filter]
  -- Step 5: apply `Finset.sum_involution` with ŌÉ(‚Ąď) = m - ‚Ąď on the filter.
  apply Finset.sum_involution (fun ‚Ąď _ => m - ‚Ąď)
  ¬∑ -- hg‚āĀ: f ‚Ąď + f (ŌÉ ‚Ąď) = 0
    intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď
    obtain ‚ü®h‚Ąď_S, hm‚Ąď_S‚ü© := h‚Ąď
    have hnorm_eq : latticeNorm ‚Ąď = latticeNorm (m - ‚Ąď) :=
      hS.2 ‚Ąď h‚Ąď_S (m - ‚Ąď) hm‚Ąď_S
    have h_pair :=
      sqgVelocitySymbol_mul_derivSymbol_pair_sum_zero_of_latticeNorm_eq
        ‚Ąď (m - ‚Ąď) hnorm_eq
    have h_sub : m - (m - ‚Ąď) = ‚Ąď := sub_sub_cancel m ‚Ąď
    rw [h_sub]
    have hring :
        a ‚Ąď * a (m - ‚Ąď)
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
          + a (m - ‚Ąď) * a ‚Ąď
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j (m - ‚Ąď) * derivSymbol j ‚Ąď)
          = a ‚Ąď * a (m - ‚Ąď)
            * ((‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
               + (‚ąĎ j : Fin 2, sqgVelocitySymbol j (m - ‚Ąď) * derivSymbol j ‚Ąď))
          := by ring
    rw [hring, h_pair, mul_zero]
  ¬∑ -- hg‚āÉ: f ‚Ąď ‚Č† 0 ‚Üí ŌÉ ‚Ąď ‚Č† ‚Ąď (equivalently, fixed point ‚áí f = 0)
    intros ‚Ąď h‚Ąď hne h_eq
    apply hne
    -- h_eq : m - ‚Ąď = ‚Ąď ‚áí m = 2‚Ąď; summand reduces to a(‚Ąď)¬≤¬∑C(‚Ąď,‚Ąď) = 0.
    rw [h_eq, sqgVelocitySymbol_mul_derivSymbol_sum_zero, mul_zero]
  ¬∑ -- g_mem: ŌÉ ‚Ąď ‚ąą filter
    intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď ‚äĘ
    obtain ‚ü®h‚Ąď_S, hm‚Ąď_S‚ü© := h‚Ąď
    refine ‚ü®hm‚Ąď_S, ?_‚ü©
    rw [sub_sub_cancel]
    exact h‚Ąď_S
  ¬∑ -- hg‚āĄ: ŌÉ ‚ąė ŌÉ = id
    intros ‚Ąď _
    exact sub_sub_cancel m ‚Ąď

/-! ### ¬ß10.34 Radial-shell stationary SQG weak-solution + axiom promotions

Bundle ¬ß10.33's `shellMode` / `shellVelocity` / flux = 0 into:

* `IsSqgWeakSolution.shellMode_const` ‚ÄĒ Duhamel identity is
  `‚ąę 0 = 0` since the flux vanishes.
* `sqgEvolutionAxioms_shellMode_const` ‚ÄĒ constant-in-time trivially
  satisfies L¬≤ and mean conservation; velocity witness via
  `isSqgVelocityComponent_shellMode`.
* `SqgEvolutionAxioms_strong.shellMode_const` ‚ÄĒ multi-mode discharge
  of the strong axioms via `of_IsSqgWeakSolution_via_MMP`, keyed on
  finite Fourier support through `MaterialMaxPrinciple.of_const`.

Covers ¬ß10.27 (`m‚āÄ`), ¬ß10.28 (`singleMode`), ¬ß10.31
(`antipodalMode`) as special cases and extends to any finite
radial shell. -/

/-- **`IsSqgWeakSolution` for constant-in-time radial-shell őł.**
Duhamel identity is immediate since the flux vanishes everywhere
(¬ß10.33). -/
theorem isSqgWeakSolution_shellMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    IsSqgWeakSolution
        (fun _ : ‚ĄĚ => shellMode S a)
        (fun (j : Fin 2) (_ : ‚ĄĚ) => shellVelocity S a j) where
  duhamel := fun m s t _ _ => by
    have h_integrand :
        (fun ŌĄ : ‚ĄĚ => sqgNonlinearFlux
            ((fun _ : ‚ĄĚ => shellMode S a) ŌĄ)
            (fun j : Fin 2 =>
              (fun (j : Fin 2) (_ : ‚ĄĚ) => shellVelocity S a j) j ŌĄ) m)
          = fun _ => (0 : ‚Ąā) := by
      funext ŌĄ
      exact sqgNonlinearFlux_shellMode_eq_zero hS a m
    rw [h_integrand]
    simp

/-- **`SqgEvolutionAxioms` for constant-in-time radial-shell őł.** -/
theorem sqgEvolutionAxioms_shellMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    SqgEvolutionAxioms (fun _ : ‚ĄĚ => shellMode S a) where
  l2Conservation := fun _ _ => rfl
  meanConservation := fun _ _ => rfl
  velocityIsRieszTransform := fun j =>
    ‚ü®fun _ : ‚ĄĚ => shellVelocity S a j,
     fun _ : ‚ĄĚ => isSqgVelocityComponent_shellMode S a j‚ü©

/-- **`SqgEvolutionAxioms_strong.shellMode_const`** ‚ÄĒ multi-mode
stationary SQG discharge of the strong axioms for any radial shell.
Strictly extends ¬ß10.28 (`singleMode_const`, |S| = 1) and ¬ß10.31
(`antipodalMode_const`, S = {m‚āÄ, -m‚āÄ}). -/
theorem SqgEvolutionAxioms_strong.shellMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    SqgEvolutionAxioms_strong (fun _ : ‚ĄĚ => shellMode S a) := by
  have hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 *
        ‚ÄĖmFourierCoeff (shellMode S a) n‚ÄĖ ^ 2) :=
    hsSeminormSq_summable_of_finite_support 1 (shellMode S a) S
      (fun n hn => mFourierCoeff_shellMode_eq_zero_of_not_mem S a hn)
  exact SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP
    (sqgEvolutionAxioms_shellMode_const S a)
    (MaterialMaxPrinciple.of_const (shellMode S a) hSumm)
    (fun j _ => shellVelocity S a j)
    (fun j _ => isSqgVelocityComponent_shellMode S a j)
    (isSqgWeakSolution_shellMode_const hS a)

/-! ### ¬ß10.35 Radial-shell regularity capstone

Plug-and-play form: any finite radial shell `S` and any amplitude
function `a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā` give a constant-in-time shellMode that
enjoys uniform ŠłĘňĘ bounds on `[0, 2]`. The summability hypothesis from
`sqg_regularity_const` is discharged by the shell's finite Fourier
support. The bound follows **unconditionally** ‚ÄĒ no MMP or BKM axiom
appears in the final statement because both are discharged by
constant-in-time specialisations.

This completes the radial-shell milestone: the witness satisfies both
`SqgEvolutionAxioms_strong` (¬ß10.34) and the integer-order regularity
inequality (here). Strictly generalises the scaled single-mode
capstone `sqg_regularity_singleMode` (¬ß10.26). -/
theorem sqg_regularity_shellMode_const
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
        hsSeminormSq s ((fun _ : ‚ĄĚ => shellMode S a) t) ‚Č§ M :=
  sqg_regularity_const (shellMode S a)
    (hsSeminormSq_summable_of_finite_support 1 (shellMode S a) S
      (fun n hn => mFourierCoeff_shellMode_eq_zero_of_not_mem S a hn))

/-! ### ¬ß10.36 Galerkin truncation ‚ÄĒ finite-dim ODE scaffold

For a finite non-empty `S ‚äÜ ‚Ą§¬≤ \ {0}`, the SQG dynamics projected
onto `span {e_n : n ‚ąą S}` reduce to a finite-dim quadratic ODE on
coefficient functions `c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā`:

    d/dŌĄ c(m) = galerkinRHS S c m
              = ‚ąí‚ąĎ_{‚Ąď ‚ąą S, m-‚Ąď ‚ąą S} c(‚Ąď) ¬∑ c(m-‚Ąď) ¬∑ C(‚Ąď, m-‚Ąď)

where `C(‚Ąď, k) := ‚ąĎ_j sqgVelocitySymbol j ‚Ąď * derivSymbol j k` is the
same coefficient used in ¬ß10.33. For a radial shell the ¬ß10.32
pair-sum identity forces `galerkinRHS S c m = 0` for every `c` and
every `m`, recovering stationarity of ¬ß10.33 as a **pointwise (in `c`)**
algebraic fact. For general finite `S` the ODE is non-trivial but
finite-dim, so mathlib's `PicardLindelof` will give local existence;
energy conservation (L¬≤ isometry at the mode-coefficient level) gives
global existence.

**This section ships only:**
* `galerkinRHS` definition.
* Identical-to-zero behaviour on radial shells.

**Deferred to later sections:**
* Local-Lipschitz of `galerkinRHS` on L‚ąě-balls (Phase 2.B).
* Energy conservation `d/dŌĄ ‚ąĎ |c m|¬≤ = 0` (Phase 2.C).
* Integration with mathlib's ODE infrastructure to produce
  `őł^S : ‚ĄĚ ‚Üí Lp ‚Ąā 2` as a weak-solution witness (Phase 2.D). -/

/-- **Galerkin nonlinear RHS at mode `m`.** Finite-sum projection
of the SQG flux onto modes whose pre-image pair lies in `S √ó S`. -/
noncomputable def galerkinRHS
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  -‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
      c ‚Ąď * c (m - ‚Ąď)
        * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))

/-- **Galerkin RHS vanishes on radial shells.** At the pointwise-in-`c`
level, `galerkinRHS S c m = 0` for every `c` and every `m` when `S`
is a radial shell. The underlying cancellation is the same
`Finset.sum_involution` argument as
`sqgNonlinearFlux_shellMode_eq_zero`, now expressed in purely
coefficient-level terms: amplitude factors `c(‚Ąď), c(m-‚Ąď)` replace the
`mFourierCoeff (shellMode ‚Ä¶)` factors, and the j-sum cancellation
still closes via
`sqgVelocitySymbol_mul_derivSymbol_pair_sum_zero_of_latticeNorm_eq`.

Consequence: the Galerkin ODE on a radial shell has trivial dynamics,
so `c` stays constant in time and the ¬ß10.33 witness re-emerges. -/
theorem galerkinRHS_eq_zero_of_isRadialShell
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S)
    (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    galerkinRHS S c m = 0 := by
  unfold galerkinRHS
  rw [neg_eq_zero]
  apply Finset.sum_involution (fun ‚Ąď _ => m - ‚Ąď)
  ¬∑ -- hg‚āĀ: paired terms sum to zero via ¬ß10.32 pair-sum + radial norm equality.
    intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď
    obtain ‚ü®h‚Ąď_S, hm‚Ąď_S‚ü© := h‚Ąď
    have hnorm_eq : latticeNorm ‚Ąď = latticeNorm (m - ‚Ąď) :=
      hS.2 ‚Ąď h‚Ąď_S (m - ‚Ąď) hm‚Ąď_S
    have h_pair :=
      sqgVelocitySymbol_mul_derivSymbol_pair_sum_zero_of_latticeNorm_eq
        ‚Ąď (m - ‚Ąď) hnorm_eq
    have h_sub : m - (m - ‚Ąď) = ‚Ąď := sub_sub_cancel m ‚Ąď
    rw [h_sub]
    have hring :
        c ‚Ąď * c (m - ‚Ąď)
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
          + c (m - ‚Ąď) * c ‚Ąď
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j (m - ‚Ąď) * derivSymbol j ‚Ąď)
          = c ‚Ąď * c (m - ‚Ąď)
            * ((‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
               + (‚ąĎ j : Fin 2, sqgVelocitySymbol j (m - ‚Ąď) * derivSymbol j ‚Ąď))
          := by ring
    rw [hring, h_pair, mul_zero]
  ¬∑ -- hg‚āÉ: fixed point ‚áí summand = 0.
    intros ‚Ąď _ hne h_eq
    apply hne
    rw [h_eq, sqgVelocitySymbol_mul_derivSymbol_sum_zero, mul_zero]
  ¬∑ -- g_mem.
    intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď ‚äĘ
    obtain ‚ü®h‚Ąď_S, hm‚Ąď_S‚ü© := h‚Ąď
    refine ‚ü®hm‚Ąď_S, ?_‚ü©
    rw [sub_sub_cancel]
    exact h‚Ąď_S
  ¬∑ -- hg‚āĄ.
    intros ‚Ąď _
    exact sub_sub_cancel m ‚Ąď

/-! ### ¬ß10.37 Galerkin vector field ‚ÄĒ finite-dim Banach setup

Lift `galerkinRHS` to a map `galerkinVectorField S : (‚Ü•S ‚Üí ‚Ąā) ‚Üí (‚Ü•S ‚Üí ‚Ąā)`
on the finite-dim Pi space indexed by the shell. `‚Ü•S ‚Üí ‚Ąā` is
automatically a Banach space (`Fintype ‚Ü•S`), the setting mathlib's
`IsPicardLindelof` / `ODE_solution_exists` theorems expect.

**Content:**
* `galerkinExtend` ‚ÄĒ zero-extension `‚Ü•S ‚Üí ‚Ąā` ‚Ü¶ `(Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā`.
* `galerkinVectorField` ‚ÄĒ the ODE RHS on the finite-dim state space.
* Radial-shell specialisation (trivial vector field).

**Deferred:**
* Lipschitz estimate on bounded balls (Phase 2.C).
* Picard-Lindel√∂f application for local existence (Phase 2.D). -/

/-- Zero-extension of a finite-support coefficient function. -/
noncomputable def galerkinExtend
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā :=
  fun m => if h : m ‚ąą S then c ‚ü®m, h‚ü© else 0

@[simp] lemma galerkinExtend_apply_of_mem
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚ąą S) :
    galerkinExtend S c m = c ‚ü®m, hm‚ü© := by
  unfold galerkinExtend
  rw [dif_pos hm]

@[simp] lemma galerkinExtend_apply_of_not_mem
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚ąČ S) :
    galerkinExtend S c m = 0 := by
  unfold galerkinExtend
  rw [dif_neg hm]

/-- **Galerkin vector field on the finite-dim coefficient space.**
Evaluates `galerkinRHS` at each shell mode `m ‚ąą S`. -/
noncomputable def galerkinVectorField
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) : ‚Ü•S ‚Üí ‚Ąā :=
  fun m => galerkinRHS S (galerkinExtend S c) ‚ÜĎm

/-- **Galerkin vector field vanishes on radial shells.** Lifts
`galerkinRHS_eq_zero_of_isRadialShell` to the state-space setting ‚ÄĒ
any coefficient `c : ‚Ü•S ‚Üí ‚Ąā` is a fixed point of the ODE. Consequence:
the Galerkin ODE on a radial shell has the constant solution
`c(ŌĄ) = c‚āÄ`, matching the ¬ß10.33 stationary witness. -/
theorem galerkinVectorField_eq_zero_of_isRadialShell
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S)
    (c : ‚Ü•S ‚Üí ‚Ąā) : galerkinVectorField S c = 0 := by
  funext m
  show galerkinRHS S (galerkinExtend S c) ‚ÜĎm = 0
  exact galerkinRHS_eq_zero_of_isRadialShell hS (galerkinExtend S c) ‚ÜĎm

/-! ### ¬ß10.38 Radial-shell Galerkin ODE ‚ÄĒ constant solution

First **ODE-level** solution statement for the Galerkin system: on a
radial shell, any initial coefficient configuration `c‚āÄ : ‚Ü•S ‚Üí ‚Ąā`
induces a time-constant solution `c(ŌĄ) = c‚āÄ` of the Galerkin ODE
`d/dŌĄ c = galerkinVectorField S c`. Existence requires no Lipschitz
analysis ‚ÄĒ the vector field is identically zero, so the constant
function has the right derivative automatically.

This is the ODE-level reflection of the ¬ß10.33/¬ß10.34 stationary
witness: the coefficient dynamics are frozen, so `shellMode S c‚āÄ`
stays constant in time, consistent with `SqgEvolutionAxioms_strong.shellMode_const`. -/
theorem galerkin_radial_shell_constant_is_solution
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (ŌĄ : ‚ĄĚ) :
    HasDerivAt (fun _ : ‚ĄĚ => c‚āÄ) (galerkinVectorField S c‚āÄ) ŌĄ := by
  rw [galerkinVectorField_eq_zero_of_isRadialShell hS]
  exact hasDerivAt_const ŌĄ c‚āÄ

/-! ### ¬ß10.39 Continuity of the Galerkin vector field

The Galerkin ODE RHS is a polynomial (degree ‚Č§ 2) map on the
finite-dim Pi space `‚Ü•S ‚Üí ‚Ąā`. Each coordinate is a finite sum of
bilinear forms in the coordinate projections ‚ÄĒ hence continuous. This
is the minimal regularity needed before invoking mathlib's ODE
existence theorems; it will extend to `ContDiff ‚ĄĚ ‚ąě` in a later step,
but continuity alone already supports the Peano existence theorem on
bounded cylinders.

This section ships only continuity; `ContDiff` and Lipschitz are
Phase 2.D. -/

/-- **Continuity of the zero-extension map.** For any fixed mode
`m : Fin 2 ‚Üí ‚Ą§`, the evaluation map `c ‚Ü¶ galerkinExtend S c m` is
continuous in `c : ‚Ü•S ‚Üí ‚Ąā`. Either a fixed coordinate projection
(if `m ‚ąą S`) or the zero constant (if not). -/
theorem galerkinExtend_continuous_apply
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m : Fin 2 ‚Üí ‚Ą§) :
    Continuous (fun c : ‚Ü•S ‚Üí ‚Ąā => galerkinExtend S c m) := by
  by_cases hm : m ‚ąą S
  ¬∑ have h_eq : (fun c : ‚Ü•S ‚Üí ‚Ąā => galerkinExtend S c m)
            = (fun c : ‚Ü•S ‚Üí ‚Ąā => c ‚ü®m, hm‚ü©) := by
      funext c
      exact galerkinExtend_apply_of_mem S c hm
    rw [h_eq]
    exact continuous_apply _
  ¬∑ have h_eq : (fun c : ‚Ü•S ‚Üí ‚Ąā => galerkinExtend S c m) = (fun _ => 0) := by
      funext c
      exact galerkinExtend_apply_of_not_mem S c hm
    rw [h_eq]
    exact continuous_const

/-- **Continuity of the Galerkin vector field.** On the finite-dim
Pi space, each coordinate is a finite sum of products of continuous
projections, so the whole map is continuous. -/
theorem galerkinVectorField_continuous
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)] :
    Continuous (galerkinVectorField S) := by
  apply continuous_pi
  intro m
  show Continuous (fun c : ‚Ü•S ‚Üí ‚Ąā =>
    galerkinRHS S (galerkinExtend S c) ‚ÜĎm)
  unfold galerkinRHS
  refine Continuous.neg ?_
  refine continuous_finset_sum _ ?_
  intro ‚Ąď _
  refine Continuous.mul (Continuous.mul ?_ ?_) continuous_const
  ¬∑ exact galerkinExtend_continuous_apply S ‚Ąď
  ¬∑ exact galerkinExtend_continuous_apply S (‚ÜĎm - ‚Ąď)

/-! ### ¬ß10.40 Collinear-support stationary SQG

A second, independent class of unconditional stationary SQG witnesses,
distinct from radial shells: any finite `S ‚äÜ ‚Ą§¬≤ \ {0}` whose modes are
pairwise collinear (i.e. `S ‚äÜ ‚Ą§ ¬∑ v` for some primitive `v`). The
cancellation mechanism here is **per-pair** rather than paired: for any
‚Ąď, k parallel to a common direction, the 2D cross product `‚Ąď √ó k = 0`,
so the j-sum `‚ąĎ_j sqgVelocitySymbol j ‚Ąď ¬∑ derivSymbol j k` vanishes
individually (before any pairing).

Physically this corresponds to the classical "functions of a single
coordinate" stationary class: `őł(x) = f(v ¬∑ x)` where `v ‚ąą ‚Ą§¬≤` fixes
the level-set direction; the velocity is along the level sets and
never sees `‚ąáőł`.

Unlike radial shells, collinear `S` can have arbitrary norms on its
elements (e.g. `{v, 2v, 3v, ‚Ä¶}`), so this is a strictly different
extension ‚ÄĒ the `IsRadialShell` and `IsCollinear` witnesses overlap
only at `|S| ‚Č§ 2` (antipodal pair) or singletons. -/

/-- **Per-pair inner-sum vanishes on collinear pairs.** For any
`‚Ąď, k : Fin 2 ‚Üí ‚Ą§` with zero 2D cross product, `C(‚Ąď, k) = 0`.
Immediate corollary of the closed-form lemma
`sum_sqgVelocitySymbol_mul_derivSymbol_of_ne_zero`. -/
lemma sqgVelocitySymbol_mul_derivSymbol_sum_zero_of_cross_zero
    (‚Ąď k : Fin 2 ‚Üí ‚Ą§) (hcross : ‚Ąď 0 * k 1 = ‚Ąď 1 * k 0) :
    (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k) = 0 := by
  by_cases h‚Ąď : ‚Ąď = 0
  ¬∑ subst h‚Ąď
    simp [sqgVelocitySymbol_zero]
  rw [sum_sqgVelocitySymbol_mul_derivSymbol_of_ne_zero _ _ h‚Ąď]
  have h_num_R : (‚Ąď 1 : ‚ĄĚ) * (k 0 : ‚ĄĚ) - (‚Ąď 0 : ‚ĄĚ) * (k 1 : ‚ĄĚ) = 0 := by
    have hR : (‚Ąď 0 : ‚ĄĚ) * (k 1 : ‚ĄĚ) = (‚Ąď 1 : ‚ĄĚ) * (k 0 : ‚ĄĚ) := by
      exact_mod_cast hcross
    linarith
  have h_num_C :
      (((‚Ąď 1 : ‚ĄĚ) * (k 0 : ‚ĄĚ) - (‚Ąď 0 : ‚ĄĚ) * (k 1 : ‚ĄĚ) : ‚ĄĚ) : ‚Ąā) = 0 := by
    exact_mod_cast h_num_R
  rw [h_num_C, zero_div]

/-- **Collinearity predicate.** `S` is collinear: every pair of modes
shares a zero 2D cross product. Equivalently, `S` lies on one line
through the origin in `‚Ą§¬≤`. -/
def IsCollinear (S : Finset (Fin 2 ‚Üí ‚Ą§)) : Prop :=
  ‚ąÄ ‚Ąď ‚ąą S, ‚ąÄ k ‚ąą S, ‚Ąď 0 * k 1 = ‚Ąď 1 * k 0

/-- **Collinear stationary SQG flux = 0.** Same outer structure as
`sqgNonlinearFlux_shellMode_eq_zero` (¬ß10.33), but each ‚Ąď-slice
individually vanishes via the collinearity cross-product identity ‚ÄĒ
no pairing/involution needed. -/
theorem sqgNonlinearFlux_shellMode_eq_zero_of_collinear
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsCollinear S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    sqgNonlinearFlux (shellMode S a) (shellVelocity S a ¬∑) m = 0 := by
  unfold sqgNonlinearFlux
  have h_tsum_eq : ‚ąÄ j : Fin 2,
      fourierConvolution
          (fun ‚Ąď => mFourierCoeff (shellVelocity S a j) ‚Ąď)
          (fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff (shellMode S a) ‚Ąď) m
        = ‚ąĎ ‚Ąď ‚ąą S,
            mFourierCoeff (shellVelocity S a j) ‚Ąď
              * (derivSymbol j (m - ‚Ąď)
                 * mFourierCoeff (shellMode S a) (m - ‚Ąď)) := by
    intro j
    unfold fourierConvolution
    apply tsum_eq_sum
    intro ‚Ąď h‚Ąď
    simp only [mFourierCoeff_shellVelocity, if_neg h‚Ąď, zero_mul]
  rw [Finset.sum_congr rfl (fun j _ => h_tsum_eq j)]
  rw [Finset.sum_comm]
  apply Finset.sum_eq_zero
  intro ‚Ąď h‚Ąď_S
  -- The inner j-sum factors to `a(‚Ąď) ¬∑ őłŐā(m-‚Ąď) ¬∑ C(‚Ąď, m-‚Ąď)`; the
  -- collinearity case-splits m-‚Ąď ‚ąą S (then C = 0 by hS) or ‚ąČ S
  -- (then őłŐā(m-‚Ąď) = 0).
  have h_factor : ‚ąÄ j : Fin 2,
      mFourierCoeff (shellVelocity S a j) ‚Ąď
        * (derivSymbol j (m - ‚Ąď) * mFourierCoeff (shellMode S a) (m - ‚Ąď))
        = a ‚Ąď * mFourierCoeff (shellMode S a) (m - ‚Ąď)
          * (sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
    intro j
    rw [mFourierCoeff_shellVelocity, if_pos h‚Ąď_S]
    ring
  rw [Finset.sum_congr rfl (fun j _ => h_factor j), ‚Üź Finset.mul_sum]
  by_cases hm‚Ąď : m - ‚Ąď ‚ąą S
  ¬∑ -- m - ‚Ąď ‚ąą S: inner j-sum vanishes by collinearity.
    rw [sqgVelocitySymbol_mul_derivSymbol_sum_zero_of_cross_zero ‚Ąď (m - ‚Ąď)
          (hS ‚Ąď h‚Ąď_S (m - ‚Ąď) hm‚Ąď),
        mul_zero]
  ¬∑ -- m - ‚Ąď ‚ąČ S: őłŐā(m-‚Ąď) = 0 kills the factor.
    rw [mFourierCoeff_shellMode, if_neg hm‚Ąď, mul_zero, zero_mul]

/-- **Collinear stationary SQG ‚ÄĒ `IsSqgWeakSolution`.** Analogue of
`isSqgWeakSolution_shellMode_const` (¬ß10.34) for collinear support. -/
theorem isSqgWeakSolution_shellMode_const_of_collinear
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsCollinear S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    IsSqgWeakSolution
        (fun _ : ‚ĄĚ => shellMode S a)
        (fun (j : Fin 2) (_ : ‚ĄĚ) => shellVelocity S a j) where
  duhamel := fun m s t _ _ => by
    have h_integrand :
        (fun ŌĄ : ‚ĄĚ => sqgNonlinearFlux
            ((fun _ : ‚ĄĚ => shellMode S a) ŌĄ)
            (fun j : Fin 2 =>
              (fun (j : Fin 2) (_ : ‚ĄĚ) => shellVelocity S a j) j ŌĄ) m)
          = fun _ => (0 : ‚Ąā) := by
      funext ŌĄ
      exact sqgNonlinearFlux_shellMode_eq_zero_of_collinear hS a m
    rw [h_integrand]
    simp

/-- **`SqgEvolutionAxioms_strong.shellMode_const_of_collinear`.**
Companion multi-mode discharge for collinear support, parallel to
¬ß10.34's radial-shell version. Routes through
`of_IsSqgWeakSolution_via_MMP` with MMP discharged by finite-support
ŠłĘ¬Ļ summability. Subsumes ¬ß10.28 (singleMode) and ¬ß10.31 (antipodal)
as the special cases |S| = 1 and |S| = 2 where the collinearity
reduces to the trivial direction. -/
theorem SqgEvolutionAxioms_strong.shellMode_const_of_collinear
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsCollinear S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    SqgEvolutionAxioms_strong (fun _ : ‚ĄĚ => shellMode S a) := by
  have hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 *
        ‚ÄĖmFourierCoeff (shellMode S a) n‚ÄĖ ^ 2) :=
    hsSeminormSq_summable_of_finite_support 1 (shellMode S a) S
      (fun n hn => mFourierCoeff_shellMode_eq_zero_of_not_mem S a hn)
  exact SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP
    (sqgEvolutionAxioms_shellMode_const S a)
    (MaterialMaxPrinciple.of_const (shellMode S a) hSumm)
    (fun j _ => shellVelocity S a j)
    (fun j _ => isSqgVelocityComponent_shellMode S a j)
    (isSqgWeakSolution_shellMode_const_of_collinear hS a)

/-! ### ¬ß10.41 `ContDiff` of the Galerkin vector field

Each coordinate of `galerkinVectorField S` is a finite sum of products
of zero-extension coordinate projections and constants. Coordinate
projections on `Fintype`-indexed Pi types are continuous linear (hence
`ContDiff ‚ĄĚ ‚ąě`), and `ContDiff` is closed under products, finite sums,
and negation. So the whole map is `ContDiff ‚ĄĚ ‚ąě`. -/

/-- Each evaluation `galerkinExtend S c m` is `ContDiff ‚ĄĚ n` in `c`. -/
theorem galerkinExtend_contDiff_apply
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (m : Fin 2 ‚Üí ‚Ą§) {n : WithTop ‚Ąē‚ąě} :
    ContDiff ‚ĄĚ n (fun c : ‚Ü•S ‚Üí ‚Ąā => galerkinExtend S c m) := by
  by_cases hm : m ‚ąą S
  ¬∑ have h_eq : (fun c : ‚Ü•S ‚Üí ‚Ąā => galerkinExtend S c m)
            = (fun c : ‚Ü•S ‚Üí ‚Ąā => c ‚ü®m, hm‚ü©) := by
      funext c
      exact galerkinExtend_apply_of_mem S c hm
    rw [h_eq]
    exact contDiff_apply ‚ĄĚ ‚Ąā (‚ü®m, hm‚ü© : ‚Ü•S)
  ¬∑ have h_eq : (fun c : ‚Ü•S ‚Üí ‚Ąā => galerkinExtend S c m) = (fun _ => 0) := by
      funext c
      exact galerkinExtend_apply_of_not_mem S c hm
    rw [h_eq]
    exact contDiff_const

/-- **Galerkin vector field is `ContDiff ‚ĄĚ ‚ąě`.** -/
theorem galerkinVectorField_contDiff
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)] {n : WithTop ‚Ąē‚ąě} :
    ContDiff ‚ĄĚ n (galerkinVectorField S) := by
  rw [contDiff_pi]
  intro m
  show ContDiff ‚ĄĚ n (fun c : ‚Ü•S ‚Üí ‚Ąā =>
    galerkinRHS S (galerkinExtend S c) ‚ÜĎm)
  unfold galerkinRHS
  refine ContDiff.neg ?_
  refine ContDiff.sum (fun ‚Ąď _ => ?_)
  refine ContDiff.mul (ContDiff.mul ?_ ?_) contDiff_const
  ¬∑ exact galerkinExtend_contDiff_apply S ‚Ąď
  ¬∑ exact galerkinExtend_contDiff_apply S (‚ÜĎm - ‚Ąď)

/-! ### ¬ß10.42 Local Lipschitz of the Galerkin vector field

Immediate corollary of `galerkinVectorField_contDiff` (¬ß10.41): a
`C^1` map on a real normed space is Lipschitz on some neighborhood of
every point. This is the analytic hypothesis feeding into mathlib's
`IsPicardLindelof` for local ODE existence.

The closed-ball version at an explicit radius (needed to compose with
Picard-Lindel√∂f) is deferred, since it requires choosing the ball size
together with the time interval. -/

/-- **Galerkin vector field is locally Lipschitz.** For any initial
coefficient `c‚āÄ`, there exists a Lipschitz constant `K` and a
neighborhood `U` of `c‚āÄ` on which `galerkinVectorField S` is
`K`-Lipschitz. -/
theorem galerkinVectorField_locally_lipschitz
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) :
    ‚ąÉ K : NNReal, ‚ąÉ U ‚ąą nhds c‚āÄ, LipschitzOnWith K (galerkinVectorField S) U :=
  ((galerkinVectorField_contDiff S (n := 1)).contDiffAt).exists_lipschitzOnWith

/-! ### ¬ß10.43 Unified stationary-shape predicate

Captures both stationary classes from ¬ß10.32-¬ß10.40 under one
predicate: `S` is *stationary-compatible* if every pair `(‚Ąď, k)` in
`S √ó S` has zero pair-sum `C(‚Ąď, k) + C(k, ‚Ąď) = 0`. This holds on:
* Radial shells (¬ß10.32): `|‚Ąď| = |k|` forces pair-sum to 0.
* Collinear `S` (¬ß10.40): per-pair `C(‚Ąď, k) = 0` forces pair-sum to 0.
* More generally, any `S` where both conditions fail but the pair-sum
  still vanishes (e.g. mixed shells where cross-shell pairs
  happen to have the sum cancel algebraically ‚ÄĒ rare but possible).

The unified predicate both *subsumes* the two specific cases and gives
a single universal discharge theorem for stationary SQG on finite
support, simplifying downstream consumers. -/

/-- **Stationary-shape predicate.** Every pair in `S √ó S` has
vanishing pair-sum of inner j-sums. Generalises `IsRadialShell` and
`IsCollinear` simultaneously. -/
def IsStationaryShape (S : Finset (Fin 2 ‚Üí ‚Ą§)) : Prop :=
  0 ‚ąČ S ‚ąß ‚ąÄ ‚Ąď ‚ąą S, ‚ąÄ k ‚ąą S,
    (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k)
      + (‚ąĎ j : Fin 2, sqgVelocitySymbol j k * derivSymbol j ‚Ąď) = 0

/-- **Radial shell ‚üĻ stationary shape.** Immediate from the pair-sum
cross div-free identity of ¬ß10.32. -/
theorem IsStationaryShape.of_isRadialShell
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S) :
    IsStationaryShape S := by
  refine ‚ü®hS.1, fun ‚Ąď h‚Ąď k hk => ?_‚ü©
  exact sqgVelocitySymbol_mul_derivSymbol_pair_sum_zero_of_latticeNorm_eq
    ‚Ąď k (hS.2 ‚Ąď h‚Ąď k hk)

/-- **Collinear ‚üĻ stationary shape.** Per-pair inner sums vanish
individually (via `sqgVelocitySymbol_mul_derivSymbol_sum_zero_of_cross_zero`),
so the pair-sum is trivially 0. Requires `0 ‚ąČ S` separately. -/
theorem IsStationaryShape.of_isCollinear
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S)
    (hS : IsCollinear S) :
    IsStationaryShape S := by
  refine ‚ü®h0, fun ‚Ąď h‚Ąď k hk => ?_‚ü©
  have h1 : (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k) = 0 :=
    sqgVelocitySymbol_mul_derivSymbol_sum_zero_of_cross_zero ‚Ąď k (hS ‚Ąď h‚Ąď k hk)
  have h2 : (‚ąĎ j : Fin 2, sqgVelocitySymbol j k * derivSymbol j ‚Ąď) = 0 := by
    have h_swap : k 0 * ‚Ąď 1 = k 1 * ‚Ąď 0 := by
      have := hS ‚Ąď h‚Ąď k hk
      linarith
    exact sqgVelocitySymbol_mul_derivSymbol_sum_zero_of_cross_zero k ‚Ąď h_swap
  rw [h1, h2, add_zero]

/-- **Universal flux-zero theorem for stationary-shape `S`.** Same
Finset.sum_involution structure as ¬ß10.33's `sqgNonlinearFlux_shellMode_eq_zero`,
but keyed on the general `IsStationaryShape` pair-sum condition rather
than the specific `IsRadialShell` or `IsCollinear`. -/
theorem sqgNonlinearFlux_shellMode_eq_zero_of_stationaryShape
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsStationaryShape S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    sqgNonlinearFlux (shellMode S a) (shellVelocity S a ¬∑) m = 0 := by
  unfold sqgNonlinearFlux
  have h_tsum_eq : ‚ąÄ j : Fin 2,
      fourierConvolution
          (fun ‚Ąď => mFourierCoeff (shellVelocity S a j) ‚Ąď)
          (fun ‚Ąď => derivSymbol j ‚Ąď * mFourierCoeff (shellMode S a) ‚Ąď) m
        = ‚ąĎ ‚Ąď ‚ąą S,
            mFourierCoeff (shellVelocity S a j) ‚Ąď
              * (derivSymbol j (m - ‚Ąď)
                 * mFourierCoeff (shellMode S a) (m - ‚Ąď)) := by
    intro j
    unfold fourierConvolution
    apply tsum_eq_sum
    intro ‚Ąď h‚Ąď
    simp only [mFourierCoeff_shellVelocity, if_neg h‚Ąď, zero_mul]
  rw [Finset.sum_congr rfl (fun j _ => h_tsum_eq j)]
  rw [Finset.sum_comm]
  have h_factor : ‚ąÄ ‚Ąď ‚ąą S,
      (‚ąĎ j : Fin 2,
        mFourierCoeff (shellVelocity S a j) ‚Ąď
          * (derivSymbol j (m - ‚Ąď) * mFourierCoeff (shellMode S a) (m - ‚Ąď)))
        = a ‚Ąď * mFourierCoeff (shellMode S a) (m - ‚Ąď)
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
    intros ‚Ąď h‚Ąď
    have h_each : ‚ąÄ j : Fin 2,
        mFourierCoeff (shellVelocity S a j) ‚Ąď
          * (derivSymbol j (m - ‚Ąď) * mFourierCoeff (shellMode S a) (m - ‚Ąď))
          = a ‚Ąď * mFourierCoeff (shellMode S a) (m - ‚Ąď)
              * (sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
      intro j
      rw [mFourierCoeff_shellVelocity, if_pos h‚Ąď]
      ring
    rw [Finset.sum_congr rfl (fun j _ => h_each j), ‚Üź Finset.mul_sum]
  rw [Finset.sum_congr rfl h_factor]
  have h_rewrite : ‚ąÄ ‚Ąď ‚ąą S,
      a ‚Ąď * mFourierCoeff (shellMode S a) (m - ‚Ąď)
        * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
        = if m - ‚Ąď ‚ąą S then
            a ‚Ąď * a (m - ‚Ąď)
              * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
          else 0 := by
    intros ‚Ąď _
    rw [mFourierCoeff_shellMode]
    split_ifs with h
    ¬∑ rfl
    ¬∑ rw [mul_zero, zero_mul]
  rw [Finset.sum_congr rfl h_rewrite]
  rw [‚Üź Finset.sum_filter]
  apply Finset.sum_involution (fun ‚Ąď _ => m - ‚Ąď)
  ¬∑ intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď
    obtain ‚ü®h‚Ąď_S, hm‚Ąď_S‚ü© := h‚Ąď
    have h_pair := hS.2 ‚Ąď h‚Ąď_S (m - ‚Ąď) hm‚Ąď_S
    have h_sub : m - (m - ‚Ąď) = ‚Ąď := sub_sub_cancel m ‚Ąď
    rw [h_sub]
    have hring :
        a ‚Ąď * a (m - ‚Ąď)
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
          + a (m - ‚Ąď) * a ‚Ąď
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j (m - ‚Ąď) * derivSymbol j ‚Ąď)
          = a ‚Ąď * a (m - ‚Ąď)
            * ((‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
               + (‚ąĎ j : Fin 2, sqgVelocitySymbol j (m - ‚Ąď) * derivSymbol j ‚Ąď))
          := by ring
    rw [hring, h_pair, mul_zero]
  ¬∑ intros ‚Ąď _ hne h_eq
    apply hne
    rw [h_eq, sqgVelocitySymbol_mul_derivSymbol_sum_zero, mul_zero]
  ¬∑ intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď ‚äĘ
    obtain ‚ü®h‚Ąď_S, hm‚Ąď_S‚ü© := h‚Ąď
    refine ‚ü®hm‚Ąď_S, ?_‚ü©
    rw [sub_sub_cancel]
    exact h‚Ąď_S
  ¬∑ intros ‚Ąď _
    exact sub_sub_cancel m ‚Ąď

/-! ### ¬ß10.44 Picard-Lindel√∂f wrapper ‚ÄĒ local Galerkin ODE solution

Packages mathlib's `IsPicardLindelof.exists_eq_forall_mem_Icc_hasDerivWithinAt‚āÄ`
into a form that consumes pre-chosen Lipschitz-, bound-, and
time-constants on a closed ball around the initial condition. The
hypotheses are: (i) `K`-Lipschitz on `closedBall c‚āÄ a`, (ii) `L`
uniform bound on `‚ÄĖgalerkinVectorField S c‚ÄĖ` for `c ‚ąą closedBall c‚āÄ a`,
(iii) time interval `őĶ` satisfies `L ¬∑ őĶ ‚Č§ a`.

The automatic version (choosing `a, L, K, őĶ` from ContDiff + continuity)
is deferred ‚ÄĒ it requires compactness ‚Üí uniform-bound extraction, then
algebraic choice of `őĶ`. Users can invoke this version directly for
specific `S` where the constants are easy to compute. -/

theorem galerkin_local_exists_given_bounds
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) {a L K : NNReal} {őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hLip : LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall c‚āÄ (a : ‚ĄĚ)))
    (hBound : ‚ąÄ c ‚ąą Metric.closedBall c‚āÄ (a : ‚ĄĚ),
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ L)
    (hTime : (L : ‚ĄĚ) * őĶ ‚Č§ (a : ‚ĄĚ)) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      ‚ąÄ t ‚ąą Set.Icc (-őĶ) őĶ,
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (-őĶ) őĶ) t := by
  classical
  -- Autonomous time-dependent vector field (constant in t).
  set f : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) ‚Üí (‚Ü•S ‚Üí ‚Ąā) := fun _ => galerkinVectorField S with hf_def
  have ht_in : (0 : ‚ĄĚ) ‚ąą Set.Icc (-őĶ) őĶ := ‚ü®by linarith, by linarith‚ü©
  set t‚āÄ : Set.Icc (-őĶ) őĶ := ‚ü®0, ht_in‚ü© with ht‚āÄ_def
  have hPL : IsPicardLindelof f t‚āÄ c‚āÄ a 0 L K := {
    lipschitzOnWith := fun _ _ => hLip
    continuousOn := fun _ _ => continuousOn_const
    norm_le := fun _ _ _ hx => hBound _ hx
    mul_max_le := by
      show (L : ‚ĄĚ) * max (őĶ - (0 : ‚ĄĚ)) ((0 : ‚ĄĚ) - (-őĶ)) ‚Č§ (a : ‚ĄĚ) - 0
      rw [sub_zero, zero_sub, neg_neg, max_self, sub_zero]
      exact hTime
  }
  obtain ‚ü®őĪ, hőĪ‚āÄ, hőĪ‚ü© := hPL.exists_eq_forall_mem_Icc_hasDerivWithinAt‚āÄ
  refine ‚ü®őĪ, hőĪ‚āÄ, ?_‚ü©
  intros t ht
  exact hőĪ t ht

/-! ### ¬ß10.45 Radial-shell ODE local solution via Picard-Lindel√∂f

Concrete application of ¬ß10.44's wrapper to the radial-shell case.
Since `galerkinVectorField_eq_zero_of_isRadialShell` (¬ß10.37) gives
`galerkinVectorField S c = 0` for every `c` on a radial shell, the
vector field is both 0-Lipschitz and bounded by 0, so Picard-Lindel√∂f
produces the constant solution `c(ŌĄ) = c‚āÄ` on any time interval. -/

theorem galerkin_radial_shell_picard_solution
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S) (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā)
    (őĶ : ‚ĄĚ) (hőĶ : 0 < őĶ) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      ‚ąÄ t ‚ąą Set.Icc (-őĶ) őĶ,
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (-őĶ) őĶ) t := by
  refine galerkin_local_exists_given_bounds S c‚āÄ (a := 1) (L := 0) (K := 0) hőĶ
    ?_ ?_ ?_
  ¬∑ -- LipschitzOnWith 0: both sides equal 0 (vector field ‚Č° 0).
    intros x _ y _
    rw [galerkinVectorField_eq_zero_of_isRadialShell hS x,
        galerkinVectorField_eq_zero_of_isRadialShell hS y]
    simp
  ¬∑ -- Bound 0: vector field ‚Č° 0.
    intros c _
    rw [galerkinVectorField_eq_zero_of_isRadialShell hS]
    simp
  ¬∑ -- L ¬∑ őĶ = 0 ¬∑ őĶ = 0 ‚Č§ 1 = a.
    push_cast
    linarith

/-! ### ¬ß10.46 Real-symmetric coefficient predicate

A coefficient function `c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā` is *real-symmetric* if
its values on `S` satisfy the Hermitian reality condition:
`c(-n) = star (c n)` for every `n ‚ąą S`, and `S` is closed under
negation. This corresponds to `shellMode S c` being real-valued as a
function on the torus.

On the real-symmetric subspace, L¬≤ is conserved by the Galerkin ODE
(reflecting the SQG PDE's L¬≤ conservation for real őł), yielding global
existence from local Picard-Lindel√∂f. This section ships only the
predicate; downstream L¬≤ identities are deferred. -/

/-- **Real-symmetric support predicate.** `S` is closed under
negation. -/
def IsSymmetricSupport (S : Finset (Fin 2 ‚Üí ‚Ą§)) : Prop :=
  ‚ąÄ n ‚ąą S, -n ‚ąą S

/-- **Real-symmetric coefficients on `S`.** `c(-n) = conj (c n)` on
every `n ‚ąą S`. (When `S` is `IsSymmetricSupport`, this extends to all
of `S`.) -/
def IsRealCoeff (S : Finset (Fin 2 ‚Üí ‚Ą§)) (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) : Prop :=
  ‚ąÄ n ‚ąą S, c (-n) = star (c n)

/-! ### ¬ß10.47 Galerkin-to-`Lp` lift

Given a Galerkin state `c : ‚Ü•S ‚Üí ‚Ąā`, its canonical `Lp` lift is
`trigPoly S (galerkinExtend S c)` ‚ÄĒ a finite-support trigonometric
polynomial with amplitudes drawn from `c`. This packages the state
into the `Lp ‚Ąā 2` setting used by `IsSqgWeakSolution`, closing the
gap between the ODE framework (on `‚Ü•S ‚Üí ‚Ąā`) and the PDE framework
(on `Lp ‚Ąā 2`).

Given a Galerkin trajectory `őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)`, the `Lp` trajectory
is `fun t => galerkinToLp S (őĪ t)`. -/

/-- Lift a Galerkin state to `Lp` via `trigPoly`. -/
noncomputable def galerkinToLp
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  trigPoly S (galerkinExtend S c)

/-- Closed-form Fourier coefficients of `galerkinToLp`. -/
theorem mFourierCoeff_galerkinToLp
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (galerkinToLp S c) m = galerkinExtend S c m := by
  unfold galerkinToLp
  rw [mFourierCoeff_trigPoly]
  by_cases hm : m ‚ąą S
  ¬∑ rw [if_pos hm, galerkinExtend_apply_of_mem _ _ hm]
  ¬∑ rw [if_neg hm, galerkinExtend_apply_of_not_mem _ _ hm]

/-! ### ¬ß10.48 Bridge `galerkinVectorField` ‚ÜĒ `sqgNonlinearFlux`

At the Fourier level, the Galerkin ODE RHS `galerkinVectorField S c`
equals (minus) the SQG nonlinear flux of the lifted `shellMode`
paired with the lifted `shellVelocity` ‚ÄĒ restricted to the shell
support. This is the algebraic content that makes Galerkin-ODE
solutions satisfy the same mode-wise evolution equation as SQG weak
solutions on span `{e_n : n ‚ąą S}`.

For modes outside `S`, both sides are zero (velocity support), but
the lifted Galerkin trajectory only tracks the shell modes anyway, so
the Galerkin ODE is equivalent to the SQG mode-wise equation on `S`. -/

/-- Galerkin RHS on the extended coefficient function equals `-sqgNonlinearFlux`
at every mode `m ‚ąą S`. Both sides decompose as the same Finset sum over
`{‚Ąď ‚ąą S : m-‚Ąď ‚ąą S}` of `a(‚Ąď) ¬∑ a(m-‚Ąď) ¬∑ C(‚Ąď, m-‚Ąď)`. -/
theorem galerkinRHS_eq_neg_sqgNonlinearFlux
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) (c : ‚Ü•S ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    galerkinRHS S (galerkinExtend S c) m
      = -sqgNonlinearFlux (galerkinToLp S c)
          (shellVelocity S (galerkinExtend S c) ¬∑) m := by
  -- Show sqgNonlinearFlux equals the positive Finset.sum over the filter.
  have h_flux : sqgNonlinearFlux (galerkinToLp S c)
          (shellVelocity S (galerkinExtend S c) ¬∑) m
        = ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
            galerkinExtend S c ‚Ąď * galerkinExtend S c (m - ‚Ąď)
              * (‚ąĎ j : Fin 2,
                  sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
    unfold sqgNonlinearFlux
    have h_tsum_eq : ‚ąÄ j : Fin 2,
        fourierConvolution
            (fun ‚Ąď => mFourierCoeff (shellVelocity S (galerkinExtend S c) j) ‚Ąď)
            (fun ‚Ąď => derivSymbol j ‚Ąď
                      * mFourierCoeff (galerkinToLp S c) ‚Ąď) m
          = ‚ąĎ ‚Ąď ‚ąą S,
              mFourierCoeff (shellVelocity S (galerkinExtend S c) j) ‚Ąď
                * (derivSymbol j (m - ‚Ąď)
                   * mFourierCoeff (galerkinToLp S c) (m - ‚Ąď)) := by
      intro j
      unfold fourierConvolution
      apply tsum_eq_sum
      intro ‚Ąď h‚Ąď
      simp only [mFourierCoeff_shellVelocity, if_neg h‚Ąď, zero_mul]
    rw [Finset.sum_congr rfl (fun j _ => h_tsum_eq j), Finset.sum_comm]
    have h_factor : ‚ąÄ ‚Ąď ‚ąą S,
        (‚ąĎ j : Fin 2,
          mFourierCoeff (shellVelocity S (galerkinExtend S c) j) ‚Ąď
            * (derivSymbol j (m - ‚Ąď)
               * mFourierCoeff (galerkinToLp S c) (m - ‚Ąď)))
          = galerkinExtend S c ‚Ąď
            * mFourierCoeff (galerkinToLp S c) (m - ‚Ąď)
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
      intros ‚Ąď h‚Ąď
      have h_each : ‚ąÄ j : Fin 2,
          mFourierCoeff (shellVelocity S (galerkinExtend S c) j) ‚Ąď
            * (derivSymbol j (m - ‚Ąď)
               * mFourierCoeff (galerkinToLp S c) (m - ‚Ąď))
            = galerkinExtend S c ‚Ąď
              * mFourierCoeff (galerkinToLp S c) (m - ‚Ąď)
              * (sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := by
        intro j
        rw [mFourierCoeff_shellVelocity, if_pos h‚Ąď,
            galerkinExtend_apply_of_mem _ _ h‚Ąď]
        ring
      rw [Finset.sum_congr rfl (fun j _ => h_each j), ‚Üź Finset.mul_sum]
    rw [Finset.sum_congr rfl h_factor]
    have h_if : ‚ąÄ ‚Ąď ‚ąą S,
        galerkinExtend S c ‚Ąď
          * mFourierCoeff (galerkinToLp S c) (m - ‚Ąď)
          * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
          = if m - ‚Ąď ‚ąą S then
              galerkinExtend S c ‚Ąď * galerkinExtend S c (m - ‚Ąď)
                * (‚ąĎ j : Fin 2,
                    sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))
            else 0 := by
      intros ‚Ąď _
      rw [mFourierCoeff_galerkinToLp]
      split_ifs with hm‚Ąď
      ¬∑ rfl
      ¬∑ rw [galerkinExtend_apply_of_not_mem _ _ hm‚Ąď, mul_zero, zero_mul]
    rw [Finset.sum_congr rfl h_if, ‚Üź Finset.sum_filter]
  -- Now conclude: galerkinRHS S (ext c) m = -(h_flux RHS) = -h_flux
  rw [h_flux]
  unfold galerkinRHS
  rfl

/-! ### ¬ß10.49 Unified stationary-shape `SqgEvolutionAxioms_strong`

Bundles the ¬ß10.43 unified flux-vanishing theorem into a universal
multi-mode discharge of `SqgEvolutionAxioms_strong`. Strictly subsumes
¬ß10.34 (`shellMode_const` for radial shell) and ¬ß10.40
(`shellMode_const_of_collinear`) as corollaries via
`IsStationaryShape.of_isRadialShell` / `of_isCollinear`. -/

/-- **`IsSqgWeakSolution` for stationary-shape őł.** Analogue of
`isSqgWeakSolution_shellMode_const` (¬ß10.34) under the unified
predicate. -/
theorem isSqgWeakSolution_shellMode_const_of_stationaryShape
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsStationaryShape S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    IsSqgWeakSolution
        (fun _ : ‚ĄĚ => shellMode S a)
        (fun (j : Fin 2) (_ : ‚ĄĚ) => shellVelocity S a j) where
  duhamel := fun m s t _ _ => by
    have h_integrand :
        (fun ŌĄ : ‚ĄĚ => sqgNonlinearFlux
            ((fun _ : ‚ĄĚ => shellMode S a) ŌĄ)
            (fun j : Fin 2 =>
              (fun (j : Fin 2) (_ : ‚ĄĚ) => shellVelocity S a j) j ŌĄ) m)
          = fun _ => (0 : ‚Ąā) := by
      funext ŌĄ
      exact sqgNonlinearFlux_shellMode_eq_zero_of_stationaryShape hS a m
    rw [h_integrand]
    simp

/-- **Unified `SqgEvolutionAxioms_strong.shellMode_const_of_stationaryShape`.**
Multi-mode discharge for any stationary-shape `S`. Recovers ¬ß10.34
(radial shell via `IsStationaryShape.of_isRadialShell`) and ¬ß10.40
(collinear via `IsStationaryShape.of_isCollinear`) as corollaries. -/
theorem SqgEvolutionAxioms_strong.shellMode_const_of_stationaryShape
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsStationaryShape S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    SqgEvolutionAxioms_strong (fun _ : ‚ĄĚ => shellMode S a) := by
  have hSumm : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 1 n) ^ 2 *
        ‚ÄĖmFourierCoeff (shellMode S a) n‚ÄĖ ^ 2) :=
    hsSeminormSq_summable_of_finite_support 1 (shellMode S a) S
      (fun n hn => mFourierCoeff_shellMode_eq_zero_of_not_mem S a hn)
  exact SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP
    (sqgEvolutionAxioms_shellMode_const S a)
    (MaterialMaxPrinciple.of_const (shellMode S a) hSumm)
    (fun j _ => shellVelocity S a j)
    (fun j _ => isSqgVelocityComponent_shellMode S a j)
    (isSqgWeakSolution_shellMode_const_of_stationaryShape hS a)

/-! ### ¬ß10.50 Unified stationary-shape regularity capstone

Consumer-facing: for any `S` with `IsStationaryShape` and any `a`, the
constant-in-time `shellMode S a` enjoys uniform ŠłĘňĘ bounds on `[0, 2]`
**unconditionally**. Same statement as `sqg_regularity_shellMode_const`
(¬ß10.35) but with the stationarity hypothesis made explicit ‚ÄĒ useful
in proofs where the shape predicate is tracked. -/

theorem sqg_regularity_via_stationaryShape
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (_hS : IsStationaryShape S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
        hsSeminormSq s ((fun _ : ‚ĄĚ => shellMode S a) t) ‚Č§ M :=
  sqg_regularity_shellMode_const S a

/-! ### ¬ß10.52 Axis-aligned stationary SQG

Specific instance of `IsCollinear` (¬ß10.40): all modes on a single
coordinate axis (x-axis or y-axis). Stationary by reduction to
`IsCollinear`, i.e., via per-pair `C(‚Ąď, k) = 0` from
‚Ąď √ó k = 0 when both on the same axis. -/

/-- **y-axis shell.** Modes with `n 0 = 0`, excluding origin. -/
def IsYAxisShell (S : Finset (Fin 2 ‚Üí ‚Ą§)) : Prop :=
  (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S ‚ąß ‚ąÄ n ‚ąą S, n 0 = 0

/-- **x-axis shell.** Modes with `n 1 = 0`, excluding origin. -/
def IsXAxisShell (S : Finset (Fin 2 ‚Üí ‚Ą§)) : Prop :=
  (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S ‚ąß ‚ąÄ n ‚ąą S, n 1 = 0

/-- y-axis ‚üĻ collinear. -/
theorem IsYAxisShell.isCollinear
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsYAxisShell S) :
    IsCollinear S := by
  intros ‚Ąď h‚Ąď k hk
  rw [hS.2 ‚Ąď h‚Ąď, hS.2 k hk]
  ring

/-- x-axis ‚üĻ collinear. -/
theorem IsXAxisShell.isCollinear
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsXAxisShell S) :
    IsCollinear S := by
  intros ‚Ąď h‚Ąď k hk
  rw [hS.2 ‚Ąď h‚Ąď, hS.2 k hk]
  ring

/-- y-axis ‚üĻ stationary shape. -/
theorem IsYAxisShell.isStationaryShape
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsYAxisShell S) :
    IsStationaryShape S :=
  IsStationaryShape.of_isCollinear hS.1 hS.isCollinear

/-- x-axis ‚üĻ stationary shape. -/
theorem IsXAxisShell.isStationaryShape
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsXAxisShell S) :
    IsStationaryShape S :=
  IsStationaryShape.of_isCollinear hS.1 hS.isCollinear

/-! ### ¬ß10.51 Auto-Picard ‚ÄĒ local existence from ContDiff alone

Automatic consumer-facing version of ¬ß10.44. Constants are derived
automatically from:
* `galerkinVectorField_locally_lipschitz` (¬ß10.42) ‚ÄĒ local Lipschitz.
* `Metric.mem_nhds_iff` ‚ÄĒ open-ball neighborhood inside the Lipschitz
  region; shrink to a closed ball `closedBall c‚āÄ (őī/2)`.
* `isCompact_closedBall` in the finite-dim Pi space
  (ProperSpace via Fintype).
* `galerkinVectorField_continuous` + `IsCompact.bddAbove_image` ‚ÄĒ
  uniform bound `L` on the closed ball.
* Pick `őĶ := a / (L + 1)`, yielding `L ¬∑ őĶ < a` for the
  `mul_max_le` Picard-Lindel√∂f hypothesis. -/

theorem galerkin_local_exists
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) :
    ‚ąÉ őĶ : ‚ĄĚ, 0 < őĶ ‚ąß ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      ‚ąÄ t ‚ąą Set.Icc (-őĶ) őĶ,
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (-őĶ) őĶ) t := by
  classical
  -- Step 1: local Lipschitz K on some neighborhood U.
  obtain ‚ü®K, U, hU, hLip‚ü© := galerkinVectorField_locally_lipschitz S c‚āÄ
  -- Step 2: U contains an open ball of radius őī.
  obtain ‚ü®őī, hőī_pos, hőī_sub‚ü© := Metric.mem_nhds_iff.mp hU
  -- Step 3: shrink to closed ball of radius a := őī/2.
  have ha_pos : (0 : ‚ĄĚ) < őī / 2 := by linarith
  set a : NNReal := ‚ü®őī / 2, ha_pos.le‚ü© with ha_def
  have ha_coe : (a : ‚ĄĚ) = őī / 2 := rfl
  have h_closedBall_sub : Metric.closedBall c‚āÄ (a : ‚ĄĚ) ‚äÜ U := by
    intro x hx
    apply hőī_sub
    rw [Metric.mem_ball]
    rw [Metric.mem_closedBall] at hx
    rw [ha_coe] at hx
    linarith
  have hLip_ball : LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall c‚āÄ (a : ‚ĄĚ)) :=
    hLip.mono h_closedBall_sub
  -- Step 4: closedBall is compact (finite-dim Pi).
  have hCompact : IsCompact (Metric.closedBall c‚āÄ (a : ‚ĄĚ)) :=
    isCompact_closedBall c‚āÄ _
  -- Step 5: galerkinVectorField is continuous ‚üĻ ‚ÄĖ¬∑‚ÄĖ bounded on ball.
  have hCont : Continuous (galerkinVectorField S) :=
    galerkinVectorField_continuous S
  have h_bdd := hCompact.bddAbove_image hCont.norm.continuousOn
  obtain ‚ü®Lreal, hLreal‚ü© := h_bdd
  have hL0 : 0 ‚Č§ Lreal := by
    have h_c‚āÄ_in : c‚āÄ ‚ąą Metric.closedBall c‚āÄ (a : ‚ĄĚ) :=
      Metric.mem_closedBall_self ha_pos.le
    have h_norm_le : ‚ÄĖgalerkinVectorField S c‚āÄ‚ÄĖ ‚Č§ Lreal :=
      hLreal ‚ü®c‚āÄ, h_c‚āÄ_in, rfl‚ü©
    exact le_trans (norm_nonneg _) h_norm_le
  set L : NNReal := ‚ü®Lreal, hL0‚ü© with hL_def
  have hBound : ‚ąÄ c ‚ąą Metric.closedBall c‚āÄ (a : ‚ĄĚ),
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ (L : ‚ĄĚ) := by
    intros c hc
    exact hLreal ‚ü®c, hc, rfl‚ü©
  -- Step 6: pick őĶ := a / (L + 1); then L ¬∑ őĶ < a.
  set őĶ : ‚ĄĚ := (a : ‚ĄĚ) / ((L : ‚ĄĚ) + 1) with hőĶ_def
  have hLp1 : 0 < (L : ‚ĄĚ) + 1 := by
    have : (L : ‚ĄĚ) = Lreal := rfl
    linarith
  have hőĶ_pos : 0 < őĶ := div_pos ha_pos hLp1
  have hTime : (L : ‚ĄĚ) * őĶ ‚Č§ (a : ‚ĄĚ) := by
    have hL_le : (L : ‚ĄĚ) ‚Č§ (L : ‚ĄĚ) + 1 := by linarith
    have h_mul_eq : ((L : ‚ĄĚ) + 1) * őĶ = (a : ‚ĄĚ) := by
      rw [hőĶ_def]; field_simp
    have h_mul_le : (L : ‚ĄĚ) * őĶ ‚Č§ ((L : ‚ĄĚ) + 1) * őĶ :=
      mul_le_mul_of_nonneg_right hL_le hőĶ_pos.le
    linarith
  -- Step 7: apply ¬ß10.44.
  obtain ‚ü®őĪ, hőĪ‚āÄ, hőĪ‚ü© :=
    galerkin_local_exists_given_bounds S c‚āÄ hőĶ_pos hLip_ball hBound hTime
  exact ‚ü®őĶ, hőĶ_pos, őĪ, hőĪ‚āÄ, hőĪ‚ü©

/-! ### ¬ß10.56 Finite-Fourier-support MMP with uniform coefficient bound

`MaterialMaxPrinciple` is an open axiom for general time-varying őł
(classical Constantin-C√≥rdoba analysis). But for the specific class
of őł with **uniformly bounded coefficients on a fixed finite Fourier
support `S`**, MMP reduces to a finite-dim polynomial-in-M bound on
the ŠłĘ¬Ļ seminorm. This section discharges that case unconditionally.

Downstream consumer: any time-varying Galerkin trajectory with
`‚ÄĖcoefficients‚ÄĖ‚ąě ‚Č§ M` (uniform in time) and support in `S` produces
MMP via this lemma, closing the `SqgEvolutionAxioms_strong` chain
for the lifted trajectory (once the Duhamel identity also holds).

**Bound formula.** `hsSeminormSq 1 (őł t) ‚Č§ M¬≤ ¬∑ ‚ąĎ_{n ‚ąą S} ŌÉ‚āĀ(n)¬≤`
where `ŌÉ‚āĀ(n) = fracDerivSymbol 1 n`. Right-hand side is a constant
depending only on `S` and `M`. -/

theorem MaterialMaxPrinciple.of_finite_support_uniform
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S, mFourierCoeff (őł ŌĄ) n = 0)
    (M : ‚ĄĚ)
    (hBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖmFourierCoeff (őł ŌĄ) n‚ÄĖ ‚Č§ M) :
    MaterialMaxPrinciple őł where
  hOnePropagation := by
    refine ‚ü®M ^ 2 * (‚ąĎ n ‚ąą S, (fracDerivSymbol 1 n) ^ 2), ?_‚ü©
    intros t ht
    unfold hsSeminormSq
    rw [tsum_eq_sum (s := S) (fun n hn => by
      rw [hSupport t n hn, norm_zero]; ring)]
    calc ‚ąĎ n ‚ąą S, (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff (őł t) n‚ÄĖ ^ 2
        ‚Č§ ‚ąĎ n ‚ąą S, (fracDerivSymbol 1 n) ^ 2 * M ^ 2 := by
          apply Finset.sum_le_sum
          intros n _
          apply mul_le_mul_of_nonneg_left _ (sq_nonneg _)
          exact pow_le_pow_left‚āÄ (norm_nonneg _) (hBound t ht n) 2
      _ = M ^ 2 * ‚ąĎ n ‚ąą S, (fracDerivSymbol 1 n) ^ 2 := by
          rw [Finset.mul_sum]; apply Finset.sum_congr rfl
          intros n _; ring
  hOneSummability := fun t _ =>
    hsSeminormSq_summable_of_finite_support 1 (őł t) S (hSupport t)
  freeDerivativeAtKappaMax := trivial
  materialSegmentExpansion := trivial
  farFieldBoundary := trivial

/-! ### ¬ß10.55 Mode-wise FTC for Galerkin trajectories

Given a Galerkin solution `őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)` satisfying
`HasDerivAt őĪ (galerkinVectorField S (őĪ ŌĄ)) ŌĄ` at every `ŌĄ`, the
mode-wise difference `őĪ t m - őĪ s m` equals the interval integral of
the mode-projected vector field over `[s, t]`.

Direct consequence of mathlib's `intervalIntegral.integral_eq_sub_of_hasDerivAt`
after projecting `őĪ` and its derivative to a single coordinate via
`hasDerivAt_pi`. Continuity of the integrand follows from continuity
of `őĪ` (every `HasDerivAt` is continuous) composed with continuity of
`galerkinVectorField` (¬ß10.39).

Combining with ¬ß10.48 `galerkinRHS_eq_neg_sqgNonlinearFlux`, this
gives the Duhamel identity at the Galerkin level ‚ÄĒ `őłŐā(m, t) - őłŐā(m, s)
= -‚ąę_s^t sqgNonlinearFlux` ‚ÄĒ the final piece needed to show the
Galerkin lift is an `IsSqgWeakSolution` for modes `m ‚ąą S`. -/

theorem galerkin_mode_FTC
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, HasDerivAt őĪ (galerkinVectorField S (őĪ ŌĄ)) ŌĄ)
    (m : ‚Ü•S) (s t : ‚ĄĚ) :
    őĪ t m - őĪ s m = ‚ąę ŌĄ in s..t, (galerkinVectorField S (őĪ ŌĄ)) m := by
  have hProj : ‚ąÄ ŌĄ, HasDerivAt (fun ŌĄ => őĪ ŌĄ m)
      ((galerkinVectorField S (őĪ ŌĄ)) m) ŌĄ :=
    fun ŌĄ => (hasDerivAt_pi.mp (hőĪ ŌĄ)) m
  have hőĪ_cont : Continuous őĪ :=
    continuous_iff_continuousAt.mpr (fun ŌĄ => (hőĪ ŌĄ).continuousAt)
  have hGVF_cont : Continuous (galerkinVectorField S) :=
    galerkinVectorField_continuous S
  have h_integrand_cont :
      Continuous (fun ŌĄ => (galerkinVectorField S (őĪ ŌĄ)) m) :=
    (continuous_apply m).comp (hGVF_cont.comp hőĪ_cont)
  symm
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ¬∑ intros ŌĄ _; exact hProj ŌĄ
  ¬∑ exact h_integrand_cont.intervalIntegrable _ _

/-! ### ¬ß10.57 Finite-support BKMCriterionS2 with uniform coefficient bound

Parallel companion to ¬ß10.56 `MaterialMaxPrinciple.of_finite_support_uniform`.
For any time-varying őł with finite Fourier support on `S` and uniform
coefficient bound `M`, `BKMCriterionS2` holds unconditionally: every
ŠłĘňĘ seminorm (s ‚ąą (1, 2]) is bounded by `M¬≤ ¬∑ ‚ąĎ_{n‚ąąS} (fracDerivSymbol s n)¬≤`.

Together ¬ß10.56 + ¬ß10.57 discharge BOTH remaining analytic axioms of
the conditional Theorem 3 chain (`MaterialMaxPrinciple` + `BKMCriterionS2`)
for the class of finite-Fourier-support trajectories with uniform
coefficient bound. Consequence: `sqg_regularity_via_s2_bootstrap`
applied to this class gives an **unconditional** ŠłĘňĘ bound on `[0, 2]`
for any such őł ‚ÄĒ and combined with `of_IsSqgWeakSolution_via_MMP`,
any such őł that is a Galerkin/weak solution admits a full
`SqgEvolutionAxioms_strong` discharge without any open axiom. -/

theorem BKMCriterionS2.of_finite_support_uniform
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S, mFourierCoeff (őł ŌĄ) n = 0)
    (M : ‚ĄĚ)
    (hBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖmFourierCoeff (őł ŌĄ) n‚ÄĖ ‚Č§ M) :
    BKMCriterionS2 őł where
  hsPropagationS2 := fun _ s _ _ => by
    refine ‚ü®M ^ 2 * (‚ąĎ n ‚ąą S, (fracDerivSymbol s n) ^ 2), ?_‚ü©
    intros t ht
    unfold hsSeminormSq
    rw [tsum_eq_sum (s := S) (fun n hn => by
      rw [hSupport t n hn, norm_zero]; ring)]
    calc ‚ąĎ n ‚ąą S, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (őł t) n‚ÄĖ ^ 2
        ‚Č§ ‚ąĎ n ‚ąą S, (fracDerivSymbol s n) ^ 2 * M ^ 2 := by
          apply Finset.sum_le_sum
          intros n _
          apply mul_le_mul_of_nonneg_left _ (sq_nonneg _)
          exact pow_le_pow_left‚āÄ (norm_nonneg _) (hBound t ht n) 2
      _ = M ^ 2 * ‚ąĎ n ‚ąą S, (fracDerivSymbol s n) ^ 2 := by
          rw [Finset.mul_sum]; apply Finset.sum_congr rfl
          intros n _; ring

/-! ### ¬ß10.58 Capstones for finite-support uniform-bound trajectories

Combines ¬ß10.56 (MMP) and ¬ß10.57 (BKM) into the two fundamental
consumer-facing results for the finite-Fourier-support + uniform-
coefficient-bound class:

1. `sqg_regularity_of_finite_support_uniform` ‚ÄĒ unconditional ŠłĘňĘ bound
   on `[0, 2]` for ANY such őł. Only hypotheses are finite support
   and uniform ‚Ąď‚ąě bound on Fourier coefficients ‚ÄĒ no axiom appears.
2. `SqgEvolutionAxioms_strong.of_finite_support_weak_solution` ‚ÄĒ full
   strong-axiom discharge for such őł that is also a weak solution.

These are the strongest results shipped in this repo: the conditional
Theorem 3 chain becomes **unconditional** for the entire finite-
Fourier-support trajectory class. Covers constant-in-time, radial-
shell, collinear, axis-aligned, and every time-varying trajectory on
a fixed finite support with controlled coefficients. -/

/-- **Unconditional regularity for finite-support uniform-bound őł.**
The ŠłĘňĘ bound holds for every `s ‚ąą [0, 2]` without any open axiom. -/
theorem sqg_regularity_of_finite_support_uniform
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S, mFourierCoeff (őł ŌĄ) n = 0)
    (M : ‚ĄĚ)
    (hBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖmFourierCoeff (őł ŌĄ) n‚ÄĖ ‚Č§ M) :
    ‚ąÄ s : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ 2 ‚Üí
      ‚ąÉ M' : ‚ĄĚ, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí hsSeminormSq s (őł t) ‚Č§ M' :=
  sqg_regularity_via_s2_bootstrap őł
    (MaterialMaxPrinciple.of_finite_support_uniform őł S hSupport M hBound)
    (BKMCriterionS2.of_finite_support_uniform őł S hSupport M hBound)

/-- **Unconditional `SqgEvolutionAxioms_strong` for finite-support
uniform-bound weak solutions.** Bundles ¬ß10.56 (MMP discharge) with
`of_IsSqgWeakSolution_via_MMP`. -/
theorem SqgEvolutionAxioms_strong.of_finite_support_weak_solution
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S, mFourierCoeff (őł ŌĄ) n = 0)
    (M : ‚ĄĚ)
    (hBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖmFourierCoeff (őł ŌĄ) n‚ÄĖ ‚Č§ M)
    (hE : SqgEvolutionAxioms őł)
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hu_velocity : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ),
      IsSqgVelocityComponent (őł ŌĄ) (u j ŌĄ) j)
    (hweak : IsSqgWeakSolution őł u) :
    SqgEvolutionAxioms_strong őł :=
  SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP hE
    (MaterialMaxPrinciple.of_finite_support_uniform őł S hSupport M hBound)
    u hu_velocity hweak

/-! ### ¬ß10.59 Demo: `shellMode_const` via ¬ß10.58 subsumption

Concrete re-derivation of ¬ß10.49 (`SqgEvolutionAxioms_strong.shellMode_const_of_stationaryShape`)
via ¬ß10.58's finite-support weak-solution route. Verifies that the new
finite-support capstone is strong enough to recover the pre-existing
stationary-shape discharge. Sanity check that the machinery composes
end-to-end.

Bound: `‚ÄĖmFourierCoeff (shellMode S a) n‚ÄĖ ‚Č§ ‚ąĎ_{m ‚ąą S} ‚ÄĖa m‚ÄĖ` ‚ÄĒ sum
of amplitudes bounds any single coefficient (trivially on S, zero
off S). -/

theorem SqgEvolutionAxioms_strong.shellMode_const_via_finite_support
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsStationaryShape S)
    (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    SqgEvolutionAxioms_strong (fun _ : ‚ĄĚ => shellMode S a) := by
  refine SqgEvolutionAxioms_strong.of_finite_support_weak_solution
    (fun _ : ‚ĄĚ => shellMode S a) S ?_ (‚ąĎ m ‚ąą S, ‚ÄĖa m‚ÄĖ) ?_
    (sqgEvolutionAxioms_shellMode_const S a)
    (fun j _ => shellVelocity S a j)
    (fun j _ => isSqgVelocityComponent_shellMode S a j)
    (isSqgWeakSolution_shellMode_const_of_stationaryShape hS a)
  ¬∑ intros _ n hn
    exact mFourierCoeff_shellMode_eq_zero_of_not_mem S a hn
  ¬∑ intros _ _ n
    rw [mFourierCoeff_shellMode]
    split_ifs with hn
    ¬∑ exact Finset.single_le_sum (f := fun m => ‚ÄĖa m‚ÄĖ)
        (fun m _ => norm_nonneg _) hn
    ¬∑ rw [norm_zero]
      exact Finset.sum_nonneg (fun _ _ => norm_nonneg _)

/-! ### ¬ß10.60 L¬≤ conservation on a radial shell (trivial case)

For a Galerkin ODE solution on a radial shell, the vector field is
identically zero (¬ß10.37), so the derivative vanishes everywhere and
the solution is **constant in time** by
`is_const_of_deriv_eq_zero`. Consequently the L¬≤ norm
`‚ąĎ_{m‚ąąS} ‚ÄĖőĪ t m‚ÄĖ¬≤` is also constant ‚ÄĒ trivial instance of the general
SQG L¬≤ conservation law.

The **non-trivial** L¬≤ conservation (for general real-symmetric
Galerkin trajectories) requires the `div u = 0` Fourier identity and
is deferred; the radial-shell case discharges it directly. -/

/-- **Radial-shell Galerkin solutions are constant in time.**
`galerkinVectorField ‚Č° 0` on a radial shell, so the derivative
vanishes everywhere and `is_const_of_deriv_eq_zero` applies. -/
theorem galerkin_radialShell_constant
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, HasDerivAt őĪ (galerkinVectorField S (őĪ ŌĄ)) ŌĄ)
    (s t : ‚ĄĚ) : őĪ s = őĪ t := by
  have hDiff : Differentiable ‚ĄĚ őĪ := fun ŌĄ => (hőĪ ŌĄ).differentiableAt
  have hDeriv : ‚ąÄ ŌĄ, deriv őĪ ŌĄ = 0 := fun ŌĄ => by
    rw [(hőĪ ŌĄ).deriv]
    exact galerkinVectorField_eq_zero_of_isRadialShell hS (őĪ ŌĄ)
  exact is_const_of_deriv_eq_zero hDiff hDeriv s t

/-- **L¬≤ norm is conserved along a radial-shell Galerkin solution.**
Trivial corollary of `galerkin_radialShell_constant`: `őĪ` is time-
constant, so every symmetric function of `őĪ t`, including the L¬≤
coordinate sum, is constant. -/
theorem galerkin_radialShell_L2_conserved
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsRadialShell S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, HasDerivAt őĪ (galerkinVectorField S (őĪ ŌĄ)) ŌĄ)
    (s t : ‚ĄĚ) :
    (‚ąĎ m, ‚ÄĖőĪ t m‚ÄĖ ^ 2) = (‚ąĎ m, ‚ÄĖőĪ s m‚ÄĖ ^ 2) := by
  rw [galerkin_radialShell_constant hS őĪ hőĪ t s]

/-! ### ¬ß10.61 Commutator symbol and trig-poly gradient surrogate

Foundational definitions for a genuine commutator-based BKM estimate
on the trig-poly class. ¬ß10.57 proves `BKMCriterionS2` on finite-
support őł via the trivial hypothesis `‚ÄĖőłŐā(n)‚ÄĖ ‚Č§ M`. The present
section, and ¬ß¬ß10.62-10.67 that follow, work toward a *derived*
bound of the form
```
‚ÄĖőł(t)‚ÄĖ¬≤_{ŠłĘ¬≤} ‚Č§ ‚ÄĖőł(0)‚ÄĖ¬≤_{ŠłĘ¬≤} ¬∑ exp (C ¬∑ K ¬∑ t)
```
where `K` bounds a velocity Sobolev quantity rather than the
coefficients themselves. This is the classical Kato-Ponce / Beale-
Kato-Majda shape.

Key definitions introduced here:

* `gradInftyFS S u` ‚ÄĒ the ‚Ąď¬Ļ Fourier surrogate for `‚ÄĖ‚ąáu‚ÄĖ_‚ąě` on the
  trig-poly class. For `u : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā` supported on `S`,
  `gradInftyFS S u := ‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖ‚Ąď‚ÄĖ ¬∑ ‚ÄĖu ‚Ąď‚ÄĖ`. By Fourier inversion
  this dominates `‚ÄĖ‚ąáu‚ÄĖ_‚ąě` in the true L‚ąě sense, but we never need
  that inequality: we use `gradInftyFS` directly as the velocity
  Sobolev hypothesis in ¬ß¬ß10.63 and following.

* `comSymb k ‚Ąď := ‚ÄĖk+‚Ąď‚ÄĖ^4 - ‚ÄĖk‚ÄĖ^4` ‚ÄĒ the symbol of the s=2 commutator
  `[őõ¬≤, u¬∑‚ąá]` on the Fourier side. ¬ß10.62 proves the pointwise
  Lipschitz-type estimate `|comSymb k ‚Ąď| ‚Č§ 4 ¬∑ (‚ÄĖk‚ÄĖ+‚ÄĖ‚Ąď‚ÄĖ)^3 ¬∑ ‚ÄĖ‚Ąď‚ÄĖ`
  used in the bilinear bound of ¬ß10.63.

Both definitions are noncomputable wrappers over `latticeNorm`; no
mathlib analytic machinery is invoked here. -/

/-- **‚Ąď¬Ļ Fourier surrogate for `‚ÄĖ‚ąáu‚ÄĖ_‚ąě`.** For a Fourier coefficient
function `u : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā` supported on a Finset `S`, returns
`‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖ‚Ąď‚ÄĖ ¬∑ ‚ÄĖu ‚Ąď‚ÄĖ`. On trig-poly this bounds the true `‚ÄĖ‚ąáu‚ÄĖ_‚ąě`
via the triangle inequality on the inverse Fourier sum; we take it
as the velocity-Sobolev hypothesis directly in ¬ß¬ß10.63-10.67. -/
noncomputable def gradInftyFS {d : Type*} [Fintype d] [DecidableEq d]
    (S : Finset (d ‚Üí ‚Ą§)) (u : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā) : ‚ĄĚ :=
  ‚ąĎ ‚Ąď ‚ąą S, latticeNorm ‚Ąď * ‚ÄĖu ‚Ąď‚ÄĖ

lemma gradInftyFS_nonneg {d : Type*} [Fintype d] [DecidableEq d]
    (S : Finset (d ‚Üí ‚Ą§)) (u : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    0 ‚Č§ gradInftyFS S u := by
  unfold gradInftyFS
  exact Finset.sum_nonneg (fun ‚Ąď _ =>
    mul_nonneg (latticeNorm_nonneg ‚Ąď) (norm_nonneg _))

lemma gradInftyFS_empty {d : Type*} [Fintype d] [DecidableEq d]
    (u : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    gradInftyFS (‚ąÖ : Finset (d ‚Üí ‚Ą§)) u = 0 := by
  unfold gradInftyFS
  simp

/-- **Commutator symbol at order s = 2.** This is the Fourier symbol
appearing in `[őõ¬≤, u¬∑‚ąá]` ‚ÄĒ specifically the factor `‚ÄĖk+‚Ąď‚ÄĖ^4 - ‚ÄĖk‚ÄĖ^4`
that multiplies `√Ľ(‚Ąď)¬∑őłŐā(k)` in the Fourier-space form of the
commutator applied to two modes with momenta `‚Ąď` (velocity) and
`k` (scalar). -/
noncomputable def comSymb {d : Type*} [Fintype d]
    (k ‚Ąď : d ‚Üí ‚Ą§) : ‚ĄĚ :=
  (latticeNorm (k + ‚Ąď)) ^ 4 - (latticeNorm k) ^ 4

lemma comSymb_zero_left {d : Type*} [Fintype d] (‚Ąď : d ‚Üí ‚Ą§) :
    comSymb (0 : d ‚Üí ‚Ą§) ‚Ąď = (latticeNorm ‚Ąď) ^ 4 := by
  unfold comSymb
  simp [latticeNorm]

lemma comSymb_zero_right {d : Type*} [Fintype d] (k : d ‚Üí ‚Ą§) :
    comSymb k (0 : d ‚Üí ‚Ą§) = 0 := by
  unfold comSymb
  simp

/-! ### ¬ß10.62 Triangle inequality, Cauchy-Schwarz, and symbol bound

Three building blocks for the commutator estimate of ¬ß10.63:

1. `latticeNorm_inner_abs_le` ‚ÄĒ Cauchy-Schwarz: `|ő£‚Īľ k‚Īľ¬∑‚Ąď‚Īľ| ‚Č§ ‚ÄĖk‚ÄĖ¬∑‚ÄĖ‚Ąď‚ÄĖ`,
   via `Finset.sum_mul_sq_le_sq_mul_sq` (squared CS) + Real.sqrt.
2. `latticeNorm_add_le` ‚ÄĒ triangle inequality on the integer lattice norm.
3. `comSymb_abs_le` ‚ÄĒ the symbol bound
   `|‚ÄĖk+‚Ąď‚ÄĖ^4 - ‚ÄĖk‚ÄĖ^4| ‚Č§ 6 ¬∑ (‚ÄĖk‚ÄĖ+‚ÄĖ‚Ąď‚ÄĖ)^3 ¬∑ ‚ÄĖ‚Ąď‚ÄĖ`, proved via the
   factorisation `a^4 - b^4 = (a¬≤-b¬≤)(a¬≤+b¬≤)` with `|a¬≤-b¬≤|` controlled
   by CS and `a¬≤+b¬≤` bounded via triangle-squared. Constant 6 is
   sub-optimal (classical Kato-Ponce is 4) but sufficient. -/

/-- **Cauchy-Schwarz on the integer lattice.** -/
lemma latticeNorm_inner_abs_le {d : Type*} [Fintype d] (k ‚Ąď : d ‚Üí ‚Ą§) :
    |‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ)| ‚Č§ latticeNorm k * latticeNorm ‚Ąď := by
  set S : ‚ĄĚ := ‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ)
  have hCSSq : S ^ 2 ‚Č§ (‚ąĎ j, (k j : ‚ĄĚ) ^ 2) * (‚ąĎ j, (‚Ąď j : ‚ĄĚ) ^ 2) :=
    Finset.sum_mul_sq_le_sq_mul_sq _ _ _
  have hKNn : 0 ‚Č§ ‚ąĎ j, (k j : ‚ĄĚ) ^ 2 := Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  have hLNn : 0 ‚Č§ ‚ąĎ j, (‚Ąď j : ‚ĄĚ) ^ 2 := Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  have hProdNn : 0 ‚Č§ (‚ąĎ j, (k j : ‚ĄĚ) ^ 2) * (‚ąĎ j, (‚Ąď j : ‚ĄĚ) ^ 2) :=
    mul_nonneg hKNn hLNn
  have hSqAbs : S ^ 2 = |S| ^ 2 := (sq_abs S).symm
  have hAbsSq : |S| ^ 2 ‚Č§ (‚ąĎ j, (k j : ‚ĄĚ) ^ 2) * (‚ąĎ j, (‚Ąď j : ‚ĄĚ) ^ 2) := by
    rw [‚Üź hSqAbs]; exact hCSSq
  have hAbsNn : 0 ‚Č§ |S| := abs_nonneg _
  have hKLNn : 0 ‚Č§ latticeNorm k * latticeNorm ‚Ąď :=
    mul_nonneg (latticeNorm_nonneg _) (latticeNorm_nonneg _)
  have hKLSq : (latticeNorm k * latticeNorm ‚Ąď) ^ 2
      = (‚ąĎ j, (k j : ‚ĄĚ) ^ 2) * (‚ąĎ j, (‚Ąď j : ‚ĄĚ) ^ 2) := by
    rw [mul_pow, latticeNorm_sq, latticeNorm_sq]
  have : |S| ^ 2 ‚Č§ (latticeNorm k * latticeNorm ‚Ąď) ^ 2 := by
    rw [hKLSq]; exact hAbsSq
  exact (pow_le_pow_iff_left‚āÄ hAbsNn hKLNn (by norm_num : (2 : ‚Ąē) ‚Č† 0)).mp this

/-- **Expansion of `‚ÄĖk+‚Ąď‚ÄĖ¬≤ - ‚ÄĖk‚ÄĖ¬≤`.** -/
lemma latticeNorm_add_sq_sub_sq {d : Type*} [Fintype d] (k ‚Ąď : d ‚Üí ‚Ą§) :
    (latticeNorm (k + ‚Ąď)) ^ 2 - (latticeNorm k) ^ 2
      = 2 * (‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ)) + (latticeNorm ‚Ąď) ^ 2 := by
  rw [latticeNorm_sq, latticeNorm_sq, latticeNorm_sq]
  have hSum : ‚ąĎ j, ((k + ‚Ąď) j : ‚ĄĚ) ^ 2
      = ‚ąĎ j, ((k j : ‚ĄĚ) ^ 2 + 2 * ((k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ)) + (‚Ąď j : ‚ĄĚ) ^ 2) := by
    apply Finset.sum_congr rfl
    intros j _
    have hCast : ((k + ‚Ąď) j : ‚ĄĚ) = (k j : ‚ĄĚ) + (‚Ąď j : ‚ĄĚ) := by
      simp only [Pi.add_apply, Int.cast_add]
    rw [hCast]; ring
  rw [hSum, Finset.sum_add_distrib, Finset.sum_add_distrib, ‚Üź Finset.mul_sum]
  ring

/-- **Triangle inequality for `latticeNorm`.** -/
lemma latticeNorm_add_le {d : Type*} [Fintype d] (k ‚Ąď : d ‚Üí ‚Ą§) :
    latticeNorm (k + ‚Ąď) ‚Č§ latticeNorm k + latticeNorm ‚Ąď := by
  have hCS := latticeNorm_inner_abs_le k ‚Ąď
  have hAbs : ‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ) ‚Č§ latticeNorm k * latticeNorm ‚Ąď :=
    le_of_abs_le hCS
  have hSq : (latticeNorm (k + ‚Ąď)) ^ 2 ‚Č§ (latticeNorm k + latticeNorm ‚Ąď) ^ 2 := by
    have hExp := latticeNorm_add_sq_sub_sq k ‚Ąď
    have hkSqNn : 0 ‚Č§ (latticeNorm k) ^ 2 := sq_nonneg _
    nlinarith [hExp, hAbs, sq_nonneg (latticeNorm k), sq_nonneg (latticeNorm ‚Ąď)]
  have h1 : 0 ‚Č§ latticeNorm (k + ‚Ąď) := latticeNorm_nonneg _
  have h2 : 0 ‚Č§ latticeNorm k + latticeNorm ‚Ąď :=
    add_nonneg (latticeNorm_nonneg _) (latticeNorm_nonneg _)
  exact (pow_le_pow_iff_left‚āÄ h1 h2 (by norm_num : (2 : ‚Ąē) ‚Č† 0)).mp hSq

/-- **Algebraic bound on `|‚ÄĖk+‚Ąď‚ÄĖ¬≤ - ‚ÄĖk‚ÄĖ¬≤|`.** -/
lemma abs_latticeNorm_add_sq_sub_sq_le {d : Type*} [Fintype d] (k ‚Ąď : d ‚Üí ‚Ą§) :
    |(latticeNorm (k + ‚Ąď)) ^ 2 - (latticeNorm k) ^ 2|
      ‚Č§ 3 * (latticeNorm k + latticeNorm ‚Ąď) * latticeNorm ‚Ąď := by
  rw [latticeNorm_add_sq_sub_sq]
  have hCS := latticeNorm_inner_abs_le k ‚Ąď
  have h‚Ąď_nn : 0 ‚Č§ latticeNorm ‚Ąď := latticeNorm_nonneg _
  have hk_nn : 0 ‚Č§ latticeNorm k := latticeNorm_nonneg _
  have hSqNn : 0 ‚Č§ (latticeNorm ‚Ąď) ^ 2 := sq_nonneg _
  have hSumBd : |2 * (‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ))|
      ‚Č§ 2 * (latticeNorm k * latticeNorm ‚Ąď) := by
    rw [abs_mul, abs_of_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 2)]
    exact mul_le_mul_of_nonneg_left hCS (by norm_num : (0 : ‚ĄĚ) ‚Č§ 2)
  have hTri : |2 * (‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ)) + (latticeNorm ‚Ąď) ^ 2|
      ‚Č§ 2 * (latticeNorm k * latticeNorm ‚Ąď) + (latticeNorm ‚Ąď) ^ 2 := by
    have step1 :
        |2 * (‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ)) + (latticeNorm ‚Ąď) ^ 2|
          ‚Č§ |2 * (‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ))| + |(latticeNorm ‚Ąď) ^ 2| :=
      abs_add_le _ _
    have step2 : |(latticeNorm ‚Ąď) ^ 2| = (latticeNorm ‚Ąď) ^ 2 := abs_of_nonneg hSqNn
    linarith [step1, step2, hSumBd]
  calc |2 * (‚ąĎ j, (k j : ‚ĄĚ) * (‚Ąď j : ‚ĄĚ)) + (latticeNorm ‚Ąď) ^ 2|
      ‚Č§ 2 * (latticeNorm k * latticeNorm ‚Ąď) + (latticeNorm ‚Ąď) ^ 2 := hTri
    _ = (2 * latticeNorm k + latticeNorm ‚Ąď) * latticeNorm ‚Ąď := by ring
    _ ‚Č§ 3 * (latticeNorm k + latticeNorm ‚Ąď) * latticeNorm ‚Ąď :=
        mul_le_mul_of_nonneg_right (by linarith) h‚Ąď_nn

/-- **Symbol bound for `comSymb`.** The Kato-Ponce‚Äďshaped Lipschitz
estimate on the s=2 commutator symbol:
`|‚ÄĖk+‚Ąď‚ÄĖ^4 - ‚ÄĖk‚ÄĖ^4| ‚Č§ 6 ¬∑ (‚ÄĖk‚ÄĖ+‚ÄĖ‚Ąď‚ÄĖ)^3 ¬∑ ‚ÄĖ‚Ąď‚ÄĖ`. Constant `6` is
sub-optimal (classical bound is 4) but suffices for ¬ß10.63. -/
lemma comSymb_abs_le {d : Type*} [Fintype d] (k ‚Ąď : d ‚Üí ‚Ą§) :
    |comSymb k ‚Ąď| ‚Č§ 6 * (latticeNorm k + latticeNorm ‚Ąď) ^ 3 * latticeNorm ‚Ąď := by
  unfold comSymb
  set a := latticeNorm (k + ‚Ąď)
  set b := latticeNorm k
  set c := latticeNorm ‚Ąď
  have hc_nn : 0 ‚Č§ c := latticeNorm_nonneg _
  have hb_nn : 0 ‚Č§ b := latticeNorm_nonneg _
  have ha_nn : 0 ‚Č§ a := latticeNorm_nonneg _
  have ha_le : a ‚Č§ b + c := latticeNorm_add_le k ‚Ąď
  -- Factor `a^4 - b^4 = (a¬≤ - b¬≤)(a¬≤ + b¬≤)`.
  have hFactor : a ^ 4 - b ^ 4 = (a ^ 2 - b ^ 2) * (a ^ 2 + b ^ 2) := by ring
  rw [hFactor, abs_mul]
  have hDiff : |a ^ 2 - b ^ 2| ‚Č§ 3 * (b + c) * c :=
    abs_latticeNorm_add_sq_sub_sq_le k ‚Ąď
  have hSum_bound : a ^ 2 + b ^ 2 ‚Č§ 2 * (b + c) ^ 2 := by
    have hb_sq : b ^ 2 ‚Č§ (b + c) ^ 2 := by
      have := sq_nonneg (b + c)
      nlinarith [hb_nn, hc_nn]
    have ha_sq : a ^ 2 ‚Č§ (b + c) ^ 2 :=
      pow_le_pow_left‚āÄ ha_nn ha_le 2
    linarith
  have hSum_nn : 0 ‚Č§ a ^ 2 + b ^ 2 := by positivity
  have hAbsSum : |a ^ 2 + b ^ 2| = a ^ 2 + b ^ 2 := abs_of_nonneg hSum_nn
  rw [hAbsSum]
  have hProd_le :
      |a ^ 2 - b ^ 2| * (a ^ 2 + b ^ 2)
        ‚Č§ (3 * (b + c) * c) * (2 * (b + c) ^ 2) := by
    have h1 : 0 ‚Č§ |a ^ 2 - b ^ 2| := abs_nonneg _
    have h2 : 0 ‚Č§ 3 * (b + c) * c := by positivity
    exact mul_le_mul hDiff hSum_bound hSum_nn h2
  calc |a ^ 2 - b ^ 2| * (a ^ 2 + b ^ 2)
      ‚Č§ (3 * (b + c) * c) * (2 * (b + c) ^ 2) := hProd_le
    _ = 6 * (b + c) ^ 3 * c := by ring

/-! ### ¬ß10.63 Bounded-support specialization and Cauchy-Schwarz helpers

Builds on ¬ß10.62 toward the commutator trilinear estimate. Two results:

1. `comSymb_abs_le_of_bounded` ‚ÄĒ on any pair `(k, ‚Ąď)` with both norms
   bounded by `D`, the symbol shrinks to `|comSymb k ‚Ąď| ‚Č§ 48 D^3 ¬∑ ‚ÄĖ‚Ąď‚ÄĖ`.
   This is the form used against trig-poly trajectories, where `D` is
   the diameter of the Fourier support.
2. `sum_mul_abs_le_CS_sqrt` ‚ÄĒ elementary Cauchy-Schwarz on a Finset in
   the "sqrt" form `‚ąĎ a¬∑b ‚Č§ ‚ąö(‚ąĎ a¬≤)¬∑‚ąö(‚ąĎ b¬≤)`. Together with ¬ß10.62's
   `sum_mul_sq_le_sq_mul_sq`, this is the scaffolding for the ¬ß10.65
   energy-evolution bilinear bound.

Note: the full Kato-Ponce trilinear bound `‚ÄĖ‚Ąď‚ÄĖ ¬∑ gradInftyFS ¬∑ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬≤}`
is deferred to a subsequent session. ¬ß10.63 lands the two cleanest
ingredients needed; ¬ß¬ß10.64-10.67 build on them. -/

/-- **Bounded-support specialization of the symbol bound.** If both
`‚ÄĖk‚ÄĖ` and `‚ÄĖ‚Ąď‚ÄĖ` are bounded by `D ‚Č• 0`, then
`|comSymb k ‚Ąď| ‚Č§ 48 ¬∑ D^3 ¬∑ ‚ÄĖ‚Ąď‚ÄĖ`. Direct corollary of ¬ß10.62's
`comSymb_abs_le` via `(‚ÄĖk‚ÄĖ + ‚ÄĖ‚Ąď‚ÄĖ)^3 ‚Č§ (2D)^3 = 8D^3`. -/
lemma comSymb_abs_le_of_bounded {d : Type*} [Fintype d]
    (k ‚Ąď : d ‚Üí ‚Ą§) (D : ‚ĄĚ) (hD : 0 ‚Č§ D)
    (hk : latticeNorm k ‚Č§ D) (h‚Ąď : latticeNorm ‚Ąď ‚Č§ D) :
    |comSymb k ‚Ąď| ‚Č§ 48 * D ^ 3 * latticeNorm ‚Ąď := by
  have hBase := comSymb_abs_le k ‚Ąď
  have hkNn : 0 ‚Č§ latticeNorm k := latticeNorm_nonneg _
  have h‚ĄďNn : 0 ‚Č§ latticeNorm ‚Ąď := latticeNorm_nonneg _
  have hSum_le : latticeNorm k + latticeNorm ‚Ąď ‚Č§ 2 * D := by linarith
  have hSum_nn : 0 ‚Č§ latticeNorm k + latticeNorm ‚Ąď := by linarith
  have hSumCube : (latticeNorm k + latticeNorm ‚Ąď) ^ 3 ‚Č§ (2 * D) ^ 3 :=
    pow_le_pow_left‚āÄ hSum_nn hSum_le 3
  have hCube_expand : (2 * D) ^ 3 = 8 * D ^ 3 := by ring
  have hFinal :
      6 * (latticeNorm k + latticeNorm ‚Ąď) ^ 3 * latticeNorm ‚Ąď
        ‚Č§ 6 * (8 * D ^ 3) * latticeNorm ‚Ąď := by
    have h1 : 0 ‚Č§ (6 : ‚ĄĚ) := by norm_num
    have h2 : 6 * (latticeNorm k + latticeNorm ‚Ąď) ^ 3
        ‚Č§ 6 * (8 * D ^ 3) := by
      rw [‚Üź hCube_expand]
      exact mul_le_mul_of_nonneg_left hSumCube h1
    exact mul_le_mul_of_nonneg_right h2 h‚ĄďNn
  calc |comSymb k ‚Ąď|
      ‚Č§ 6 * (latticeNorm k + latticeNorm ‚Ąď) ^ 3 * latticeNorm ‚Ąď := hBase
    _ ‚Č§ 6 * (8 * D ^ 3) * latticeNorm ‚Ąď := hFinal
    _ = 48 * D ^ 3 * latticeNorm ‚Ąď := by ring

/-- **Cauchy-Schwarz on a Finset in the sqrt form.**
`‚ąĎ a¬∑b ‚Č§ ‚ąö(‚ąĎ a¬≤) ¬∑ ‚ąö(‚ąĎ b¬≤)`, with all terms nonneg so the bound is
also an upper bound on `|‚ąĎ a¬∑b|`. Direct consequence of
`Finset.sum_mul_sq_le_sq_mul_sq` + `Real.sqrt_mul` + `Real.sqrt_sq`. -/
lemma sum_mul_abs_le_CS_sqrt {őĻ : Type*} (S : Finset őĻ) (a b : őĻ ‚Üí ‚ĄĚ) :
    |‚ąĎ i ‚ąą S, a i * b i|
      ‚Č§ Real.sqrt (‚ąĎ i ‚ąą S, a i ^ 2) * Real.sqrt (‚ąĎ i ‚ąą S, b i ^ 2) := by
  set T : ‚ĄĚ := ‚ąĎ i ‚ąą S, a i * b i
  have hCSSq : T ^ 2 ‚Č§ (‚ąĎ i ‚ąą S, a i ^ 2) * (‚ąĎ i ‚ąą S, b i ^ 2) :=
    Finset.sum_mul_sq_le_sq_mul_sq _ _ _
  have hANn : 0 ‚Č§ ‚ąĎ i ‚ąą S, a i ^ 2 :=
    Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  have hBNn : 0 ‚Č§ ‚ąĎ i ‚ąą S, b i ^ 2 :=
    Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  have hProdSqrt :
      Real.sqrt ((‚ąĎ i ‚ąą S, a i ^ 2) * (‚ąĎ i ‚ąą S, b i ^ 2))
        = Real.sqrt (‚ąĎ i ‚ąą S, a i ^ 2) * Real.sqrt (‚ąĎ i ‚ąą S, b i ^ 2) :=
    Real.sqrt_mul hANn _
  have hAbsSq : |T| ^ 2 = T ^ 2 := sq_abs T
  have hAbsNn : 0 ‚Č§ |T| := abs_nonneg _
  have hAbsBound : |T| ^ 2 ‚Č§ (‚ąĎ i ‚ąą S, a i ^ 2) * (‚ąĎ i ‚ąą S, b i ^ 2) := by
    rw [hAbsSq]; exact hCSSq
  have hSqrtMono :
      Real.sqrt (|T| ^ 2)
        ‚Č§ Real.sqrt ((‚ąĎ i ‚ąą S, a i ^ 2) * (‚ąĎ i ‚ąą S, b i ^ 2)) :=
    Real.sqrt_le_sqrt hAbsBound
  have hSqrtAbs : Real.sqrt (|T| ^ 2) = |T| := Real.sqrt_sq hAbsNn
  rw [hSqrtAbs, hProdSqrt] at hSqrtMono
  exact hSqrtMono

/-! ### ¬ß10.64 Scalar Gronwall exponential bound

Clean wrapper around mathlib's `norm_le_gronwallBound_of_norm_deriv_right_le`
specialised to a **nonneg scalar** `E : ‚ĄĚ ‚Üí ‚ĄĚ`. If `E` is differentiable
on `[0, T]`, nonneg, and satisfies `|deriv E t| ‚Č§ K ¬∑ E t` (the classic
BKM-shape hypothesis), then `E(t) ‚Č§ E(0) ¬∑ exp(K ¬∑ t)` on `[0, T]`.

Specialising `gronwallBound őī K 0 x = őī ¬∑ exp (K ¬∑ x)` via
`gronwallBound_őĶ0`.

Used in ¬ß10.66 to pass from a Galerkin-derived energy inequality
(¬ß10.65) to a uniform L‚ąě coefficient bound feeding ¬ß10.57. -/

/-- **Scalar Gronwall exponential bound.** Given `E : ‚ĄĚ ‚Üí ‚ĄĚ` that is
nonneg and differentiable on `[0, T]` with `|E' t| ‚Č§ K ¬∑ E t`, we
have `E t ‚Č§ E 0 ¬∑ exp (K ¬∑ t)` on `[0, T]`. -/
lemma scalar_gronwall_exp
    (E : ‚ĄĚ ‚Üí ‚ĄĚ) (K T : ‚ĄĚ) (hT : 0 ‚Č§ T)
    (hE_cont : ContinuousOn E (Set.Icc 0 T))
    (hE_deriv : ‚ąÄ x ‚ąą Set.Ico 0 T,
      HasDerivWithinAt E (deriv E x) (Set.Ici x) x)
    (hE_bound : ‚ąÄ x ‚ąą Set.Ico 0 T, |deriv E x| ‚Č§ K * |E x|)
    (hE_nn : ‚ąÄ x ‚ąą Set.Icc 0 T, 0 ‚Č§ E x) :
    ‚ąÄ t ‚ąą Set.Icc 0 T, E t ‚Č§ E 0 * Real.exp (K * t) := by
  have hNormInit : ‚ÄĖE 0‚ÄĖ ‚Č§ |E 0| := le_of_eq (Real.norm_eq_abs _)
  have hBound' : ‚ąÄ x ‚ąą Set.Ico 0 T, ‚ÄĖderiv E x‚ÄĖ ‚Č§ K * ‚ÄĖE x‚ÄĖ + 0 := by
    intros x hx
    rw [Real.norm_eq_abs, Real.norm_eq_abs, add_zero]
    exact hE_bound x hx
  have hNormBound := norm_le_gronwallBound_of_norm_deriv_right_le (f := E)
    (f' := deriv E) (őī := |E 0|) (K := K) (őĶ := 0) (a := 0) (b := T)
    hE_cont hE_deriv (le_of_eq (Real.norm_eq_abs _)) hBound'
  intros t ht
  have hGronwall : ‚ÄĖE t‚ÄĖ ‚Č§ gronwallBound (|E 0|) K 0 (t - 0) :=
    hNormBound t ht
  rw [gronwallBound_őĶ0, sub_zero] at hGronwall
  have hEt_nn : 0 ‚Č§ E t := hE_nn t ht
  have hE0_nn : 0 ‚Č§ E 0 := hE_nn 0 ‚ü®le_refl _, hT‚ü©
  have hAbs_E0 : |E 0| = E 0 := abs_of_nonneg hE0_nn
  have hNorm_Et : ‚ÄĖE t‚ÄĖ = E t := by rw [Real.norm_eq_abs, abs_of_nonneg hEt_nn]
  rw [hNorm_Et, hAbs_E0] at hGronwall
  exact hGronwall

/-! ### ¬ß10.65 ŠłĘ¬≤ ‚Üí ‚Ąď‚ąě coefficient extraction

From a uniform ŠłĘ¬≤ bound `hsSeminormSq 2 (őł t) ‚Č§ E` we extract a
uniform bound `‚ÄĖmFourierCoeff (őł t) n‚ÄĖ ‚Č§ ‚ąöE` for every nonzero
lattice point `n` (integer lattice lower bound `‚ÄĖn‚ÄĖ ‚Č• 1`, hence
`(fracDerivSymbol 2 n)¬≤ = ‚ÄĖn‚ÄĖ^4 ‚Č• 1`).

This is the bridge between the exponential bound produced by ¬ß10.64's
Gronwall inequality and the uniform ‚Ąď‚ąě coefficient hypothesis
consumed by ¬ß10.57. -/

lemma fourier_coeff_bound_from_hs2
    {S : Finset (Fin 2 ‚Üí ‚Ą§)}
    {f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))} {E : ‚ĄĚ}
    (hE_nn : 0 ‚Č§ E)
    (hSupp : ‚ąÄ m ‚ąČ S, mFourierCoeff f m = 0)
    (hEnergy : hsSeminormSq 2 f ‚Č§ E) (n : Fin 2 ‚Üí ‚Ą§) (hn : n ‚Č† 0) :
    ‚ÄĖmFourierCoeff f n‚ÄĖ ‚Č§ Real.sqrt E := by
  -- Trivial if `n ‚ąČ S`.
  by_cases hn_mem : n ‚ąą S
  ¬∑ -- Convert tsum to Finset sum via finite support.
    have hZeroOff : ‚ąÄ m ‚ąČ S,
        (fracDerivSymbol 2 m) ^ 2 * ‚ÄĖmFourierCoeff f m‚ÄĖ ^ 2 = 0 := by
      intros m hm
      rw [hSupp m hm, norm_zero]; ring
    have hS_eq :
        ‚ąĎ' m, (fracDerivSymbol 2 m) ^ 2 * ‚ÄĖmFourierCoeff f m‚ÄĖ ^ 2
          = ‚ąĎ m ‚ąą S, (fracDerivSymbol 2 m) ^ 2 * ‚ÄĖmFourierCoeff f m‚ÄĖ ^ 2 :=
      tsum_eq_sum (s := S) (fun m hm => hZeroOff m hm)
    have hS_eq' : hsSeminormSq 2 f
        = ‚ąĎ m ‚ąą S, (fracDerivSymbol 2 m) ^ 2 * ‚ÄĖmFourierCoeff f m‚ÄĖ ^ 2 := by
      unfold hsSeminormSq; exact hS_eq
    -- Integer-lattice lower bound: `(fracDerivSymbol 2 n)¬≤ ‚Č• 1`.
    have hL : 1 ‚Č§ latticeNorm n := latticeNorm_ge_one_of_ne_zero hn
    have hFDS_ge_one : (1 : ‚ĄĚ) ‚Č§ fracDerivSymbol 2 n := by
      rw [fracDerivSymbol_of_ne_zero 2 hn]
      have h0 : (0 : ‚ĄĚ) ‚Č§ 1 := by norm_num
      calc (1 : ‚ĄĚ) = 1 ^ (2 : ‚ĄĚ) := (Real.one_rpow 2).symm
        _ ‚Č§ (latticeNorm n) ^ (2 : ‚ĄĚ) :=
            Real.rpow_le_rpow h0 hL (by norm_num : (0 : ‚ĄĚ) ‚Č§ 2)
    have hFDS_nn : 0 ‚Č§ fracDerivSymbol 2 n := fracDerivSymbol_nonneg 2 n
    have hFDS_sq_ge_one : (1 : ‚ĄĚ) ‚Č§ (fracDerivSymbol 2 n) ^ 2 := by
      have := mul_le_mul hFDS_ge_one hFDS_ge_one (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1) hFDS_nn
      simpa [sq, one_mul] using this
    -- Single term ‚Č§ finite sum = hsSeminormSq ‚Č§ E.
    have hSingle :
        (fracDerivSymbol 2 n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2
          ‚Č§ ‚ąĎ m ‚ąą S, (fracDerivSymbol 2 m) ^ 2 * ‚ÄĖmFourierCoeff f m‚ÄĖ ^ 2 := by
      apply Finset.single_le_sum (f := fun m =>
        (fracDerivSymbol 2 m) ^ 2 * ‚ÄĖmFourierCoeff f m‚ÄĖ ^ 2)
      ¬∑ intros m _
        exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
      ¬∑ exact hn_mem
    have hSingleLeE :
        (fracDerivSymbol 2 n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 ‚Č§ E := by
      linarith [hSingle, hEnergy, hS_eq'.symm.le, hS_eq'.le]
    -- Drop the `(fracDerivSymbol 2 n)¬≤‚Ąď ‚Č• 1` factor.
    have hCoeffSqNn : 0 ‚Č§ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := sq_nonneg _
    have hCoeffSq_le_E : ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 ‚Č§ E := by
      have : ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2
          ‚Č§ (fracDerivSymbol 2 n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := by
        have h := mul_le_mul_of_nonneg_right hFDS_sq_ge_one hCoeffSqNn
        linarith
      linarith
    have hCoeff_nn : 0 ‚Č§ ‚ÄĖmFourierCoeff f n‚ÄĖ := norm_nonneg _
    calc ‚ÄĖmFourierCoeff f n‚ÄĖ
        = Real.sqrt (‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := (Real.sqrt_sq hCoeff_nn).symm
      _ ‚Č§ Real.sqrt E := Real.sqrt_le_sqrt hCoeffSq_le_E
  ¬∑ -- Off-support: coefficient is zero.
    rw [hSupp n hn_mem, norm_zero]
    exact Real.sqrt_nonneg _

/-! ### ¬ß10.66 Galerkin energy Gronwall predicate

Packages the Gronwall hypothesis used by ¬ß10.67. A `GalerkinEnergyGronwall`
for a trajectory `őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 _` on `[0, T]` with rate `K` asserts
that the ŠłĘ¬≤ energy is bounded exponentially: `‚ÄĖőł(t)‚ÄĖ¬≤_{ŠłĘ¬≤} ‚Č§
E‚āÄ ¬∑ exp (K ¬∑ t)` for all `t ‚ąą [0, T]`, where `E‚āÄ` bounds the
initial energy.

This predicate is the natural output of a future analytic section
(the commutator-based derivation from ¬ß10.63's symbol bound + the
Galerkin PDE `galerkinRHS_eq_neg_sqgNonlinearFlux` + advection
cancellation); for the present session we take it as a hypothesis
and show it is sufficient for full BKM discharge. -/

/-- **Galerkin energy Gronwall hypothesis.** Packages the output of
the analytic BKM-commutator argument: the ŠłĘ¬≤ seminorm squared grows
at most exponentially with rate `K` from an initial value `E‚āÄ` on
`[0, T]`. -/
structure GalerkinEnergyGronwall
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (E‚āÄ K T : ‚ĄĚ) : Prop where
  nonneg_T : 0 ‚Č§ T
  nonneg_E‚āÄ : 0 ‚Č§ E‚āÄ
  nonneg_K : 0 ‚Č§ K
  initial_bound : hsSeminormSq 2 (őł 0) ‚Č§ E‚āÄ
  exp_bound : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) T,
    hsSeminormSq 2 (őł t) ‚Č§ E‚āÄ * Real.exp (K * t)

/-- **Uniform ‚Ąď‚ąě coefficient bound from Galerkin Gronwall hypothesis.**
The exponential ŠłĘ¬≤ bound on `[0, T]` implies each non-zero Fourier
coefficient is uniformly bounded (in `t`) by `‚ąö(E‚āÄ ¬∑ exp(K¬∑T))`. -/
lemma uniform_fourier_bound_of_galerkinEnergyGronwall
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {E‚āÄ K T : ‚ĄĚ} (hGW : GalerkinEnergyGronwall őł E‚āÄ K T)
    {S : Finset (Fin 2 ‚Üí ‚Ą§)}
    (hSupp : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ m ‚ąČ S, mFourierCoeff (őł ŌĄ) m = 0)
    (n : Fin 2 ‚Üí ‚Ą§) (hn : n ‚Č† 0) :
    ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) T,
      ‚ÄĖmFourierCoeff (őł t) n‚ÄĖ ‚Č§ Real.sqrt (E‚āÄ * Real.exp (K * T)) := by
  intros t ht
  have hET := hGW.exp_bound t ht
  have hExp_mono : Real.exp (K * t) ‚Č§ Real.exp (K * T) := by
    apply Real.exp_le_exp.mpr
    exact mul_le_mul_of_nonneg_left ht.2 hGW.nonneg_K
  have hET' : hsSeminormSq 2 (őł t) ‚Č§ E‚āÄ * Real.exp (K * T) := by
    calc hsSeminormSq 2 (őł t)
        ‚Č§ E‚āÄ * Real.exp (K * t) := hET
      _ ‚Č§ E‚āÄ * Real.exp (K * T) :=
          mul_le_mul_of_nonneg_left hExp_mono hGW.nonneg_E‚āÄ
  have hExp_pos : 0 < Real.exp (K * T) := Real.exp_pos _
  have hE_target_nn : 0 ‚Č§ E‚āÄ * Real.exp (K * T) :=
    mul_nonneg hGW.nonneg_E‚āÄ hExp_pos.le
  exact fourier_coeff_bound_from_hs2 hE_target_nn (hSupp t) hET' n hn

/-! ### ¬ß10.67 Derived `BKMCriterionS2` via Galerkin energy Gronwall

The top-level capstone of the ¬ß10.61-¬ß10.67 chain: compose ¬ß10.66's
uniform Fourier-coefficient bound with ¬ß10.57's finite-support
`BKMCriterionS2` discharge. The resulting theorem takes a
`GalerkinEnergyGronwall` hypothesis plus a mean-preservation property
(to handle the zero mode) and yields `BKMCriterionS2 őł`.

This closes the plan's target: a *derived* BKM discharge route (via
the symbol bound + Gronwall + finite support) parallel to ¬ß10.57's
axiomatic trivial discharge. The remaining analytic step ‚ÄĒ deriving
`GalerkinEnergyGronwall` from Galerkin dynamics + ¬ß10.63's symbol
bound ‚ÄĒ is the natural next-session continuation. -/

/-- **Derived BKMCriterionS2 from Galerkin energy Gronwall.** For a
trig-poly trajectory with finite support `S`, a Gronwall exponential
bound on ŠłĘ¬≤ energy, and a uniform zero-mode bound `M‚āÄ`, we extract
a uniform ‚Ąď‚ąě Fourier-coefficient bound and invoke
`BKMCriterionS2.of_finite_support_uniform` (¬ß10.57) to conclude
`BKMCriterionS2 őł`. -/
theorem BKMCriterionS2.of_galerkinEnergyGronwall
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S, mFourierCoeff (őł ŌĄ) n = 0)
    (E‚āÄ K T M‚āÄ : ‚ĄĚ) (hT_pos : 0 < T)
    (hGW : GalerkinEnergyGronwall őł E‚āÄ K T)
    (hM‚āÄ_nn : 0 ‚Č§ M‚āÄ)
    (hZeroMode : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ŌĄ ‚Č§ T ‚Üí
      ‚ÄĖmFourierCoeff (őł ŌĄ) (0 : Fin 2 ‚Üí ‚Ą§)‚ÄĖ ‚Č§ M‚āÄ)
    (hExtend : ‚ąÄ ŌĄ : ‚ĄĚ, T < ŌĄ ‚Üí ‚ąÄ n, mFourierCoeff (őł ŌĄ) n = 0) :
    BKMCriterionS2 őł := by
  -- Define the uniform bound.
  set M : ‚ĄĚ := max M‚āÄ (Real.sqrt (E‚āÄ * Real.exp (K * T)))
  have hM_nn : 0 ‚Č§ M := le_max_of_le_left hM‚āÄ_nn
  -- Build the hypothesis for ¬ß10.57.
  have hBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖmFourierCoeff (őł ŌĄ) n‚ÄĖ ‚Č§ M := by
    intros ŌĄ hŌĄ n
    by_cases hŌĄT : ŌĄ ‚Č§ T
    ¬∑ by_cases hn : n = 0
      ¬∑ subst hn
        calc ‚ÄĖmFourierCoeff (őł ŌĄ) (0 : Fin 2 ‚Üí ‚Ą§)‚ÄĖ
            ‚Č§ M‚āÄ := hZeroMode ŌĄ hŌĄ hŌĄT
          _ ‚Č§ M := le_max_left _ _
      ¬∑ have hŌĄ_mem : ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) T := ‚ü®hŌĄ, hŌĄT‚ü©
        calc ‚ÄĖmFourierCoeff (őł ŌĄ) n‚ÄĖ
            ‚Č§ Real.sqrt (E‚āÄ * Real.exp (K * T)) :=
              uniform_fourier_bound_of_galerkinEnergyGronwall hGW hSupport n hn ŌĄ hŌĄ_mem
          _ ‚Č§ M := le_max_right _ _
    ¬∑ push Not at hŌĄT
      rw [hExtend ŌĄ hŌĄT n, norm_zero]
      exact hM_nn
  exact BKMCriterionS2.of_finite_support_uniform őł S hSupport M hBound

/-! ### ¬ß10.68 Trig-poly finite-sum energy and bridge to `hsSeminormSq`

Defines `trigPolyEnergyHs2 S c` as the finite-sum form of the ŠłĘ¬≤
seminorm squared for a Galerkin coefficient vector `c : ‚Ü•S ‚Üí ‚Ąā`:
```
trigPolyEnergyHs2 S c := ‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val)¬≤ ¬∑ ‚ÄĖc m‚ÄĖ¬≤
```
This is the **pointwise-differentiable** form of the energy used in
¬ß¬ß10.69-10.72, whereas `hsSeminormSq 2 (galerkinToLp S c)` is defined
as a tsum over all of `‚Ą§¬≤` (not immediately differentiable).

`trigPolyEnergyHs2_eq_hsSeminormSq` establishes the equality: since
`mFourierCoeff (galerkinToLp S c) n = 0` for `n ‚ąČ S`, the tsum collapses
to the finite sum over `S` via `tsum_eq_sum`. -/

/-- **Trig-poly ŠłĘ¬≤ energy (finite-sum form).** -/
noncomputable def trigPolyEnergyHs2
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) : ‚ĄĚ :=
  ‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val) ^ 2 * ‚ÄĖc m‚ÄĖ ^ 2

lemma trigPolyEnergyHs2_nonneg
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)] (c : ‚Ü•S ‚Üí ‚Ąā) :
    0 ‚Č§ trigPolyEnergyHs2 S c := by
  unfold trigPolyEnergyHs2
  exact Finset.sum_nonneg (fun m _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))

/-- **Bridge: finite-sum energy equals `hsSeminormSq 2 (galerkinToLp S c)`.**
Uses `galerkinExtend` support (`= 0` outside `S`) to collapse the tsum
into a Finset sum via `tsum_eq_sum`, then re-indexes from `Fin 2 ‚Üí ‚Ą§`
to `‚Ü•S` via `Finset.sum_attach`. -/
theorem trigPolyEnergyHs2_eq_hsSeminormSq
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) :
    trigPolyEnergyHs2 S c = hsSeminormSq 2 (galerkinToLp S c) := by
  unfold trigPolyEnergyHs2 hsSeminormSq
  -- Show the tsum collapses to a Finset sum over `S`.
  have hZeroOff : ‚ąÄ n ‚ąČ S,
      (fracDerivSymbol 2 n) ^ 2 * ‚ÄĖmFourierCoeff (galerkinToLp S c) n‚ÄĖ ^ 2 = 0 := by
    intros n hn
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ hn,
        norm_zero]; ring
  rw [tsum_eq_sum (s := S) (fun n hn => hZeroOff n hn)]
  -- Rewrite the Finset sum over S as a sum over the subtype ‚Ü•S.
  rw [‚Üź Finset.sum_attach S (fun n =>
      (fracDerivSymbol 2 n) ^ 2 * ‚ÄĖmFourierCoeff (galerkinToLp S c) n‚ÄĖ ^ 2)]
  apply Finset.sum_congr rfl
  intros m _
  rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_mem _ _ m.property]

/-- **Uniform energy bound transferred from trig-poly to `hsSeminormSq`.**
For downstream use: bounding `trigPolyEnergyHs2 S (őĪ ŌĄ)` uniformly gives
a bound on `hsSeminormSq 2 (galerkinToLp S (őĪ ŌĄ))` suitable for
`GalerkinEnergyGronwall`. -/
lemma hsSeminormSq_le_of_trigPolyEnergyHs2_le
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) (E : ‚ĄĚ) (hE : trigPolyEnergyHs2 S c ‚Č§ E) :
    hsSeminormSq 2 (galerkinToLp S c) ‚Č§ E := by
  rw [‚Üź trigPolyEnergyHs2_eq_hsSeminormSq]; exact hE

/-! ### ¬ß10.69 Pointwise derivative of `trigPolyEnergyHs2 ‚ąė őĪ`

Given a Galerkin trajectory `őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)` with
`HasDerivAt őĪ (galerkinVectorField S (őĪ ŌĄ)) ŌĄ`, each coordinate
`ŌĄ ‚Ü¶ (őĪ ŌĄ) m` has derivative `galerkinVectorField S (őĪ ŌĄ) m`
(by `hasDerivAt_pi`). Combining with mathlib's `HasDerivAt.norm_sq`
for the real inner product on `‚Ąā`, we obtain a pointwise derivative
for the finite-sum energy.

Output formula:
```
d/dŌĄ trigPolyEnergyHs2 S (őĪ ŌĄ)
  = ‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val)¬≤ ¬∑ 2 ¬∑ ‚ü™őĪ ŌĄ m, galerkinVectorField S (őĪ ŌĄ) m‚üę_‚ĄĚ
```
where the real inner product on `‚Ąā` is `‚ü™z, w‚üę_‚ĄĚ = Re(conj z ¬∑ w)`. -/

theorem trigPolyEnergyHs2_hasDerivAt
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (ŌĄ : ‚ĄĚ) :
    HasDerivAt (fun t => trigPolyEnergyHs2 S (őĪ t))
      (‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val) ^ 2 *
        (2 * (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m)))) ŌĄ := by
  unfold trigPolyEnergyHs2
  apply HasDerivAt.fun_sum
  intros m _
  -- The coordinate map `t ‚Ü¶ (őĪ t) m` has derivative `galerkinVectorField S (őĪ ŌĄ) m`.
  have hőĪm : HasDerivAt (fun t => őĪ t m) (galerkinVectorField S (őĪ ŌĄ) m) ŌĄ :=
    (hasDerivAt_pi.mp (hőĪ ŌĄ)) m
  -- `HasDerivAt.norm_sq` differentiates the squared norm via the real inner product.
  have hNormSq := hőĪm.norm_sq
  -- Finally multiply by the constant weight `(fracDerivSymbol 2 m.val)¬≤`.
  exact hNormSq.const_mul _

/-! ### ¬ß10.70 Pair-index Finset + advection-swap involution

Foundation for the advection-cancellation argument of ¬ß10.74. The
bilinear Galerkin flux `galerkinRHS S c m` is a sum over
`‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S)`; when paired against the energy
weight `|m|^4 ¬∑ conj(c(m))`, it becomes a double sum over pairs
`(k, ‚Ąď) ‚ąą S √ó S` with `k + ‚Ąď ‚ąą S` (setting `k := m - ‚Ąď`).

`pairIdx S` packages this index set as a Finset of pairs. The
involution `advectionSwap : (k, ‚Ąď) ‚Ü¶ (k+‚Ąď, -‚Ąď)` self-maps this set
under `IsSymmetricSupport S` and is its own inverse (`advectionSwap¬≤
= id`). ¬ß10.74 will apply `Finset.sum_involution` with this map to
collapse the advection term.

The geometric meaning: swapping the "scalar mode" `k` and "output
mode" `k+‚Ąď` while reversing the velocity direction `‚Ąď ‚Ü¶ -‚Ąď`
rearranges the same physical interaction seen from the opposite
endpoint. Combined with the div-free Fourier condition
`‚Ąď ¬∑ √Ľ(‚Ąď) = 0` and the Fourier-reality `√Ľ(-‚Ąď) = star √Ľ(‚Ąď)`, the
paired contributions cancel at the Re level. -/

/-- **Pair-index Finset for the advection double-sum.** -/
noncomputable def pairIdx (S : Finset (Fin 2 ‚Üí ‚Ą§))
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)] :
    Finset ((Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) :=
  (S √óňĘ S).filter (fun p => p.1 + p.2 ‚ąą S)

lemma mem_pairIdx {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)} :
    p ‚ąą pairIdx S ‚ÜĒ p.1 ‚ąą S ‚ąß p.2 ‚ąą S ‚ąß p.1 + p.2 ‚ąą S := by
  unfold pairIdx
  rw [Finset.mem_filter, Finset.mem_product]
  tauto

/-- **Advection-swap involution.** `ŌĄ(k, ‚Ąď) = (k + ‚Ąď, -‚Ąď)`. -/
def advectionSwap :
    (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) ‚Üí (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) :=
  fun p => (p.1 + p.2, -p.2)

@[simp]
lemma advectionSwap_apply (k ‚Ąď : Fin 2 ‚Üí ‚Ą§) :
    advectionSwap (k, ‚Ąď) = (k + ‚Ąď, -‚Ąď) := rfl

lemma advectionSwap_involutive (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) :
    advectionSwap (advectionSwap p) = p := by
  obtain ‚ü®k, ‚Ąď‚ü© := p
  simp [advectionSwap]

lemma advectionSwap_mem_pairIdx
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)} (hp : p ‚ąą pairIdx S) :
    advectionSwap p ‚ąą pairIdx S := by
  obtain ‚ü®k, ‚Ąď‚ü© := p
  rw [mem_pairIdx] at hp
  obtain ‚ü®hk, h‚Ąď, hk‚Ąď‚ü© := hp
  rw [advectionSwap_apply, mem_pairIdx]
  refine ‚ü®hk‚Ąď, ?_, ?_‚ü©
  ¬∑ exact hS ‚Ąď h‚Ąď
  ¬∑ -- (k + ‚Ąď) + (-‚Ąď) = k ‚ąą S
    have : k + ‚Ąď + -‚Ąď = k := by abel
    rw [this]; exact hk

/-- **Fixed points of `advectionSwap`.** Fixed iff `‚Ąď = 0`. The `k+‚Ąď = k`
condition already forces `‚Ąď = 0`, making `-‚Ąď = ‚Ąď` redundant. -/
lemma advectionSwap_eq_self_iff
    (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) :
    advectionSwap p = p ‚ÜĒ p.2 = 0 := by
  obtain ‚ü®k, ‚Ąď‚ü© := p
  simp only [advectionSwap_apply, Prod.mk.injEq]
  constructor
  ¬∑ rintro ‚ü®hk, _‚ü©
    -- k + ‚Ąď = k ‚áí ‚Ąď = 0
    have : k + ‚Ąď - k = k - k := by rw [hk]
    simpa [add_sub_cancel_left, sub_self] using this
  ¬∑ rintro rfl
    refine ‚ü®?_, ?_‚ü© <;> simp

/-! ### ¬ß10.71 Fourier divergence-free predicate + Riesz instance

Predicate capturing the div-free condition at the Fourier level:
`IsFourierDivFree u := ‚ąÄ ‚Ąď, ő£_j (‚Ąď_j : ‚Ąā) ¬∑ u_j ‚Ąď = 0`. In real space
this is `‚ąá ¬∑ u = 0`. Used by ¬ß10.73 to kill the leading term of the
pair-swap cancellation: the kernel `F(ŌĄ(k,‚Ąď)) + conj(F(k,‚Ąď))`
factors through `‚Ąď ¬∑ √Ľ(‚Ąď)`, which this predicate forces to zero.

The Riesz-transform velocity `u_j ‚Ąď := sqgVelocitySymbol j ‚Ąď ¬∑ c(‚Ąď)`
satisfies `IsFourierDivFree` for any coefficient function `c`, by
`sqgVelocitySymbol_divergence_free` (already established in ¬ß10.8). -/

/-- **Fourier-level divergence-free condition.** -/
def IsFourierDivFree (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) : Prop :=
  ‚ąÄ ‚Ąď : Fin 2 ‚Üí ‚Ą§, ‚ąĎ j : Fin 2, ((‚Ąď j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď = 0

/-- **Riesz instance.** The Riesz-transform velocity of any scalar
Fourier coefficient function is Fourier-div-free. -/
lemma isFourierDivFree_riesz (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    IsFourierDivFree (fun j ‚Ąď => sqgVelocitySymbol j ‚Ąď * c ‚Ąď) := by
  intros ‚Ąď
  rw [Fin.sum_univ_two]
  exact sqgVelocitySymbol_divergence_free ‚Ąď (c ‚Ąď)

/-! ### ¬ß10.72 Fourier-reality predicate + Riesz instance

Predicate: `IsRealFourier u := ‚ąÄ (j, ‚Ąď), u_j (-‚Ąď) = star (u_j ‚Ąď)`.
This is the Fourier-side statement that `u` is real-valued in physical
space (`u(-n) = conj u(n)` is the Fourier symmetry of real functions).

Used by ¬ß10.73 to simplify `F(ŌĄ(k,‚Ąď))`: substituting `√Ľ(-‚Ąď) = star √Ľ(‚Ąď)`
(along with `sqgVelocitySymbol (-‚Ąď) = -sqgVelocitySymbol ‚Ąď`, the oddness
of the Riesz kernel) is what produces the `conj(‚Ąď ¬∑ √Ľ(‚Ąď))` factor that
the `IsFourierDivFree` hypothesis then zeroes out.

For the Riesz velocity of a real-symmetric coefficient function
(`IsRealCoeff c` + `IsSymmetricSupport S`), the resulting Riesz
velocity is automatically Fourier-real. -/

/-- **Fourier-level reality condition** (each component). -/
def IsRealFourier (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) : Prop :=
  ‚ąÄ (j : Fin 2) (‚Ąď : Fin 2 ‚Üí ‚Ą§), u j (-‚Ąď) = star (u j ‚Ąď)

/-- **Real part of the Riesz symbol is zero** (for nonzero `n`). -/
lemma rieszSymbol_re {d : Type*} [Fintype d] {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (j : d) :
    (rieszSymbol j n).re = 0 := by
  unfold rieszSymbol
  rw [if_neg hn]
  simp [Complex.div_re, Complex.mul_re, Complex.neg_re, Complex.I_re,
        Complex.I_im, Complex.ofReal_re, Complex.ofReal_im,
        Complex.neg_im, Complex.normSq_ofReal]

/-- **Star identity for the Riesz symbol.** `star (rieszSymbol j n) =
-rieszSymbol j n`. The Riesz symbol is purely imaginary, so its complex
conjugate equals its negation. -/
lemma star_rieszSymbol {d : Type*} [Fintype d] (j : d) (n : d ‚Üí ‚Ą§) :
    star (rieszSymbol j n) = -rieszSymbol j n := by
  by_cases hn : n = 0
  ¬∑ subst hn; simp
  apply Complex.ext
  ¬∑ rw [show star (rieszSymbol j n) = starRingEnd ‚Ąā (rieszSymbol j n) from rfl,
        Complex.conj_re, Complex.neg_re, rieszSymbol_re hn, neg_zero]
  ¬∑ rw [show star (rieszSymbol j n) = starRingEnd ‚Ąā (rieszSymbol j n) from rfl,
        Complex.conj_im, Complex.neg_im]

/-- **Star identity for `sqgVelocitySymbol`.** -/
lemma star_sqgVelocitySymbol (j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) :
    star (sqgVelocitySymbol j n) = -sqgVelocitySymbol j n := by
  unfold sqgVelocitySymbol
  split_ifs
  ¬∑ exact star_rieszSymbol 1 n
  ¬∑ rw [star_neg, star_rieszSymbol]

/-- **Riesz instance for `IsRealFourier`.** For `c` satisfying
`IsRealCoeff S c` (and support in `S` for both `‚Ąď` and `-‚Ąď`), the
Riesz velocity is Fourier-real. Stated here in an unconditional form
that holds pointwise off-support too, because both `c(-‚Ąď)` and `c(‚Ąď)`
vanish off `S` when `S` is symmetric and `c` vanishes off `S`. -/
lemma isRealFourier_riesz
    {S : Finset (Fin 2 ‚Üí ‚Ą§)}
    (hS : IsSymmetricSupport S)
    (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hRealC : ‚ąÄ n ‚ąą S, c (-n) = star (c n))
    (hOff : ‚ąÄ n ‚ąČ S, c n = 0) :
    IsRealFourier (fun j ‚Ąď => sqgVelocitySymbol j ‚Ąď * c ‚Ąď) := by
  intros j ‚Ąď
  change sqgVelocitySymbol j (-‚Ąď) * c (-‚Ąď) = star (sqgVelocitySymbol j ‚Ąď * c ‚Ąď)
  by_cases h‚Ąď : ‚Ąď ‚ąą S
  ¬∑ -- ‚Ąď ‚ąą S: use sqgVelocitySymbol_neg + hRealC.
    rw [sqgVelocitySymbol_neg, hRealC ‚Ąď h‚Ąď, star_mul, star_sqgVelocitySymbol]
    ring
  ¬∑ -- ‚Ąď ‚ąČ S: c(‚Ąď) = 0, and also -‚Ąď ‚ąČ S (hence c(-‚Ąď) = 0) via hS.mt.
    have hneg‚Ąď : -‚Ąď ‚ąČ S := by
      intro h
      apply h‚Ąď
      have := hS (-‚Ąď) h
      simpa using this
    rw [hOff ‚Ąď h‚Ąď, hOff (-‚Ąď) hneg‚Ąď]
    simp

/-! ### ¬ß10.73 Advection pair-summand (definition)

Defines `advectionSummand u c p` ‚ÄĒ the scalar factor appearing in the
Fourier expansion of `‚ü®u¬∑‚ąá(őõ¬≤őł), őõ¬≤őł‚ü©` at the pair `p = (k, ‚Ąď)`:
```
F(k, ‚Ąď) = i ¬∑ ‚ÄĖk‚ÄĖ¬≤ ¬∑ ‚ÄĖk+‚Ąď‚ÄĖ¬≤ ¬∑ (k ¬∑ √Ľ(‚Ąď)) ¬∑ c(k) ¬∑ star(c(k+‚Ąď))
```
where `k ¬∑ √Ľ(‚Ąď) := ő£_j (k_j : ‚Ąā) ¬∑ u_j ‚Ąď`.

The algebraic kernel identity
`advectionSummand u c (advectionSwap p) + star (advectionSummand u c p) = 0`
under `IsFourierDivFree u` + `IsRealFourier u` is deferred to a
subsequent session ‚ÄĒ its proof requires careful `star`-distribution
through products involving `Complex.I` and real-casted norms, and
must be engineered against Lean's goal-reduction of `advectionSwap`
inside `advectionSummand`. ¬ß10.70-¬ß10.72 (pair-index, involution,
div-free and real-Fourier predicates + Riesz instances) provide the
entire structural scaffolding needed to state and apply it. -/

/-- **Advection pair-summand** at `(k, ‚Ąď)` ‚ÄĒ the scalar factor of the
Fourier expansion of `‚ü®u¬∑‚ąá(őõ¬≤őł), őõ¬≤őł‚ü©`. -/
noncomputable def advectionSummand
    (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) : ‚Ąā :=
  Complex.I * (((latticeNorm p.1 : ‚ĄĚ) : ‚Ąā) ^ 2)
    * (((latticeNorm (p.1 + p.2) : ‚ĄĚ) : ‚Ąā) ^ 2)
    * (‚ąĎ j : Fin 2, ((p.1 j : ‚ĄĚ) : ‚Ąā) * u j p.2)
    * c p.1 * star (c (p.1 + p.2))

/-- Helper: `star` of a real-cast in `‚Ąā` is itself (real is self-conjugate).
Bridges the `star` vs `Complex.conj` notation mismatch ‚ÄĒ `Complex.conj_ofReal`
has pattern `(starRingEnd ‚Ąā) ‚ÜĎr`, but downstream proofs use `star ‚ÜĎr`. -/
lemma star_ofReal_complex (r : ‚ĄĚ) : star ((r : ‚Ąā)) = ((r : ‚Ąā)) :=
  Complex.conj_ofReal r

/-- **Key j-sum identity** (¬ß10.73 core): under Fourier div-free + real-
Fourier hypotheses, the `ŌĄ`-swapped j-sum `ő£_j (k+‚Ąď)_j ¬∑ u_j(-‚Ąď)` equals
the star of the original `ő£_j k_j ¬∑ u_j(‚Ąď)`. -/
lemma advection_jsum_swap_eq_star
    {u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    (hDivFree : IsFourierDivFree u) (hReal : IsRealFourier u)
    (k ‚Ąď : Fin 2 ‚Üí ‚Ą§) :
    (‚ąĎ j : Fin 2, (((k + ‚Ąď) j : ‚ĄĚ) : ‚Ąā) * u j (-‚Ąď))
      = star (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď) := by
  -- Step A: hReal converts u_j(-‚Ąď) to star(u_j ‚Ąď), then (k+‚Ąď)_j splits.
  have hCast : ‚ąÄ j : Fin 2,
      (((k + ‚Ąď) j : ‚ĄĚ) : ‚Ąā) = ((k j : ‚ĄĚ) : ‚Ąā) + ((‚Ąď j : ‚ĄĚ) : ‚Ąā) := by
    intro j
    simp only [Pi.add_apply, Int.cast_add, Complex.ofReal_add]
  have hLHS_split :
      (‚ąĎ j : Fin 2, (((k + ‚Ąď) j : ‚ĄĚ) : ‚Ąā) * u j (-‚Ąď))
        = (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * star (u j ‚Ąď))
          + (‚ąĎ j : Fin 2, ((‚Ąď j : ‚ĄĚ) : ‚Ąā) * star (u j ‚Ąď)) := by
    rw [‚Üź Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intros j _
    rw [hReal j ‚Ąď, hCast j]
    ring
  -- Step B: ‚Ąď-part vanishes via star applied to div-free.
  have h‚ĄďPart_zero :
      (‚ąĎ j : Fin 2, ((‚Ąď j : ‚ĄĚ) : ‚Ąā) * star (u j ‚Ąď)) = 0 := by
    have hEq : (‚ąĎ j : Fin 2, ((‚Ąď j : ‚ĄĚ) : ‚Ąā) * star (u j ‚Ąď))
        = star (‚ąĎ j : Fin 2, ((‚Ąď j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď) := by
      rw [star_sum]
      apply Finset.sum_congr rfl
      intros j _
      rw [star_mul', star_ofReal_complex]
    rw [hEq, hDivFree ‚Ąď, star_zero]
  -- Step C: k-part equals star(U).
  have hKPart_eq :
      (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * star (u j ‚Ąď))
        = star (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď) := by
    rw [star_sum]
    apply Finset.sum_congr rfl
    intros j _
    rw [star_mul', star_ofReal_complex]
  rw [hLHS_split, h‚ĄďPart_zero, add_zero, hKPart_eq]

/-- **Kernel identity:** `advectionSummand (ŌĄ p) + star (advectionSummand p)
= 0` under div-free + reality hypotheses. Core algebraic step for the
advection cancellation (¬ß10.74 applies `Finset.sum_involution` to
collapse `Re(ő£_{pairIdx} advectionSummand) = 0`). -/
theorem advectionSummand_swap_add_star_eq_zero
    {u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā} {c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    (hDivFree : IsFourierDivFree u) (hReal : IsRealFourier u)
    (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) :
    advectionSummand u c (advectionSwap p) + star (advectionSummand u c p) = 0 := by
  obtain ‚ü®k, ‚Ąď‚ü© := p
  unfold advectionSummand
  simp only [advectionSwap_apply]
  -- The ŌĄ-swapped pair has k' + ‚Ąď' = (k+‚Ąď) + (-‚Ąď) = k.
  rw [show (k + ‚Ąď) + -‚Ąď = k from by abel]
  -- Apply j-sum identity to collapse the ŌĄ-swapped j-sum to star U.
  rw [advection_jsum_swap_eq_star hDivFree hReal]
  -- Now compute star of the original term explicitly, preparing for ring.
  -- Helper facts (using star_mul' since ‚Ąā is commutative).
  have hSI : star Complex.I = -Complex.I := Complex.conj_I
  have hSrealSq : ‚ąÄ r : ‚ĄĚ, star (((r : ‚ĄĚ) : ‚Ąā) ^ 2) = ((r : ‚ĄĚ) : ‚Ąā) ^ 2 := by
    intro r; rw [star_pow, star_ofReal_complex]
  -- Rewrite the star of the full product.
  have hStarProd :
      star (Complex.I * ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2
            * ((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2
            * (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)
            * c k * star (c (k + ‚Ąď)))
        = -Complex.I * ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2
            * ((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2
            * star (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)
            * star (c k) * c (k + ‚Ąď) := by
    simp only [star_mul', hSI, hSrealSq, star_star]
  rw [hStarProd]
  ring

/-! ### ¬ß10.74 Advection cancellation on `pairIdx S`

Given `IsSymmetricSupport S` + `IsFourierDivFree u` + `IsRealFourier u`,
the total advection sum satisfies `ő£ + star(ő£) = 0`, i.e., its real part
is zero. This is the **advection cancellation theorem**:
```
Re (ő£_{p ‚ąą pairIdx S} advectionSummand u c p) = 0
```

Proof:
1. Reindex via `advectionSwap` (a bijection of `pairIdx S` under
   `IsSymmetricSupport S` + `advectionSwap_involutive`): `ő£ F = ő£ F ‚ąė ŌÉ`.
2. Sum of `F(ŌÉ p) + star(F p) = 0` pointwise gives `ő£ F ‚ąė ŌÉ + ő£ star F = 0`.
3. Equivalently `ő£ F + star (ő£ F) = 0` via `star_sum`.
4. `z + star z = 2¬∑(z.re : ‚Ąā)` gives `(ő£ F).re = 0`.

This closes the analytic content of the advection term of the energy
derivative; ¬ß10.75 handles the commutator term separately. -/

/-- **Reindex via `advectionSwap`:** `ő£ F p = ő£ F (ŌÉ p)` on `pairIdx S`. -/
theorem advectionSum_reindex_swap
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    (‚ąĎ p ‚ąą pairIdx S, advectionSummand u c p)
      = ‚ąĎ p ‚ąą pairIdx S, advectionSummand u c (advectionSwap p) := by
  apply Finset.sum_nbij' (fun p => advectionSwap p) (fun p => advectionSwap p)
  ¬∑ intros p hp; exact advectionSwap_mem_pairIdx hS hp
  ¬∑ intros p hp; exact advectionSwap_mem_pairIdx hS hp
  ¬∑ intros p _; exact advectionSwap_involutive p
  ¬∑ intros p _; exact advectionSwap_involutive p
  ¬∑ intros p _
    rw [advectionSwap_involutive]

/-- **Advection cancellation:** the total sum equals its own negative
conjugate, i.e., `ő£ + star(ő£) = 0`. -/
theorem advectionSum_add_star_eq_zero
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā} {c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    (hDivFree : IsFourierDivFree u) (hReal : IsRealFourier u) :
    (‚ąĎ p ‚ąą pairIdx S, advectionSummand u c p)
      + star (‚ąĎ p ‚ąą pairIdx S, advectionSummand u c p) = 0 := by
  rw [star_sum]
  rw [advectionSum_reindex_swap hS u c]
  rw [‚Üź Finset.sum_add_distrib]
  apply Finset.sum_eq_zero
  intros p _
  exact advectionSummand_swap_add_star_eq_zero hDivFree hReal p

/-- Helper: `.re` of `star z` equals `.re` of `z` (real part preserved
by conjugation). Bridges the `star`/`conj` notation. -/
lemma star_re_complex (z : ‚Ąā) : (star z).re = z.re := Complex.conj_re z

/-- **Advection cancellation (real-part form):** `Re(ő£_{pairIdx} F) = 0`.
The headline consequence. -/
theorem advectionSum_re_eq_zero
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā} {c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    (hDivFree : IsFourierDivFree u) (hReal : IsRealFourier u) :
    (‚ąĎ p ‚ąą pairIdx S, advectionSummand u c p).re = 0 := by
  have h : (‚ąĎ p ‚ąą pairIdx S, advectionSummand u c p)
             + star (‚ąĎ p ‚ąą pairIdx S, advectionSummand u c p) = 0 :=
    advectionSum_add_star_eq_zero hS hDivFree hReal
  -- Take .re of both sides.
  have h_re := congr_arg Complex.re h
  rw [Complex.add_re, star_re_complex, Complex.zero_re] at h_re
  linarith

/-! ### ¬ß10.75 Commutator pair-summand + pointwise bound

After the advection split `|k+‚Ąď|‚Āī = |k|¬≤¬∑|k+‚Ąď|¬≤ + (|k+‚Ąď|¬≤ - |k|¬≤)¬∑|k+‚Ąď|¬≤`,
the commutator term of `‚ü®őõ¬≤(u¬∑‚ąáőł), őõ¬≤őł‚ü©` has Fourier factor
```
G(k, ‚Ąď) = (|k+‚Ąď|¬≤ - |k|¬≤) ¬∑ |k+‚Ąď|¬≤ ¬∑ i¬∑(k¬∑√Ľ(‚Ąď)) ¬∑ c(k) ¬∑ star(c(k+‚Ąď))
```
This section ships:

1. `commutatorSummand` ‚ÄĒ the above pair-summand, isolated from
   `advectionSummand` by the split `|k+‚Ąď|‚Āī = advection + commutator`.
2. `commutatorSummand_norm_le_on_support` ‚ÄĒ pointwise bound when all
   momenta are bounded by `D`:
   `‚ÄĖcommutatorSummand u c p‚ÄĖ ‚Č§ 6¬∑D‚ĀĶ¬∑‚ÄĖ√Ľ(p.2)‚ÄĖ¬∑‚ÄĖc p.1‚ÄĖ¬∑‚ÄĖc (p.1 + p.2)‚ÄĖ`
   via `abs_latticeNorm_add_sq_sub_sq_le` (¬ß10.62) + triangle on the
   j-sum + bounded-support factoring.

The sum bound connecting to energy (¬ß10.76) uses this pointwise
estimate together with Cauchy-Schwarz on the double sum. -/

/-- **Commutator pair-summand** at `(k, ‚Ąď)`: the leftover Fourier factor
after removing the advection piece from `‚ü®őõ¬≤(u¬∑‚ąáőł), őõ¬≤őł‚ü©`. -/
noncomputable def commutatorSummand
    (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) : ‚Ąā :=
  Complex.I
    * (((latticeNorm (p.1 + p.2) : ‚ĄĚ) : ‚Ąā) ^ 2
        - ((latticeNorm p.1 : ‚ĄĚ) : ‚Ąā) ^ 2)
    * (((latticeNorm (p.1 + p.2) : ‚ĄĚ) : ‚Ąā) ^ 2)
    * (‚ąĎ j : Fin 2, ((p.1 j : ‚ĄĚ) : ‚Ąā) * u j p.2)
    * c p.1 * star (c (p.1 + p.2))

/-- **Pointwise norm bound** for `commutatorSummand` on bounded support.
For `(k, ‚Ąď) ‚ąą pairIdx S` with support diameter `D`,
`‚ÄĖcommutatorSummand u c (k, ‚Ąď)‚ÄĖ ‚Č§ 6¬∑D‚ĀĶ¬∑(ő£_j ‚ÄĖu_j ‚Ąď‚ÄĖ)¬∑‚ÄĖc k‚ÄĖ¬∑‚ÄĖc (k+‚Ąď)‚ÄĖ`.

Proof chain:
- `ő£_j (k_j : ‚Ąā) ¬∑ u_j ‚Ąď` has norm `‚Č§ ‚ÄĖk‚ÄĖ¬∑(ő£_j ‚ÄĖu_j ‚Ąď‚ÄĖ)` via triangle
  + componentwise bound `‚ÄĖk_j‚ÄĖ ‚Č§ ‚ÄĖk‚ÄĖ`.
- `|(‚ÄĖk+‚Ąď‚ÄĖ¬≤ - ‚ÄĖk‚ÄĖ¬≤)|` has bound `3¬∑(‚ÄĖk‚ÄĖ+‚ÄĖ‚Ąď‚ÄĖ)¬∑‚ÄĖ‚Ąď‚ÄĖ` via ¬ß10.62.
- On support, all norms bounded by `D`, so product `‚Č§ 6¬∑D‚ĀĶ¬∑‚ÄĖ‚Ąď‚ÄĖ¬∑...`.

This is the analog of ¬ß10.63's `comSymb_abs_le_of_bounded` for the
full commutator-summand; ¬ß10.76 uses it plus CS to bound the sum. -/
lemma commutatorSummand_norm_le_on_support
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (D : ‚ĄĚ) (hD : 0 ‚Č§ D)
    (hSupport_le : ‚ąÄ n ‚ąą S, latticeNorm n ‚Č§ D)
    (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) (hp : p ‚ąą pairIdx S) :
    ‚ÄĖcommutatorSummand u c p‚ÄĖ
      ‚Č§ 6 * D ^ 5 * (‚ąĎ j : Fin 2, ‚ÄĖu j p.2‚ÄĖ) * ‚ÄĖc p.1‚ÄĖ * ‚ÄĖc (p.1 + p.2)‚ÄĖ := by
  obtain ‚ü®k, ‚Ąď‚ü© := p
  rw [mem_pairIdx] at hp
  obtain ‚ü®hk, h‚Ąď, hk‚Ąď‚ü© := hp
  have hkD : latticeNorm k ‚Č§ D := hSupport_le k hk
  have h‚ĄďD : latticeNorm ‚Ąď ‚Č§ D := hSupport_le ‚Ąď h‚Ąď
  have hk‚ĄďD : latticeNorm (k + ‚Ąď) ‚Č§ D := hSupport_le (k + ‚Ąď) hk‚Ąď
  have hk_nn : 0 ‚Č§ latticeNorm k := latticeNorm_nonneg _
  have h‚Ąď_nn : 0 ‚Č§ latticeNorm ‚Ąď := latticeNorm_nonneg _
  have hk‚Ąď_nn : 0 ‚Č§ latticeNorm (k + ‚Ąď) := latticeNorm_nonneg _
  unfold commutatorSummand
  -- Bound each factor.
  -- 1) ‚ÄĖI ¬∑ X‚ÄĖ = ‚ÄĖX‚ÄĖ
  -- 2) ‚ÄĖ(|k+‚Ąď|¬≤ - |k|¬≤)‚ÄĖ = |(|k+‚Ąď|¬≤ - |k|¬≤)| ‚Č§ 3¬∑(‚ÄĖk‚ÄĖ+‚ÄĖ‚Ąď‚ÄĖ)¬∑‚ÄĖ‚Ąď‚ÄĖ ‚Č§ 3¬∑2D¬∑D = 6D¬≤
  -- 3) ‚ÄĖ|k+‚Ąď|¬≤‚ÄĖ = (|k+‚Ąď|)¬≤ ‚Č§ D¬≤
  -- 4) ‚ÄĖő£_j k_j¬∑u_j ‚Ąď‚ÄĖ ‚Č§ ő£_j |k_j|¬∑‚ÄĖu_j ‚Ąď‚ÄĖ ‚Č§ ‚ÄĖk‚ÄĖ¬∑ő£_j ‚ÄĖu_j ‚Ąď‚ÄĖ ‚Č§ D¬∑ő£_j ‚ÄĖu_j ‚Ąď‚ÄĖ
  -- 5) ‚ÄĖc k‚ÄĖ, ‚ÄĖc (k+‚Ąď)‚ÄĖ as-is
  -- Total: 1 ¬∑ 6D¬≤ ¬∑ D¬≤ ¬∑ D¬∑ő£ ¬∑ ‚ÄĖc k‚ÄĖ¬∑‚ÄĖc (k+‚Ąď)‚ÄĖ = 6¬∑D‚ĀĶ¬∑ő£¬∑‚ÄĖc k‚ÄĖ¬∑‚ÄĖc (k+‚Ąď)‚ÄĖ
  have hDiff_abs :
      ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2 - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ
        ‚Č§ 3 * (latticeNorm k + latticeNorm ‚Ąď) * latticeNorm ‚Ąď := by
    have hReal_diff :
        ((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2 - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2
          = (((latticeNorm (k + ‚Ąď)) ^ 2 - (latticeNorm k) ^ 2 : ‚ĄĚ) : ‚Ąā) := by
      push_cast; ring
    rw [hReal_diff, Complex.norm_real, Real.norm_eq_abs]
    exact abs_latticeNorm_add_sq_sub_sq_le k ‚Ąď
  have hDiff_le : ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2
                    - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ
                 ‚Č§ 6 * D ^ 2 := by
    calc ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2 - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ
        ‚Č§ 3 * (latticeNorm k + latticeNorm ‚Ąď) * latticeNorm ‚Ąď := hDiff_abs
      _ ‚Č§ 3 * (2 * D) * D := by
          have h1 : latticeNorm k + latticeNorm ‚Ąď ‚Č§ 2 * D := by linarith
          have h2 : latticeNorm ‚Ąď ‚Č§ D := h‚ĄďD
          have h3 : 0 ‚Č§ latticeNorm k + latticeNorm ‚Ąď := by linarith
          nlinarith [h1, h2, h3, h‚Ąď_nn]
      _ = 6 * D ^ 2 := by ring
  have hKLSq_le : ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ ‚Č§ D ^ 2 := by
    rw [norm_pow, Complex.norm_of_nonneg hk‚Ąď_nn]
    exact pow_le_pow_left‚āÄ hk‚Ąď_nn hk‚ĄďD 2
  have hJsum_le :
      ‚ÄĖ(‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)‚ÄĖ
        ‚Č§ D * (‚ąĎ j : Fin 2, ‚ÄĖu j ‚Ąď‚ÄĖ) := by
    calc ‚ÄĖ(‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)‚ÄĖ
        ‚Č§ ‚ąĎ j : Fin 2, ‚ÄĖ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď‚ÄĖ := norm_sum_le _ _
      _ = ‚ąĎ j : Fin 2, |((k j : ‚ĄĚ))| * ‚ÄĖu j ‚Ąď‚ÄĖ := by
          apply Finset.sum_congr rfl
          intros j _
          rw [norm_mul]
          congr 1
          exact Complex.norm_real _
      _ ‚Č§ ‚ąĎ j : Fin 2, latticeNorm k * ‚ÄĖu j ‚Ąď‚ÄĖ := by
          apply Finset.sum_le_sum
          intros j _
          have hComp : |((k j : ‚ĄĚ))| ‚Č§ latticeNorm k := by
            have h1 : ((k j : ‚ĄĚ)) ^ 2 ‚Č§ (latticeNorm k) ^ 2 :=
              sq_le_latticeNorm_sq k j
            have h2 : 0 ‚Č§ latticeNorm k := latticeNorm_nonneg _
            nlinarith [h1, abs_nonneg ((k j : ‚ĄĚ)), sq_abs ((k j : ‚ĄĚ))]
          exact mul_le_mul_of_nonneg_right hComp (norm_nonneg _)
      _ ‚Č§ ‚ąĎ j : Fin 2, D * ‚ÄĖu j ‚Ąď‚ÄĖ := by
          apply Finset.sum_le_sum
          intros j _
          exact mul_le_mul_of_nonneg_right hkD (norm_nonneg _)
      _ = D * (‚ąĎ j : Fin 2, ‚ÄĖu j ‚Ąď‚ÄĖ) := by rw [‚Üź Finset.mul_sum]
  -- Combine all bounds.
  have hJsum_nn : 0 ‚Č§ (‚ąĎ j : Fin 2, ‚ÄĖu j ‚Ąď‚ÄĖ) :=
    Finset.sum_nonneg (fun _ _ => norm_nonneg _)
  have hD_pow_nn : 0 ‚Č§ D ^ 2 := sq_nonneg _
  have hNormI : ‚ÄĖComplex.I‚ÄĖ = 1 := Complex.norm_I
  -- The full product:
  -- ‚ÄĖI ¬∑ (diff) ¬∑ (sq) ¬∑ jsum ¬∑ c k ¬∑ star(c (k+‚Ąď))‚ÄĖ
  -- = ‚ÄĖI‚ÄĖ ¬∑ ‚ÄĖdiff‚ÄĖ ¬∑ ‚ÄĖsq‚ÄĖ ¬∑ ‚ÄĖjsum‚ÄĖ ¬∑ ‚ÄĖc k‚ÄĖ ¬∑ ‚ÄĖstar(c (k+‚Ąď))‚ÄĖ
  -- = 1 ¬∑ ‚ÄĖdiff‚ÄĖ ¬∑ ‚ÄĖsq‚ÄĖ ¬∑ ‚ÄĖjsum‚ÄĖ ¬∑ ‚ÄĖc k‚ÄĖ ¬∑ ‚ÄĖc (k+‚Ąď)‚ÄĖ  (star preserves norm)
  rw [show (Complex.I
            * (((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2 - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2)
            * ((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2
            * (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)
            * c k * star (c (k + ‚Ąď)))
        = Complex.I * ((((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2 - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2)
            * (((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2
            * ((‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)
            * (c k * star (c (k + ‚Ąď)))))) from by ring]
  rw [norm_mul, hNormI, one_mul]
  rw [norm_mul, norm_mul, norm_mul, norm_mul]
  rw [show ‚ÄĖstar (c (k + ‚Ąď))‚ÄĖ = ‚ÄĖc (k + ‚Ąď)‚ÄĖ from norm_star _]
  -- Goal: ‚ÄĖdiff‚ÄĖ ¬∑ ‚ÄĖsq‚ÄĖ ¬∑ ‚ÄĖjsum‚ÄĖ ¬∑ ‚ÄĖc k‚ÄĖ ¬∑ ‚ÄĖc (k+‚Ąď)‚ÄĖ ‚Č§ 6¬∑D‚ĀĶ¬∑ő£‚ÄĖu_j ‚Ąď‚ÄĖ¬∑‚ÄĖc k‚ÄĖ¬∑‚ÄĖc (k+‚Ąď)‚ÄĖ
  have hCK_nn : 0 ‚Č§ ‚ÄĖc k‚ÄĖ := norm_nonneg _
  have hCKL_nn : 0 ‚Č§ ‚ÄĖc (k + ‚Ąď)‚ÄĖ := norm_nonneg _
  -- Chain of mul_le_mul: ‚ÄĖdiff‚ÄĖ¬∑‚ÄĖsq‚ÄĖ ‚Č§ 6D¬≤¬∑D¬≤ = 6D‚Āī
  have hDiffSq : ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2
                  - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ
                * ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ ‚Č§ 6 * D ^ 4 := by
    calc ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2 - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ
         * ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ
        ‚Č§ (6 * D ^ 2) * (D ^ 2) := by
          apply mul_le_mul hDiff_le hKLSq_le (norm_nonneg _)
          nlinarith [hD]
      _ = 6 * D ^ 4 := by ring
  -- Full chain: explicit calc to avoid nlinarith friction on products.
  set Ndiff := ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2
                 - ((latticeNorm k : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ with hNdiff
  set Nsq := ‚ÄĖ(((latticeNorm (k + ‚Ąď) : ‚ĄĚ) : ‚Ąā) ^ 2)‚ÄĖ with hNsq
  set Nj := ‚ÄĖ(‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)‚ÄĖ with hNj
  set SumU := ‚ąĎ j : Fin 2, ‚ÄĖu j ‚Ąď‚ÄĖ with hSumU
  have hNdiff_nn : 0 ‚Č§ Ndiff := norm_nonneg _
  have hNsq_nn : 0 ‚Č§ Nsq := norm_nonneg _
  have hNj_nn : 0 ‚Č§ Nj := norm_nonneg _
  have hDiffSq' : Ndiff * Nsq ‚Č§ 6 * D ^ 4 := hDiffSq
  have hJsum_le' : Nj ‚Č§ D * SumU := hJsum_le
  have hD_nn4 : 0 ‚Č§ 6 * D ^ 4 := by positivity
  calc Ndiff * (Nsq * (Nj * (‚ÄĖc k‚ÄĖ * ‚ÄĖc (k + ‚Ąď)‚ÄĖ)))
      = (Ndiff * Nsq) * Nj * ‚ÄĖc k‚ÄĖ * ‚ÄĖc (k + ‚Ąď)‚ÄĖ := by ring
    _ ‚Č§ (6 * D ^ 4) * Nj * ‚ÄĖc k‚ÄĖ * ‚ÄĖc (k + ‚Ąď)‚ÄĖ := by
        have h1 : 0 ‚Č§ Nj := hNj_nn
        have h2 : 0 ‚Č§ ‚ÄĖc k‚ÄĖ := hCK_nn
        have h3 : 0 ‚Č§ ‚ÄĖc (k + ‚Ąď)‚ÄĖ := hCKL_nn
        nlinarith [hDiffSq', h1, h2, h3, mul_nonneg (mul_nonneg h1 h2) h3]
    _ ‚Č§ (6 * D ^ 4) * (D * SumU) * ‚ÄĖc k‚ÄĖ * ‚ÄĖc (k + ‚Ąď)‚ÄĖ := by
        have h1 : (0 : ‚ĄĚ) ‚Č§ 6 * D ^ 4 := hD_nn4
        have h2 : 0 ‚Č§ ‚ÄĖc k‚ÄĖ := hCK_nn
        have h3 : 0 ‚Č§ ‚ÄĖc (k + ‚Ąď)‚ÄĖ := hCKL_nn
        nlinarith [hJsum_le', h1, h2, h3, mul_nonneg (mul_nonneg h1 h2) h3]
    _ = 6 * D ^ 5 * SumU * ‚ÄĖc k‚ÄĖ * ‚ÄĖc (k + ‚Ąď)‚ÄĖ := by ring

/-! ### ¬ß10.76 Energy-inequality-to-exponential bound

The analytic cancellation (¬ß10.74) and commutator estimate (¬ß10.75)
combine at the Galerkin trajectory level to an **energy inequality**:
```
|deriv (trigPolyEnergyHs2 S ‚ąė őĪ) ŌĄ| ‚Č§ K ¬∑ trigPolyEnergyHs2 S (őĪ ŌĄ)
```
for some rate `K` depending on the support diameter, velocity Sobolev
bound, and shape constants.

Given this inequality, ¬ß10.64's `scalar_gronwall_exp` immediately
yields the exponential bound
```
trigPolyEnergyHs2 S (őĪ ŌĄ) ‚Č§ trigPolyEnergyHs2 S (őĪ 0) ¬∑ exp(K ¬∑ ŌĄ)
```
on `[0, T]`. Bridging via ¬ß10.68's `trigPolyEnergyHs2_eq_hsSeminormSq`,
this is exactly what `GalerkinEnergyGronwall` packages.

This section wraps the Gronwall application; ¬ß10.77 promotes it to a
`GalerkinEnergyGronwall` witness; ¬ß10.78 composes with ¬ß10.67 for the
unconditional BKMCriterionS2. -/

/-- **Energy-inequality-to-exponential bound.** -/
theorem trigPolyEnergy_exp_bound_of_deriv_le
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)) (K T : ‚ĄĚ) (hT : 0 ‚Č§ T) (hK_nn : 0 ‚Č§ K)
    (hE_cont : ContinuousOn (fun t => trigPolyEnergyHs2 S (őĪ t)) (Set.Icc 0 T))
    (hE_deriv : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
      HasDerivWithinAt (fun t => trigPolyEnergyHs2 S (őĪ t))
        (deriv (fun t => trigPolyEnergyHs2 S (őĪ t)) x) (Set.Ici x) x)
    (hE_bound : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
      |deriv (fun t => trigPolyEnergyHs2 S (őĪ t)) x|
        ‚Č§ K * |trigPolyEnergyHs2 S (őĪ x)|) :
    ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) T,
      trigPolyEnergyHs2 S (őĪ t)
        ‚Č§ trigPolyEnergyHs2 S (őĪ 0) * Real.exp (K * t) :=
  scalar_gronwall_exp (fun t => trigPolyEnergyHs2 S (őĪ t)) K T hT
    hE_cont hE_deriv hE_bound
    (fun _ _ => trigPolyEnergyHs2_nonneg (őĪ _))

/-! ### ¬ß10.77 Promotion to `GalerkinEnergyGronwall`

Wraps the ¬ß10.76 exponential bound as a `GalerkinEnergyGronwall` witness
for the lifted Lp trajectory `ŌĄ ‚Ü¶ galerkinToLp S (őĪ ŌĄ)`. The trig-poly
finite-sum energy equals `hsSeminormSq 2 (galerkinToLp ...)` via ¬ß10.68,
so the witness's `hsSeminormSq`-indexed bounds come for free. -/

/-- **Promotion to `GalerkinEnergyGronwall`.** -/
theorem galerkinEnergyGronwall_of_deriv_le
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)) (K T : ‚ĄĚ) (hT : 0 ‚Č§ T) (hK_nn : 0 ‚Č§ K)
    (hE_cont : ContinuousOn (fun t => trigPolyEnergyHs2 S (őĪ t)) (Set.Icc 0 T))
    (hE_deriv : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
      HasDerivWithinAt (fun t => trigPolyEnergyHs2 S (őĪ t))
        (deriv (fun t => trigPolyEnergyHs2 S (őĪ t)) x) (Set.Ici x) x)
    (hE_bound : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
      |deriv (fun t => trigPolyEnergyHs2 S (őĪ t)) x|
        ‚Č§ K * |trigPolyEnergyHs2 S (őĪ x)|) :
    GalerkinEnergyGronwall (fun ŌĄ => galerkinToLp S (őĪ ŌĄ))
      (trigPolyEnergyHs2 S (őĪ 0)) K T where
  nonneg_T := hT
  nonneg_E‚āÄ := trigPolyEnergyHs2_nonneg (őĪ 0)
  nonneg_K := hK_nn
  initial_bound := by
    rw [‚Üź trigPolyEnergyHs2_eq_hsSeminormSq]
  exp_bound := fun t ht => by
    rw [‚Üź trigPolyEnergyHs2_eq_hsSeminormSq]
    exact trigPolyEnergy_exp_bound_of_deriv_le őĪ K T hT hK_nn
      hE_cont hE_deriv hE_bound t ht

/-! ### ¬ß10.78 Final capstone: unconditional `BKMCriterionS2` from energy inequality

Top-level capstone of the ¬ß10.61-¬ß10.78 chain. Composes ¬ß10.77
(GalerkinEnergyGronwall from energy inequality) with ¬ß10.67
(`BKMCriterionS2.of_galerkinEnergyGronwall`) to give an **unconditional**
`BKMCriterionS2` for any Galerkin trajectory on a finite-support `S`
satisfying the energy inequality hypothesis. -/

/-- **Unconditional `BKMCriterionS2` from energy inequality.** Closes
the ¬ß10.61-¬ß10.78 chain: given a Galerkin trajectory `őĪ` on finite
support `S` with energy inequality `|d/dt E| ‚Č§ K¬∑|E|`, zero-mode bound,
and extension-to-infinity convention, `BKMCriterionS2` holds for the
lifted Lp trajectory. -/
theorem BKMCriterionS2.of_galerkin_energy_inequality
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S,
      mFourierCoeff (galerkinToLp S (őĪ ŌĄ)) n = 0)
    (K T M‚āÄ : ‚ĄĚ) (hT_pos : 0 < T) (hK_nn : 0 ‚Č§ K) (hM‚āÄ_nn : 0 ‚Č§ M‚āÄ)
    (hE_cont : ContinuousOn (fun t => trigPolyEnergyHs2 S (őĪ t)) (Set.Icc 0 T))
    (hE_deriv : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
      HasDerivWithinAt (fun t => trigPolyEnergyHs2 S (őĪ t))
        (deriv (fun t => trigPolyEnergyHs2 S (őĪ t)) x) (Set.Ici x) x)
    (hE_bound : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
      |deriv (fun t => trigPolyEnergyHs2 S (őĪ t)) x|
        ‚Č§ K * |trigPolyEnergyHs2 S (őĪ x)|)
    (hZeroMode : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ŌĄ ‚Č§ T ‚Üí
      ‚ÄĖmFourierCoeff (galerkinToLp S (őĪ ŌĄ)) (0 : Fin 2 ‚Üí ‚Ą§)‚ÄĖ ‚Č§ M‚āÄ)
    (hExtend : ‚ąÄ ŌĄ : ‚ĄĚ, T < ŌĄ ‚Üí
      ‚ąÄ n, mFourierCoeff (galerkinToLp S (őĪ ŌĄ)) n = 0) :
    BKMCriterionS2 (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) := by
  have hGW := galerkinEnergyGronwall_of_deriv_le őĪ K T (le_of_lt hT_pos) hK_nn
    hE_cont hE_deriv hE_bound
  exact BKMCriterionS2.of_galerkinEnergyGronwall
    (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) S hSupport
    (trigPolyEnergyHs2 S (őĪ 0)) K T M‚āÄ hT_pos hGW hM‚āÄ_nn hZeroMode hExtend

/-! ### ¬ß10.79 Combined advection + commutator summand factorization

The advection split `‚ÄĖk+‚Ąď‚ÄĖ‚Āī = ‚ÄĖk‚ÄĖ¬≤¬∑‚ÄĖk+‚Ąď‚ÄĖ¬≤ + (‚ÄĖk+‚Ąď‚ÄĖ¬≤ - ‚ÄĖk‚ÄĖ¬≤)¬∑‚ÄĖk+‚Ąď‚ÄĖ¬≤`
gives the algebraic identity

```
advectionSummand u c (k, ‚Ąď) + commutatorSummand u c (k, ‚Ąď)
  = i ¬∑ ‚ÄĖk+‚Ąď‚ÄĖ‚Āī ¬∑ (‚ąĎ_j k_j ¬∑ u_j ‚Ąď) ¬∑ c(k) ¬∑ star(c(k+‚Ąď))
```

This is the kernel that connects ¬ß10.69's energy-derivative formula to
the ¬ß10.74 (advection cancellation) + ¬ß10.75 (commutator bound) chain.
The right-hand side is exactly what appears when expanding the inner
product `‚ü™c m, galerkinVectorField S c m‚üę_‚ĄĚ` weighted by `(fracDerivSymbol
2 m.val)^2` and reindexing `m = k + ‚Ąď`. -/

/-- **Combined advection + commutator factorization.** -/
lemma advectionSummand_add_commutatorSummand
    (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) :
    advectionSummand u c p + commutatorSummand u c p
      = Complex.I * (((latticeNorm (p.1 + p.2) : ‚ĄĚ) : ‚Ąā) ^ 4)
        * (‚ąĎ j : Fin 2, ((p.1 j : ‚ĄĚ) : ‚Ąā) * u j p.2)
        * c p.1 * star (c (p.1 + p.2)) := by
  obtain ‚ü®k, ‚Ąď‚ü© := p
  unfold advectionSummand commutatorSummand
  -- LHS = i¬∑|k|¬≤¬∑|k+‚Ąď|¬≤¬∑X + i¬∑(|k+‚Ąď|¬≤ - |k|¬≤)¬∑|k+‚Ąď|¬≤¬∑X
  --     = i¬∑|k+‚Ąď|¬≤¬∑X¬∑(|k|¬≤ + |k+‚Ąď|¬≤ - |k|¬≤)
  --     = i¬∑|k+‚Ąď|‚Āī¬∑X
  -- where X = (‚ąĎ_j k_j¬∑u_j(‚Ąď))¬∑c(k)¬∑star(c(k+‚Ąď))
  -- The factor `((‚ÄĖk+‚Ąď‚ÄĖ)¬≤ - ‚ÄĖk‚ÄĖ¬≤)¬∑(‚ÄĖk+‚Ąď‚ÄĖ)¬≤ + ‚ÄĖk‚ÄĖ¬≤¬∑(‚ÄĖk+‚Ąď‚ÄĖ)¬≤ = (‚ÄĖk+‚Ąď‚ÄĖ)‚Āī`
  -- collapses by `ring` after recognising `((¬∑:‚ĄĚ):‚Ąā)^4 = ((¬∑:‚ĄĚ):‚Ąā)^2 ¬∑ ((¬∑:‚ĄĚ):‚Ąā)^2`.
  ring

/-! ### ¬ß10.80 Pair-Finset reindexing for the energy double sum

Bijection between the index set `{(m, ‚Ąď) ‚ąą S √ó S : m - ‚Ąď ‚ąą S}` arising
from the Galerkin RHS expansion and `pairIdx S = {(k, ‚Ąď) ‚ąą S √ó S :
k + ‚Ąď ‚ąą S}` used by ¬ß10.74/¬ß10.75. The map `(m, ‚Ąď) ‚Ü¶ (m - ‚Ąď, ‚Ąď)` is the
natural bijection (inverse `(k, ‚Ąď) ‚Ü¶ (k + ‚Ąď, ‚Ąď)`).

Used by ¬ß10.81 to reindex `‚ąĎ_m ‚ąĎ_{‚Ąď : m-‚Ąď ‚ąą S} F(m, ‚Ąď) =
‚ąĎ_{(k, ‚Ąď) ‚ąą pairIdx S} F(k+‚Ąď, ‚Ąď)` so the ¬ß10.79 factorization applies. -/

/-- **Pair-Finset reindexing lemma.** -/
lemma sum_pair_diff_eq_sum_pairIdx
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {őĪ : Type*} [AddCommMonoid őĪ]
    (F : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) ‚Üí őĪ) :
    (‚ąĎ m ‚ąą S, ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S), F (m, ‚Ąď))
      = ‚ąĎ p ‚ąą pairIdx S, F (p.1 + p.2, p.2) := by
  -- Step 1: convert double sum (filter inside) to single sum (filter outside).
  have hCombine : (‚ąĎ m ‚ąą S, ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S), F (m, ‚Ąď))
                = ‚ąĎ p ‚ąą (S √óňĘ S).filter (fun p => p.1 - p.2 ‚ąą S), F p := by
    -- Inner sum filter ‚Üí if-then-else
    have hInner : ‚ąÄ m ‚ąą S,
        (‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S), F (m, ‚Ąď))
          = ‚ąĎ ‚Ąď ‚ąą S, if m - ‚Ąď ‚ąą S then F (m, ‚Ąď) else 0 := by
      intros m _; rw [Finset.sum_filter]
    rw [Finset.sum_congr rfl hInner]
    -- Combine product
    rw [‚Üź Finset.sum_product
          (f := fun p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) =>
                  if p.1 - p.2 ‚ąą S then F p else 0)]
    -- Outer if-then-else ‚Üí filter (back direction)
    rw [Finset.sum_filter]
  rw [hCombine]
  -- Step 2: bijection (m, ‚Ąď) ‚Ü¶ (m - ‚Ąď, ‚Ąď) on (S √óňĘ S).filter (m - ‚Ąď ‚ąą S) ‚Üí pairIdx S.
  refine Finset.sum_nbij' (fun p => (p.1 - p.2, p.2)) (fun p => (p.1 + p.2, p.2)) ?_ ?_ ?_ ?_ ?_
  ¬∑ intros p hp
    rw [Finset.mem_filter, Finset.mem_product] at hp
    obtain ‚ü®‚ü®_, h‚Ąď‚ü©, hm‚Ąď‚ü© := hp
    rw [mem_pairIdx]
    refine ‚ü®hm‚Ąď, h‚Ąď, ?_‚ü©
    show p.1 - p.2 + p.2 ‚ąą S
    rwa [sub_add_cancel]
  ¬∑ intros p hp
    rw [mem_pairIdx] at hp
    obtain ‚ü®hk, h‚Ąď, hk‚Ąď‚ü© := hp
    rw [Finset.mem_filter, Finset.mem_product]
    refine ‚ü®‚ü®hk‚Ąď, h‚Ąď‚ü©, ?_‚ü©
    show p.1 + p.2 - p.2 ‚ąą S
    rwa [add_sub_cancel_right]
  ¬∑ intros p _
    obtain ‚ü®k, ‚Ąď‚ü© := p
    show (k - ‚Ąď + ‚Ąď, ‚Ąď) = (k, ‚Ąď)
    rw [sub_add_cancel]
  ¬∑ intros p _
    obtain ‚ü®m, ‚Ąď‚ü© := p
    show (m + ‚Ąď - ‚Ąď, ‚Ąď) = (m, ‚Ąď)
    rw [add_sub_cancel_right]
  ¬∑ intros p _
    obtain ‚ü®m, ‚Ąď‚ü© := p
    show F (m, ‚Ąď) = F ((m - ‚Ąď) + ‚Ąď, ‚Ąď)
    rw [sub_add_cancel]

/-! ### ¬ß10.81 Energy summand factorization at fixed `(k, ‚Ąď)`

At each `(k, ‚Ąď) ‚ąą pairIdx S` with `k + ‚Ąď ‚Č† 0` (true whenever `0 ‚ąČ S`),
the algebraic factor that appears in ¬ß10.69's energy-derivative formula
after substituting `m = k + ‚Ąď` matches `advectionSummand u cŐÉ + commutatorSummand u cŐÉ`
under the Riesz velocity `u_j ‚Ąď = sqgVelocitySymbol j ‚Ąď * cŐÉ ‚Ąď`.

This is the per-pair piece of the ¬ß10.82 main identity. -/

/-- **Energy summand factorization at fixed `(k, ‚Ąď)`.** -/
lemma energySummand_eq_advectionSummand_add_commutatorSummand
    (c' : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) {k ‚Ąď : Fin 2 ‚Üí ‚Ą§} (hk‚Ąď : k + ‚Ąď ‚Č† 0) :
    (((fracDerivSymbol 2 (k + ‚Ąď)) ^ 2 : ‚ĄĚ) : ‚Ąā) * star (c' (k + ‚Ąď))
        * c' ‚Ąď * c' k * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k)
      = advectionSummand (fun j ‚Ąď' => sqgVelocitySymbol j ‚Ąď' * c' ‚Ąď') c' (k, ‚Ąď)
        + commutatorSummand (fun j ‚Ąď' => sqgVelocitySymbol j ‚Ąď' * c' ‚Ąď') c' (k, ‚Ąď) := by
  rw [advectionSummand_add_commutatorSummand, fracDerivSymbol_two_eq hk‚Ąď]
  -- Rewrite both j-sums into the canonical form ő£ j, sqgVS j ‚Ąď ¬∑ ((k j : ‚ĄĚ) : ‚Ąā),
  -- pulling out I (LHS) and c' ‚Ąď (RHS) so `ring` can close the rest.
  have hLHS_sum : (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k)
                  = Complex.I * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * ((k j : ‚ĄĚ) : ‚Ąā)) := by
    unfold derivSymbol
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intros j _; ring
  have hRHS_sum : (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * (sqgVelocitySymbol j ‚Ąď * c' ‚Ąď))
                  = c' ‚Ąď * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * ((k j : ‚ĄĚ) : ‚Ąā)) := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intros j _; ring
  rw [hLHS_sum, hRHS_sum]
  push_cast
  ring

/-! ### ¬ß10.82 Real inner-product on `‚Ąā` via `star z ¬∑ w`

Bridge helper: `@inner ‚ĄĚ ‚Ąā _ z w = (star z ¬∑ w).re`. Used in ¬ß10.83 to
convert ¬ß10.69's HasDerivAt formula (inner-product form) into the `.re`
form amenable to the pair-sum reindexing. -/

/-- **Real inner product on `‚Ąā` = `Re(star z ¬∑ w)`.** -/
lemma inner_real_complex_eq_re_star_mul (z w : ‚Ąā) :
    @inner ‚ĄĚ ‚Ąā _ z w = (star z * w).re := by
  rw [Complex.inner, mul_comm]
  rfl

/-! ### ¬ß10.83 Pair-sum form of the energy-derivative

Combining ¬ß10.69 (HasDerivAt formula), ¬ß10.82 (inner-product ‚Üí Re form),
¬ß10.80 (pair-Finset reindexing), ¬ß10.81 (per-pair factorization), and
¬ß10.48-style `galerkinRHS` unfolding, the ŠłĘ¬≤ energy-derivative summand
admits the pair-sum form:
```
‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val)¬≤ ¬∑ 2 ¬∑ ‚ü™c m, galerkinVectorField S c m‚üę_‚ĄĚ
  = -2 ¬∑ Re(‚ąĎ_{p ‚ąą pairIdx S} (advectionSummand u c' p + commutatorSummand u c' p))
```
where `c' = galerkinExtend S c` and `u_j ‚Ąď = sqgVelocitySymbol j ‚Ąď ¬∑ c' ‚Ąď`
(Riesz-transform velocity).

Requires `0 ‚ąČ S` so `fracDerivSymbol_two_eq` applies at every `k + ‚Ąď ‚ąą S`. -/

/-- **Pair-sum form of the energy derivative.** -/
theorem trigPolyEnergyHs2_deriv_eq_neg_two_re_pairSum
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S)
    (c : ‚Ü•S ‚Üí ‚Ąā) :
    (‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val) ^ 2 *
        (2 * (@inner ‚ĄĚ ‚Ąā _ (c m) (galerkinVectorField S c m))))
      = -2 * (‚ąĎ p ‚ąą pairIdx S, (
          advectionSummand (fun j ‚Ąď' => sqgVelocitySymbol j ‚Ąď' * galerkinExtend S c ‚Ąď')
              (galerkinExtend S c) p
          + commutatorSummand (fun j ‚Ąď' => sqgVelocitySymbol j ‚Ąď' * galerkinExtend S c ‚Ąď')
              (galerkinExtend S c) p)).re := by
  set c' := galerkinExtend S c
  -- Step 1: per-term inner-product ‚Üí Re conversion + factor extraction.
  have hTerm : ‚ąÄ m : ‚Ü•S,
      (fracDerivSymbol 2 m.val) ^ 2 * (2 * (@inner ‚ĄĚ ‚Ąā _ (c m) (galerkinVectorField S c m)))
        = 2 * ((((fracDerivSymbol 2 m.val) ^ 2 : ‚ĄĚ) : ‚Ąā) *
                (star (c' m.val) * galerkinRHS S c' m.val)).re := by
    intro m
    rw [inner_real_complex_eq_re_star_mul]
    rw [show c m = c' m.val from
          (galerkinExtend_apply_of_mem _ _ m.property).symm]
    rw [show galerkinVectorField S c m = galerkinRHS S c' m.val from rfl]
    rw [Complex.re_ofReal_mul]
    ring
  rw [Finset.sum_congr rfl (fun m _ => hTerm m)]
  rw [‚Üź Finset.mul_sum]
  -- Step 2: Re commutes with sum.
  rw [show (‚ąĎ m : ‚Ü•S, ((((fracDerivSymbol 2 m.val) ^ 2 : ‚ĄĚ) : ‚Ąā) *
                          (star (c' m.val) * galerkinRHS S c' m.val)).re)
            = (‚ąĎ m : ‚Ü•S, (((fracDerivSymbol 2 m.val) ^ 2 : ‚ĄĚ) : ‚Ąā) *
                          (star (c' m.val) * galerkinRHS S c' m.val)).re from
        (Complex.re_sum _ _).symm]
  -- Step 3: ‚Ü•S ‚Üí S via Finset.sum_attach (going through Finset.univ_eq_attach).
  rw [show (‚ąĎ m : ‚Ü•S, (((fracDerivSymbol 2 m.val) ^ 2 : ‚ĄĚ) : ‚Ąā) *
                       (star (c' m.val) * galerkinRHS S c' m.val))
          = ‚ąĎ m ‚ąą S, (((fracDerivSymbol 2 m) ^ 2 : ‚ĄĚ) : ‚Ąā) *
                       (star (c' m) * galerkinRHS S c' m) from by
        rw [show ((Finset.univ : Finset ‚Ü•S)) = S.attach from Finset.univ_eq_attach S]
        exact Finset.sum_attach S
          (fun m => (((fracDerivSymbol 2 m) ^ 2 : ‚ĄĚ) : ‚Ąā) *
                     (star (c' m) * galerkinRHS S c' m))]
  -- Step 4: substitute galerkinRHS, distribute, factor reorder.
  rw [show (‚ąĎ m ‚ąą S, (((fracDerivSymbol 2 m) ^ 2 : ‚ĄĚ) : ‚Ąā) *
                      (star (c' m) * galerkinRHS S c' m))
          = -‚ąĎ m ‚ąą S, ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
                (((fracDerivSymbol 2 m) ^ 2 : ‚ĄĚ) : ‚Ąā) * star (c' m) *
                c' ‚Ąď * c' (m - ‚Ąď) *
                (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) from by
        rw [‚Üź Finset.sum_neg_distrib]
        apply Finset.sum_congr rfl
        intros m _
        have hGR : galerkinRHS S c' m
                  = -‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
                      c' ‚Ąď * c' (m - ‚Ąď)
                        * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)) := rfl
        rw [hGR]
        -- Push negations outward explicitly: s * (-‚ąĎ) ‚Üí -(s * ‚ąĎ); r * (-X) ‚Üí -(r * X).
        rw [mul_neg, mul_neg, neg_inj]
        -- Distribute r and star (c' m) over the sum.
        rw [Finset.mul_sum, Finset.mul_sum]
        apply Finset.sum_congr rfl
        intros ‚Ąď _
        ring]
  -- Step 5: ¬ß10.80 reindexing.
  rw [sum_pair_diff_eq_sum_pairIdx
        (fun p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) =>
          (((fracDerivSymbol 2 p.1) ^ 2 : ‚ĄĚ) : ‚Ąā) * star (c' p.1) * c' p.2 * c' (p.1 - p.2) *
          (‚ąĎ j : Fin 2, sqgVelocitySymbol j p.2 * derivSymbol j (p.1 - p.2)))]
  -- Step 6: simplify (p.1 + p.2 - p.2) = p.1 (in c' and derivSymbol).
  rw [show (‚ąĎ p ‚ąą pairIdx S,
              (((fracDerivSymbol 2 (p.1 + p.2)) ^ 2 : ‚ĄĚ) : ‚Ąā) * star (c' (p.1 + p.2)) *
              c' p.2 * c' (p.1 + p.2 - p.2) *
              (‚ąĎ j : Fin 2, sqgVelocitySymbol j p.2 * derivSymbol j (p.1 + p.2 - p.2)))
          = ‚ąĎ p ‚ąą pairIdx S,
              (((fracDerivSymbol 2 (p.1 + p.2)) ^ 2 : ‚ĄĚ) : ‚Ąā) * star (c' (p.1 + p.2)) *
              c' p.2 * c' p.1 *
              (‚ąĎ j : Fin 2, sqgVelocitySymbol j p.2 * derivSymbol j p.1) from by
        apply Finset.sum_congr rfl
        intros p _
        simp_rw [add_sub_cancel_right]]
  -- Step 7: Apply ¬ß10.81 per pair to recognize as advection + commutator.
  rw [show (‚ąĎ p ‚ąą pairIdx S,
              (((fracDerivSymbol 2 (p.1 + p.2)) ^ 2 : ‚ĄĚ) : ‚Ąā) * star (c' (p.1 + p.2)) *
              c' p.2 * c' p.1 *
              (‚ąĎ j : Fin 2, sqgVelocitySymbol j p.2 * derivSymbol j p.1))
          = ‚ąĎ p ‚ąą pairIdx S,
              (advectionSummand (fun j ‚Ąď' => sqgVelocitySymbol j ‚Ąď' * c' ‚Ąď') c' (p.1, p.2)
              + commutatorSummand (fun j ‚Ąď' => sqgVelocitySymbol j ‚Ąď' * c' ‚Ąď') c' (p.1, p.2))
            from by
        apply Finset.sum_congr rfl
        intros p hp
        rw [mem_pairIdx] at hp
        obtain ‚ü®_, _, hk‚Ąď‚ü© := hp
        have h_ne : p.1 + p.2 ‚Č† 0 := fun h => h0 (h ‚Ėł hk‚Ąď)
        exact energySummand_eq_advectionSummand_add_commutatorSummand c' h_ne]
  -- Step 8: 2 * (-X).re = -2 * X.re via Complex.neg_re + ring.
  rw [Complex.neg_re]
  ring

/-! ### ¬ß10.84 Energy-derivative collapses to the commutator part

Combining ¬ß10.83 (pair-sum form) with ¬ß10.74 (advection cancellation)
under the Riesz-velocity symmetry hypotheses (`IsSymmetricSupport S` +
`IsRealCoeff` of the lifted coefficients), the energy-derivative reduces
to a sum involving only the commutator pair-summand:
```
‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val)¬≤ ¬∑ 2 ¬∑ ‚ü™c m, GVF S c m‚üę_‚ĄĚ
  = -2 ¬∑ Re(‚ąĎ_{p ‚ąą pairIdx S} commutatorSummand u c' p)
```
The Riesz velocity is automatically `IsFourierDivFree` (¬ß10.71); reality
follows from `IsRealCoeff c` + symmetric support via ¬ß10.72. -/

/-- **Advection cancellation in the energy-derivative.** -/
theorem trigPolyEnergyHs2_deriv_eq_neg_two_re_commutatorSum
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S) (hSym : IsSymmetricSupport S)
    (c : ‚Ü•S ‚Üí ‚Ąā)
    (hRealCoeff : ‚ąÄ n ‚ąą S, galerkinExtend S c (-n) = star (galerkinExtend S c n)) :
    (‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val) ^ 2 *
        (2 * (@inner ‚ĄĚ ‚Ąā _ (c m) (galerkinVectorField S c m))))
      = -2 * (‚ąĎ p ‚ąą pairIdx S,
          commutatorSummand (fun j ‚Ąď' => sqgVelocitySymbol j ‚Ąď' * galerkinExtend S c ‚Ąď')
            (galerkinExtend S c) p).re := by
  rw [trigPolyEnergyHs2_deriv_eq_neg_two_re_pairSum h0 c]
  -- Strip the leading `-2 *` via congr 1 so we work with the .re directly.
  congr 1
  -- Goal: (‚ąĎ p, A + C).re = (‚ąĎ p, C).re
  rw [Finset.sum_add_distrib, Complex.add_re]
  -- ¬ß10.74: Re(‚ąĎ advectionSummand) = 0.
  have hOff : ‚ąÄ n ‚ąČ S, galerkinExtend S c n = 0 := fun n hn =>
    galerkinExtend_apply_of_not_mem _ _ hn
  rw [advectionSum_re_eq_zero hSym
        (isFourierDivFree_riesz (galerkinExtend S c))
        (isRealFourier_riesz hSym (galerkinExtend S c) hRealCoeff hOff)]
  exact zero_add _

/-! ### ¬ß10.85 Per-mode L¬≤ bound from the ŠłĘ¬≤ energy

For `m ‚ąą S` with `0 ‚ąČ S`, the squared modulus `‚ÄĖc' m‚ÄĖ¬≤` is bounded by
the full ŠłĘ¬≤ energy:
```
‚ÄĖgalerkinExtend S c m‚ÄĖ¬≤ ‚Č§ trigPolyEnergyHs2 S c
```
because `(fracDerivSymbol 2 m)¬≤ = (latticeNorm m)‚Āī ‚Č• 1` (since `m ‚Č† 0`)
and the term `(fracDerivSymbol 2 m)¬≤ ¬∑ ‚ÄĖc' m‚ÄĖ¬≤` is non-negatively
dominated by the full sum. -/

/-- **Per-mode L¬≤ bound from ŠłĘ¬≤ energy.** -/
lemma sqNorm_le_trigPolyEnergyHs2
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S)
    (c : ‚Ü•S ‚Üí ‚Ąā) {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚ąą S) :
    ‚ÄĖgalerkinExtend S c m‚ÄĖ^2 ‚Č§ trigPolyEnergyHs2 S c := by
  have hm_ne : m ‚Č† 0 := fun h => h0 (h ‚Ėł hm)
  have hLat : 1 ‚Č§ latticeNorm m := latticeNorm_ge_one_of_ne_zero hm_ne
  have hLat_nn : 0 ‚Č§ latticeNorm m := latticeNorm_nonneg m
  -- (fracDerivSymbol 2 m)¬≤ = ((latticeNorm m)¬≤)¬≤ = (latticeNorm m)‚Āī ‚Č• 1.
  have hFD_eq : fracDerivSymbol 2 m = (latticeNorm m)^2 :=
    fracDerivSymbol_two_eq hm_ne
  have hFDSq_ge_one : 1 ‚Č§ (fracDerivSymbol 2 m)^2 := by
    rw [hFD_eq]
    calc (1 : ‚ĄĚ) = 1^4 := by norm_num
      _ ‚Č§ (latticeNorm m)^4 := pow_le_pow_left‚āÄ (by norm_num : (0:‚ĄĚ) ‚Č§ 1) hLat 4
      _ = ((latticeNorm m)^2)^2 := by ring
  -- Reduce ‚ÄĖgalerkinExtend S c m‚ÄĖ¬≤ to ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ¬≤.
  have hCEq : ‚ÄĖgalerkinExtend S c m‚ÄĖ = ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ := by
    rw [galerkinExtend_apply_of_mem _ _ hm]
  rw [hCEq]
  -- ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ¬≤ ‚Č§ (fracDerivSymbol 2 m)¬≤ ¬∑ ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ¬≤.
  have h_one_le : ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ^2 ‚Č§ (fracDerivSymbol 2 m)^2 * ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ^2 := by
    have h := mul_le_mul_of_nonneg_right hFDSq_ge_one (sq_nonneg ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ)
    linarith
  -- (fracDerivSymbol 2 m)¬≤ ¬∑ ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ¬≤ ‚Č§ trigPolyEnergyHs2 S c
  -- (the term at ‚ü®m, hm‚ü© is ‚Č§ the full sum since all terms ‚Č• 0).
  have h_term_le : (fracDerivSymbol 2 m)^2 * ‚ÄĖc ‚ü®m, hm‚ü©‚ÄĖ^2 ‚Č§ trigPolyEnergyHs2 S c := by
    unfold trigPolyEnergyHs2
    exact Finset.single_le_sum (s := Finset.univ)
      (f := fun m' : ‚Ü•S => (fracDerivSymbol 2 m'.val) ^ 2 * ‚ÄĖc m'‚ÄĖ ^ 2)
      (fun m' _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))
      (Finset.mem_univ ‚ü®m, hm‚ü©)
  linarith

/-- **Pair-product L¬≤ bound from ŠłĘ¬≤ energy.** For `a, b ‚ąą S` with
`0 ‚ąČ S`, `‚ÄĖc' a‚ÄĖ ¬∑ ‚ÄĖc' b‚ÄĖ ‚Č§ trigPolyEnergyHs2 S c` via AM-GM. -/
lemma normPairProd_le_trigPolyEnergyHs2
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S)
    (c : ‚Ü•S ‚Üí ‚Ąā) {a b : Fin 2 ‚Üí ‚Ą§} (ha : a ‚ąą S) (hb : b ‚ąą S) :
    ‚ÄĖgalerkinExtend S c a‚ÄĖ * ‚ÄĖgalerkinExtend S c b‚ÄĖ ‚Č§ trigPolyEnergyHs2 S c := by
  have hA := sqNorm_le_trigPolyEnergyHs2 h0 c ha
  have hB := sqNorm_le_trigPolyEnergyHs2 h0 c hb
  set őĪ := ‚ÄĖgalerkinExtend S c a‚ÄĖ
  set ő≤ := ‚ÄĖgalerkinExtend S c b‚ÄĖ
  have hőĪ_nn : 0 ‚Č§ őĪ := norm_nonneg _
  have hő≤_nn : 0 ‚Č§ ő≤ := norm_nonneg _
  -- AM-GM: őĪ ¬∑ ő≤ ‚Č§ (őĪ¬≤ + ő≤¬≤)/2 ‚Č§ E (since őĪ¬≤, ő≤¬≤ ‚Č§ E).
  have hAMGM : őĪ * ő≤ ‚Č§ (őĪ^2 + ő≤^2) / 2 := by nlinarith [sq_nonneg (őĪ - ő≤)]
  linarith

/-! ### ¬ß10.86 Energy inequality |d/dt E| ‚Č§ 24¬∑D‚ĀĶ¬∑M¬∑|S|¬≤¬∑E

Combining ¬ß10.84 (advection cancellation), ¬ß10.75 (commutator pointwise
bound), ¬ß10.85 (per-pair L¬≤ bound), and the brutal pair count
`|pairIdx S| ‚Č§ |S|¬≤`, we obtain the linear energy inequality
```
|d/dt trigPolyEnergyHs2 S c| ‚Č§ K ¬∑ trigPolyEnergyHs2 S c
```
with `K = 24¬∑D‚ĀĶ¬∑M¬∑|S|¬≤`, under hypotheses:
- 0 ‚ąČ S, IsSymmetricSupport S, IsRealCoeff
- Support diameter `D` (`‚ąÄ n ‚ąą S, latticeNorm n ‚Č§ D`)
- L^‚ąě bound `M` on `galerkinExtend S c` over all of `Fin 2 ‚Üí ‚Ą§`

Discharges the `hE_bound` hypothesis of ¬ß10.78. -/

/-- **Energy inequality for the Galerkin trajectory.** -/
theorem trigPolyEnergyHs2_deriv_abs_le
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S) (hSym : IsSymmetricSupport S)
    {D : ‚ĄĚ} (hD_nn : 0 ‚Č§ D) (hSupport_le : ‚ąÄ n ‚ąą S, latticeNorm n ‚Č§ D)
    {M : ‚ĄĚ} (hM_nn : 0 ‚Č§ M)
    (c : ‚Ü•S ‚Üí ‚Ąā)
    (hRealCoeff : ‚ąÄ n ‚ąą S, galerkinExtend S c (-n) = star (galerkinExtend S c n))
    (hCBound : ‚ąÄ m, ‚ÄĖgalerkinExtend S c m‚ÄĖ ‚Č§ M) :
    |‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val) ^ 2 *
        (2 * (@inner ‚ĄĚ ‚Ąā _ (c m) (galerkinVectorField S c m)))|
      ‚Č§ 24 * D^5 * M * (S.card : ‚ĄĚ)^2 * trigPolyEnergyHs2 S c := by
  -- Apply ¬ß10.84 to reduce to commutator-only sum.
  rw [trigPolyEnergyHs2_deriv_eq_neg_two_re_commutatorSum h0 hSym c hRealCoeff]
  set u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā :=
    fun j ‚Ąď' => sqgVelocitySymbol j ‚Ąď' * galerkinExtend S c ‚Ąď'
  set E := trigPolyEnergyHs2 S c with hE_def
  have hE_nn : 0 ‚Č§ E := trigPolyEnergyHs2_nonneg c
  -- Per-pair commutator bound.
  have hPairBound : ‚ąÄ p ‚ąą pairIdx S,
      ‚ÄĖcommutatorSummand u (galerkinExtend S c) p‚ÄĖ ‚Č§ 12 * D^5 * M * E := by
    intros p hp
    have h75 := commutatorSummand_norm_le_on_support u (galerkinExtend S c) D
                  hD_nn hSupport_le p hp
    -- Riesz velocity bound: ‚ąĎ‚Īľ ‚ÄĖu_j p.2‚ÄĖ ‚Č§ 2¬∑‚ÄĖgalerkinExtend S c p.2‚ÄĖ.
    have h_uj : ‚ąÄ j : Fin 2, ‚ÄĖu j p.2‚ÄĖ ‚Č§ ‚ÄĖgalerkinExtend S c p.2‚ÄĖ := by
      intro j
      show ‚ÄĖsqgVelocitySymbol j p.2 * galerkinExtend S c p.2‚ÄĖ
            ‚Č§ ‚ÄĖgalerkinExtend S c p.2‚ÄĖ
      rw [norm_mul]
      have h_sqgVS : ‚ÄĖsqgVelocitySymbol j p.2‚ÄĖ ‚Č§ 1 :=
        sqgVelocitySymbol_norm_le_one j p.2
      nlinarith [norm_nonneg (galerkinExtend S c p.2)]
    have h_uSum : (‚ąĎ j : Fin 2, ‚ÄĖu j p.2‚ÄĖ)
                  ‚Č§ 2 * ‚ÄĖgalerkinExtend S c p.2‚ÄĖ := by
      calc (‚ąĎ j : Fin 2, ‚ÄĖu j p.2‚ÄĖ)
          ‚Č§ ‚ąĎ _j : Fin 2, ‚ÄĖgalerkinExtend S c p.2‚ÄĖ :=
              Finset.sum_le_sum (fun j _ => h_uj j)
        _ = 2 * ‚ÄĖgalerkinExtend S c p.2‚ÄĖ := by
              rw [Finset.sum_const, Finset.card_univ, Fintype.card_fin]
              ring
    rw [mem_pairIdx] at hp
    obtain ‚ü®hp1, hp2, hpKL‚ü© := hp
    have h_pp_le_E : ‚ÄĖgalerkinExtend S c p.1‚ÄĖ
                    * ‚ÄĖgalerkinExtend S c (p.1 + p.2)‚ÄĖ ‚Č§ E :=
      normPairProd_le_trigPolyEnergyHs2 h0 c hp1 hpKL
    have h_p2_le_M : ‚ÄĖgalerkinExtend S c p.2‚ÄĖ ‚Č§ M := hCBound p.2
    have h_p2_nn : 0 ‚Č§ ‚ÄĖgalerkinExtend S c p.2‚ÄĖ := norm_nonneg _
    have h_pp_nn : 0 ‚Č§ ‚ÄĖgalerkinExtend S c p.1‚ÄĖ
                      * ‚ÄĖgalerkinExtend S c (p.1 + p.2)‚ÄĖ := by positivity
    have h_6D5_nn : (0 : ‚ĄĚ) ‚Č§ 6 * D^5 := by positivity
    calc ‚ÄĖcommutatorSummand u (galerkinExtend S c) p‚ÄĖ
        ‚Č§ 6 * D^5 * (‚ąĎ j : Fin 2, ‚ÄĖu j p.2‚ÄĖ) * ‚ÄĖgalerkinExtend S c p.1‚ÄĖ
              * ‚ÄĖgalerkinExtend S c (p.1 + p.2)‚ÄĖ := h75
      _ ‚Č§ 6 * D^5 * (2 * ‚ÄĖgalerkinExtend S c p.2‚ÄĖ) * ‚ÄĖgalerkinExtend S c p.1‚ÄĖ
              * ‚ÄĖgalerkinExtend S c (p.1 + p.2)‚ÄĖ := by gcongr
      _ = 12 * D^5 * ‚ÄĖgalerkinExtend S c p.2‚ÄĖ
              * (‚ÄĖgalerkinExtend S c p.1‚ÄĖ
                    * ‚ÄĖgalerkinExtend S c (p.1 + p.2)‚ÄĖ) := by ring
      _ ‚Č§ 12 * D^5 * M
              * (‚ÄĖgalerkinExtend S c p.1‚ÄĖ
                    * ‚ÄĖgalerkinExtend S c (p.1 + p.2)‚ÄĖ) := by gcongr
      _ ‚Č§ 12 * D^5 * M * E := by gcongr
  -- Sum bound.
  have hSumBound : (‚ąĎ p ‚ąą pairIdx S,
                      ‚ÄĖcommutatorSummand u (galerkinExtend S c) p‚ÄĖ)
                  ‚Č§ 12 * D^5 * M * (S.card : ‚ĄĚ)^2 * E := by
    calc (‚ąĎ p ‚ąą pairIdx S, ‚ÄĖcommutatorSummand u (galerkinExtend S c) p‚ÄĖ)
        ‚Č§ ‚ąĎ _ ‚ąą pairIdx S, 12 * D^5 * M * E := Finset.sum_le_sum hPairBound
      _ = ((pairIdx S).card : ‚ĄĚ) * (12 * D^5 * M * E) := by
            rw [Finset.sum_const]; ring
      _ ‚Č§ ((S.card : ‚ĄĚ) * (S.card : ‚ĄĚ)) * (12 * D^5 * M * E) := by
            have h_pic_le : (pairIdx S).card ‚Č§ S.card * S.card := by
              calc (pairIdx S).card
                  ‚Č§ (S √óňĘ S).card := Finset.card_filter_le _ _
                _ = S.card * S.card := Finset.card_product _ _
            have h_cast : ((pairIdx S).card : ‚ĄĚ)
                        ‚Č§ (S.card : ‚ĄĚ) * (S.card : ‚ĄĚ) := by exact_mod_cast h_pic_le
            gcongr
      _ = 12 * D^5 * M * (S.card : ‚ĄĚ)^2 * E := by ring
  -- Bound the energy derivative.
  have h_re_le_norm :
      |(‚ąĎ p ‚ąą pairIdx S, commutatorSummand u (galerkinExtend S c) p).re|
        ‚Č§ ‚ÄĖ‚ąĎ p ‚ąą pairIdx S, commutatorSummand u (galerkinExtend S c) p‚ÄĖ :=
    abs_re_le_norm _
  have h_norm_le_sum :
      ‚ÄĖ‚ąĎ p ‚ąą pairIdx S, commutatorSummand u (galerkinExtend S c) p‚ÄĖ
        ‚Č§ ‚ąĎ p ‚ąą pairIdx S, ‚ÄĖcommutatorSummand u (galerkinExtend S c) p‚ÄĖ :=
    norm_sum_le _ _
  -- Final calc: |-2 ¬∑ X.re| = 2 ¬∑ |X.re| ‚Č§ 2 ¬∑ ‚ąĎ ‚ÄĖcomponents‚ÄĖ ‚Č§ ...
  have h_two_pos : (0 : ‚ĄĚ) < 2 := two_pos
  calc |(-2) * (‚ąĎ p ‚ąą pairIdx S, commutatorSummand u (galerkinExtend S c) p).re|
      = 2 * |(‚ąĎ p ‚ąą pairIdx S, commutatorSummand u (galerkinExtend S c) p).re| := by
            rw [abs_mul]
            have h_two : |(-2 : ‚ĄĚ)| = 2 := by norm_num
            rw [h_two]
    _ ‚Č§ 2 * (12 * D^5 * M * (S.card : ‚ĄĚ)^2 * E) := by
            have h_chain : |(‚ąĎ p ‚ąą pairIdx S,
                              commutatorSummand u (galerkinExtend S c) p).re|
                          ‚Č§ 12 * D^5 * M * (S.card : ‚ĄĚ)^2 * E :=
              le_trans h_re_le_norm (le_trans h_norm_le_sum hSumBound)
            nlinarith
    _ = 24 * D^5 * M * (S.card : ‚ĄĚ)^2 * E := by ring

/-! ### ¬ß10.87 Top-level `BKMCriterionS2` from Galerkin dynamics + L^‚ąě bound

The complete capstone: combining ¬ß10.69 (HasDerivAt formula), ¬ß10.86
(energy inequality), and ¬ß10.78 (`BKMCriterionS2.of_galerkin_energy_inequality`),
we obtain `BKMCriterionS2` from Galerkin dynamics plus a uniform L^‚ąě bound
on the coefficients along the trajectory, discharging the energy-inequality
hypothesis automatically.

K = 24 ¬∑ D‚ĀĶ ¬∑ M ¬∑ |S|¬≤. -/

/-- **BKMCriterionS2 from Galerkin dynamics + L^‚ąě bound.** Top-level capstone
of the ¬ß10.61-¬ß10.87 chain. -/
theorem BKMCriterionS2.of_galerkin_dynamics_with_L_inf_bound
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S) (hSym : IsSymmetricSupport S)
    {D : ‚ĄĚ} (hD_nn : 0 ‚Č§ D) (hSupport_le : ‚ąÄ n ‚ąą S, latticeNorm n ‚Č§ D)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealCoeff : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąą S,
                    galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    {M T M‚āÄ : ‚ĄĚ} (hT_pos : 0 < T) (hM_nn : 0 ‚Č§ M) (hM‚āÄ_nn : 0 ‚Č§ M‚āÄ)
    (hCBound : ‚ąÄ ŌĄ ‚ąą Set.Icc (0:‚ĄĚ) T, ‚ąÄ m, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) m‚ÄĖ ‚Č§ M)
    (hZeroMode : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ŌĄ ‚Č§ T ‚Üí
      ‚ÄĖmFourierCoeff (galerkinToLp S (őĪ ŌĄ)) (0 : Fin 2 ‚Üí ‚Ą§)‚ÄĖ ‚Č§ M‚āÄ)
    (hExtend : ‚ąÄ ŌĄ : ‚ĄĚ, T < ŌĄ ‚Üí
      ‚ąÄ n, mFourierCoeff (galerkinToLp S (őĪ ŌĄ)) n = 0) :
    BKMCriterionS2 (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) := by
  set K : ‚ĄĚ := 24 * D^5 * M * (S.card : ‚ĄĚ)^2 with hK_def
  have hK_nn : 0 ‚Č§ K := by rw [hK_def]; positivity
  -- Support condition for BKM.
  have hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S,
      mFourierCoeff (galerkinToLp S (őĪ ŌĄ)) n = 0 := by
    intros ŌĄ n hn
    rw [mFourierCoeff_galerkinToLp]
    exact galerkinExtend_apply_of_not_mem _ _ hn
  -- Energy's derivative from ¬ß10.69.
  have hE_hasDeriv : ‚ąÄ ŌĄ, HasDerivAt (fun t => trigPolyEnergyHs2 S (őĪ t))
      (‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val)^2 *
        (2 * (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m)))) ŌĄ :=
    fun ŌĄ => trigPolyEnergyHs2_hasDerivAt őĪ hőĪ ŌĄ
  -- ContinuousOn from HasDerivAt everywhere.
  have hE_cont : ContinuousOn
      (fun t => trigPolyEnergyHs2 S (őĪ t)) (Set.Icc 0 T) := by
    refine Continuous.continuousOn ?_
    exact continuous_iff_continuousAt.mpr (fun ŌĄ => (hE_hasDeriv ŌĄ).continuousAt)
  -- HasDerivWithinAt from HasDerivAt via `.hasDerivWithinAt`.
  have hE_deriv : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
      HasDerivWithinAt (fun t => trigPolyEnergyHs2 S (őĪ t))
        (deriv (fun t => trigPolyEnergyHs2 S (őĪ t)) x) (Set.Ici x) x := by
    intros x _
    have h := hE_hasDeriv x
    rw [h.deriv]
    exact h.hasDerivWithinAt
  -- Energy bound from ¬ß10.86.
  have hE_bound : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
      |deriv (fun t => trigPolyEnergyHs2 S (őĪ t)) x|
        ‚Č§ K * |trigPolyEnergyHs2 S (őĪ x)| := by
    intros x hx
    have h_in_Icc : x ‚ąą Set.Icc (0:‚ĄĚ) T := ‚ü®hx.1, hx.2.le‚ü©
    have hBound := trigPolyEnergyHs2_deriv_abs_le h0 hSym hD_nn hSupport_le hM_nn
                    (őĪ x) (hRealCoeff x) (hCBound x h_in_Icc)
    rw [(hE_hasDeriv x).deriv]
    have h_E_nn : 0 ‚Č§ trigPolyEnergyHs2 S (őĪ x) := trigPolyEnergyHs2_nonneg (őĪ x)
    calc |‚ąĎ m : ‚Ü•S, (fracDerivSymbol 2 m.val) ^ 2 *
              (2 * (@inner ‚ĄĚ ‚Ąā _ (őĪ x m) (galerkinVectorField S (őĪ x) m)))|
        ‚Č§ 24 * D^5 * M * (S.card : ‚ĄĚ)^2 * trigPolyEnergyHs2 S (őĪ x) := hBound
      _ = K * trigPolyEnergyHs2 S (őĪ x) := by rw [hK_def]
      _ = K * |trigPolyEnergyHs2 S (őĪ x)| := by rw [abs_of_nonneg h_E_nn]
  -- Apply ¬ß10.78.
  exact BKMCriterionS2.of_galerkin_energy_inequality őĪ hSupport K T M‚āÄ hT_pos hK_nn hM‚āÄ_nn
    hE_cont hE_deriv hE_bound hZeroMode hExtend

/-! ### ¬ß10.88 Zero-mode-trivial specialization of ¬ß10.87

When `0 ‚ąČ S`, the zero-mode Fourier coefficient `mFourierCoeff (galerkinToLp S c) 0`
equals `galerkinExtend S c 0 = 0` ‚ÄĒ so the `hZeroMode` hypothesis of ¬ß10.87
holds trivially with `M‚āÄ = 0`. This specialization drops `hZeroMode` and `M‚āÄ`
from the parameter list. -/

/-- **BKMCriterionS2 from Galerkin dynamics + L^‚ąě bound (zero-mode-trivial).**
Specialization of ¬ß10.87: when `0 ‚ąČ S`, the zero-mode hypothesis is automatic
with `M‚āÄ = 0`. -/
theorem BKMCriterionS2.of_galerkin_dynamics_zero_excluded
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S) (hSym : IsSymmetricSupport S)
    {D : ‚ĄĚ} (hD_nn : 0 ‚Č§ D) (hSupport_le : ‚ąÄ n ‚ąą S, latticeNorm n ‚Č§ D)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealCoeff : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąą S,
                    galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    {M T : ‚ĄĚ} (hT_pos : 0 < T) (hM_nn : 0 ‚Č§ M)
    (hCBound : ‚ąÄ ŌĄ ‚ąą Set.Icc (0:‚ĄĚ) T, ‚ąÄ m, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) m‚ÄĖ ‚Č§ M)
    (hExtend : ‚ąÄ ŌĄ : ‚ĄĚ, T < ŌĄ ‚Üí
      ‚ąÄ n, mFourierCoeff (galerkinToLp S (őĪ ŌĄ)) n = 0) :
    BKMCriterionS2 (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) := by
  -- Zero-mode is 0 since 0 ‚ąČ S.
  have hZeroMode : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ŌĄ ‚Č§ T ‚Üí
      ‚ÄĖmFourierCoeff (galerkinToLp S (őĪ ŌĄ)) (0 : Fin 2 ‚Üí ‚Ą§)‚ÄĖ ‚Č§ 0 := by
    intros ŌĄ _ _
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ h0, norm_zero]
  exact BKMCriterionS2.of_galerkin_dynamics_with_L_inf_bound
    h0 hSym hD_nn hSupport_le őĪ hőĪ hRealCoeff hT_pos hM_nn (M‚āÄ := 0) le_rfl hCBound
    hZeroMode hExtend

/-! ### ¬ß10.89 On-support weak solution ‚Üí `ModeLipschitz` (route 3)

For a trajectory with finite Fourier support `S`, the `ModeLipschitz`
bound that feeds `SqgEvolutionAxioms_strong` only needs the Fourier-
mode Duhamel identity **at modes `m ‚ąą S`**. Off-support the coefficient
is identically zero (by `hSupport`), so the Lipschitz bound at
`m ‚ąČ S` is automatic with constant `0`.

This bypasses the need to construct a global `DuhamelFlux` from a
Galerkin trajectory ‚ÄĒ which would require the flux to vanish
off-support, a property that holds only for stationary shapes
(¬ß10.33, ¬ß10.49) where the Galerkin dynamics are trivial (¬ß10.60).

By rescoping the Duhamel hypothesis to `m ‚ąą S`, non-trivial Galerkin
trajectories (¬ß10.87) can feed ¬ß10.58-style capstones. -/

/-- **On-support weak-solution predicate.** Demands the Fourier-mode
Duhamel identity only at modes `m ‚ąą S`. For `m ‚ąČ S` the identity is
vacuous given the support hypothesis. -/
def IsSqgWeakSolutionOnSupport
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) : Prop :=
  ‚ąÄ m ‚ąą S, ‚ąÄ s t : ‚ĄĚ, 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
    mFourierCoeff (őł t) m - mFourierCoeff (őł s) m
      = -‚ąę ŌĄ in Set.Icc s t, sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m

/-- **`IsSqgWeakSolution` promotes to `IsSqgWeakSolutionOnSupport`.** For
any `S`, the global weak-solution identity implies its on-support
restriction (forget the `m ‚ąČ S` Duhamel identities). -/
theorem IsSqgWeakSolution.toOnSupport
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hWeak : IsSqgWeakSolution őł u) (S : Finset (Fin 2 ‚Üí ‚Ą§)) :
    IsSqgWeakSolutionOnSupport S őł u :=
  fun m _ s t hs hst => hWeak.duhamel m s t hs hst

/-- **`ModeLipschitz` from finite support + on-support Duhamel identity.**

Mirror of `DuhamelFlux.modeLipschitz`'s Bochner chain (¬ß10.11), but with
the Duhamel hypothesis restricted to modes `m ‚ąą S`. At `m ‚ąČ S`, the
coefficient is zero for all `ŌĄ` (from `hSupport`), so the Lipschitz
bound is immediate with constant `0`.

Per-mode flux bound `hFluxBound` is taken as a hypothesis: callers
(e.g. Galerkin + finite-support + uniform `L^‚ąě` bound) supply it via
`sqgNonlinearFlux_bounded` + ‚Ąď¬≤-summability of velocity/gradient
coefficients. -/
theorem ModeLipschitz.of_finite_support_weak_on_support
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S, mFourierCoeff (őł ŌĄ) n = 0)
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hFluxBound : ‚ąÄ m ‚ąą S, ‚ąÉ K : ‚ĄĚ, 0 ‚Č§ K ‚ąß
      ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖsqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m‚ÄĖ ‚Č§ K)
    (hDuhamelOnS : IsSqgWeakSolutionOnSupport S őł u) :
    ModeLipschitz őł := by
  intro m
  by_cases hm : m ‚ąą S
  ¬∑ -- On-support: Bochner bound on the Duhamel integral.
    obtain ‚ü®K, hK_nn, hK‚ü© := hFluxBound m hm
    refine ‚ü®K, hK_nn, fun s t hs hst => ?_‚ü©
    rw [hDuhamelOnS m hm s t hs hst, norm_neg]
    have hvol_lt_top : (volume : Measure ‚ĄĚ) (Set.Icc s t) < ‚ä§ := by
      rw [Real.volume_Icc]
      exact ENNReal.ofReal_lt_top
    have hbound_on : ‚ąÄ ŌĄ ‚ąą Set.Icc s t,
        ‚ÄĖsqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m‚ÄĖ ‚Č§ K :=
      fun ŌĄ hŌĄ => hK ŌĄ (le_trans hs hŌĄ.1)
    have hbochner :
        ‚ÄĖ‚ąę ŌĄ in Set.Icc s t, sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m‚ÄĖ
          ‚Č§ K * ((volume : Measure ‚ĄĚ).real (Set.Icc s t)) :=
      MeasureTheory.norm_setIntegral_le_of_norm_le_const hvol_lt_top hbound_on
    have hvol_real : ((volume : Measure ‚ĄĚ).real (Set.Icc s t)) = t - s := by
      simp [MeasureTheory.measureReal_def, Real.volume_Icc,
            ENNReal.toReal_ofReal (show (0 : ‚ĄĚ) ‚Č§ t - s by linarith)]
    calc ‚ÄĖ‚ąę ŌĄ in Set.Icc s t, sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m‚ÄĖ
        ‚Č§ K * ((volume : Measure ‚ĄĚ).real (Set.Icc s t)) := hbochner
      _ = K * (t - s) := by rw [hvol_real]
      _ = (t - s) * K := by ring
  ¬∑ -- Off-support: both coefficients are zero, Lipschitz bound trivial.
    refine ‚ü®0, le_refl 0, fun s t _ _ => ?_‚ü©
    rw [hSupport t m hm, hSupport s m hm, sub_self, norm_zero, mul_zero]

/-! ### ¬ß10.90 `SqgEvolutionAxioms_strong` capstone from on-support Duhamel

Parallel to ¬ß10.58 `SqgEvolutionAxioms_strong.of_finite_support_weak_solution`,
but consumes the on-support Duhamel predicate (¬ß10.89). Wraps Phase A's
`ModeLipschitz` construction into the full `SqgEvolutionAxioms_strong`
bundle via the weak-axiom carrier `hE`. -/

/-- **`SqgEvolutionAxioms_strong` from finite support + on-support Duhamel.**
Rescoped ¬ß10.58: consumes `IsSqgWeakSolutionOnSupport` (Duhamel only at
modes `m ‚ąą S`) instead of global `IsSqgWeakSolution`. The off-support
Duhamel identity is not needed because `ModeLipschitz` at `m ‚ąČ S` is
trivially satisfied with constant `0`. -/
theorem SqgEvolutionAxioms_strong.of_finite_support_weak_on_support
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (S : Finset (Fin 2 ‚Üí ‚Ą§))
    (hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S, mFourierCoeff (őł ŌĄ) n = 0)
    (hE : SqgEvolutionAxioms őł)
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hFluxBound : ‚ąÄ m ‚ąą S, ‚ąÉ K : ‚ĄĚ, 0 ‚Č§ K ‚ąß
      ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖsqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m‚ÄĖ ‚Č§ K)
    (hDuhamelOnS : IsSqgWeakSolutionOnSupport S őł u) :
    SqgEvolutionAxioms_strong őł where
  weak := hE
  modeLipschitz :=
    ModeLipschitz.of_finite_support_weak_on_support
      S hSupport u hFluxBound hDuhamelOnS

/-! ### ¬ß10.91 Galerkin dynamics ‚Üí `IsSqgWeakSolutionOnSupport`

The on-support Duhamel identity holds for the lifted Galerkin trajectory
at every mode `m ‚ąą S`. Composes ¬ß10.55 `galerkin_mode_FTC` (per-mode FTC
on the coefficient function) with ¬ß10.48 `galerkinRHS_eq_neg_sqgNonlinearFlux`
(algebraic identification of the Galerkin ODE RHS with the SQG flux) and
the standard `intervalIntegral ‚Üí Set.Icc` bridge for Lebesgue volume.

Off-support modes are out of scope for `IsSqgWeakSolutionOnSupport` ‚ÄĒ they
are handled downstream by Phase A/B via the `hSupport` hypothesis. -/

/-- **Galerkin dynamics yields `IsSqgWeakSolutionOnSupport`.** For any
Galerkin coefficient trajectory `őĪ` on a finite shell `S` solving
`d/dŌĄ őĪ = galerkinVectorField S őĪ`, the lifted `Lp` trajectory satisfies
the Fourier-mode Duhamel identity at every mode `m ‚ąą S`. -/
theorem IsSqgWeakSolutionOnSupport.of_galerkin_dynamics
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, HasDerivAt őĪ (galerkinVectorField S (őĪ ŌĄ)) ŌĄ) :
    IsSqgWeakSolutionOnSupport S
      (fun ŌĄ => galerkinToLp S (őĪ ŌĄ))
      (fun j ŌĄ => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) := by
  intro m hm s t hs hst
  -- Step 1: LHS to őĪ-coefficient difference via `mFourierCoeff_galerkinToLp`.
  have hLHS :
      mFourierCoeff (galerkinToLp S (őĪ t)) m -
          mFourierCoeff (galerkinToLp S (őĪ s)) m
        = őĪ t ‚ü®m, hm‚ü© - őĪ s ‚ü®m, hm‚ü© := by
    rw [mFourierCoeff_galerkinToLp, mFourierCoeff_galerkinToLp,
        galerkinExtend_apply_of_mem _ _ hm, galerkinExtend_apply_of_mem _ _ hm]
  -- Step 2: FTC (¬ß10.55) turns the őĪ-difference into the interval integral.
  have hFTC : őĪ t ‚ü®m, hm‚ü© - őĪ s ‚ü®m, hm‚ü©
      = ‚ąę ŌĄ in s..t, (galerkinVectorField S (őĪ ŌĄ)) ‚ü®m, hm‚ü© :=
    galerkin_mode_FTC őĪ hőĪ ‚ü®m, hm‚ü© s t
  -- Step 3: ¬ß10.48 identifies the integrand as `-sqgNonlinearFlux`.
  have h_vf : ‚ąÄ ŌĄ : ‚ĄĚ,
      (galerkinVectorField S (őĪ ŌĄ)) ‚ü®m, hm‚ü©
        = -sqgNonlinearFlux (galerkinToLp S (őĪ ŌĄ))
            (fun j => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) m := fun ŌĄ =>
    galerkinRHS_eq_neg_sqgNonlinearFlux S (őĪ ŌĄ) m
  have h_integrand :
      ‚ąę ŌĄ in s..t, (galerkinVectorField S (őĪ ŌĄ)) ‚ü®m, hm‚ü©
        = ‚ąę ŌĄ in s..t, -sqgNonlinearFlux (galerkinToLp S (őĪ ŌĄ))
            (fun j => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) m :=
    intervalIntegral.integral_congr (fun ŌĄ _ => h_vf ŌĄ)
  -- Step 4: Chain hLHS + hFTC + h_integrand + factor out `-1`.
  rw [hLHS, hFTC, h_integrand, intervalIntegral.integral_neg]
  -- Goal: -‚ąę ŌĄ in s..t, flux = -‚ąę ŌĄ in Set.Icc s t, flux
  -- Step 5: Bridge interval integral (Ioc) to `Set.Icc` via `integral_of_le`
  -- (‚Üí Ioc) and `integral_Icc_eq_integral_Ioc` (Icc = Ioc under `NoAtoms volume`).
  congr 1
  rw [intervalIntegral.integral_of_le hst,
      ‚Üź MeasureTheory.integral_Icc_eq_integral_Ioc]

/-! ### ¬ß10.92 Unified capstone: Galerkin dynamics ‚Üí `SqgEvolutionAxioms_strong`

Composes ¬ß10.91 (Galerkin ‚Üí on-support Duhamel) with ¬ß10.90 (on-support
Duhamel ‚Üí strong axioms) for the lifted Galerkin trajectory. Takes the
base `SqgEvolutionAxioms` witness and a per-mode flux bound as hypotheses
‚ÄĒ `hSupport` is automatic from `galerkinExtend_apply_of_not_mem`. -/

/-- **Galerkin dynamics + per-mode flux bound ‚Üí `SqgEvolutionAxioms_strong`.**
End-to-end capstone: any Galerkin trajectory on a finite shell `S` with
(i) the base SQG evolution axioms (l¬≤ conservation + zero-mode + Riesz
velocity), and (ii) a uniform-in-time per-mode flux bound, yields the
strengthened axiom bundle.

The flux-bound hypothesis is ordinarily discharged from a uniform `L^‚ąě`
coefficient bound via `sqgNonlinearFlux_bounded` applied pointwise ‚ÄĒ but
is taken abstractly here so that callers can supply any convenient
witness. -/
theorem SqgEvolutionAxioms_strong.of_galerkin_dynamics_on_support
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, HasDerivAt őĪ (galerkinVectorField S (őĪ ŌĄ)) ŌĄ)
    (hE : SqgEvolutionAxioms (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)))
    (hFluxBound : ‚ąÄ m ‚ąą S, ‚ąÉ K : ‚ĄĚ, 0 ‚Č§ K ‚ąß
      ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí
        ‚ÄĖsqgNonlinearFlux (galerkinToLp S (őĪ ŌĄ))
            (fun j => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) m‚ÄĖ ‚Č§ K) :
    SqgEvolutionAxioms_strong (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) := by
  -- Automatic support in `S` from the `galerkinExtend` zero-padding.
  have hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S,
      mFourierCoeff (galerkinToLp S (őĪ ŌĄ)) n = 0 := fun ŌĄ n hn => by
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ hn]
  exact SqgEvolutionAxioms_strong.of_finite_support_weak_on_support
    (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) S hSupport hE
    (fun j ŌĄ => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j)
    hFluxBound
    (IsSqgWeakSolutionOnSupport.of_galerkin_dynamics őĪ hőĪ)

/-! ### ¬ß10.93 Per-mode flux bound from uniform L‚ąě (Phase-2 input)

Derives `hFluxBound` of ¬ß10.92 from a uniform ‚Ąď‚ąě bound on the Galerkin
coefficient vector, closing the remaining abstract hypothesis.

Flux bound (Young-type) from `sqgNonlinearFlux_bounded`:
  `‚ÄĖflux‚ÄĖ ‚Č§ ‚ąĎ_{j=0,1} (‚ÄĖu_j‚ÄĖ¬≤_{‚Ąď¬≤} + ‚ÄĖ‚ąá‚Īľőł‚ÄĖ¬≤_{‚Ąď¬≤}) / 2`.
For Galerkin:
- `‚ÄĖu_j‚ÄĖ¬≤_{‚Ąď¬≤} ‚Č§ M¬≤ ¬∑ |S|` via `‚ÄĖsqgVelocitySymbol‚ÄĖ ‚Č§ 1` + Parseval.
- `‚ÄĖ‚ąá‚Īľőł‚ÄĖ¬≤_{‚Ąď¬≤} ‚Č§ M¬≤ ¬∑ ‚ąĎ_{‚Ąď‚ąąS} (fracDerivSymbol 1 ‚Ąď)¬≤` via ¬ß10.12's
  `norm_derivSymbol_sq_le_fracDerivSymbol_one_sq`.
Summing over the two directions gives `M¬≤¬∑|S| + M¬≤¬∑‚ąĎ_{‚Ąď‚ąąS} ŌÉ‚āĀ(‚Ąď)¬≤`. -/

/-- **Galerkin őł-norm ‚Ąď¬≤ tsum bounded by `M¬≤¬∑|S|` under uniform L‚ąě.** -/
lemma theta_fourier_tsum_le_galerkin_of_L_inf
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) {M : ‚ĄĚ}
    (hBound : ‚ąÄ n, ‚ÄĖgalerkinExtend S c n‚ÄĖ ‚Č§ M) :
    (‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (galerkinToLp S c) ‚Ąď‚ÄĖ ^ 2)
      ‚Č§ M ^ 2 * (S.card : ‚ĄĚ) := by
  rw [tsum_eq_sum (s := S) (by
    intros ‚Ąď h‚Ąď
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ h‚Ąď,
        norm_zero]; ring)]
  calc ‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖmFourierCoeff (galerkinToLp S c) ‚Ąď‚ÄĖ ^ 2
      = ‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 :=
        Finset.sum_congr rfl (fun ‚Ąď _ => by rw [mFourierCoeff_galerkinToLp])
    _ ‚Č§ ‚ąĎ _‚Ąď ‚ąą S, M ^ 2 :=
        Finset.sum_le_sum (fun ‚Ąď _ =>
          pow_le_pow_left‚āÄ (norm_nonneg _) (hBound ‚Ąď) 2)
    _ = M ^ 2 * (S.card : ‚ĄĚ) := by
        rw [Finset.sum_const, nsmul_eq_mul]; ring

/-- **Galerkin velocity ‚Ąď¬≤ tsum bounded by `M¬≤¬∑|S|` under uniform L‚ąě.**
Chains through `IsSqgVelocityComponent` (via ¬ß10.27's
`isSqgVelocityComponent_shellMode`, which applies definitionally since
`galerkinToLp = shellMode ‚ąė galerkinExtend`) and
`velocity_fourier_tsum_le_of_IsSqgVelocityComponent`. -/
lemma velocity_fourier_tsum_le_galerkin_of_L_inf
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) {M : ‚ĄĚ}
    (hBound : ‚ąÄ n, ‚ÄĖgalerkinExtend S c n‚ÄĖ ‚Č§ M)
    (j : Fin 2) :
    (‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (shellVelocity S (galerkinExtend S c) j) ‚Ąď‚ÄĖ ^ 2)
      ‚Č§ M ^ 2 * (S.card : ‚ĄĚ) := by
  have h_vel : IsSqgVelocityComponent (galerkinToLp S c)
      (shellVelocity S (galerkinExtend S c) j) j :=
    isSqgVelocityComponent_shellMode S (galerkinExtend S c) j
  calc (‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (shellVelocity S (galerkinExtend S c) j) ‚Ąď‚ÄĖ ^ 2)
      ‚Č§ ‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (galerkinToLp S c) ‚Ąď‚ÄĖ ^ 2 :=
        velocity_fourier_tsum_le_of_IsSqgVelocityComponent _ _ j h_vel
    _ ‚Č§ M ^ 2 * (S.card : ‚ĄĚ) :=
        theta_fourier_tsum_le_galerkin_of_L_inf c hBound

/-- **Galerkin gradient ‚Ąď¬≤ tsum bounded under uniform L‚ąě.** Finite-support
sum against `fracDerivSymbol 1` weights. -/
lemma gradient_fourier_tsum_le_galerkin_of_L_inf
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) {M : ‚ĄĚ}
    (hBound : ‚ąÄ n, ‚ÄĖgalerkinExtend S c n‚ÄĖ ‚Č§ M)
    (j : Fin 2) :
    (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (galerkinToLp S c) ‚Ąď‚ÄĖ ^ 2)
      ‚Č§ M ^ 2 * ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 := by
  rw [tsum_eq_sum (s := S) (by
    intros ‚Ąď h‚Ąď
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ h‚Ąď,
        mul_zero, norm_zero]; ring)]
  calc ‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (galerkinToLp S c) ‚Ąď‚ÄĖ ^ 2
      = ‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖderivSymbol j ‚Ąď‚ÄĖ ^ 2 * ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 := by
        apply Finset.sum_congr rfl
        intros ‚Ąď _
        rw [mFourierCoeff_galerkinToLp, norm_mul, mul_pow]
    _ ‚Č§ ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 * M ^ 2 := by
        apply Finset.sum_le_sum
        intros ‚Ąď _
        have h1 : ‚ÄĖderivSymbol j ‚Ąď‚ÄĖ ^ 2 ‚Č§ (fracDerivSymbol 1 ‚Ąď) ^ 2 :=
          norm_derivSymbol_sq_le_fracDerivSymbol_one_sq j ‚Ąď
        have h2 : ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 ‚Č§ M ^ 2 :=
          pow_le_pow_left‚āÄ (norm_nonneg _) (hBound ‚Ąď) 2
        have h_nn : 0 ‚Č§ ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 := sq_nonneg _
        have h_frac_nn : 0 ‚Č§ (fracDerivSymbol 1 ‚Ąď) ^ 2 := sq_nonneg _
        nlinarith
    _ = M ^ 2 * ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 := by
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl (fun ‚Ąď _ => by ring)

/-- **Per-mode flux bound for Galerkin trajectories under uniform L‚ąě.**
Discharges the `hFluxBound` hypothesis of ¬ß10.92 with an explicit
constant depending only on `M` and `S`. -/
theorem sqgNonlinearFlux_galerkin_bounded_of_L_inf
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) {M : ‚ĄĚ}
    (hBound : ‚ąÄ n, ‚ÄĖgalerkinExtend S c n‚ÄĖ ‚Č§ M)
    (m : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖsqgNonlinearFlux (galerkinToLp S c)
        (fun j => shellVelocity S (galerkinExtend S c) j) m‚ÄĖ
      ‚Č§ M ^ 2 * (S.card : ‚ĄĚ)
        + M ^ 2 * ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 := by
  -- Summability witnesses: velocity via Parseval, gradient via finite support.
  have hu_sum : ‚ąÄ j : Fin 2,
      Summable (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ =>
        ‚ÄĖmFourierCoeff (shellVelocity S (galerkinExtend S c) j) ‚Ąď‚ÄĖ ^ 2) :=
    fun j => velocity_fourier_summable _
  have hgrad_sum : ‚ąÄ j : Fin 2,
      Summable (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ =>
        ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (galerkinToLp S c) ‚Ąď‚ÄĖ ^ 2) := by
    intro j
    apply summable_of_ne_finset_zero (s := S)
    intros ‚Ąď h‚Ąď
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ h‚Ąď,
        mul_zero, norm_zero]; ring
  have hFlux := sqgNonlinearFlux_bounded (galerkinToLp S c)
    (fun j => shellVelocity S (galerkinExtend S c) j) hu_sum hgrad_sum m
  calc ‚ÄĖsqgNonlinearFlux (galerkinToLp S c)
          (fun j => shellVelocity S (galerkinExtend S c) j) m‚ÄĖ
      ‚Č§ ‚ąĎ j : Fin 2,
          ((‚ąĎ' ‚Ąď, ‚ÄĖmFourierCoeff (shellVelocity S (galerkinExtend S c) j) ‚Ąď‚ÄĖ ^ 2)
            + (‚ąĎ' ‚Ąď, ‚ÄĖderivSymbol j ‚Ąď * mFourierCoeff (galerkinToLp S c) ‚Ąď‚ÄĖ ^ 2))
            / 2 := hFlux
    _ ‚Č§ ‚ąĎ _j : Fin 2,
          (M ^ 2 * (S.card : ‚ĄĚ)
            + M ^ 2 * ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2) / 2 := by
        apply Finset.sum_le_sum
        intros j _
        have h1 := velocity_fourier_tsum_le_galerkin_of_L_inf c hBound j
        have h2 := gradient_fourier_tsum_le_galerkin_of_L_inf c hBound j
        linarith
    _ = M ^ 2 * (S.card : ‚ĄĚ)
          + M ^ 2 * ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 := by
        rw [Fin.sum_univ_two]; ring

/-! ### ¬ß10.94 Phase-2 capstone: Galerkin + L‚ąě ‚Üí `SqgEvolutionAxioms_strong`

Self-contained upgrade of ¬ß10.92: `hFluxBound` is discharged internally
via ¬ß10.93, so the caller only supplies the Galerkin ODE witness, the
base `SqgEvolutionAxioms`, and the uniform L‚ąě coefficient bound. -/

/-- **Galerkin dynamics + uniform L‚ąě ‚Üí `SqgEvolutionAxioms_strong`.**
Composes ¬ß10.92 with ¬ß10.93's per-mode flux bound. Drops the abstract
`hFluxBound` hypothesis in favour of the concrete `hBound : ‚ÄĖőĪ ŌĄ n‚ÄĖ ‚Č§ M`. -/
theorem SqgEvolutionAxioms_strong.of_galerkin_dynamics_with_L_inf_bound_on_support
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, HasDerivAt őĪ (galerkinVectorField S (őĪ ŌĄ)) ŌĄ)
    (hE : SqgEvolutionAxioms (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)))
    {M : ‚ĄĚ}
    (hBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ M) :
    SqgEvolutionAxioms_strong (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) := by
  set K : ‚ĄĚ := M ^ 2 * (S.card : ‚ĄĚ)
    + M ^ 2 * ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 with hK_def
  have hK_nn : 0 ‚Č§ K := by
    have h_card_nn : (0 : ‚ĄĚ) ‚Č§ (S.card : ‚ĄĚ) := Nat.cast_nonneg _
    have h_sum_nn : (0 : ‚ĄĚ) ‚Č§ ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 :=
      Finset.sum_nonneg (fun _ _ => sq_nonneg _)
    have h_M2_nn : (0 : ‚ĄĚ) ‚Č§ M ^ 2 := sq_nonneg _
    rw [hK_def]; nlinarith
  have hFluxBound : ‚ąÄ m ‚ąą S, ‚ąÉ Km : ‚ĄĚ, 0 ‚Č§ Km ‚ąß
      ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí
        ‚ÄĖsqgNonlinearFlux (galerkinToLp S (őĪ ŌĄ))
            (fun j => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) m‚ÄĖ ‚Č§ Km :=
    fun m _ => ‚ü®K, hK_nn, fun ŌĄ hŌĄ => by
      rw [hK_def]
      exact sqgNonlinearFlux_galerkin_bounded_of_L_inf (őĪ ŌĄ) (hBound ŌĄ hŌĄ) m‚ü©
  exact SqgEvolutionAxioms_strong.of_galerkin_dynamics_on_support
    őĪ hőĪ hE hFluxBound

/-! ### ¬ß10.95 ŠłĘ‚Āį advection cancellation

Parallel to the ŠłĘ¬≤ advection cancellation of ¬ß10.73-¬ß10.74, but without
the `|k|¬≤¬∑|k+‚Ąď|¬≤` weights. Used for L¬≤ conservation: the Fourier form of
`Re ‚ü®őł, u¬∑‚ąáőł‚ü© = 0` under `div u = 0`.

Summand: `F(k, ‚Ąď) = i ¬∑ (k ¬∑ √Ľ(‚Ąď)) ¬∑ c(k) ¬∑ star(c(k+‚Ąď))`. Under `advectionSwap`
(defined in ¬ß10.70) and div-free + real-Fourier hypotheses on `u`,
`F(ŌÉ p) + star(F p) = 0`, giving `Re(ő£ F) = 0` via the same pair-swap
cancellation as ¬ß10.74. -/

/-- **ŠłĘ‚Āį advection pair-summand** at `(k, ‚Ąď)`. Strips the `|k|¬≤¬∑|k+‚Ąď|¬≤`
weights of `advectionSummand` (¬ß10.72); the `Complex.I` prefix from
`derivSymbol` is retained because it is essential for the
`star I = -I` cancellation. -/
noncomputable def advectionSummandH0
    (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) : ‚Ąā :=
  Complex.I * (‚ąĎ j : Fin 2, ((p.1 j : ‚ĄĚ) : ‚Ąā) * u j p.2)
    * c p.1 * star (c (p.1 + p.2))

/-- **Kernel identity for ŠłĘ‚Āį:** `advectionSummandH0 (ŌĄ p) + star (advectionSummandH0 p)
= 0` under div-free + reality hypotheses. Simpler than ¬ß10.73 because no
real-norm squared factors need to be handled. -/
theorem advectionSummandH0_swap_add_star_eq_zero
    {u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā} {c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    (hDivFree : IsFourierDivFree u) (hReal : IsRealFourier u)
    (p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§)) :
    advectionSummandH0 u c (advectionSwap p) + star (advectionSummandH0 u c p) = 0 := by
  obtain ‚ü®k, ‚Ąď‚ü© := p
  unfold advectionSummandH0
  simp only [advectionSwap_apply]
  rw [show (k + ‚Ąď) + -‚Ąď = k from by abel]
  rw [advection_jsum_swap_eq_star hDivFree hReal]
  have hSI : star Complex.I = -Complex.I := Complex.conj_I
  have hStarProd :
      star (Complex.I
              * (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)
              * c k * star (c (k + ‚Ąď)))
        = -Complex.I
            * star (‚ąĎ j : Fin 2, ((k j : ‚ĄĚ) : ‚Ąā) * u j ‚Ąď)
            * star (c k) * c (k + ‚Ąď) := by
    simp only [star_mul', hSI, star_star]
  rw [hStarProd]
  ring

/-- **Reindex via `advectionSwap` for ŠłĘ‚Āį:** `ő£ F p = ő£ F (ŌÉ p)` on `pairIdx S`. -/
theorem advectionSumH0_reindex_swap
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    (‚ąĎ p ‚ąą pairIdx S, advectionSummandH0 u c p)
      = ‚ąĎ p ‚ąą pairIdx S, advectionSummandH0 u c (advectionSwap p) := by
  apply Finset.sum_nbij' (fun p => advectionSwap p) (fun p => advectionSwap p)
  ¬∑ intros p hp; exact advectionSwap_mem_pairIdx hS hp
  ¬∑ intros p hp; exact advectionSwap_mem_pairIdx hS hp
  ¬∑ intros p _; exact advectionSwap_involutive p
  ¬∑ intros p _; exact advectionSwap_involutive p
  ¬∑ intros p _; rw [advectionSwap_involutive]

/-- **ŠłĘ‚Āį advection cancellation:** `ő£ + star(ő£) = 0`. -/
theorem advectionSumH0_add_star_eq_zero
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā} {c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    (hDivFree : IsFourierDivFree u) (hReal : IsRealFourier u) :
    (‚ąĎ p ‚ąą pairIdx S, advectionSummandH0 u c p)
      + star (‚ąĎ p ‚ąą pairIdx S, advectionSummandH0 u c p) = 0 := by
  rw [star_sum, advectionSumH0_reindex_swap hS u c, ‚Üź Finset.sum_add_distrib]
  apply Finset.sum_eq_zero
  intros p _
  exact advectionSummandH0_swap_add_star_eq_zero hDivFree hReal p

/-- **ŠłĘ‚Āį advection cancellation (real-part form):** `Re(ő£ F) = 0`. -/
theorem advectionSumH0_re_eq_zero
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {u : Fin 2 ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā} {c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    (hDivFree : IsFourierDivFree u) (hReal : IsRealFourier u) :
    (‚ąĎ p ‚ąą pairIdx S, advectionSummandH0 u c p).re = 0 := by
  have h : (‚ąĎ p ‚ąą pairIdx S, advectionSummandH0 u c p)
             + star (‚ąĎ p ‚ąą pairIdx S, advectionSummandH0 u c p) = 0 :=
    advectionSumH0_add_star_eq_zero hS hDivFree hReal
  have h_re := congr_arg Complex.re h
  rw [Complex.add_re, star_re_complex, Complex.zero_re] at h_re
  linarith

/-! ### ¬ß10.96 Galerkin inner-product real part = 0

Connects the Galerkin RHS sum to `advectionSumH0` via ¬ß10.80's pair-Finset
reindexing. The algebraic identity matches per-pair because ¬ß10.80's
convention `(p.1, p.2) = (m - ‚Ąď, ‚Ąď)` aligns perfectly with
`advectionSummandH0`'s `(q.1, q.2) = (outgoing-mode, velocity-mode)`. -/

/-- **Galerkin inner-product sum = ‚ąí`advectionSumH0`.** Identity bridging
the Galerkin coefficient-sum form to the ŠłĘ‚Āį pair-summand form. -/
theorem galerkinRHS_inner_sum_eq_neg_advectionSumH0
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    (‚ąĎ n ‚ąą S, star (c n) * galerkinRHS S c n)
      = -‚ąĎ p ‚ąą pairIdx S,
          advectionSummandH0 (fun j ‚Ąď => sqgVelocitySymbol j ‚Ąď * c ‚Ąď) c p := by
  -- Step 1: Unfold galerkinRHS, distribute star(c n) through the outer negation.
  have h1 :
      (‚ąĎ n ‚ąą S, star (c n) * galerkinRHS S c n)
        = -‚ąĎ n ‚ąą S, ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => n - ‚Ąď ‚ąą S),
            star (c n) * (c ‚Ąď * c (n - ‚Ąď)
              * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (n - ‚Ąď))) := by
    rw [‚Üź Finset.sum_neg_distrib]
    apply Finset.sum_congr rfl
    intros n _
    unfold galerkinRHS
    rw [mul_neg, Finset.mul_sum]
  rw [h1]
  -- Step 2: Apply ¬ß10.80 reindex to the inner double sum.
  congr 1
  rw [sum_pair_diff_eq_sum_pairIdx
      (F := fun p => star (c p.1) * (c p.2 * c (p.1 - p.2)
        * (‚ąĎ j : Fin 2, sqgVelocitySymbol j p.2 * derivSymbol j (p.1 - p.2))))]
  -- Step 3: Per-pair identity.
  apply Finset.sum_congr rfl
  intros p _
  show star (c (p.1 + p.2)) * (c p.2 * c ((p.1 + p.2) - p.2)
      * (‚ąĎ j : Fin 2, sqgVelocitySymbol j p.2 * derivSymbol j ((p.1 + p.2) - p.2)))
    = advectionSummandH0 (fun j ‚Ąď => sqgVelocitySymbol j ‚Ąď * c ‚Ąď) c p
  rw [show (p.1 + p.2) - p.2 = p.1 from by abel]
  unfold advectionSummandH0 derivSymbol
  have hSumL :
      (‚ąĎ j : Fin 2, sqgVelocitySymbol j p.2 * (I * ((p.1 j : ‚ĄĚ) : ‚Ąā)))
        = I * ‚ąĎ j : Fin 2, ((p.1 j : ‚ĄĚ) : ‚Ąā) * sqgVelocitySymbol j p.2 := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intros j _; ring
  have hSumR :
      (‚ąĎ j : Fin 2, ((p.1 j : ‚ĄĚ) : ‚Ąā) * (sqgVelocitySymbol j p.2 * c p.2))
        = c p.2 * ‚ąĎ j : Fin 2, ((p.1 j : ‚ĄĚ) : ‚Ąā) * sqgVelocitySymbol j p.2 := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intros j _; ring
  rw [hSumL, hSumR]
  ring

/-- **Galerkin inner-product real part vanishes.** Under symmetric support
+ real-coefficient symmetry + off-support vanishing, the real part of
`‚ąĎ_{n ‚ąą S} star(c n) ¬∑ galerkinRHS S c n` is zero. This is the Fourier
form of L¬≤ conservation `Re ‚ü®őł, -u¬∑‚ąáőł‚ü© = 0` under `div u = 0`. -/
theorem galerkinRHS_inner_sum_re_eq_zero
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hRealC : ‚ąÄ n ‚ąą S, c (-n) = star (c n))
    (hOff : ‚ąÄ n ‚ąČ S, c n = 0) :
    (‚ąĎ n ‚ąą S, star (c n) * galerkinRHS S c n).re = 0 := by
  rw [galerkinRHS_inner_sum_eq_neg_advectionSumH0, Complex.neg_re]
  have hcancel :
      (‚ąĎ p ‚ąą pairIdx S,
        advectionSummandH0 (fun j ‚Ąď => sqgVelocitySymbol j ‚Ąď * c ‚Ąď) c p).re = 0 :=
    advectionSumH0_re_eq_zero hS
      (isFourierDivFree_riesz c)
      (isRealFourier_riesz hS c hRealC hOff)
  linarith [hcancel]

/-! ### ¬ß10.97 L¬≤ conservation for Galerkin trajectories

Combines ¬ß10.96 (galerkin inner-product real part vanishes) with
`HasDerivAt.norm_sq` + `HasDerivAt.fun_sum` to show the L¬≤ norm squared
of the Galerkin trajectory is constant in time. -/

/-- **Pointwise derivative of the Galerkin ŠłĘ‚Āį (L¬≤) energy.** Analogue of
¬ß10.69 `trigPolyEnergyHs2_hasDerivAt` without the `(fracDerivSymbol 2)¬≤`
weighting ‚ÄĒ just `‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ ŌĄ m‚ÄĖ¬≤`. -/
theorem galerkinEnergyH0_hasDerivAt
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (ŌĄ : ‚ĄĚ) :
    HasDerivAt (fun t => ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2)
      (‚ąĎ m : ‚Ü•S, 2 *
        (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m))) ŌĄ := by
  apply HasDerivAt.fun_sum
  intros m _
  have hőĪm : HasDerivAt (fun t => őĪ t m) (galerkinVectorField S (őĪ ŌĄ) m) ŌĄ :=
    (hasDerivAt_pi.mp (hőĪ ŌĄ)) m
  exact hőĪm.norm_sq

/-- **Galerkin ŠłĘ‚Āį energy derivative = 0.** Under symmetric support +
real-coefficient symmetry, `d/dŌĄ ‚ąĎ_{m ‚ąą ‚Ü•S} ‚ÄĖőĪ ŌĄ m‚ÄĖ¬≤ = 0`. -/
theorem galerkinEnergyH0_deriv_eq_zero
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealC : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    (ŌĄ : ‚ĄĚ) :
    deriv (fun t => ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2) ŌĄ = 0 := by
  rw [(galerkinEnergyH0_hasDerivAt őĪ hőĪ ŌĄ).deriv]
  -- Step 1: Per-term inner ‚Üí .re conversion.
  have hTerm : ‚ąÄ m : ‚Ü•S,
      2 * (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m))
        = 2 * (star (galerkinExtend S (őĪ ŌĄ) m.val)
                * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m.val).re := by
    intro m
    rw [inner_real_complex_eq_re_star_mul]
    rw [show őĪ ŌĄ m = galerkinExtend S (őĪ ŌĄ) m.val from
          (galerkinExtend_apply_of_mem _ _ m.property).symm]
    rfl
  rw [Finset.sum_congr rfl (fun m _ => hTerm m)]
  -- Step 2: Factor 2 out.
  rw [‚Üź Finset.mul_sum]
  -- Step 3: Re commutes with sum.
  rw [show (‚ąĎ m : ‚Ü•S, (star (galerkinExtend S (őĪ ŌĄ) m.val)
                        * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m.val).re)
           = (‚ąĎ m : ‚Ü•S, star (galerkinExtend S (őĪ ŌĄ) m.val)
                         * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m.val).re from
       (Complex.re_sum _ _).symm]
  -- Step 4: ‚Ü•S ‚Üí S via Finset.sum_attach.
  rw [show (‚ąĎ m : ‚Ü•S, star (galerkinExtend S (őĪ ŌĄ) m.val)
                        * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m.val)
           = ‚ąĎ n ‚ąą S, star (galerkinExtend S (őĪ ŌĄ) n)
                       * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) n from by
       rw [show ((Finset.univ : Finset ‚Ü•S)) = S.attach from Finset.univ_eq_attach S]
       exact Finset.sum_attach S
         (fun n => star (galerkinExtend S (őĪ ŌĄ) n)
                    * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) n)]
  -- Step 5: Apply ¬ß10.96.
  rw [galerkinRHS_inner_sum_re_eq_zero hS (galerkinExtend S (őĪ ŌĄ))
      (fun n hn => hRealC ŌĄ n hn)
      (fun n hn => galerkinExtend_apply_of_not_mem _ _ hn)]
  ring

/-- **Galerkin finite-sum L¬≤ energy is constant in time.** Direct
consequence of `galerkinEnergyH0_deriv_eq_zero` + `is_const_of_deriv_eq_zero`. -/
theorem galerkinEnergyH0_const
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealC : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    (s t : ‚ĄĚ) :
    (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ s m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2 := by
  have hE_hasDeriv : ‚ąÄ ŌĄ,
      HasDerivAt (fun t' => ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t' m‚ÄĖ ^ 2) (0 : ‚ĄĚ) ŌĄ := by
    intro ŌĄ
    have h := galerkinEnergyH0_hasDerivAt őĪ hőĪ ŌĄ
    have hZero := galerkinEnergyH0_deriv_eq_zero hS őĪ hőĪ hRealC ŌĄ
    rw [h.deriv] at hZero
    rw [‚Üź hZero]; exact h
  have hDiff : Differentiable ‚ĄĚ (fun t' => ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t' m‚ÄĖ ^ 2) :=
    fun ŌĄ => (hE_hasDeriv ŌĄ).differentiableAt
  have hDeriv : ‚ąÄ ŌĄ, deriv (fun t' => ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t' m‚ÄĖ ^ 2) ŌĄ = 0 :=
    fun ŌĄ => (hE_hasDeriv ŌĄ).deriv
  exact is_const_of_deriv_eq_zero hDiff hDeriv s t

/-- **L¬≤ conservation for the lifted Galerkin trajectory** in terms of
`hsSeminormSq 0`. Requires `0 ‚ąČ S` so the ŠłĘ‚Āį seminorm (which zeroes the
zero-mode contribution) coincides with the finite-sum L¬≤ energy. -/
theorem galerkinToLp_hsSeminormSq_zero_const
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S)
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealC : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    (s t : ‚ĄĚ) :
    hsSeminormSq 0 (galerkinToLp S (őĪ s)) = hsSeminormSq 0 (galerkinToLp S (őĪ t)) := by
  have hExp : ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā,
      hsSeminormSq 0 (galerkinToLp S c) = ‚ąĎ m : ‚Ü•S, ‚ÄĖc m‚ÄĖ ^ 2 := by
    intro c
    unfold hsSeminormSq
    have hZeroOff : ‚ąÄ n ‚ąČ S,
        (fracDerivSymbol 0 n) ^ 2 * ‚ÄĖmFourierCoeff (galerkinToLp S c) n‚ÄĖ ^ 2 = 0 := by
      intros n hn
      rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ hn,
          norm_zero]; ring
    rw [tsum_eq_sum (s := S) (fun n hn => hZeroOff n hn)]
    rw [show ((Finset.univ : Finset ‚Ü•S)) = S.attach from Finset.univ_eq_attach S]
    rw [‚Üź Finset.sum_attach S (fun n =>
        (fracDerivSymbol 0 n) ^ 2 * ‚ÄĖmFourierCoeff (galerkinToLp S c) n‚ÄĖ ^ 2)]
    apply Finset.sum_congr rfl
    intros m _
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_mem _ _ m.property]
    have hm_ne : m.val ‚Č† 0 := fun hv => h0 (hv ‚Ėł m.property)
    rw [fracDerivSymbol_of_ne_zero 0 hm_ne, Real.rpow_zero]; ring
  rw [hExp (őĪ s), hExp (őĪ t)]
  exact galerkinEnergyH0_const hS őĪ hőĪ hRealC s t

/-! ### ¬ß10.98 `SqgEvolutionAxioms` for Galerkin + Phase-3 final capstone

Wraps ¬ß10.97 (L¬≤ conservation) with zero-mode triviality (`0 ‚ąČ S`) and
Riesz velocity witness to produce `SqgEvolutionAxioms` directly from the
Galerkin ODE hypothesis. Feeds ¬ß10.94's Phase-2 capstone to yield a
fully self-contained `SqgEvolutionAxioms_strong` result ‚ÄĒ no auxiliary
hypotheses beyond Galerkin dynamics + structural conditions on `S` +
real-coefficient symmetry + uniform L‚ąě bound. -/

/-- **`SqgEvolutionAxioms` for the lifted Galerkin trajectory.** -/
theorem SqgEvolutionAxioms.of_galerkin_dynamics
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S)
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealC : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n)) :
    SqgEvolutionAxioms (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) where
  l2Conservation := fun t _ =>
    galerkinToLp_hsSeminormSq_zero_const h0 hS őĪ hőĪ hRealC t 0
  meanConservation := fun t _ => by
    rw [mFourierCoeff_galerkinToLp, mFourierCoeff_galerkinToLp,
        galerkinExtend_apply_of_not_mem _ _ h0,
        galerkinExtend_apply_of_not_mem _ _ h0]
  velocityIsRieszTransform := fun j =>
    ‚ü®fun ŌĄ => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j,
      fun ŌĄ => isSqgVelocityComponent_shellMode S (galerkinExtend S (őĪ ŌĄ)) j‚ü©

/-- **Phase-3 final capstone: Galerkin + L‚ąě ‚Üí `SqgEvolutionAxioms_strong`,
fully self-contained.** No `hE` hypothesis ‚ÄĒ `SqgEvolutionAxioms` is
derived internally from the Galerkin ODE via ¬ß10.98. Composes with
¬ß10.94 to give the complete unconditional `SqgEvolutionAxioms_strong`
for any Galerkin trajectory on a finite, symmetric, zero-excluding shell
with real-coefficient symmetry and a uniform L‚ąě coefficient bound. -/
theorem SqgEvolutionAxioms_strong.of_galerkin_dynamics_with_L_inf_bound
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S)
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealC : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    {M : ‚ĄĚ}
    (hBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ M) :
    SqgEvolutionAxioms_strong (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) :=
  SqgEvolutionAxioms_strong.of_galerkin_dynamics_with_L_inf_bound_on_support
    őĪ hőĪ (SqgEvolutionAxioms.of_galerkin_dynamics h0 hS őĪ hőĪ hRealC) hBound

/-! ### ¬ß10.99 Real-coefficient symmetry: algebraic preservation

For any `c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā` with real-coefficient symmetry on `S`
(`c(-n) = star(c(n))` for `n ‚ąą S`), the identity
`galerkinRHS S c (-n) = star(galerkinRHS S c n)` holds for every `n`.

Ingredients: `sqgVelocitySymbol_neg` (odd), `derivSymbol_neg` (odd),
K-kernel self-star via product of two purely-imaginary factors,
K-kernel invariant under double negation of arguments, and the
reindex `‚Ąď ‚Ü¶ -‚Ąď` on the Galerkin filter under `hSym`. -/

/-- **Star of `derivSymbol` negates it.** -/
lemma star_derivSymbol (j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) :
    star (derivSymbol j n) = -derivSymbol j n := by
  unfold derivSymbol
  rw [star_mul']
  have hSI : star Complex.I = -Complex.I := Complex.conj_I
  rw [hSI, star_ofReal_complex]
  ring

/-- **K-kernel is real (self-star).** -/
lemma star_K_eq_K (a b : Fin 2 ‚Üí ‚Ą§) :
    star (‚ąĎ j : Fin 2, sqgVelocitySymbol j a * derivSymbol j b)
      = ‚ąĎ j : Fin 2, sqgVelocitySymbol j a * derivSymbol j b := by
  rw [star_sum]
  apply Finset.sum_congr rfl
  intros j _
  rw [star_mul', star_sqgVelocitySymbol, star_derivSymbol]
  ring

/-- **Algebraic real-symmetry preservation for `galerkinRHS`.** -/
theorem galerkinRHS_neg_eq_star_of_realSymmetric
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (c : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hRealC : ‚ąÄ n ‚ąą S, c (-n) = star (c n))
    {n : Fin 2 ‚Üí ‚Ą§} :
    galerkinRHS S c (-n) = star (galerkinRHS S c n) := by
  unfold galerkinRHS
  rw [star_neg, star_sum]
  congr 1
  -- Reindex via ‚Ąď ‚ÜĒ -‚Ąď. Finset.sum_nbij' takes non-dependent i, j.
  apply Finset.sum_nbij' (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => -‚Ąď) (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => -‚Ąď)
  ¬∑ intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď ‚äĘ
    obtain ‚ü®h‚ĄďS, h‚Ąď'‚ü© := h‚Ąď
    refine ‚ü®hS _ h‚ĄďS, ?_‚ü©
    show n - -‚Ąď ‚ąą S
    rw [sub_neg_eq_add, show n + ‚Ąď = -(-n - ‚Ąď) from by ring]
    exact hS _ h‚Ąď'
  ¬∑ intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď ‚äĘ
    obtain ‚ü®h‚ĄďS, h‚Ąď'‚ü© := h‚Ąď
    refine ‚ü®hS _ h‚ĄďS, ?_‚ü©
    show -n - -‚Ąď ‚ąą S
    rw [sub_neg_eq_add, show -n + ‚Ąď = -(n - ‚Ąď) from by ring]
    exact hS _ h‚Ąď'
  ¬∑ intros ‚Ąď _; simp
  ¬∑ intros ‚Ąď _; simp
  ¬∑ intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď
    obtain ‚ü®h‚ĄďS, h‚Ąď'‚ü© := h‚Ąď
    have h_n_plus_‚Ąď_S : n + ‚Ąď ‚ąą S := by
      rw [show n + ‚Ąď = -(-n - ‚Ąď) from by ring]
      exact hS _ h‚Ąď'
    -- Goal: c(‚Ąď) ¬∑ c(-n - ‚Ąď) ¬∑ K(‚Ąď, -n - ‚Ąď)
    --     = star (c(-‚Ąď) ¬∑ c(n - -‚Ąď) ¬∑ K(-‚Ąď, n - -‚Ąď))
    rw [show (n : Fin 2 ‚Üí ‚Ą§) - -‚Ąď = n + ‚Ąď from by ring]
    rw [show (‚ąĎ j : Fin 2, sqgVelocitySymbol j (-‚Ąď) * derivSymbol j (n + ‚Ąď))
          = ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (-n - ‚Ąď) from by
      apply Finset.sum_congr rfl
      intros j _
      rw [sqgVelocitySymbol_neg,
          show (n + ‚Ąď : Fin 2 ‚Üí ‚Ą§) = -(-n - ‚Ąď) from by ring, derivSymbol_neg]
      ring]
    rw [star_mul', star_mul']
    rw [star_K_eq_K]
    rw [hRealC ‚Ąď h‚ĄďS, star_star]
    rw [show (-n - ‚Ąď : Fin 2 ‚Üí ‚Ą§) = -(n + ‚Ąď) from by ring,
        hRealC (n + ‚Ąď) h_n_plus_‚Ąď_S]

/-- **Subtype-level lift of ¬ß10.99.** For a Galerkin coefficient vector
`c : ‚Ü•S ‚Üí ‚Ąā` whose zero-extension satisfies real-coefficient symmetry on
`S`, the `galerkinVectorField` satisfies
`galerkinVectorField S c ‚ü®-n, hS n hn‚ü© = star (galerkinVectorField S c ‚ü®n, hn‚ü©)`
for every `n ‚ąą S`. Direct corollary of
`galerkinRHS_neg_eq_star_of_realSymmetric` unfolded at the subtype level. -/
theorem galerkinVectorField_neg_eq_star_of_realSymmetric
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (c : ‚Ü•S ‚Üí ‚Ąā)
    (hRealC : ‚ąÄ n ‚ąą S, galerkinExtend S c (-n) = star (galerkinExtend S c n))
    {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚ąą S) :
    galerkinVectorField S c ‚ü®-n, hS n hn‚ü©
      = star (galerkinVectorField S c ‚ü®n, hn‚ü©) := by
  show galerkinRHS S (galerkinExtend S c) (-n)
      = star (galerkinRHS S (galerkinExtend S c) n)
  exact galerkinRHS_neg_eq_star_of_realSymmetric hS _ hRealC

/-- **Universal starSwap identity for `galerkinRHS`.** For any coefficient
function `d : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā` (no real-symmetry required), the `galerkinRHS`
satisfies
`galerkinRHS S (fun m => star (d (-m))) n = star (galerkinRHS S d (-n))`
under `IsSymmetricSupport S`. This is the algebraic identity underlying
real-symmetry propagation via ODE uniqueness: defining `ő≤ ŌĄ := starSwap (őĪ ŌĄ)`,
it ensures `ő≤` satisfies the same Galerkin ODE as `őĪ`. -/
theorem galerkinRHS_starSwap_identity
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (d : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    galerkinRHS S (fun m => star (d (-m))) n = star (galerkinRHS S d (-n)) := by
  unfold galerkinRHS
  rw [star_neg, star_sum]
  congr 1
  apply Finset.sum_nbij' (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => -‚Ąď) (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => -‚Ąď)
  ¬∑ intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď ‚äĘ
    obtain ‚ü®h‚ĄďS, h‚Ąď'‚ü© := h‚Ąď
    refine ‚ü®hS _ h‚ĄďS, ?_‚ü©
    show -n - -‚Ąď ‚ąą S
    rw [sub_neg_eq_add, show -n + ‚Ąď = -(n - ‚Ąď) from by ring]
    exact hS _ h‚Ąď'
  ¬∑ intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď ‚äĘ
    obtain ‚ü®h‚ĄďS, h‚Ąď'‚ü© := h‚Ąď
    refine ‚ü®hS _ h‚ĄďS, ?_‚ü©
    show n - -‚Ąď ‚ąą S
    rw [sub_neg_eq_add, show n + ‚Ąď = -(-n - ‚Ąď) from by ring]
    exact hS _ h‚Ąď'
  ¬∑ intros ‚Ąď _; simp
  ¬∑ intros ‚Ąď _; simp
  ¬∑ intros ‚Ąď h‚Ąď
    rw [Finset.mem_filter] at h‚Ąď
    obtain ‚ü®h‚ĄďS, _‚ü© := h‚Ąď
    -- Beta-reduce the (fun m => ...) lambdas from the LHS summand.
    dsimp only
    rw [show (-n - -‚Ąď : Fin 2 ‚Üí ‚Ą§) = -n + ‚Ąď from by ring]
    rw [show (‚ąĎ j : Fin 2, sqgVelocitySymbol j (-‚Ąď) * derivSymbol j (-n + ‚Ąď))
          = ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (n - ‚Ąď) from by
      apply Finset.sum_congr rfl
      intros j _
      rw [sqgVelocitySymbol_neg,
          show (-n + ‚Ąď : Fin 2 ‚Üí ‚Ą§) = -(n - ‚Ąď) from by ring, derivSymbol_neg]
      ring]
    rw [star_mul', star_mul', star_K_eq_K]
    rw [show (-(n - ‚Ąď) : Fin 2 ‚Üí ‚Ą§) = -n + ‚Ąď from by ring]

/-! ### ¬ß10.100 Real-symmetry ODE propagation ‚ÄĒ closing `hRealC` to ŌĄ=0

Using the universal `galerkinRHS_starSwap_identity` (¬ß10.99) plus
mathlib's `ODE_solution_unique_univ` on the Galerkin ODE with a fixed
Lipschitz region (`closedBall 0 M`), real-coefficient symmetry
propagates from `ŌĄ = 0` to all `ŌĄ`. Requires the uniform L‚ąě coefficient
bound on **all** `ŌĄ : ‚ĄĚ` (not just `ŌĄ ‚Č• 0`) so that the starSwapped
trajectory and the original trajectory both stay in the same Lipschitz
ball globally in time.

**Device.** Let `starSwap hS : (‚Ü•S ‚Üí ‚Ąā) ‚Üí (‚Ü•S ‚Üí ‚Ąā)` send `c` to the
star-conjugated, index-negated coefficient vector. Define
`ő≤ ŌĄ := starSwap hS (őĪ ŌĄ)`. Then:
* `ő≤` satisfies the Galerkin ODE (via ¬ß10.99's universal starSwap id).
* `ő≤ 0 = őĪ 0` iff `hRealC` holds at `ŌĄ = 0`.
* Both `őĪ ŌĄ`, `ő≤ ŌĄ` live in `closedBall 0 M` (by `hBound`).
* `galerkinVectorField_contDiff` (¬ß10.41) gives Lipschitz on the compact
  convex `closedBall 0 M`.
* `ODE_solution_unique_univ` forces `őĪ = ő≤`, yielding `hRealC` for all ŌĄ. -/

/-- **Subtype negation on `‚Ü•S` under `IsSymmetricSupport`.** -/
noncomputable def negSubtype
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsSymmetricSupport S) (n : ‚Ü•S) : ‚Ü•S :=
  ‚ü®-n.val, hS n.val n.property‚ü©

@[simp] lemma negSubtype_val
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsSymmetricSupport S) (n : ‚Ü•S) :
    (negSubtype hS n).val = -n.val := rfl

lemma negSubtype_negSubtype
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsSymmetricSupport S) (n : ‚Ü•S) :
    negSubtype hS (negSubtype hS n) = n := by
  apply Subtype.ext
  show -(-n.val) = n.val
  ring

/-- **StarSwap on the Galerkin state space.** -/
noncomputable def starSwap
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsSymmetricSupport S)
    (c : ‚Ü•S ‚Üí ‚Ąā) : ‚Ü•S ‚Üí ‚Ąā :=
  fun n => star (c (negSubtype hS n))

/-- **StarSwap is involutive.** -/
lemma starSwap_starSwap
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsSymmetricSupport S)
    (c : ‚Ü•S ‚Üí ‚Ąā) :
    starSwap hS (starSwap hS c) = c := by
  funext n
  show star (star (c (negSubtype hS (negSubtype hS n)))) = c n
  rw [star_star, negSubtype_negSubtype]

/-- **StarSwap preserves the sup-norm.** -/
lemma norm_starSwap_apply
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} (hS : IsSymmetricSupport S)
    (c : ‚Ü•S ‚Üí ‚Ąā) (n : ‚Ü•S) :
    ‚ÄĖstarSwap hS c n‚ÄĖ = ‚ÄĖc (negSubtype hS n)‚ÄĖ := by
  show ‚ÄĖstar (c (negSubtype hS n))‚ÄĖ = ‚ÄĖc (negSubtype hS n)‚ÄĖ
  exact norm_star _

/-- **`galerkinExtend` commutes with `starSwap`.** At the full lattice
level, the zero-extension of `starSwap hS c` is
`fun m => star (galerkinExtend S c (-m))`. -/
lemma galerkinExtend_starSwap
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (c : ‚Ü•S ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    galerkinExtend S (starSwap hS c) m = star (galerkinExtend S c (-m)) := by
  by_cases hm : m ‚ąą S
  ¬∑ have hmneg : -m ‚ąą S := hS m hm
    rw [galerkinExtend_apply_of_mem S _ hm,
        galerkinExtend_apply_of_mem S _ hmneg]
    rfl
  ¬∑ have hmneg : -m ‚ąČ S := by
      intro hmem
      have hnn : -(-m) ‚ąą S := hS (-m) hmem
      rw [neg_neg] at hnn
      exact hm hnn
    rw [galerkinExtend_apply_of_not_mem S _ hm,
        galerkinExtend_apply_of_not_mem S _ hmneg, star_zero]

/-- **`galerkinVectorField` commutes with `starSwap`.** Consumes the
universal `galerkinRHS_starSwap_identity` from ¬ß10.99. -/
theorem galerkinVectorField_starSwap
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (c : ‚Ü•S ‚Üí ‚Ąā) :
    galerkinVectorField S (starSwap hS c)
      = starSwap hS (galerkinVectorField S c) := by
  funext n
  show galerkinRHS S (galerkinExtend S (starSwap hS c)) ‚ÜĎn
      = star (galerkinRHS S (galerkinExtend S c) ‚ÜĎ(negSubtype hS n))
  have hExtend : galerkinExtend S (starSwap hS c)
               = fun m => star (galerkinExtend S c (-m)) := by
    funext m
    exact galerkinExtend_starSwap hS c m
  rw [hExtend, galerkinRHS_starSwap_identity hS (galerkinExtend S c) ‚ÜĎn]
  show star (galerkinRHS S (galerkinExtend S c) (-(n.val)))
      = star (galerkinRHS S (galerkinExtend S c) (negSubtype hS n).val)
  rfl

/-- **`HasDerivAt` transports through `starSwap`.** If `őĪ` solves the
Galerkin ODE, so does `ő≤ := fun ŌĄ => starSwap hS (őĪ ŌĄ)`. -/
theorem starSwap_hasDerivAt
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (ŌĄ : ‚ĄĚ) :
    HasDerivAt (fun t => starSwap hS (őĪ t))
               (galerkinVectorField S (starSwap hS (őĪ ŌĄ))) ŌĄ := by
  rw [galerkinVectorField_starSwap hS (őĪ ŌĄ)]
  rw [hasDerivAt_pi]
  intro n
  show HasDerivAt (fun t => star (őĪ t (negSubtype hS n)))
                  (star (galerkinVectorField S (őĪ ŌĄ) (negSubtype hS n))) ŌĄ
  exact ((hasDerivAt_pi.mp (hőĪ ŌĄ)) (negSubtype hS n)).star

/-- **Real-symmetry ODE propagation.** Given the Galerkin ODE, real-
coefficient symmetry at `ŌĄ = 0`, and a uniform L‚ąě coefficient bound on
**all** `ŌĄ : ‚ĄĚ`, real-coefficient symmetry holds for every `ŌĄ`. -/
theorem hRealC_of_initial_and_bound
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ 0) (-n) = star (galerkinExtend S (őĪ 0) n))
    {M : ‚ĄĚ} (hM : 0 ‚Č§ M)
    (hBound : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ M) :
    ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąą S,
      galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n) := by
  classical
  set ő≤ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) := fun ŌĄ => starSwap hS (őĪ ŌĄ) with hő≤_def
  have hő≤ : ‚ąÄ t, HasDerivAt ő≤ (galerkinVectorField S (ő≤ t)) t :=
    fun t => starSwap_hasDerivAt hS őĪ hőĪ t
  -- őĪ 0 = ő≤ 0 from hRealC‚āÄ
  have hőĪő≤_zero : őĪ 0 = ő≤ 0 := by
    funext n
    show őĪ 0 n = star (őĪ 0 (negSubtype hS n))
    have hn_in : n.val ‚ąą S := n.property
    have hnn_in : -n.val ‚ąą S := hS n.val hn_in
    have hRC := hRealC‚āÄ n.val hn_in
    rw [galerkinExtend_apply_of_mem S _ hnn_in,
        galerkinExtend_apply_of_mem S _ hn_in] at hRC
    -- hRC : őĪ 0 ‚ü®-n.val, hnn_in‚ü© = star (őĪ 0 ‚ü®n.val, hn_in‚ü©)
    have hn_eq : (n : ‚Ü•S) = ‚ü®n.val, hn_in‚ü© := by
      apply Subtype.ext; rfl
    -- Apply star_star symmetry
    have : őĪ 0 ‚ü®n.val, hn_in‚ü© = star (őĪ 0 ‚ü®-n.val, hnn_in‚ü©) := by
      rw [hRC, star_star]
    rw [hn_eq, this]
    rfl
  -- Norm bounds: both őĪ and ő≤ live in closedBall 0 M.
  have hőĪ_ball : ‚ąÄ t, őĪ t ‚ąą Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M := by
    intro t
    rw [Metric.mem_closedBall, dist_zero_right]
    rw [pi_norm_le_iff_of_nonneg hM]
    intro n
    have hn_in : n.val ‚ąą S := n.property
    have := hBound t n.val
    rw [galerkinExtend_apply_of_mem S _ hn_in] at this
    exact this
  have hő≤_ball : ‚ąÄ t, ő≤ t ‚ąą Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M := by
    intro t
    rw [Metric.mem_closedBall, dist_zero_right]
    rw [pi_norm_le_iff_of_nonneg hM]
    intro n
    rw [hő≤_def]
    rw [norm_starSwap_apply]
    have hnn_in : (negSubtype hS n).val ‚ąą S := (negSubtype hS n).property
    have := hBound t (negSubtype hS n).val
    rw [galerkinExtend_apply_of_mem S _ hnn_in] at this
    exact this
  -- Lipschitz on closedBall 0 M via C¬Ļ on compact convex set.
  obtain ‚ü®K, hK‚ü© : ‚ąÉ K, LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M) := by
    refine (galerkinVectorField_contDiff S (n := 1)).contDiffOn.exists_lipschitzOnWith
      ?_ (convex_closedBall 0 M) (isCompact_closedBall 0 M)
    decide
  -- Apply ODE_solution_unique_univ.
  have heq : őĪ = ő≤ :=
    ODE_solution_unique_univ (v := fun _ => galerkinVectorField S)
      (s := fun _ => Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M)
      (t‚āÄ := 0)
      (fun _ => hK)
      (fun t => ‚ü®hőĪ t, hőĪ_ball t‚ü©)
      (fun t => ‚ü®hő≤ t, hő≤_ball t‚ü©)
      hőĪő≤_zero
  -- Unpack: őĪ ŌĄ = ő≤ ŌĄ = starSwap (őĪ ŌĄ), i.e. őĪ ŌĄ ‚ü®-n, ...‚ü© = star (őĪ ŌĄ ‚ü®n, ...‚ü©).
  intro ŌĄ n hn
  have hnn_in : -n ‚ąą S := hS n hn
  rw [galerkinExtend_apply_of_mem S _ hnn_in,
      galerkinExtend_apply_of_mem S _ hn]
  have hfun : őĪ ŌĄ = ő≤ ŌĄ := by rw [heq]
  -- ő≤ ŌĄ ‚ü®-n, hnn_in‚ü© = star (őĪ ŌĄ ‚ü®-(-n), hS (-n) hnn_in‚ü©)
  have hő≤app : ő≤ ŌĄ ‚ü®-n, hnn_in‚ü© = star (őĪ ŌĄ ‚ü®n, hn‚ü©) := by
    rw [hő≤_def]
    show star (őĪ ŌĄ (negSubtype hS ‚ü®-n, hnn_in‚ü©)) = star (őĪ ŌĄ ‚ü®n, hn‚ü©)
    have hsub : negSubtype hS ‚ü®-n, hnn_in‚ü© = ‚ü®n, hn‚ü© := by
      apply Subtype.ext
      show -(-n) = n
      ring
    rw [hsub]
  calc őĪ ŌĄ ‚ü®-n, hnn_in‚ü©
      = ő≤ ŌĄ ‚ü®-n, hnn_in‚ü© := by rw [hfun]
    _ = star (őĪ ŌĄ ‚ü®n, hn‚ü©) := hő≤app

/-- **Phase-3 final capstone (ŌĄ=0 hRealC variant).** Same conclusion as
`SqgEvolutionAxioms_strong.of_galerkin_dynamics_with_L_inf_bound` but
with `hRealC` replaced by `hRealC‚āÄ` (at `ŌĄ = 0` only) and the uniform
L‚ąě bound strengthened from `ŌĄ ‚Č• 0` to all `ŌĄ : ‚ĄĚ`. Internally propagates
`hRealC` via ODE uniqueness (`hRealC_of_initial_and_bound`). -/
theorem SqgEvolutionAxioms_strong.of_galerkin_dynamics_with_L_inf_bound_from_initial_realC
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S)
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ 0) (-n) = star (galerkinExtend S (őĪ 0) n))
    {M : ‚ĄĚ} (hM : 0 ‚Č§ M)
    (hBound_all : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ M) :
    SqgEvolutionAxioms_strong (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) := by
  have hRealC := hRealC_of_initial_and_bound hS őĪ hőĪ hRealC‚āÄ hM hBound_all
  have hBound_fwd : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ M :=
    fun ŌĄ _ => hBound_all ŌĄ
  exact SqgEvolutionAxioms_strong.of_galerkin_dynamics_with_L_inf_bound
    h0 hS őĪ hőĪ hRealC hBound_fwd

/-! ### ¬ß10.101 Quadratic growth bound for `galerkinVectorField`

The Galerkin vector field `galerkinVectorField S c` is a bilinear
polynomial in `c`, so it has *quadratic* growth: there exists a
constant `C = C(S)` with `‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ C ¬∑ ‚ÄĖc‚ÄĖ¬≤` for
every `c`. First step toward uniform-őĶ Picard-Lindel√∂f and global
extension under an a priori L¬≤ bound.

**Formula.** `C := S.card ¬∑ K_S`, where
`K_S := ‚ąĎ_{(‚Ąď, k) ‚ąą S √ó S} ‚ÄĖ‚ąĎ_j ŌÉ_j(‚Ąď) ¬∑ őĻ¬∑k_j‚ÄĖ` majorises the
K-kernel on `S √ó S`. (Overcount ‚ÄĒ bounds the filtered sum by the full
bilinear pairing sum.) -/

/-- **The K-kernel factor** `‚ąĎ_j sqgVelocitySymbol j ‚Ąď ¬∑ derivSymbol j k`.
Abstracted for reuse in bounds. -/
noncomputable def galerkinKKernel
    (‚Ąď k : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j k

/-- **Per-mode pointwise norm bound.** For any `c : ‚Ü•S ‚Üí ‚Ąā` and any
`m : Fin 2 ‚Üí ‚Ą§`, `‚ÄĖgalerkinExtend S c m‚ÄĖ ‚Č§ ‚ÄĖc‚ÄĖ`. -/
lemma norm_galerkinExtend_le
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖgalerkinExtend S c m‚ÄĖ ‚Č§ ‚ÄĖc‚ÄĖ := by
  by_cases hm : m ‚ąą S
  ¬∑ rw [galerkinExtend_apply_of_mem S _ hm]
    exact norm_le_pi_norm c ‚ü®m, hm‚ü©
  ¬∑ rw [galerkinExtend_apply_of_not_mem S _ hm, norm_zero]
    exact norm_nonneg _

/-- **Per-mode quadratic bound on `galerkinRHS`, filtered form.** For any
`c : ‚Ü•S ‚Üí ‚Ąā` and any `m : Fin 2 ‚Üí ‚Ą§`,
`‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ‚Č§
    (‚ąĎ_{‚Ąď ‚ąą filter} ‚ÄĖgalerkinKKernel ‚Ąď (m-‚Ąď)‚ÄĖ) ¬∑ ‚ÄĖc‚ÄĖ¬≤`, where the filter
restricts to ‚Ąď with both `‚Ąď` and `m - ‚Ąď` in `S`. -/
lemma norm_galerkinRHS_le_filter_kernel_sq
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ
      ‚Č§ (‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
            ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ) * ‚ÄĖc‚ÄĖ ^ 2 := by
  unfold galerkinRHS
  rw [norm_neg]
  calc ‚ÄĖ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          galerkinExtend S c ‚Ąď * galerkinExtend S c (m - ‚Ąď)
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))‚ÄĖ
      ‚Č§ ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          ‚ÄĖgalerkinExtend S c ‚Ąď * galerkinExtend S c (m - ‚Ąď)
            * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))‚ÄĖ :=
        norm_sum_le _ _
    _ ‚Č§ ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply Finset.sum_le_sum
          intros ‚Ąď _
          rw [norm_mul, norm_mul]
          show ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ
                * ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ
              ‚Č§ ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ * ‚ÄĖc‚ÄĖ ^ 2
          have h1 : ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ‚Č§ ‚ÄĖc‚ÄĖ := norm_galerkinExtend_le c ‚Ąď
          have h2 : ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ‚Č§ ‚ÄĖc‚ÄĖ := norm_galerkinExtend_le c (m - ‚Ąď)
          have hc : 0 ‚Č§ ‚ÄĖc‚ÄĖ := norm_nonneg _
          have hK : 0 ‚Č§ ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ := norm_nonneg _
          have hprod : ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ
                      ‚Č§ ‚ÄĖc‚ÄĖ * ‚ÄĖc‚ÄĖ :=
            mul_le_mul h1 h2 (norm_nonneg _) hc
          calc ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ
                  * ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ
              ‚Č§ (‚ÄĖc‚ÄĖ * ‚ÄĖc‚ÄĖ) * ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ :=
                mul_le_mul_of_nonneg_right hprod hK
            _ = ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ * ‚ÄĖc‚ÄĖ ^ 2 := by ring
    _ = (‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
            ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ) * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [‚Üź Finset.sum_mul]

/-- **Quadratic growth bound for the Galerkin vector field.** There
exists `C ‚Č• 0` (depending only on `S`) with
`‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ C ¬∑ ‚ÄĖc‚ÄĖ¬≤` for every `c : ‚Ü•S ‚Üí ‚Ąā`.

Formula: `C := ‚ąĎ_{‚Ąď ‚ąą S} ‚ąĎ_{k ‚ąą S} ‚ÄĖgalerkinKKernel ‚Ąď k‚ÄĖ`. Per mode, the
filtered `galerkinRHS` sum is indexed by pairs `(‚Ąď, m - ‚Ąď) ‚ąą S √ó S`,
which is a subset of all `(‚Ąď, k) ‚ąą S √ó S` under the bijection
`‚Ąď ‚Ü¶ (‚Ąď, m - ‚Ąď)`. -/
theorem galerkinVectorField_quadratic_bound
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)] :
    ‚ąÉ C : ‚ĄĚ, 0 ‚Č§ C ‚ąß ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā,
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ C * ‚ÄĖc‚ÄĖ ^ 2 := by
  classical
  refine ‚ü®‚ąĎ ‚Ąď ‚ąą S, ‚ąĎ k ‚ąą S, ‚ÄĖgalerkinKKernel ‚Ąď k‚ÄĖ, ?_, ?_‚ü©
  ¬∑ exact Finset.sum_nonneg (fun _ _ => Finset.sum_nonneg (fun _ _ => norm_nonneg _))
  intro c
  rw [pi_norm_le_iff_of_nonneg (by positivity)]
  intro m
  show ‚ÄĖgalerkinRHS S (galerkinExtend S c) ‚ÜĎm‚ÄĖ
      ‚Č§ (‚ąĎ ‚Ąď ‚ąą S, ‚ąĎ k ‚ąą S, ‚ÄĖgalerkinKKernel ‚Ąď k‚ÄĖ) * ‚ÄĖc‚ÄĖ ^ 2
  refine (norm_galerkinRHS_le_filter_kernel_sq c ‚ÜĎm).trans ?_
  apply mul_le_mul_of_nonneg_right _ (sq_nonneg _)
  -- Reindex ‚Ąď ‚Ü¶ (‚Ąď, m-‚Ąď) sends the filter injectively into S √óňĘ S; bound by the full double sum.
  have hInj : ‚ąÄ ‚Ąď ‚ąą S.filter (fun ‚Ąď => (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď ‚ąą S),
      ‚ąÄ ‚Ąď' ‚ąą S.filter (fun ‚Ąď => (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď ‚ąą S),
      (‚Ąď, (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď) = (‚Ąď', (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď') ‚Üí ‚Ąď = ‚Ąď' := by
    intros ‚Ąď _ ‚Ąď' _ heq
    exact (Prod.ext_iff.mp heq).1
  -- Reindex: ‚ąĎ_{‚Ąď ‚ąą filter} ‚ÄĖK(‚Ąď, m-‚Ąď)‚ÄĖ = ‚ąĎ_{p ‚ąą image (‚Ąď ‚Ü¶ (‚Ąď, m-‚Ąď))} ‚ÄĖK(p.1, p.2)‚ÄĖ
  -- And image ‚äÜ S √óňĘ S.
  have hSubset : (S.filter (fun ‚Ąď => (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď ‚ąą S)).image
      (fun ‚Ąď => (‚Ąď, (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď)) ‚äÜ S √óňĘ S := by
    intros p hp
    rw [Finset.mem_image] at hp
    obtain ‚ü®‚Ąď, h‚Ąď, rfl‚ü© := hp
    rw [Finset.mem_filter] at h‚Ąď
    rw [Finset.mem_product]
    exact ‚ü®h‚Ąď.1, h‚Ąď.2‚ü©
  calc ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď ‚ąą S),
          ‚ÄĖgalerkinKKernel ‚Ąď (‚ÜĎm - ‚Ąď)‚ÄĖ
      = ‚ąĎ p ‚ąą (S.filter (fun ‚Ąď => (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď ‚ąą S)).image
              (fun ‚Ąď => (‚Ąď, (‚ÜĎm : Fin 2 ‚Üí ‚Ą§) - ‚Ąď)),
          ‚ÄĖgalerkinKKernel p.1 p.2‚ÄĖ := by
            rw [Finset.sum_image (fun ‚Ąď h‚Ąď ‚Ąď' h‚Ąď' h => hInj ‚Ąď h‚Ąď ‚Ąď' h‚Ąď' h)]
    _ ‚Č§ ‚ąĎ p ‚ąą S √óňĘ S, ‚ÄĖgalerkinKKernel p.1 p.2‚ÄĖ :=
          Finset.sum_le_sum_of_subset_of_nonneg hSubset
            (fun _ _ _ => norm_nonneg _)
    _ = ‚ąĎ ‚Ąď ‚ąą S, ‚ąĎ k ‚ąą S, ‚ÄĖgalerkinKKernel ‚Ąď k‚ÄĖ := by
          rw [Finset.sum_product]

/-! ### ¬ß10.102 Uniform-őĶ Picard on a fixed outer ball

Given radius `R > 0`, extract Lipschitz constant and uniform bound on
`closedBall 0 R` (via `ContDiffOn.exists_lipschitzOnWith` and the
quadratic growth bound ¬ß10.101), then pick a step size `őĶ > 0`
depending only on `R` and `S`. For any `c‚āÄ ‚ąą closedBall 0 (R/2)`,
Picard-Lindel√∂f on `closedBall c‚āÄ (R/2) ‚äÜ closedBall 0 R` produces a
local solution on `[-őĶ, őĶ]`. -/

theorem galerkin_uniform_őĶ_picard
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {R : ‚ĄĚ} (hR : 0 < R) :
    ‚ąÉ őĶ : ‚ĄĚ, 0 < őĶ ‚ąß
      ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
        ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
          ‚ąÄ t ‚ąą Set.Icc (-őĶ) őĶ,
            HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (-őĶ) őĶ) t := by
  classical
  -- Step 1: Lipschitz on closedBall 0 R.
  obtain ‚ü®K, hK‚ü© : ‚ąÉ K, LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) R) := by
    refine (galerkinVectorField_contDiff S (n := 1)).contDiffOn.exists_lipschitzOnWith
      ?_ (convex_closedBall 0 R) (isCompact_closedBall 0 R)
    decide
  -- Step 2: uniform bound L := C ¬∑ R¬≤ on closedBall 0 R.
  obtain ‚ü®C, hC_nn, hC_bound‚ü© := galerkinVectorField_quadratic_bound S
  set L_real : ‚ĄĚ := C * R ^ 2 with hL_def
  have hL_nn : 0 ‚Č§ L_real := by positivity
  have hL_nn' : (0 : ‚ĄĚ) ‚Č§ L_real + 1 := by linarith
  set L : NNReal := ‚ü®L_real, hL_nn‚ü© with hL_NN
  have hL_coe : (L : ‚ĄĚ) = L_real := rfl
  have hBound_ball : ‚ąÄ c ‚ąą Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) R,
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ (L : ‚ĄĚ) := by
    intros c hc
    rw [Metric.mem_closedBall, dist_zero_right] at hc
    calc ‚ÄĖgalerkinVectorField S c‚ÄĖ
        ‚Č§ C * ‚ÄĖc‚ÄĖ ^ 2 := hC_bound c
      _ ‚Č§ C * R ^ 2 := by
          apply mul_le_mul_of_nonneg_left (pow_le_pow_left‚āÄ (norm_nonneg _) hc 2) hC_nn
      _ = L_real := rfl
  -- Step 3: pick őĶ = (R/2) / (L + 1), so L ¬∑ őĶ ‚Č§ R/2.
  set őĶ : ‚ĄĚ := (R / 2) / ((L : ‚ĄĚ) + 1) with hőĶ_def
  have hLp1_pos : 0 < (L : ‚ĄĚ) + 1 := by rw [hL_coe]; linarith
  have hR2_pos : 0 < R / 2 := by linarith
  have hőĶ_pos : 0 < őĶ := div_pos hR2_pos hLp1_pos
  refine ‚ü®őĶ, hőĶ_pos, ?_‚ü©
  -- Step 4: for any c‚āÄ with ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R/2, apply galerkin_local_exists_given_bounds.
  intro c‚āÄ hc‚āÄ_norm
  have h_ball_sub : Metric.closedBall c‚āÄ (R / 2) ‚äÜ Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) R := by
    intros x hx
    rw [Metric.mem_closedBall, dist_zero_right]
    rw [Metric.mem_closedBall] at hx
    calc ‚ÄĖx‚ÄĖ = ‚ÄĖ(x - c‚āÄ) + c‚āÄ‚ÄĖ := by rw [sub_add_cancel]
      _ ‚Č§ ‚ÄĖx - c‚āÄ‚ÄĖ + ‚ÄĖc‚āÄ‚ÄĖ := norm_add_le _ _
      _ = dist x c‚āÄ + ‚ÄĖc‚āÄ‚ÄĖ := by rw [dist_eq_norm]
      _ ‚Č§ R / 2 + R / 2 := add_le_add hx hc‚āÄ_norm
      _ = R := by ring
  have hLip_small : LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall c‚āÄ (R / 2)) := hK.mono h_ball_sub
  have hBound_small : ‚ąÄ c ‚ąą Metric.closedBall c‚āÄ (R / 2),
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ (L : ‚ĄĚ) :=
    fun c hc => hBound_ball c (h_ball_sub hc)
  set a : NNReal := ‚ü®R / 2, hR2_pos.le‚ü© with ha_def
  have ha_coe : (a : ‚ĄĚ) = R / 2 := rfl
  have hTime : (L : ‚ĄĚ) * őĶ ‚Č§ (a : ‚ĄĚ) := by
    have h1 : (L : ‚ĄĚ) * őĶ ‚Č§ ((L : ‚ĄĚ) + 1) * őĶ :=
      mul_le_mul_of_nonneg_right (by linarith) hőĶ_pos.le
    have h2 : ((L : ‚ĄĚ) + 1) * őĶ = R / 2 := by
      rw [hőĶ_def]
      field_simp
    rw [ha_coe]
    linarith
  -- Rewrite Lipschitz/bound in terms of ‚ÜĎa.
  have hLip_small' : LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall c‚āÄ (a : ‚ĄĚ)) := by
    rw [ha_coe]; exact hLip_small
  have hBound_small' : ‚ąÄ c ‚ąą Metric.closedBall c‚āÄ (a : ‚ĄĚ),
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ (L : ‚ĄĚ) := by
    rw [ha_coe]; exact hBound_small
  exact galerkin_local_exists_given_bounds S c‚āÄ hőĶ_pos hLip_small' hBound_small' hTime

/-! ### ¬ß10.103 Forward one-step: `c‚āÄ ‚Ü¶ őĪ(őĶ)` via `galerkin_uniform_őĶ_picard`

Utility extracting the "next value" `őĪ(őĶ)` from the uniform-őĶ Picard
theorem, plus the HasDerivWithinAt witness over the interval `[0, őĶ]`. -/

theorem galerkin_forward_step
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {R : ‚ĄĚ} (hR : 0 < R) :
    ‚ąÉ őĶ : ‚ĄĚ, 0 < őĶ ‚ąß
      ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
        ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
          ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
            HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t := by
  obtain ‚ü®őĶ, hőĶ_pos, hExist‚ü© := galerkin_uniform_őĶ_picard S hR
  refine ‚ü®őĶ, hőĶ_pos, ?_‚ü©
  intros c‚āÄ hc‚āÄ
  obtain ‚ü®őĪ, hőĪ0, hőĪ_deriv‚ü© := hExist c‚āÄ hc‚āÄ
  refine ‚ü®őĪ, hőĪ0, ?_‚ü©
  intros t ht
  have ht_big : t ‚ąą Set.Icc (-őĶ) őĶ := ‚ü®le_trans (neg_nonpos_of_nonneg hőĶ_pos.le) ht.1, ht.2‚ü©
  exact (hőĪ_deriv t ht_big).mono (Set.Icc_subset_Icc (by linarith) le_rfl)

/-! ### ¬ß10.104 Nat-indexed chain of local Picard solutions

Given a forward-step existence hypothesis (`hStep`, matching the shape of
`galerkin_forward_step`) and a ball-invariance hypothesis (`hInv` ‚ÄĒ every
solution starting in the `R/2`-ball stays in the `R/2`-ball throughout
`[0, őĶ]`), iterate forward by `‚Ąē`-induction to obtain, for each `n : ‚Ąē`, a
solution on the interval `[0, n¬∑őĶ]` that stays inside the ball.

The ball-invariance hypothesis is separated from the existence hypothesis
so that it may be discharged later from `L¬≤`-conservation (¬ß10.97) without
re-proving the local Picard-Lindel√∂f step. -/

theorem galerkin_chain_n_step
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {R őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hStep : ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hInv : ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÄ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚Üí
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚Üí
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ : ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2) (n : ‚Ąē) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ),
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t))
          (Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ)) t) ‚ąß
      (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ), ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2) := by
  induction n with
  | zero =>
    -- Base case: interval is {0}. Use the forward-step solution restricted to {0}.
    obtain ‚ü®őĪ‚āÄ, hőĪ‚āÄ0, hőĪ‚āÄD‚ü© := hStep c‚āÄ hc‚āÄ
    refine ‚ü®őĪ‚āÄ, hőĪ‚āÄ0, ?_, ?_‚ü©
    ¬∑ intros t ht
      have h_zero : ((0 : ‚Ąē) : ‚ĄĚ) * őĶ = 0 := by simp
      rw [h_zero] at ht
      have h0 : t = 0 := le_antisymm ht.2 ht.1
      subst h0
      rw [h_zero]
      have h_sub : Set.Icc (0 : ‚ĄĚ) 0 ‚äÜ Set.Icc (0 : ‚ĄĚ) őĶ :=
        Set.Icc_subset_Icc le_rfl hőĶ.le
      exact (hőĪ‚āÄD 0 ‚ü®le_rfl, hőĶ.le‚ü©).mono h_sub
    ¬∑ intros t ht
      have h_zero : ((0 : ‚Ąē) : ‚ĄĚ) * őĶ = 0 := by simp
      rw [h_zero] at ht
      have h0 : t = 0 := le_antisymm ht.2 ht.1
      subst h0
      rw [hőĪ‚āÄ0]; exact hc‚āÄ
  | succ n ih =>
    obtain ‚ü®őĪ_n, hőĪ_n0, hőĪ_nD, hőĪ_nB‚ü© := ih
    set Tn : ‚ĄĚ := (n : ‚ĄĚ) * őĶ with hTn_def
    set Tn1 : ‚ĄĚ := ((n + 1 : ‚Ąē) : ‚ĄĚ) * őĶ with hTn1_def
    have hTn_nn : 0 ‚Č§ Tn := mul_nonneg (Nat.cast_nonneg _) hőĶ.le
    have hTn_succ : Tn1 = Tn + őĶ := by
      show ((n + 1 : ‚Ąē) : ‚ĄĚ) * őĶ = (n : ‚ĄĚ) * őĶ + őĶ
      push_cast; ring
    have hTn_le : Tn ‚Č§ Tn1 := by rw [hTn_succ]; linarith
    have h_őĪTn_bound : ‚ÄĖőĪ_n Tn‚ÄĖ ‚Č§ R / 2 := hőĪ_nB Tn ‚ü®hTn_nn, le_rfl‚ü©
    obtain ‚ü®ő≤, hő≤0, hő≤D‚ü© := hStep (őĪ_n Tn) h_őĪTn_bound
    have hő≤B : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖő≤ t‚ÄĖ ‚Č§ R / 2 :=
      hInv _ h_őĪTn_bound ő≤ hő≤0 hő≤D
    -- Concatenation ő≥(t) = if t ‚Č§ Tn then őĪ_n t else ő≤ (t - Tn).
    set ő≥ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) := fun t => if t ‚Č§ Tn then őĪ_n t else ő≤ (t - Tn)
      with hő≥_def
    -- Pointwise agreements.
    have hő≥_left : ‚ąÄ t, t ‚Č§ Tn ‚Üí ő≥ t = őĪ_n t := fun t ht => by
      show (if t ‚Č§ Tn then őĪ_n t else ő≤ (t - Tn)) = őĪ_n t
      rw [if_pos ht]
    have hő≥_right : ‚ąÄ t, Tn ‚Č§ t ‚Üí ő≥ t = ő≤ (t - Tn) := fun t ht => by
      show (if t ‚Č§ Tn then őĪ_n t else ő≤ (t - Tn)) = ő≤ (t - Tn)
      by_cases heq : t = Tn
      ¬∑ subst heq; rw [if_pos le_rfl, sub_self, hő≤0]
      ¬∑ have hlt : Tn < t := lt_of_le_of_ne ht (Ne.symm heq)
        rw [if_neg (not_le.mpr hlt)]
    have hő≥0 : ő≥ 0 = c‚āÄ := by
      rw [hő≥_left 0 hTn_nn, hőĪ_n0]
    -- Translated ő≤ has HasDerivWithinAt on [Tn, Tn1].
    have hő≤_transD : ‚ąÄ t ‚ąą Set.Icc Tn Tn1,
        HasDerivWithinAt (fun y => ő≤ (y - Tn))
          (galerkinVectorField S (ő≤ (t - Tn)))
          (Set.Icc Tn Tn1) t := by
      intros t ht
      have hmem : t - Tn ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := by
        refine ‚ü®sub_nonneg.mpr ht.1, ?_‚ü©
        have := ht.2; rw [hTn_succ] at this; linarith
      have hg : HasDerivWithinAt ő≤ (galerkinVectorField S (ő≤ (t - Tn)))
          (Set.Icc (0 : ‚ĄĚ) őĶ) (t - Tn) := hő≤D _ hmem
      have hh : HasDerivWithinAt (fun y : ‚ĄĚ => y - Tn) 1 (Set.Icc Tn Tn1) t :=
        (hasDerivWithinAt_id t _).sub_const _
      have hst : Set.MapsTo (fun y : ‚ĄĚ => y - Tn) (Set.Icc Tn Tn1)
          (Set.Icc (0 : ‚ĄĚ) őĶ) := by
        intros y hy
        refine ‚ü®sub_nonneg.mpr hy.1, ?_‚ü©
        have := hy.2; rw [hTn_succ] at this; linarith
      have key := hg.scomp t hh hst
      simpa using key
    refine ‚ü®ő≥, hő≥0, ?_, ?_‚ü©
    ¬∑ -- HasDerivWithinAt ő≥ ... (Icc 0 Tn1) at each t ‚ąą Icc 0 Tn1.
      intros t ht
      by_cases ht_le : t ‚Č§ Tn
      ¬∑ -- Left piece.
        have ht_left : t ‚ąą Set.Icc (0 : ‚ĄĚ) Tn := ‚ü®ht.1, ht_le‚ü©
        have hő≥t : ő≥ t = őĪ_n t := hő≥_left t ht_le
        have hő≥_on_left : HasDerivWithinAt ő≥ (galerkinVectorField S (ő≥ t))
            (Set.Icc (0 : ‚ĄĚ) Tn) t := by
          rw [hő≥t]
          refine (hőĪ_nD t ht_left).congr ?_ ?_
          ¬∑ intros y hy; exact hő≥_left y hy.2
          ¬∑ exact hő≥_left t ht_le
        by_cases ht_eq : t = Tn
        ¬∑ subst ht_eq
          have h_ő≤_right_deriv : HasDerivWithinAt ő≥ (galerkinVectorField S (ő≥ Tn))
              (Set.Icc Tn Tn1) Tn := by
            have hő≥t' : ő≥ Tn = ő≤ (Tn - Tn) := hő≥_right Tn le_rfl
            rw [hő≥t']
            refine (hő≤_transD Tn ‚ü®le_rfl, hTn_le‚ü©).congr ?_ ?_
            ¬∑ intros y hy; exact hő≥_right y hy.1
            ¬∑ exact hő≥_right Tn le_rfl
          have h_union : HasDerivWithinAt ő≥ (galerkinVectorField S (ő≥ Tn))
              (Set.Icc (0 : ‚ĄĚ) Tn ‚ą™ Set.Icc Tn Tn1) Tn :=
            hő≥_on_left.union h_ő≤_right_deriv
          rwa [Set.Icc_union_Icc_eq_Icc ht.1 hTn_le] at h_union
        ¬∑ -- t < Tn strictly.
          have ht_lt : t < Tn := lt_of_le_of_ne ht_le ht_eq
          have hU_nhds : Set.Iio Tn ‚ąą nhds t := Iio_mem_nhds ht_lt
          rw [‚Üź hasDerivWithinAt_inter hU_nhds]
          have hsub : Set.Icc (0 : ‚ĄĚ) Tn1 ‚ą© Set.Iio Tn ‚äÜ Set.Icc (0 : ‚ĄĚ) Tn := by
            intros x hx
            exact ‚ü®hx.1.1, le_of_lt hx.2‚ü©
          exact hő≥_on_left.mono hsub
      ¬∑ -- Right piece: t > Tn.
        push Not at ht_le
        have ht_right : t ‚ąą Set.Icc Tn Tn1 := ‚ü®le_of_lt ht_le, ht.2‚ü©
        have hő≥t : ő≥ t = ő≤ (t - Tn) := hő≥_right t (le_of_lt ht_le)
        have hő≥_on_right : HasDerivWithinAt ő≥ (galerkinVectorField S (ő≥ t))
            (Set.Icc Tn Tn1) t := by
          rw [hő≥t]
          refine (hő≤_transD t ht_right).congr ?_ ?_
          ¬∑ intros y hy; exact hő≥_right y hy.1
          ¬∑ exact hő≥_right t (le_of_lt ht_le)
        have hU_nhds : Set.Ioi Tn ‚ąą nhds t := Ioi_mem_nhds ht_le
        rw [‚Üź hasDerivWithinAt_inter hU_nhds]
        have hsub : Set.Icc (0 : ‚ĄĚ) Tn1 ‚ą© Set.Ioi Tn ‚äÜ Set.Icc Tn Tn1 := by
          intros x hx
          exact ‚ü®le_of_lt hx.2, hx.1.2‚ü©
        exact hő≥_on_right.mono hsub
    ¬∑ -- Norm bound on [0, Tn1].
      intros t ht
      by_cases ht_le : t ‚Č§ Tn
      ¬∑ rw [hő≥_left t ht_le]
        exact hőĪ_nB t ‚ü®ht.1, ht_le‚ü©
      ¬∑ push Not at ht_le
        rw [hő≥_right t (le_of_lt ht_le)]
        have hmem : t - Tn ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := by
          refine ‚ü®sub_nonneg.mpr (le_of_lt ht_le), ?_‚ü©
          have := ht.2; rw [hTn_succ] at this; linarith
        exact hő≤B (t - Tn) hmem

/-! ### ¬ß10.105 Chain sequence of endpoints and step solutions

Under ball-invariance, bundle the forward iteration into two sequences:
  `ő∑ : ‚Ąē ‚Üí ‚Ü•S ‚Üí ‚Ąā` ‚ÄĒ endpoint values with `ő∑ 0 = c‚āÄ` and `‚ÄĖő∑ n‚ÄĖ ‚Č§ R/2`.
  `ő≤ : ‚Ąē ‚Üí ‚ĄĚ ‚Üí ‚Ü•S ‚Üí ‚Ąā` ‚ÄĒ step solutions with `ő≤ n 0 = ő∑ n`,
     `ő≤ n őĶ = ő∑ (n+1)`, and `HasDerivWithinAt` on `[0, őĶ]`.

These are produced via `Nat.rec` + `Classical.choose` on `hStep`.
`¬ß10.106` glues them into a single `őĪ : ‚ĄĚ ‚Üí ‚Ü•S ‚Üí ‚Ąā`. -/

theorem galerkin_chain_sequence
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {R őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hStep : ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hInv : ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÄ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚Üí
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚Üí
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ : ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2) :
    ‚ąÉ ő∑ : ‚Ąē ‚Üí (‚Ü•S ‚Üí ‚Ąā), ‚ąÉ ő≤ : ‚Ąē ‚Üí ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā),
      ő∑ 0 = c‚āÄ ‚ąß
      (‚ąÄ n, ‚ÄĖő∑ n‚ÄĖ ‚Č§ R / 2) ‚ąß
      (‚ąÄ n, ő≤ n 0 = ő∑ n) ‚ąß
      (‚ąÄ n, ő≤ n őĶ = ő∑ (n + 1)) ‚ąß
      (‚ąÄ n, ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
        HasDerivWithinAt (ő≤ n) (galerkinVectorField S (ő≤ n t))
          (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚ąß
      (‚ąÄ n, ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖő≤ n t‚ÄĖ ‚Č§ R / 2) := by
  classical
  -- Classical-choice step function.
  let stepFn : (c : ‚Ü•S ‚Üí ‚Ąā) ‚Üí ‚ÄĖc‚ÄĖ ‚Č§ R / 2 ‚Üí ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) :=
    fun c hc => Classical.choose (hStep c hc)
  have stepSpec : ‚ąÄ (c : ‚Ü•S ‚Üí ‚Ąā) (hc : ‚ÄĖc‚ÄĖ ‚Č§ R / 2),
      (stepFn c hc) 0 = c ‚ąß
      ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
        HasDerivWithinAt (stepFn c hc)
          (galerkinVectorField S ((stepFn c hc) t))
          (Set.Icc (0 : ‚ĄĚ) őĶ) t := fun c hc => Classical.choose_spec (hStep c hc)
  -- Endpoint sequence as Nat-indexed pairs carrying the norm bound.
  let chainEndpt : ‚Ąē ‚Üí {c : ‚Ü•S ‚Üí ‚Ąā // ‚ÄĖc‚ÄĖ ‚Č§ R / 2} := fun n =>
    Nat.rec (motive := fun _ => {c : ‚Ü•S ‚Üí ‚Ąā // ‚ÄĖc‚ÄĖ ‚Č§ R / 2})
      ‚ü®c‚āÄ, hc‚āÄ‚ü©
      (fun _ prev =>
        let f := stepFn prev.val prev.property
        let hsp := stepSpec prev.val prev.property
        ‚ü®f őĶ, hInv prev.val prev.property f hsp.1 hsp.2 őĶ ‚ü®hőĶ.le, le_rfl‚ü©‚ü©)
      n
  refine ‚ü®fun n => (chainEndpt n).val,
          fun n => stepFn (chainEndpt n).val (chainEndpt n).property,
          ?_, ?_, ?_, ?_, ?_, ?_‚ü©
  ¬∑ -- ő∑ 0 = c‚āÄ
    rfl
  ¬∑ -- ‚ąÄ n, ‚ÄĖő∑ n‚ÄĖ ‚Č§ R/2
    intro n; exact (chainEndpt n).property
  ¬∑ -- ő≤ n 0 = ő∑ n
    intro n
    exact (stepSpec (chainEndpt n).val (chainEndpt n).property).1
  ¬∑ -- ő≤ n őĶ = ő∑ (n+1)
    intro n; rfl
  ¬∑ -- HasDerivWithinAt
    intro n t ht
    exact (stepSpec (chainEndpt n).val (chainEndpt n).property).2 t ht
  ¬∑ -- Norm bound on ő≤ n
    intro n t ht
    exact hInv (chainEndpt n).val (chainEndpt n).property
      (stepFn (chainEndpt n).val (chainEndpt n).property)
      (stepSpec (chainEndpt n).val (chainEndpt n).property).1
      (stepSpec (chainEndpt n).val (chainEndpt n).property).2 t ht

/-! ### ¬ß10.106 Global function from the chain pieces (value + norm bound)

Given the chain sequence `(ő∑, ő≤)` from ¬ß10.105, define a single
`őĪ : ‚ĄĚ ‚Üí ‚Ü•S ‚Üí ‚Ąā` piecewise:
  `őĪ t = ő≤ ‚Ćät/őĶ‚Ćč‚āä (t ‚ąí ‚Ćät/őĶ‚Ćč‚āä ¬∑ őĶ)`  for `t ‚Č• 0`.

This section establishes `őĪ 0 = c‚āÄ` and the pointwise norm bound
`‚ÄĖőĪ t‚ÄĖ ‚Č§ R/2` for all `t ‚Č• 0`. The `HasDerivAt` assembly is deferred
to ¬ß10.107 (interior) and ¬ß10.108 (final capstone). -/

theorem galerkin_global_alpha_exists
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {R őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hStep : ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hInv : ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÄ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚Üí
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚Üí
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ : ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2) := by
  classical
  obtain ‚ü®ő∑, ő≤, hő∑0, hő∑B, hő≤0, hő≤őĶ, _hő≤D, hő≤B‚ü© :=
    galerkin_chain_sequence S hőĶ hStep hInv c‚āÄ hc‚āÄ
  -- Global őĪ via Nat.floor.
  refine ‚ü®fun t => ő≤ (‚Ćät / őĶ‚Ćč‚āä) (t - (‚Ćät / őĶ‚Ćč‚āä : ‚ĄĚ) * őĶ), ?_, ?_‚ü©
  ¬∑ -- őĪ 0 = c‚āÄ
    show ő≤ (‚Ćä(0 : ‚ĄĚ) / őĶ‚Ćč‚āä) (0 - (‚Ćä(0 : ‚ĄĚ) / őĶ‚Ćč‚āä : ‚ĄĚ) * őĶ) = c‚āÄ
    have h0 : ‚Ćä(0 : ‚ĄĚ) / őĶ‚Ćč‚āä = 0 := by
      simp [Nat.floor_eq_zero, hőĶ]
    rw [h0]
    simp [hő≤0, hő∑0]
  ¬∑ -- Norm bound for t ‚Č• 0.
    intros t ht
    set k : ‚Ąē := ‚Ćät / őĶ‚Ćč‚āä with hk_def
    have ht_őĶ : 0 ‚Č§ t / őĶ := div_nonneg ht hőĶ.le
    have hk_lo : (k : ‚ĄĚ) ‚Č§ t / őĶ := Nat.floor_le ht_őĶ
    have hk_hi : t / őĶ < (k : ‚ĄĚ) + 1 := Nat.lt_floor_add_one _
    -- Reduce to ő≤ k (t - k¬∑őĶ) with (t - k¬∑őĶ) ‚ąą [0, őĶ].
    have h_shift_nn : 0 ‚Č§ t - (k : ‚ĄĚ) * őĶ := by
      have h : (k : ‚ĄĚ) * őĶ ‚Č§ t := (le_div_iff‚āÄ hőĶ).mp hk_lo
      linarith
    have h_shift_lt : t - (k : ‚ĄĚ) * őĶ < őĶ := by
      have h1 : t < ((k : ‚ĄĚ) + 1) * őĶ := (div_lt_iff‚āÄ hőĶ).mp hk_hi
      nlinarith
    exact hő≤B k (t - (k : ‚ĄĚ) * őĶ) ‚ü®h_shift_nn, h_shift_lt.le‚ü©

/-! ### ¬ß10.107 Global `HasDerivWithinAt` assembly

Strengthens ¬ß10.106 with `HasDerivWithinAt` on `Set.Ici 0` at each `t ‚Č• 0`.
The construction of `őĪ` is the same Nat-floor piecewise formula; the new
content is the derivative argument:

* On each step `[k¬∑őĶ, (k+1)¬∑őĶ]`, `őĪ` equals the translated ő≤-piece
  `ő≤ k (¬∑ ‚ąí k¬∑őĶ)` (endpoints included via `ő≤ n őĶ = ő∑ (n+1) = ő≤ (n+1) 0`).
* Translated ő≤ has `HasDerivWithinAt` on `[k¬∑őĶ, (k+1)¬∑őĶ]` via
  `HasDerivWithinAt.scomp` with the translation `(¬∑ ‚ąí k¬∑őĶ)`.
* Case analysis `t > k¬∑őĶ` (strict interior), `t = k¬∑őĶ ‚Č• 1¬∑őĶ` (junction),
  or `t = 0` uses `hasDerivWithinAt_inter` with an appropriate open
  neighborhood + `HasDerivWithinAt.union` at junctions. -/

theorem galerkin_global_hasDerivWithinAt_conditional
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {R őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hStep : ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hInv : ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÄ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚Üí
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚Üí
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ : ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2) ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ici (0 : ‚ĄĚ)) t) := by
  classical
  obtain ‚ü®ő∑, ő≤, hő∑0, hő∑B, hő≤0, hő≤őĶ, hő≤D, hő≤B‚ü© :=
    galerkin_chain_sequence S hőĶ hStep hInv c‚āÄ hc‚āÄ
  set őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) :=
    fun t => ő≤ (‚Ćät / őĶ‚Ćč‚āä) (t - (‚Ćät / őĶ‚Ćč‚āä : ‚ĄĚ) * őĶ) with hőĪ_def
  -- Helper: őĪ equals ő≤ k (¬∑ ‚ąí k¬∑őĶ) on [k¬∑őĶ, (k+1)¬∑őĶ].
  have hőĪ_step_eq : ‚ąÄ (k : ‚Ąē) (t' : ‚ĄĚ),
      (k : ‚ĄĚ) * őĶ ‚Č§ t' ‚Üí t' ‚Č§ ((k : ‚ĄĚ) + 1) * őĶ ‚Üí
      őĪ t' = ő≤ k (t' - (k : ‚ĄĚ) * őĶ) := by
    intros k t' ht_lo ht_hi
    by_cases heq : t' = ((k : ‚ĄĚ) + 1) * őĶ
    ¬∑ -- Right endpoint: floor jumps to k+1.
      have hfl : ‚Ćät' / őĶ‚Ćč‚āä = k + 1 := by
        rw [heq]
        have h1 : ((k : ‚ĄĚ) + 1) * őĶ / őĶ = ((k + 1 : ‚Ąē) : ‚ĄĚ) := by
          push_cast; field_simp
        rw [h1]
        exact Nat.floor_natCast _
      show ő≤ (‚Ćät' / őĶ‚Ćč‚āä) (t' - (‚Ćät' / őĶ‚Ćč‚āä : ‚ĄĚ) * őĶ) = ő≤ k (t' - (k : ‚ĄĚ) * őĶ)
      rw [hfl]
      -- ő≤ (k+1) (t' - (k+1)¬∑őĶ) where t' = (k+1)¬∑őĶ ‚Üí ő≤ (k+1) 0 = ő∑ (k+1).
      -- ő≤ k (t' - k¬∑őĶ) where t' = (k+1)¬∑őĶ ‚Üí ő≤ k őĶ = ő∑ (k+1).
      rw [heq]
      have h_lhs : (((k : ‚ĄĚ) + 1) * őĶ - ((k + 1 : ‚Ąē) : ‚ĄĚ) * őĶ) = 0 := by
        push_cast; ring
      have h_rhs : (((k : ‚ĄĚ) + 1) * őĶ - (k : ‚ĄĚ) * őĶ) = őĶ := by ring
      rw [h_lhs, h_rhs, hő≤0 (k + 1), hő≤őĶ k]
    ¬∑ -- Strict interior.
      have ht_lt : t' < ((k : ‚ĄĚ) + 1) * őĶ := lt_of_le_of_ne ht_hi heq
      have ht_nn : 0 ‚Č§ t' := le_trans (mul_nonneg (Nat.cast_nonneg _) hőĶ.le) ht_lo
      have hfl : ‚Ćät' / őĶ‚Ćč‚āä = k := by
        rw [Nat.floor_eq_iff (by positivity)]
        refine ‚ü®?_, ?_‚ü©
        ¬∑ exact (le_div_iff‚āÄ hőĶ).mpr ht_lo
        ¬∑ rw [div_lt_iff‚āÄ hőĶ]
          linarith
      show ő≤ (‚Ćät' / őĶ‚Ćč‚āä) (t' - (‚Ćät' / őĶ‚Ćč‚āä : ‚ĄĚ) * őĶ) = ő≤ k (t' - (k : ‚ĄĚ) * őĶ)
      rw [hfl]
  -- Helper: translated ő≤ has HasDerivWithinAt on [k¬∑őĶ, (k+1)¬∑őĶ].
  have hő≤_step_transD : ‚ąÄ (k : ‚Ąē) (t' : ‚ĄĚ),
      t' ‚ąą Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) ‚Üí
      HasDerivWithinAt (fun y => ő≤ k (y - (k : ‚ĄĚ) * őĶ))
        (galerkinVectorField S (ő≤ k (t' - (k : ‚ĄĚ) * őĶ)))
        (Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ)) t' := by
    intros k t' ht'
    have hmem : t' - (k : ‚ĄĚ) * őĶ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := by
      refine ‚ü®sub_nonneg.mpr ht'.1, ?_‚ü©
      have := ht'.2; nlinarith
    have hg : HasDerivWithinAt (ő≤ k) (galerkinVectorField S (ő≤ k (t' - (k : ‚ĄĚ) * őĶ)))
        (Set.Icc (0 : ‚ĄĚ) őĶ) (t' - (k : ‚ĄĚ) * őĶ) := hő≤D k _ hmem
    have hh : HasDerivWithinAt (fun y : ‚ĄĚ => y - (k : ‚ĄĚ) * őĶ) 1
        (Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ)) t' :=
      (hasDerivWithinAt_id t' _).sub_const _
    have hst : Set.MapsTo (fun y : ‚ĄĚ => y - (k : ‚ĄĚ) * őĶ)
        (Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ)) (Set.Icc (0 : ‚ĄĚ) őĶ) := by
      intros y hy
      refine ‚ü®sub_nonneg.mpr hy.1, ?_‚ü©
      have := hy.2; nlinarith
    have key := hg.scomp t' hh hst
    simpa using key
  -- Helper: HasDerivWithinAt őĪ on step interval.
  have hőĪ_step_D : ‚ąÄ (k : ‚Ąē) (t' : ‚ĄĚ),
      t' ‚ąą Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) ‚Üí
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t'))
        (Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ)) t' := by
    intros k t' ht'
    have hőĪ_t' : őĪ t' = ő≤ k (t' - (k : ‚ĄĚ) * őĶ) := hőĪ_step_eq k t' ht'.1 ht'.2
    rw [hőĪ_t']
    refine (hő≤_step_transD k t' ht').congr ?_ ?_
    ¬∑ intros y hy; exact hőĪ_step_eq k y hy.1 hy.2
    ¬∑ exact hőĪ_step_eq k t' ht'.1 ht'.2
  refine ‚ü®őĪ, ?_, ?_, ?_‚ü©
  ¬∑ -- őĪ 0 = c‚āÄ
    show ő≤ (‚Ćä(0 : ‚ĄĚ) / őĶ‚Ćč‚āä) (0 - (‚Ćä(0 : ‚ĄĚ) / őĶ‚Ćč‚āä : ‚ĄĚ) * őĶ) = c‚āÄ
    have h0 : ‚Ćä(0 : ‚ĄĚ) / őĶ‚Ćč‚āä = 0 := by simp [Nat.floor_eq_zero, hőĶ]
    rw [h0]; simp [hő≤0, hő∑0]
  ¬∑ -- Norm bound.
    intros t ht
    set k : ‚Ąē := ‚Ćät / őĶ‚Ćč‚āä with hk_def
    have ht_őĶ : 0 ‚Č§ t / őĶ := div_nonneg ht hőĶ.le
    have hk_lo : (k : ‚ĄĚ) ‚Č§ t / őĶ := Nat.floor_le ht_őĶ
    have hk_hi : t / őĶ < (k : ‚ĄĚ) + 1 := Nat.lt_floor_add_one _
    have h_shift_nn : 0 ‚Č§ t - (k : ‚ĄĚ) * őĶ := by
      have h : (k : ‚ĄĚ) * őĶ ‚Č§ t := (le_div_iff‚āÄ hőĶ).mp hk_lo
      linarith
    have h_shift_lt : t - (k : ‚ĄĚ) * őĶ < őĶ := by
      have h1 : t < ((k : ‚ĄĚ) + 1) * őĶ := (div_lt_iff‚āÄ hőĶ).mp hk_hi
      nlinarith
    exact hő≤B k (t - (k : ‚ĄĚ) * őĶ) ‚ü®h_shift_nn, h_shift_lt.le‚ü©
  ¬∑ -- HasDerivWithinAt őĪ on Ici 0.
    intros t ht
    set k : ‚Ąē := ‚Ćät / őĶ‚Ćč‚āä with hk_def
    have ht_őĶ : 0 ‚Č§ t / őĶ := div_nonneg ht hőĶ.le
    have hk_lo_div : (k : ‚ĄĚ) ‚Č§ t / őĶ := Nat.floor_le ht_őĶ
    have hk_hi_div : t / őĶ < (k : ‚ĄĚ) + 1 := Nat.lt_floor_add_one _
    have hk_lo : (k : ‚ĄĚ) * őĶ ‚Č§ t := (le_div_iff‚āÄ hőĶ).mp hk_lo_div
    have hk_hi : t ‚Č§ ((k : ‚ĄĚ) + 1) * őĶ :=
      le_of_lt ((div_lt_iff‚āÄ hőĶ).mp hk_hi_div)
    have h_kőĶ_nn : 0 ‚Č§ (k : ‚ĄĚ) * őĶ := mul_nonneg (Nat.cast_nonneg _) hőĶ.le
    have h_kőĶ1_nn : 0 ‚Č§ ((k : ‚ĄĚ) + 1) * őĶ := by positivity
    have h_Ik_deriv : HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t))
        (Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ)) t :=
      hőĪ_step_D k t ‚ü®hk_lo, hk_hi‚ü©
    by_cases ht_pos : 0 < t
    ¬∑ -- t > 0 case. Split on t = k*őĶ junction or strict interior.
      by_cases ht_eq_kőĶ : t = (k : ‚ĄĚ) * őĶ
      ¬∑ -- Junction: k ‚Č• 1. Combine with previous step [k-1)¬∑őĶ, k¬∑őĶ].
        have hk_pos : 0 < k := by
          rcases Nat.eq_zero_or_pos k with hk0 | hkp
          ¬∑ exfalso
            rw [hk0, Nat.cast_zero, zero_mul] at ht_eq_kőĶ
            exact ne_of_gt ht_pos ht_eq_kőĶ
          ¬∑ exact hkp
        set kp : ‚Ąē := k - 1 with hkp_def
        have hkp_succ : kp + 1 = k := Nat.succ_pred_eq_of_pos hk_pos
        have hkp_cast : (kp : ‚ĄĚ) + 1 = (k : ‚ĄĚ) := by
          have := congrArg (Nat.cast (R := ‚ĄĚ)) hkp_succ
          push_cast at this; linarith
        -- Previous step interval: Icc ((kp:‚ĄĚ)¬∑őĶ) (((kp:‚ĄĚ)+1)¬∑őĶ) = Icc ((kp:‚ĄĚ)¬∑őĶ) ((k:‚ĄĚ)¬∑őĶ).
        have h_prev_top_eq : ((kp : ‚ĄĚ) + 1) * őĶ = (k : ‚ĄĚ) * őĶ := by rw [hkp_cast]
        have h_prev_mem : t ‚ąą Set.Icc ((kp : ‚ĄĚ) * őĶ) (((kp : ‚ĄĚ) + 1) * őĶ) := by
          rw [h_prev_top_eq]
          refine ‚ü®?_, ht_eq_kőĶ.le‚ü©
          rw [ht_eq_kőĶ]
          have : (kp : ‚ĄĚ) ‚Č§ (k : ‚ĄĚ) := by exact_mod_cast Nat.sub_le k 1
          nlinarith
        have h_prev_deriv : HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t))
            (Set.Icc ((kp : ‚ĄĚ) * őĶ) (((kp : ‚ĄĚ) + 1) * őĶ)) t :=
          hőĪ_step_D kp t h_prev_mem
        -- Rewrite h_prev_deriv on Icc ((kp:‚ĄĚ)¬∑őĶ) ((k:‚ĄĚ)¬∑őĶ).
        rw [h_prev_top_eq] at h_prev_deriv
        -- Union h_prev_deriv and h_Ik_deriv to get on Icc ((kp:‚ĄĚ)¬∑őĶ) (((k:‚ĄĚ)+1)¬∑őĶ).
        have h_union := h_prev_deriv.union h_Ik_deriv
        have h_kp_le_k : (kp : ‚ĄĚ) * őĶ ‚Č§ (k : ‚ĄĚ) * őĶ := by
          have : (kp : ‚ĄĚ) ‚Č§ (k : ‚ĄĚ) := by exact_mod_cast Nat.sub_le k 1
          nlinarith
        have h_k_le_succ : (k : ‚ĄĚ) * őĶ ‚Č§ ((k : ‚ĄĚ) + 1) * őĶ := by nlinarith
        have h_icc_union :
            Set.Icc ((kp : ‚ĄĚ) * őĶ) ((k : ‚ĄĚ) * őĶ) ‚ą™
              Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ)
            = Set.Icc ((kp : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) :=
          Set.Icc_union_Icc_eq_Icc h_kp_le_k h_k_le_succ
        rw [h_icc_union] at h_union
        -- Extend to Ici 0 via hasDerivWithinAt_inter with Ioo nbhd.
        have h_kp_lt_t : (kp : ‚ĄĚ) * őĶ < t := by
          rw [ht_eq_kőĶ]
          have h_kp_lt_k : (kp : ‚ĄĚ) < (k : ‚ĄĚ) := by
            have : kp < k := by omega
            exact_mod_cast this
          nlinarith
        have h_t_lt_succ : t < ((k : ‚ĄĚ) + 1) * őĶ := by
          rw [ht_eq_kőĶ]; nlinarith
        have hU_nhds :
            Set.Ioo ((kp : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) ‚ąą nhds t :=
          Ioo_mem_nhds h_kp_lt_t h_t_lt_succ
        rw [‚Üź hasDerivWithinAt_inter hU_nhds]
        have hsub : Set.Ici (0 : ‚ĄĚ) ‚ą©
            Set.Ioo ((kp : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) ‚äÜ
            Set.Icc ((kp : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) := by
          intros x hx
          exact ‚ü®le_of_lt hx.2.1, le_of_lt hx.2.2‚ü©
        exact h_union.mono hsub
      ¬∑ -- Strict interior of step: k¬∑őĶ < t < (k+1)¬∑őĶ.
        have hk_lt : (k : ‚ĄĚ) * őĶ < t := lt_of_le_of_ne hk_lo (Ne.symm ht_eq_kőĶ)
        have hk_hi_strict : t < ((k : ‚ĄĚ) + 1) * őĶ :=
          (div_lt_iff‚āÄ hőĶ).mp hk_hi_div
        have hU_nhds :
            Set.Ioo ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) ‚ąą nhds t :=
          Ioo_mem_nhds hk_lt hk_hi_strict
        rw [‚Üź hasDerivWithinAt_inter hU_nhds]
        have hsub : Set.Ici (0 : ‚ĄĚ) ‚ą©
            Set.Ioo ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) ‚äÜ
            Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) := by
          intros x hx
          exact ‚ü®le_of_lt hx.2.1, le_of_lt hx.2.2‚ü©
        exact h_Ik_deriv.mono hsub
    ¬∑ -- t = 0 case.
      push Not at ht_pos
      have ht0 : t = 0 := le_antisymm ht_pos ht
      subst ht0
      -- k = 0.
      have hk0 : k = 0 := by simp [hk_def, Nat.floor_eq_zero, hőĶ]
      -- h_Ik_deriv: HasDerivWithinAt őĪ ... (Icc (0¬∑őĶ) ((0+1)¬∑őĶ)) 0 = Icc 0 őĶ at 0.
      have h_IőĶ_nhd : Set.Iio őĶ ‚ąą nhds (0 : ‚ĄĚ) := Iio_mem_nhds hőĶ
      rw [‚Üź hasDerivWithinAt_inter h_IőĶ_nhd]
      have hsub : Set.Ici (0 : ‚ĄĚ) ‚ą© Set.Iio őĶ ‚äÜ
          Set.Icc ((k : ‚ĄĚ) * őĶ) (((k : ‚ĄĚ) + 1) * őĶ) := by
        intros x hx
        rw [hk0, Nat.cast_zero]
        refine ‚ü®?_, ?_‚ü©
        ¬∑ rw [zero_mul]; exact hx.1
        ¬∑ rw [zero_add, one_mul]; exact le_of_lt hx.2
      exact h_Ik_deriv.mono hsub

/-! ### ¬ß10.108 Time-global existence capstone

Pulls ¬ß10.107 together with `galerkin_forward_step` (¬ß10.103) so that the
caller only needs to supply a ball-invariance hypothesis (parameterised in
the step size `őĶ`) and the initial data. The forward-step existence is
then discharged internally from the uniform-`őĶ` Picard construction
(¬ß10.102). The remaining open premise is `hInv` ‚ÄĒ forward-invariance of
the `R/2`-ball in the phase space `‚Ü•S ‚Üí ‚Ąā`, which is expected to be
discharged unconditionally in a later section via the L¬≤-conservation
identity (¬ß10.97). -/

theorem galerkin_global_existence_from_invariance
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {R : ‚ĄĚ} (hR : 0 < R)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ : ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2)
    (hInv : ‚ąÄ őĶ > 0, ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÄ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c ‚Üí
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚Üí
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2) ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ici (0 : ‚ĄĚ)) t) := by
  obtain ‚ü®őĶ, hőĶ, hStep‚ü© := galerkin_forward_step S hR
  exact galerkin_global_hasDerivWithinAt_conditional S hőĶ hStep (hInv őĶ hőĶ) c‚āÄ hc‚āÄ

/-! ### ¬ß10.109 Sup-norm bound from `L¬≤`-energy conservation

Finite-sum `L¬≤` energy conservation (¬ß10.97, `galerkinEnergyH0_const`)
does not directly preserve the Pi sup-norm on `‚Ü•S ‚Üí ‚Ąā`, but bounds it
up to a factor `‚ąö|S|`. Specifically for any `c : ‚Ü•S ‚Üí ‚Ąā`:

  `‚ÄĖc‚ÄĖ¬≤ ‚Č§ ‚ąĎ_m ‚ÄĖc m‚ÄĖ¬≤ ‚Č§ |S| ¬∑ ‚ÄĖc‚ÄĖ¬≤`,

whence conservation of the middle quantity gives
`‚ÄĖőĪ t‚ÄĖ ‚Č§ ‚ąö|S| ¬∑ ‚ÄĖőĪ 0‚ÄĖ`. This section exposes that bound as a pure
corollary of sum conservation ‚ÄĒ independent of how conservation is
established (in particular it applies to solutions with
`HasDerivWithinAt` on an interval, not just `HasDerivAt` on ‚ĄĚ). -/

lemma pi_sum_sq_le_card_mul_sup_sq
    {őĻ : Type*} [Fintype őĻ] {ő≤ : Type*} [SeminormedAddCommGroup ő≤]
    (c : őĻ ‚Üí ő≤) :
    (‚ąĎ m : őĻ, ‚ÄĖc m‚ÄĖ ^ 2) ‚Č§ (Fintype.card őĻ : ‚ĄĚ) * ‚ÄĖc‚ÄĖ ^ 2 := by
  calc (‚ąĎ m : őĻ, ‚ÄĖc m‚ÄĖ ^ 2)
      ‚Č§ ‚ąĎ _m : őĻ, ‚ÄĖc‚ÄĖ ^ 2 :=
        Finset.sum_le_sum (fun m _ => by
          have : ‚ÄĖc m‚ÄĖ ‚Č§ ‚ÄĖc‚ÄĖ := norm_le_pi_norm c m
          have h0 : 0 ‚Č§ ‚ÄĖc m‚ÄĖ := norm_nonneg _
          nlinarith)
    _ = (Fintype.card őĻ : ‚ĄĚ) * ‚ÄĖc‚ÄĖ ^ 2 := by
        rw [Finset.sum_const, Finset.card_univ]
        ring

lemma pi_term_sq_le_sum_sq
    {őĻ : Type*} [Fintype őĻ] {ő≤ : Type*} [SeminormedAddCommGroup ő≤]
    (c : őĻ ‚Üí ő≤) (m : őĻ) :
    ‚ÄĖc m‚ÄĖ ^ 2 ‚Č§ ‚ąĎ m' : őĻ, ‚ÄĖc m'‚ÄĖ ^ 2 := by
  refine Finset.single_le_sum (f := fun m' => ‚ÄĖc m'‚ÄĖ ^ 2) ?_ (Finset.mem_univ m)
  intros i _; positivity

theorem galerkin_supNorm_le_sqrt_card_of_sum_sq_const
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hE : ‚ąÄ t : ‚ĄĚ, (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ 0 m‚ÄĖ ^ 2)
    (t : ‚ĄĚ) :
    ‚ÄĖőĪ t‚ÄĖ ‚Č§ Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ := by
  have hCard : (Fintype.card (‚Ü•S) : ‚ĄĚ) = (S.card : ‚ĄĚ) := by
    rw [Fintype.card_coe]
  have hRHS_nn : 0 ‚Č§ Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ :=
    mul_nonneg (Real.sqrt_nonneg _) (norm_nonneg _)
  rw [pi_norm_le_iff_of_nonneg hRHS_nn]
  intro m
  -- ‚ÄĖőĪ t m‚ÄĖ¬≤ ‚Č§ ‚ąĎ ‚ÄĖőĪ t m'‚ÄĖ¬≤ = ‚ąĎ ‚ÄĖőĪ 0 m'‚ÄĖ¬≤ ‚Č§ |S| ¬∑ ‚ÄĖőĪ 0‚ÄĖ¬≤.
  have hSq : ‚ÄĖőĪ t m‚ÄĖ ^ 2 ‚Č§ (S.card : ‚ĄĚ) * ‚ÄĖőĪ 0‚ÄĖ ^ 2 := by
    calc ‚ÄĖőĪ t m‚ÄĖ ^ 2
        ‚Č§ ‚ąĎ m' : ‚Ü•S, ‚ÄĖőĪ t m'‚ÄĖ ^ 2 := pi_term_sq_le_sum_sq (őĪ t) m
      _ = ‚ąĎ m' : ‚Ü•S, ‚ÄĖőĪ 0 m'‚ÄĖ ^ 2 := hE t
      _ ‚Č§ (Fintype.card ‚Ü•S : ‚ĄĚ) * ‚ÄĖőĪ 0‚ÄĖ ^ 2 := pi_sum_sq_le_card_mul_sup_sq (őĪ 0)
      _ = (S.card : ‚ĄĚ) * ‚ÄĖőĪ 0‚ÄĖ ^ 2 := by rw [hCard]
  -- Take square roots.
  have hLHS_nn : 0 ‚Č§ ‚ÄĖőĪ t m‚ÄĖ := norm_nonneg _
  have h_target : (‚ÄĖőĪ t m‚ÄĖ) ^ 2 ‚Č§ (Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ) ^ 2 := by
    have hCd_nn : (0 : ‚ĄĚ) ‚Č§ (S.card : ‚ĄĚ) := Nat.cast_nonneg _
    have hSq0 : (Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ) ^ 2
        = (S.card : ‚ĄĚ) * ‚ÄĖőĪ 0‚ÄĖ ^ 2 := by
      rw [mul_pow, Real.sq_sqrt hCd_nn]
    rw [hSq0]; exact hSq
  exact abs_le_of_sq_le_sq' h_target hRHS_nn |>.2

/-! ### ¬ß10.110 Within-interval `L¬≤`-sum conservation

Adapts ¬ß10.97 (`galerkinEnergyH0_const`) from the global
`‚ąÄ t, HasDerivAt őĪ ...` hypothesis to the within-interval
`‚ąÄ t ‚ąą [0, őĶ], HasDerivWithinAt őĪ ...`, using `HasDerivWithinAt.fun_sum`
+ `.norm_sq` and `constant_of_has_deriv_right_zero`. -/

theorem galerkinEnergyH0_hasDerivWithinAt
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)) (s : Set ‚ĄĚ) (ŌĄ : ‚ĄĚ)
    (hőĪ : HasDerivWithinAt őĪ (galerkinVectorField S (őĪ ŌĄ)) s ŌĄ) :
    HasDerivWithinAt (fun t => ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2)
      (‚ąĎ m : ‚Ü•S, 2 *
        (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m))) s ŌĄ := by
  apply HasDerivWithinAt.fun_sum
  intros m _
  have hőĪm : HasDerivWithinAt (fun t => őĪ t m)
      (galerkinVectorField S (őĪ ŌĄ) m) s ŌĄ :=
    (hasDerivWithinAt_pi.mp hőĪ) m
  exact hőĪm.norm_sq

theorem galerkinEnergyH0_hasDerivWithinAt_zero
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)) (s : Set ‚ĄĚ) (ŌĄ : ‚ĄĚ)
    (hőĪ : HasDerivWithinAt őĪ (galerkinVectorField S (őĪ ŌĄ)) s ŌĄ)
    (hRealC : ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n)) :
    HasDerivWithinAt (fun t => ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2) 0 s ŌĄ := by
  have h := galerkinEnergyH0_hasDerivWithinAt őĪ s ŌĄ hőĪ
  have h0 : (‚ąĎ m : ‚Ü•S,
      2 * (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m))) = 0 := by
    have hTerm : ‚ąÄ m : ‚Ü•S,
        2 * (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m))
          = 2 * (star (galerkinExtend S (őĪ ŌĄ) m.val)
                  * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m.val).re := by
      intro m
      rw [inner_real_complex_eq_re_star_mul]
      rw [show őĪ ŌĄ m = galerkinExtend S (őĪ ŌĄ) m.val from
            (galerkinExtend_apply_of_mem _ _ m.property).symm]
      rfl
    rw [Finset.sum_congr rfl (fun m _ => hTerm m)]
    rw [‚Üź Finset.mul_sum]
    rw [show (‚ąĎ m : ‚Ü•S, (star (galerkinExtend S (őĪ ŌĄ) m.val)
                          * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m.val).re)
             = (‚ąĎ m : ‚Ü•S, star (galerkinExtend S (őĪ ŌĄ) m.val)
                           * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m.val).re from
         (Complex.re_sum _ _).symm]
    rw [show (‚ąĎ m : ‚Ü•S, star (galerkinExtend S (őĪ ŌĄ) m.val)
                          * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m.val)
             = ‚ąĎ n ‚ąą S, star (galerkinExtend S (őĪ ŌĄ) n)
                         * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) n from by
         rw [show ((Finset.univ : Finset ‚Ü•S)) = S.attach from Finset.univ_eq_attach S]
         exact Finset.sum_attach S
           (fun n => star (galerkinExtend S (őĪ ŌĄ) n)
                      * galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) n)]
    rw [galerkinRHS_inner_sum_re_eq_zero hS (galerkinExtend S (őĪ ŌĄ))
        (fun n hn => hRealC n hn)
        (fun n hn => galerkinExtend_apply_of_not_mem _ _ hn)]
    ring
  rw [h0] at h; exact h

theorem galerkinEnergyH0_const_on_Icc
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S) (őĶ : ‚ĄĚ)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hRealC : ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    (t : ‚ĄĚ) (ht : t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ) :
    (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ 0 m‚ÄĖ ^ 2 := by
  set E : ‚ĄĚ ‚Üí ‚ĄĚ := fun t => ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2 with hE_def
  have hE_cont : ContinuousOn E (Set.Icc (0 : ‚ĄĚ) őĶ) := fun x hx =>
    (galerkinEnergyH0_hasDerivWithinAt őĪ _ x (hőĪ x hx)).continuousWithinAt
  have hE_right_deriv : ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt E 0 (Set.Ici x) x := by
    intros x hx
    have hx_in : x ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := ‚ü®hx.1, le_of_lt hx.2‚ü©
    have hE_Icc : HasDerivWithinAt E 0 (Set.Icc (0 : ‚ĄĚ) őĶ) x :=
      galerkinEnergyH0_hasDerivWithinAt_zero hS őĪ (Set.Icc 0 őĶ) x (hőĪ x hx_in)
        (hRealC x hx_in)
    have h_ico : HasDerivWithinAt E 0 (Set.Ico x őĶ) x := by
      apply hE_Icc.mono
      intros y hy; exact ‚ü®le_trans hx.1 hy.1, le_of_lt hy.2‚ü©
    have h_inter : Set.Ici x ‚ą© Set.Iio őĶ = Set.Ico x őĶ := by
      ext y; constructor
      ¬∑ intro ‚ü®hy1, hy2‚ü©; exact ‚ü®hy1, hy2‚ü©
      ¬∑ intro ‚ü®hy1, hy2‚ü©; exact ‚ü®hy1, hy2‚ü©
    rw [‚Üź hasDerivWithinAt_inter (Iio_mem_nhds hx.2 : Set.Iio őĶ ‚ąą nhds x), h_inter]
    exact h_ico
  have h_const : ‚ąÄ x ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, E x = E 0 :=
    constant_of_has_deriv_right_zero hE_cont hE_right_deriv
  exact h_const t ht

/-! ### ¬ß10.111 Sup-norm bound on an interval + unconditional `hInv` discharge

Combines ¬ß10.109 (sup-`‚Ąď¬≤` bridge) with ¬ß10.110 (within-interval L¬≤-sum
conservation). The main result
`galerkin_supNorm_bound_on_Icc` gives `‚ÄĖőĪ t‚ÄĖ ‚Č§ ‚ąö|S| ¬∑ ‚ÄĖőĪ 0‚ÄĖ` for any
within-interval Galerkin solution with real-symmetric data. The
convenience wrapper `galerkin_hInv_discharged` repackages this into
the shape consumed by ¬ß10.108's `hInv` hypothesis (with the
`R / (2¬∑‚ąö|S|)` initial-data hypothesis rescaling). -/

theorem galerkin_supNorm_bound_on_Icc
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S) (őĶ : ‚ĄĚ)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hRealC : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    (t : ‚ĄĚ) (ht : t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ) :
    ‚ÄĖőĪ t‚ÄĖ ‚Č§ Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ := by
  have hE : (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ 0 m‚ÄĖ ^ 2 :=
    galerkinEnergyH0_const_on_Icc hS őĶ őĪ hőĪ
      (fun ŌĄ hŌĄ => hRealC ŌĄ hŌĄ.1) t ht
  have hCard : (Fintype.card (‚Ü•S) : ‚ĄĚ) = (S.card : ‚ĄĚ) := by rw [Fintype.card_coe]
  have hRHS_nn : 0 ‚Č§ Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ :=
    mul_nonneg (Real.sqrt_nonneg _) (norm_nonneg _)
  rw [pi_norm_le_iff_of_nonneg hRHS_nn]
  intro m
  have hSq : ‚ÄĖőĪ t m‚ÄĖ ^ 2 ‚Č§ (S.card : ‚ĄĚ) * ‚ÄĖőĪ 0‚ÄĖ ^ 2 := by
    calc ‚ÄĖőĪ t m‚ÄĖ ^ 2
        ‚Č§ ‚ąĎ m' : ‚Ü•S, ‚ÄĖőĪ t m'‚ÄĖ ^ 2 := pi_term_sq_le_sum_sq (őĪ t) m
      _ = ‚ąĎ m' : ‚Ü•S, ‚ÄĖőĪ 0 m'‚ÄĖ ^ 2 := hE
      _ ‚Č§ (Fintype.card ‚Ü•S : ‚ĄĚ) * ‚ÄĖőĪ 0‚ÄĖ ^ 2 := pi_sum_sq_le_card_mul_sup_sq (őĪ 0)
      _ = (S.card : ‚ĄĚ) * ‚ÄĖőĪ 0‚ÄĖ ^ 2 := by rw [hCard]
  have hCd_nn : (0 : ‚ĄĚ) ‚Č§ (S.card : ‚ĄĚ) := Nat.cast_nonneg _
  have hSq0 : (Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ) ^ 2
      = (S.card : ‚ĄĚ) * ‚ÄĖőĪ 0‚ÄĖ ^ 2 := by
    rw [mul_pow, Real.sq_sqrt hCd_nn]
  have h_target : (‚ÄĖőĪ t m‚ÄĖ) ^ 2 ‚Č§ (Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ) ^ 2 := by
    rw [hSq0]; exact hSq
  exact abs_le_of_sq_le_sq' h_target hRHS_nn |>.2

/-- **Unconditional `hInv` discharge (from L¬≤ conservation).** Provided
`S` is nonempty, an initial sup-norm bound `‚ÄĖc‚ÄĖ ‚Č§ R / (2 ¬∑ ‚ąö|S|)` is
enough to guarantee `‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2` throughout any within-interval
real-symmetric Galerkin solution. Matches the shape consumed by
¬ß10.108's `hInv` hypothesis, modulo the `‚ąö|S|` hypothesis-rescaling. -/
theorem galerkin_hInv_discharged
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S) (hS_card : 0 < S.card)
    {R őĶ : ‚ĄĚ}
    (c : ‚Ü•S ‚Üí ‚Ąā) (hc : ‚ÄĖc‚ÄĖ ‚Č§ R / (2 * Real.sqrt ((S.card : ‚ĄĚ))))
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)) (hőĪ0 : őĪ 0 = c)
    (hőĪ : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hRealC : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    (t : ‚ĄĚ) (ht : t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ) :
    ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2 := by
  have h_bound := galerkin_supNorm_bound_on_Icc hS őĶ őĪ hőĪ hRealC t ht
  rw [hőĪ0] at h_bound
  have h_sqrt_pos : 0 < Real.sqrt ((S.card : ‚ĄĚ)) := by
    apply Real.sqrt_pos.mpr
    exact_mod_cast hS_card
  have h_denom_pos : 0 < 2 * Real.sqrt ((S.card : ‚ĄĚ)) := by positivity
  have h_mul : Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖc‚ÄĖ
      ‚Č§ Real.sqrt ((S.card : ‚ĄĚ)) * (R / (2 * Real.sqrt ((S.card : ‚ĄĚ)))) :=
    mul_le_mul_of_nonneg_left hc (Real.sqrt_nonneg _)
  have h_simp : Real.sqrt ((S.card : ‚ĄĚ)) * (R / (2 * Real.sqrt ((S.card : ‚ĄĚ))))
      = R / 2 := by
    field_simp
  linarith [h_mul, h_simp ‚Ėł h_mul, h_bound]

/-! ### ¬ß10.112 Unified global sup-norm bound on `Ici 0`

Extends ¬ß10.111 from the bounded interval `Icc 0 őĶ` to the unbounded
`Ici 0`: for any Galerkin trajectory with real-symmetric data that is
`HasDerivWithinAt` on `Ici 0` at every `t ‚Č• 0`, the sup norm is
bounded uniformly in time by `‚ąö|S| ¬∑ ‚ÄĖőĪ 0‚ÄĖ`.

This is the time-global counterpart of ¬ß10.111. In particular, paired
with ¬ß10.108's conditional time-global existence it gives
**unconditional uniform boundedness** of any real-symmetric
trajectory produced by the construction. -/

theorem galerkin_supNorm_le_sqrt_card_on_Ici
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, 0 ‚Č§ t ‚Üí
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ici (0 : ‚ĄĚ)) t)
    (hRealC : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    (t : ‚ĄĚ) (ht : 0 ‚Č§ t) :
    ‚ÄĖőĪ t‚ÄĖ ‚Č§ Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖőĪ 0‚ÄĖ := by
  -- Apply galerkin_supNorm_bound_on_Icc with őĶ := t + 1.
  set őĶ : ‚ĄĚ := t + 1 with hőĶ_def
  have hőĶ_pos : 0 < őĶ := by linarith
  -- Convert `HasDerivWithinAt őĪ ... (Ici 0) ŌĄ` to `... (Icc 0 őĶ) ŌĄ` for ŌĄ ‚ąą Icc 0 őĶ.
  have hőĪ_Icc : ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ ŌĄ)) (Set.Icc (0 : ‚ĄĚ) őĶ) ŌĄ := by
    intros ŌĄ hŌĄ
    have hŌĄ_ge : 0 ‚Č§ ŌĄ := hŌĄ.1
    have hsub : Set.Icc (0 : ‚ĄĚ) őĶ ‚äÜ Set.Ici (0 : ‚ĄĚ) := fun x hx => hx.1
    exact (hőĪ ŌĄ hŌĄ_ge).mono hsub
  have ht_in : t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := ‚ü®ht, by linarith‚ü©
  exact galerkin_supNorm_bound_on_Icc hS őĶ őĪ hőĪ_Icc hRealC t ht_in

/-! ### ¬ß10.113 Unified time-global capstone ‚ÄĒ real-symmetric class

Packages ¬ß10.108 + ¬ß10.112 into a single existence statement that delivers
`‚ÄĖőĪ t‚ÄĖ ‚Č§ ‚ąö|S| ¬∑ ‚ÄĖc‚āÄ‚ÄĖ` (the sharp `‚Ąď¬≤`-derived bound) for `t ‚Č• 0`, in
addition to the `HasDerivWithinAt` Galerkin-ODE witness.

The theorem still takes two hypotheses the caller must supply:

* `hInv` ‚ÄĒ ¬ß10.108's universal ball-invariance (reshape of `galerkin_hInv_discharged`
  under the subclass `‚ÄĖc‚ÄĖ ‚Č§ R/(2¬∑‚ąö|S|)` suffices to supply it for a chain
  started from real-symmetric `c‚āÄ`; see the CHANGELOG v0.4.19 note).
* `hRealSymPropagates` ‚ÄĒ real-symmetry propagation along the constructed `őĪ`.
  This is the obstacle to a fully unconditional capstone: a within-interval
  adaptation of ¬ß10.100's `hRealC_of_initial_and_bound` (currently stated
  for `HasDerivAt` on ‚ĄĚ) would discharge this internally. -/

theorem galerkin_time_global_real_symmetric
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S) (hS_card : 0 < S.card)
    {R : ‚ĄĚ} (hR : 0 < R)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ : ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2)
    (hInv : ‚ąÄ őĶ > 0, ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÄ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c ‚Üí
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚Üí
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2)
    (hRealSymPropagates : ‚ąÄ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚Üí
      (‚ąÄ t, 0 ‚Č§ t ‚Üí
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ici (0 : ‚ĄĚ)) t) ‚Üí
      ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n)) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2) ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ici (0 : ‚ĄĚ)) t) ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí ‚ÄĖőĪ t‚ÄĖ ‚Č§ Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖc‚āÄ‚ÄĖ) := by
  obtain ‚ü®őĪ, hőĪ0, hőĪ_norm, hőĪ_deriv‚ü© :=
    galerkin_global_existence_from_invariance S hR c‚āÄ hc‚āÄ hInv
  refine ‚ü®őĪ, hőĪ0, hőĪ_norm, hőĪ_deriv, ?_‚ü©
  intros t ht
  have hRealC := hRealSymPropagates őĪ hőĪ0 hőĪ_deriv
  have h_bound := galerkin_supNorm_le_sqrt_card_on_Ici hS őĪ hőĪ_deriv hRealC t ht
  rw [hőĪ0] at h_bound
  exact h_bound

/-! ### ¬ß10.114 Within-interval real-symmetry propagation

Ports ¬ß10.100's `hRealC_of_initial_and_bound` from the global
`‚ąÄ t, HasDerivAt őĪ ... t` hypothesis to the within-interval
`‚ąÄ t ‚Č• 0, HasDerivWithinAt őĪ ... (Ici 0) t`, using
`ODE_solution_unique_of_mem_Icc_right` in place of
`ODE_solution_unique_univ`. Combined with ¬ß10.113, this closes the
remaining `hRealSymPropagates` hypothesis for time-global existence
on the real-symmetric class ‚ÄĒ provided an L‚ąě coefficient bound is
supplied (which ¬ß10.112 produces from real-symmetry itself, but
the circularity is broken by supplying a slack bound, e.g.
`M := ‚ąö|S|¬∑‚ÄĖc‚āÄ‚ÄĖ + 1`). -/

theorem starSwap_hasDerivWithinAt
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)) (s : Set ‚ĄĚ) (ŌĄ : ‚ĄĚ)
    (hőĪ : HasDerivWithinAt őĪ (galerkinVectorField S (őĪ ŌĄ)) s ŌĄ) :
    HasDerivWithinAt (fun t => starSwap hS (őĪ t))
                     (galerkinVectorField S (starSwap hS (őĪ ŌĄ))) s ŌĄ := by
  rw [galerkinVectorField_starSwap hS (őĪ ŌĄ)]
  rw [hasDerivWithinAt_pi]
  intro n
  show HasDerivWithinAt (fun t => star (őĪ t (negSubtype hS n)))
                        (star (galerkinVectorField S (őĪ ŌĄ) (negSubtype hS n))) s ŌĄ
  exact ((hasDerivWithinAt_pi.mp hőĪ) (negSubtype hS n)).star

theorem hRealC_of_initial_and_bound_on_Ici
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, 0 ‚Č§ t ‚Üí
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ici (0 : ‚ĄĚ)) t)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ 0) (-n) = star (galerkinExtend S (őĪ 0) n))
    {M : ‚ĄĚ} (hM : 0 ‚Č§ M)
    (hBound : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ M) :
    ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n ‚ąą S,
      galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n) := by
  classical
  set ő≤ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) := fun ŌĄ => starSwap hS (őĪ ŌĄ) with hő≤_def
  have hő≤ : ‚ąÄ t, 0 ‚Č§ t ‚Üí
      HasDerivWithinAt ő≤ (galerkinVectorField S (ő≤ t)) (Set.Ici (0 : ‚ĄĚ)) t :=
    fun t ht => starSwap_hasDerivWithinAt hS őĪ (Set.Ici 0) t (hőĪ t ht)
  have hőĪő≤_zero : őĪ 0 = ő≤ 0 := by
    funext n
    show őĪ 0 n = star (őĪ 0 (negSubtype hS n))
    have hn_in : n.val ‚ąą S := n.property
    have hnn_in : -n.val ‚ąą S := hS n.val hn_in
    have hRC := hRealC‚āÄ n.val hn_in
    rw [galerkinExtend_apply_of_mem S _ hnn_in,
        galerkinExtend_apply_of_mem S _ hn_in] at hRC
    have hn_eq : (n : ‚Ü•S) = ‚ü®n.val, hn_in‚ü© := by apply Subtype.ext; rfl
    have : őĪ 0 ‚ü®n.val, hn_in‚ü© = star (őĪ 0 ‚ü®-n.val, hnn_in‚ü©) := by
      rw [hRC, star_star]
    rw [hn_eq, this]; rfl
  have hőĪ_ball : ‚ąÄ t, 0 ‚Č§ t ‚Üí őĪ t ‚ąą Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M := by
    intros t ht
    rw [Metric.mem_closedBall, dist_zero_right, pi_norm_le_iff_of_nonneg hM]
    intro n
    have hn_in := n.property
    have := hBound t ht n.val
    rw [galerkinExtend_apply_of_mem S _ hn_in] at this
    exact this
  have hő≤_ball : ‚ąÄ t, 0 ‚Č§ t ‚Üí ő≤ t ‚ąą Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M := by
    intros t ht
    rw [Metric.mem_closedBall, dist_zero_right, pi_norm_le_iff_of_nonneg hM]
    intro n
    rw [hő≤_def, norm_starSwap_apply]
    have hnn_in := (negSubtype hS n).property
    have := hBound t ht (negSubtype hS n).val
    rw [galerkinExtend_apply_of_mem S _ hnn_in] at this
    exact this
  obtain ‚ü®K, hK‚ü© : ‚ąÉ K, LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M) := by
    refine (galerkinVectorField_contDiff S (n := 1)).contDiffOn.exists_lipschitzOnWith
      ?_ (convex_closedBall 0 M) (isCompact_closedBall 0 M)
    decide
  have hőĪ_cont : ‚ąÄ T, ContinuousOn őĪ (Set.Icc (0 : ‚ĄĚ) T) := fun T x hx =>
    (hőĪ x hx.1).continuousWithinAt.mono Set.Icc_subset_Ici_self
  have hő≤_cont : ‚ąÄ T, ContinuousOn ő≤ (Set.Icc (0 : ‚ĄĚ) T) := fun T x hx =>
    (hő≤ x hx.1).continuousWithinAt.mono Set.Icc_subset_Ici_self
  have h_eq_on : ‚ąÄ T, 0 ‚Č§ T ‚Üí Set.EqOn őĪ ő≤ (Set.Icc (0 : ‚ĄĚ) T) := by
    intros T _hT
    apply ODE_solution_unique_of_mem_Icc_right
      (v := fun _ c => galerkinVectorField S c)
      (s := fun _ => Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M)
      (K := K)
    ¬∑ intros _ _; exact hK
    ¬∑ exact hőĪ_cont T
    ¬∑ intros t ht; exact (hőĪ t ht.1).mono (Set.Ici_subset_Ici.mpr ht.1)
    ¬∑ intros t ht; exact hőĪ_ball t ht.1
    ¬∑ exact hő≤_cont T
    ¬∑ intros t ht; exact (hő≤ t ht.1).mono (Set.Ici_subset_Ici.mpr ht.1)
    ¬∑ intros t ht; exact hő≤_ball t ht.1
    ¬∑ exact hőĪő≤_zero
  intros ŌĄ hŌĄ n hn
  have heq : őĪ ŌĄ = ő≤ ŌĄ := h_eq_on (ŌĄ + 1) (by linarith) ‚ü®hŌĄ, by linarith‚ü©
  have hnn_in : -n ‚ąą S := hS n hn
  rw [galerkinExtend_apply_of_mem S _ hnn_in,
      galerkinExtend_apply_of_mem S _ hn]
  have hő≤app : ő≤ ŌĄ ‚ü®-n, hnn_in‚ü© = star (őĪ ŌĄ ‚ü®n, hn‚ü©) := by
    rw [hő≤_def]
    show star (őĪ ŌĄ (negSubtype hS ‚ü®-n, hnn_in‚ü©)) = star (őĪ ŌĄ ‚ü®n, hn‚ü©)
    have hsub : negSubtype hS ‚ü®-n, hnn_in‚ü© = ‚ü®n, hn‚ü© := by
      apply Subtype.ext; show -(-n) = n; ring
    rw [hsub]
  calc őĪ ŌĄ ‚ü®-n, hnn_in‚ü©
      = ő≤ ŌĄ ‚ü®-n, hnn_in‚ü© := by rw [heq]
    _ = star (őĪ ŌĄ ‚ü®n, hn‚ü©) := hő≤app

/-! ### ¬ß10.115 Time-global capstone with real-symmetric initial data

Wires ¬ß10.114 into ¬ß10.113 to discharge the `hRealSymPropagates`
hypothesis internally. The only remaining open hypothesis is `hInv`
(universal ball-invariance over the `R/2`-ball). Real-symmetry of
the initial coefficient vector `c‚āÄ` plus the L‚ąě bound `‚ÄĖőĪ ŌĄ‚ÄĖ ‚Č§ R/2`
(from `hInv` via ¬ß10.108) together feed
`hRealC_of_initial_and_bound_on_Ici` with `M := R/2`, producing
within-interval real-symmetry propagation of the constructed `őĪ`. -/

theorem galerkin_time_global_real_symmetric_initial
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S) (hS_card : 0 < S.card)
    {R : ‚ĄĚ} (hR : 0 < R)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ : ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2)
    (hRealSym‚āÄ : ‚ąÄ n ‚ąą S,
      galerkinExtend S c‚āÄ (-n) = star (galerkinExtend S c‚āÄ n))
    (hInv : ‚ąÄ őĶ > 0, ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚ÄĖ ‚Č§ R / 2 ‚Üí
      ‚ąÄ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c ‚Üí
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚Üí
        ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí ‚ÄĖőĪ t‚ÄĖ ‚Č§ R / 2) ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ici (0 : ‚ĄĚ)) t) ‚ąß
      (‚ąÄ t, 0 ‚Č§ t ‚Üí ‚ÄĖőĪ t‚ÄĖ ‚Č§ Real.sqrt ((S.card : ‚ĄĚ)) * ‚ÄĖc‚āÄ‚ÄĖ) := by
  apply galerkin_time_global_real_symmetric S hS hS_card hR c‚āÄ hc‚āÄ hInv
  intros őĪ hőĪ0 hőĪ_deriv
  have hR2 : 0 ‚Č§ R / 2 := le_of_lt (half_pos hR)
  -- Re-derive the L‚ąě bound from `hInv` directly (since ¬ß10.113 hands us only
  -- `hőĪ0` and `hőĪ_deriv`). For each `ŌĄ ‚Č• 0`, invoke `hInv` on `[0, ŌĄ + 1]`.
  have hőĪ_norm : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ÄĖőĪ ŌĄ‚ÄĖ ‚Č§ R / 2 := by
    intros ŌĄ hŌĄ
    set őĶT : ‚ĄĚ := ŌĄ + 1 with hőĶT_def
    have hőĶT_pos : 0 < őĶT := by linarith
    have hőĪ_Icc : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶT,
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶT) t := by
      intros t ht
      have ht_ge : 0 ‚Č§ t := ht.1
      have hsub : Set.Icc (0 : ‚ĄĚ) őĶT ‚äÜ Set.Ici (0 : ‚ĄĚ) := fun x hx => hx.1
      exact (hőĪ_deriv t ht_ge).mono hsub
    have hŌĄ_in : ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶT := ‚ü®hŌĄ, by linarith‚ü©
    exact hInv őĶT hőĶT_pos c‚āÄ hc‚āÄ őĪ hőĪ0 hőĪ_Icc ŌĄ hŌĄ_in
  -- L‚ąě coefficient bound in the shape expected by ¬ß10.114.
  have hBound : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ R / 2 := by
    intros ŌĄ hŌĄ n
    by_cases hn : n ‚ąą S
    ¬∑ rw [galerkinExtend_apply_of_mem S _ hn]
      exact (norm_le_pi_norm (őĪ ŌĄ) ‚ü®n, hn‚ü©).trans (hőĪ_norm ŌĄ hŌĄ)
    ¬∑ rw [galerkinExtend_apply_of_not_mem S _ hn, norm_zero]; exact hR2
  -- Real-symmetry at ŌĄ = 0, via őĪ 0 = c‚āÄ.
  have hRealC‚āÄ_őĪ : ‚ąÄ n ‚ąą S,
      galerkinExtend S (őĪ 0) (-n) = star (galerkinExtend S (őĪ 0) n) := by
    intros n hn; rw [hőĪ0]; exact hRealSym‚āÄ n hn
  -- Apply ¬ß10.114 to propagate real-symmetry to every ŌĄ ‚Č• 0.
  exact hRealC_of_initial_and_bound_on_Ici hS őĪ hőĪ_deriv hRealC‚āÄ_őĪ hR2 hBound

/-! ### ¬ß10.116.A Local Picard-Lindel√∂f wrapper with ball-containment

Variant of `galerkin_local_exists_given_bounds` that additionally
exposes `őĪ t ‚ąą closedBall c‚āÄ a` for all `t : ‚ĄĚ`. Mathlib's
`IsPicardLindelof.exists_eq_forall_mem_Icc_hasDerivWithinAt‚āÄ`
proves this containment internally (via
`ODE.FunSpace.compProj_mem_closedBall`) but does not expose it in the
return signature; we replay the proof here to keep the containment
witness. -/

open ODE in
theorem galerkin_local_exists_with_ball_containment
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) {a L K : NNReal} {őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ)
    (hLip : LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall c‚āÄ (a : ‚ĄĚ)))
    (hBound : ‚ąÄ c ‚ąą Metric.closedBall c‚āÄ (a : ‚ĄĚ),
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ L)
    (hTime : (L : ‚ĄĚ) * őĶ ‚Č§ (a : ‚ĄĚ)) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t ‚ąą Set.Icc (-őĶ) őĶ,
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (-őĶ) őĶ) t) ‚ąß
      (‚ąÄ t : ‚ĄĚ, őĪ t ‚ąą Metric.closedBall c‚āÄ (a : ‚ĄĚ)) := by
  classical
  set f : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) ‚Üí (‚Ü•S ‚Üí ‚Ąā) := fun _ => galerkinVectorField S with hf_def
  have ht_in : (0 : ‚ĄĚ) ‚ąą Set.Icc (-őĶ) őĶ := ‚ü®by linarith, by linarith‚ü©
  set t‚āÄ : Set.Icc (-őĶ) őĶ := ‚ü®0, ht_in‚ü© with ht‚āÄ_def
  have hPL : IsPicardLindelof f t‚āÄ c‚āÄ a 0 L K := {
    lipschitzOnWith := fun _ _ => hLip
    continuousOn := fun _ _ => continuousOn_const
    norm_le := fun _ _ _ hx => hBound _ hx
    mul_max_le := by
      show (L : ‚ĄĚ) * max (őĶ - (0 : ‚ĄĚ)) ((0 : ‚ĄĚ) - (-őĶ)) ‚Č§ (a : ‚ĄĚ) - 0
      rw [sub_zero, zero_sub, neg_neg, max_self, sub_zero]
      exact hTime
  }
  obtain ‚ü®őĪ, hőĪ‚ü© := FunSpace.exists_isFixedPt_next hPL (Metric.mem_closedBall_self le_rfl)
  refine ‚ü®őĪ.compProj, ?_, ?_, ?_‚ü©
  ¬∑ show őĪ.compProj (t‚āÄ : ‚ĄĚ) = c‚āÄ
    rw [FunSpace.compProj_val, ‚Üź hőĪ, FunSpace.next_apply‚āÄ]
  ¬∑ intros t ht
    apply hasDerivWithinAt_picard_Icc t‚āÄ.2 hPL.continuousOn_uncurry
      őĪ.continuous_compProj.continuousOn
      (fun _ _ => őĪ.compProj_mem_closedBall hPL.mul_max_le) c‚āÄ ht |>.congr_of_mem _ ht
    intros t' ht'
    nth_rw 1 [‚Üź hőĪ]
    rw [FunSpace.compProj_of_mem ht', FunSpace.next_apply]
  ¬∑ intro t
    exact őĪ.compProj_mem_closedBall hPL.mul_max_le

/-! ### ¬ß10.116.B Within-`Icc` variant of real-symmetry propagation

Ports `hRealC_of_initial_and_bound_on_Ici` (¬ß10.114) from `Ici 0` to
`Icc 0 őĶ`. Same proof strategy: `starSwap`-image has identical
initial condition and same ODE, so by `ODE_solution_unique_of_mem_Icc_right`
they coincide on `Icc 0 őĶ`. -/

theorem hRealC_of_initial_and_bound_on_Icc
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    (őĶ : ‚ĄĚ) (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ 0) (-n) = star (galerkinExtend S (őĪ 0) n))
    {M : ‚ĄĚ} (hM : 0 ‚Č§ M)
    (hBound : ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ M) :
    ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n ‚ąą S,
      galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n) := by
  classical
  set ő≤ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) := fun ŌĄ => starSwap hS (őĪ ŌĄ) with hő≤_def
  have hő≤ : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt ő≤ (galerkinVectorField S (ő≤ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t :=
    fun t ht => starSwap_hasDerivWithinAt hS őĪ (Set.Icc 0 őĶ) t (hőĪ t ht)
  have hőĪő≤_zero : őĪ 0 = ő≤ 0 := by
    funext n
    show őĪ 0 n = star (őĪ 0 (negSubtype hS n))
    have hn_in : n.val ‚ąą S := n.property
    have hnn_in : -n.val ‚ąą S := hS n.val hn_in
    have hRC := hRealC‚āÄ n.val hn_in
    rw [galerkinExtend_apply_of_mem S _ hnn_in,
        galerkinExtend_apply_of_mem S _ hn_in] at hRC
    have hn_eq : (n : ‚Ü•S) = ‚ü®n.val, hn_in‚ü© := by apply Subtype.ext; rfl
    have : őĪ 0 ‚ü®n.val, hn_in‚ü© = star (őĪ 0 ‚ü®-n.val, hnn_in‚ü©) := by
      rw [hRC, star_star]
    rw [hn_eq, this]; rfl
  have hőĪ_ball : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      őĪ t ‚ąą Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M := by
    intros t ht
    rw [Metric.mem_closedBall, dist_zero_right, pi_norm_le_iff_of_nonneg hM]
    intro n
    have hn_in := n.property
    have := hBound t ht n.val
    rw [galerkinExtend_apply_of_mem S _ hn_in] at this
    exact this
  have hő≤_ball : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      ő≤ t ‚ąą Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M := by
    intros t ht
    rw [Metric.mem_closedBall, dist_zero_right, pi_norm_le_iff_of_nonneg hM]
    intro n
    rw [hő≤_def, norm_starSwap_apply]
    have hnn_in := (negSubtype hS n).property
    have := hBound t ht (negSubtype hS n).val
    rw [galerkinExtend_apply_of_mem S _ hnn_in] at this
    exact this
  obtain ‚ü®K, hK‚ü© : ‚ąÉ K, LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M) := by
    refine (galerkinVectorField_contDiff S (n := 1)).contDiffOn.exists_lipschitzOnWith
      ?_ (convex_closedBall 0 M) (isCompact_closedBall 0 M)
    decide
  have hőĪ_cont : ContinuousOn őĪ (Set.Icc (0 : ‚ĄĚ) őĶ) := fun x hx =>
    (hőĪ x hx).continuousWithinAt
  have hő≤_cont : ContinuousOn ő≤ (Set.Icc (0 : ‚ĄĚ) őĶ) := fun x hx =>
    (hő≤ x hx).continuousWithinAt
  -- Convert within-Icc derivatives to within-Ici via open-set intersection.
  have hőĪ_right : ‚ąÄ t ‚ąą Set.Ico (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ici t) t := by
    intros t ht
    have ht_icc : t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := ‚ü®ht.1, le_of_lt ht.2‚ü©
    have h_ico : HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Ico t őĶ) t := by
      apply (hőĪ t ht_icc).mono
      intros y hy; exact ‚ü®le_trans ht.1 hy.1, le_of_lt hy.2‚ü©
    have h_inter : Set.Ici t ‚ą© Set.Iio őĶ = Set.Ico t őĶ := by
      ext y; exact ‚ü®fun ‚ü®a, b‚ü© => ‚ü®a, b‚ü©, fun ‚ü®a, b‚ü© => ‚ü®a, b‚ü©‚ü©
    rw [‚Üź hasDerivWithinAt_inter (Iio_mem_nhds ht.2 : Set.Iio őĶ ‚ąą nhds t), h_inter]
    exact h_ico
  have hő≤_right : ‚ąÄ t ‚ąą Set.Ico (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt ő≤ (galerkinVectorField S (ő≤ t)) (Set.Ici t) t := by
    intros t ht
    have ht_icc : t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := ‚ü®ht.1, le_of_lt ht.2‚ü©
    have h_ico : HasDerivWithinAt ő≤ (galerkinVectorField S (ő≤ t)) (Set.Ico t őĶ) t := by
      apply (hő≤ t ht_icc).mono
      intros y hy; exact ‚ü®le_trans ht.1 hy.1, le_of_lt hy.2‚ü©
    have h_inter : Set.Ici t ‚ą© Set.Iio őĶ = Set.Ico t őĶ := by
      ext y; exact ‚ü®fun ‚ü®a, b‚ü© => ‚ü®a, b‚ü©, fun ‚ü®a, b‚ü© => ‚ü®a, b‚ü©‚ü©
    rw [‚Üź hasDerivWithinAt_inter (Iio_mem_nhds ht.2 : Set.Iio őĶ ‚ąą nhds t), h_inter]
    exact h_ico
  have h_eq_on : Set.EqOn őĪ ő≤ (Set.Icc (0 : ‚ĄĚ) őĶ) := by
    apply ODE_solution_unique_of_mem_Icc_right
      (v := fun _ c => galerkinVectorField S c)
      (s := fun _ => Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) M)
      (K := K)
    ¬∑ intros _ _; exact hK
    ¬∑ exact hőĪ_cont
    ¬∑ exact hőĪ_right
    ¬∑ intros t ht; exact hőĪ_ball t ‚ü®ht.1, le_of_lt ht.2‚ü©
    ¬∑ exact hő≤_cont
    ¬∑ exact hő≤_right
    ¬∑ intros t ht; exact hő≤_ball t ‚ü®ht.1, le_of_lt ht.2‚ü©
    ¬∑ exact hőĪő≤_zero
  intros ŌĄ hŌĄ n hn
  have heq : őĪ ŌĄ = ő≤ ŌĄ := h_eq_on hŌĄ
  have hnn_in : -n ‚ąą S := hS n hn
  rw [galerkinExtend_apply_of_mem S _ hnn_in,
      galerkinExtend_apply_of_mem S _ hn]
  have hő≤app : ő≤ ŌĄ ‚ü®-n, hnn_in‚ü© = star (őĪ ŌĄ ‚ü®n, hn‚ü©) := by
    rw [hő≤_def]
    show star (őĪ ŌĄ (negSubtype hS ‚ü®-n, hnn_in‚ü©)) = star (őĪ ŌĄ ‚ü®n, hn‚ü©)
    have hsub : negSubtype hS ‚ü®-n, hnn_in‚ü© = ‚ü®n, hn‚ü© := by
      apply Subtype.ext; show -(-n) = n; ring
    rw [hsub]
  calc őĪ ŌĄ ‚ü®-n, hnn_in‚ü©
      = ő≤ ŌĄ ‚ü®-n, hnn_in‚ü© := by rw [heq]
    _ = star (őĪ ŌĄ ‚ü®n, hn‚ü©) := hő≤app

/-! ### ¬ß10.116.C Uniform-`őĶ` forward step with ball-containment

Parallel to `galerkin_forward_step` (¬ß10.103) but delivering the
`őĪ t ‚ąą closedBall c‚āÄ (R/2)` containment from ¬ß10.116.A, needed for
the L‚ąě coefficient bound when applying ¬ß10.116.B. -/

theorem galerkin_forward_step_with_ball
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {R : ‚ĄĚ} (hR : 0 < R) :
    ‚ąÉ őĶ : ‚ĄĚ, 0 < őĶ ‚ąß
      ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
        ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
          (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
            HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚ąß
          (‚ąÄ t : ‚ĄĚ, őĪ t ‚ąą Metric.closedBall c‚āÄ (R / 2)) := by
  classical
  obtain ‚ü®K, hK‚ü© : ‚ąÉ K, LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) R) := by
    refine (galerkinVectorField_contDiff S (n := 1)).contDiffOn.exists_lipschitzOnWith
      ?_ (convex_closedBall 0 R) (isCompact_closedBall 0 R)
    decide
  obtain ‚ü®C, hC_nn, hC_bound‚ü© := galerkinVectorField_quadratic_bound S
  set L_real : ‚ĄĚ := C * R ^ 2 with hL_def
  have hL_nn : 0 ‚Č§ L_real := by positivity
  set L : NNReal := ‚ü®L_real, hL_nn‚ü© with hL_NN
  have hL_coe : (L : ‚ĄĚ) = L_real := rfl
  have hBound_ball : ‚ąÄ c ‚ąą Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) R,
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ (L : ‚ĄĚ) := by
    intros c hc
    rw [Metric.mem_closedBall, dist_zero_right] at hc
    calc ‚ÄĖgalerkinVectorField S c‚ÄĖ
        ‚Č§ C * ‚ÄĖc‚ÄĖ ^ 2 := hC_bound c
      _ ‚Č§ C * R ^ 2 := by
          apply mul_le_mul_of_nonneg_left (pow_le_pow_left‚āÄ (norm_nonneg _) hc 2) hC_nn
      _ = L_real := rfl
  set őĶ : ‚ĄĚ := (R / 2) / ((L : ‚ĄĚ) + 1) with hőĶ_def
  have hLp1_pos : 0 < (L : ‚ĄĚ) + 1 := by rw [hL_coe]; linarith
  have hR2_pos : 0 < R / 2 := by linarith
  have hőĶ_pos : 0 < őĶ := div_pos hR2_pos hLp1_pos
  refine ‚ü®őĶ, hőĶ_pos, ?_‚ü©
  intro c‚āÄ hc‚āÄ_norm
  have h_ball_sub : Metric.closedBall c‚āÄ (R / 2) ‚äÜ Metric.closedBall (0 : ‚Ü•S ‚Üí ‚Ąā) R := by
    intros x hx
    rw [Metric.mem_closedBall, dist_zero_right]
    rw [Metric.mem_closedBall] at hx
    calc ‚ÄĖx‚ÄĖ = ‚ÄĖ(x - c‚āÄ) + c‚āÄ‚ÄĖ := by rw [sub_add_cancel]
      _ ‚Č§ ‚ÄĖx - c‚āÄ‚ÄĖ + ‚ÄĖc‚āÄ‚ÄĖ := norm_add_le _ _
      _ = dist x c‚āÄ + ‚ÄĖc‚āÄ‚ÄĖ := by rw [dist_eq_norm]
      _ ‚Č§ R / 2 + R / 2 := add_le_add hx hc‚āÄ_norm
      _ = R := by ring
  have hLip_small : LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall c‚āÄ (R / 2)) := hK.mono h_ball_sub
  have hBound_small : ‚ąÄ c ‚ąą Metric.closedBall c‚āÄ (R / 2),
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ (L : ‚ĄĚ) :=
    fun c hc => hBound_ball c (h_ball_sub hc)
  set a : NNReal := ‚ü®R / 2, hR2_pos.le‚ü© with ha_def
  have ha_coe : (a : ‚ĄĚ) = R / 2 := rfl
  have hTime : (L : ‚ĄĚ) * őĶ ‚Č§ (a : ‚ĄĚ) := by
    have h1 : (L : ‚ĄĚ) * őĶ ‚Č§ ((L : ‚ĄĚ) + 1) * őĶ :=
      mul_le_mul_of_nonneg_right (by linarith) hőĶ_pos.le
    have h2 : ((L : ‚ĄĚ) + 1) * őĶ = R / 2 := by
      rw [hőĶ_def]; field_simp
    rw [ha_coe]; linarith
  have hLip_small' : LipschitzOnWith K (galerkinVectorField S)
      (Metric.closedBall c‚āÄ (a : ‚ĄĚ)) := by rw [ha_coe]; exact hLip_small
  have hBound_small' : ‚ąÄ c ‚ąą Metric.closedBall c‚āÄ (a : ‚ĄĚ),
      ‚ÄĖgalerkinVectorField S c‚ÄĖ ‚Č§ (L : ‚ĄĚ) := by rw [ha_coe]; exact hBound_small
  obtain ‚ü®őĪ, hőĪ0, hőĪ_deriv, hőĪ_ball‚ü© :=
    galerkin_local_exists_with_ball_containment S c‚āÄ hőĶ_pos hLip_small' hBound_small' hTime
  refine ‚ü®őĪ, hőĪ0, ?_, ?_‚ü©
  ¬∑ intros t ht
    have ht_big : t ‚ąą Set.Icc (-őĶ) őĶ := ‚ü®le_trans (neg_nonpos_of_nonneg hőĶ_pos.le) ht.1, ht.2‚ü©
    exact (hőĪ_deriv t ht_big).mono (Set.Icc_subset_Icc (by linarith) le_rfl)
  ¬∑ intros t
    have := hőĪ_ball t
    rw [ha_coe] at this
    exact this

/-! ### ¬ß10.116.D Real-symmetric forward step

Combines ¬ß10.116.B (within-Icc real-symmetry propagation) with ¬ß10.116.C
(ball-containment forward step). Given real-symmetric `c‚āÄ`, the forward
Picard step produces `őĪ` with `őĪ(ŌĄ)` real-symmetric for every
`ŌĄ ‚ąą Icc 0 őĶ`. The L‚ąě bound `M := R` feeding ¬ß10.116.B comes from the
ball-containment `‚ÄĖőĪ ŌĄ - c‚āÄ‚ÄĖ ‚Č§ R/2` plus `‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R/2`, giving `‚ÄĖőĪ ŌĄ‚ÄĖ ‚Č§ R`. -/

theorem galerkin_realSym_forward_step
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {R : ‚ĄĚ} (hR : 0 < R) :
    ‚ąÉ őĶ : ‚ĄĚ, 0 < őĶ ‚ąß
      ‚ąÄ c‚āÄ : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 ‚Üí
        (‚ąÄ n ‚ąą S, galerkinExtend S c‚āÄ (-n) = star (galerkinExtend S c‚āÄ n)) ‚Üí
        ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
          (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
            HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚ąß
          (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n ‚ąą S,
            galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n)) := by
  obtain ‚ü®őĶ, hőĶ_pos, hStep‚ü© := galerkin_forward_step_with_ball S hR
  refine ‚ü®őĶ, hőĶ_pos, ?_‚ü©
  intros c‚āÄ hc‚āÄ hRealC‚āÄ
  obtain ‚ü®őĪ, hőĪ0, hőĪ_deriv, hőĪ_ball‚ü© := hStep c‚āÄ hc‚āÄ
  refine ‚ü®őĪ, hőĪ0, hőĪ_deriv, ?_‚ü©
  have hR_nn : 0 ‚Č§ R := le_of_lt hR
  have hBound : ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ R := by
    intros ŌĄ _hŌĄ n
    by_cases hn : n ‚ąą S
    ¬∑ rw [galerkinExtend_apply_of_mem S _ hn]
      have hdist : dist (őĪ ŌĄ) c‚āÄ ‚Č§ R / 2 := (Metric.mem_closedBall.mp (hőĪ_ball ŌĄ))
      have hdiff : ‚ÄĖőĪ ŌĄ - c‚āÄ‚ÄĖ ‚Č§ R / 2 := by rw [‚Üź dist_eq_norm]; exact hdist
      have hnorm_t : ‚ÄĖőĪ ŌĄ‚ÄĖ ‚Č§ R := by
        calc ‚ÄĖőĪ ŌĄ‚ÄĖ = ‚ÄĖ(őĪ ŌĄ - c‚āÄ) + c‚āÄ‚ÄĖ := by rw [sub_add_cancel]
          _ ‚Č§ ‚ÄĖőĪ ŌĄ - c‚āÄ‚ÄĖ + ‚ÄĖc‚āÄ‚ÄĖ := norm_add_le _ _
          _ ‚Č§ R / 2 + R / 2 := add_le_add hdiff hc‚āÄ
          _ = R := by ring
      exact (norm_le_pi_norm (őĪ ŌĄ) ‚ü®n, hn‚ü©).trans hnorm_t
    ¬∑ rw [galerkinExtend_apply_of_not_mem S _ hn, norm_zero]
      exact hR_nn
  have hRealC‚āÄ_őĪ : ‚ąÄ n ‚ąą S,
      galerkinExtend S (őĪ 0) (-n) = star (galerkinExtend S (őĪ 0) n) := by
    intros n hn; rw [hőĪ0]; exact hRealC‚āÄ n hn
  exact hRealC_of_initial_and_bound_on_Icc hS őĶ őĪ hőĪ_deriv hRealC‚āÄ_őĪ hR_nn hBound

/-! ### ¬ß10.116.E Sharp ‚Ąď¬≤‚Üípi sup-norm bound on an interval

For a real-symmetric Galerkin trajectory on `[0, őĶ]`, ‚Ąď¬≤ conservation
(¬ß10.110) gives `‚ÄĖőĪ t‚ÄĖ_ŌÄ ‚Č§ ‚ąö(‚ąĎ ‚ÄĖőĪ 0 m‚ÄĖ¬≤)`. This is sharper than
¬ß10.111's `‚ÄĖőĪ t‚ÄĖ_ŌÄ ‚Č§ ‚ąö|S|¬∑‚ÄĖőĪ 0‚ÄĖ_ŌÄ` and is the invariant that
propagates across Picard chain steps: if `c_k := őĪ_{k-1}(őĶ)`, then
`‚ąĎ ‚ÄĖc_k m‚ÄĖ¬≤ = ‚ąĎ ‚ÄĖc_{k-1} m‚ÄĖ¬≤` by ‚Ąď¬≤ conservation, so the bound
is preserved exactly. -/

theorem galerkin_piNorm_le_‚Ąď2_on_Icc
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S) (őĶ : ‚ĄĚ)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t)
    (hRealC : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n))
    (t : ‚ĄĚ) (ht : t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ) :
    ‚ÄĖőĪ t‚ÄĖ ‚Č§ Real.sqrt (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ 0 m‚ÄĖ ^ 2) := by
  have hE : (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ t m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ 0 m‚ÄĖ ^ 2 :=
    galerkinEnergyH0_const_on_Icc hS őĶ őĪ hőĪ
      (fun ŌĄ hŌĄ => hRealC ŌĄ hŌĄ.1) t ht
  have hRHS_nn : 0 ‚Č§ Real.sqrt (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ 0 m‚ÄĖ ^ 2) := Real.sqrt_nonneg _
  rw [pi_norm_le_iff_of_nonneg hRHS_nn]
  intro m
  have hSq : ‚ÄĖőĪ t m‚ÄĖ ^ 2 ‚Č§ ‚ąĎ m' : ‚Ü•S, ‚ÄĖőĪ 0 m'‚ÄĖ ^ 2 := by
    calc ‚ÄĖőĪ t m‚ÄĖ ^ 2 ‚Č§ ‚ąĎ m' : ‚Ü•S, ‚ÄĖőĪ t m'‚ÄĖ ^ 2 := pi_term_sq_le_sum_sq (őĪ t) m
      _ = ‚ąĎ m' : ‚Ü•S, ‚ÄĖőĪ 0 m'‚ÄĖ ^ 2 := hE
  have h_nn : (0 : ‚ĄĚ) ‚Č§ ‚ÄĖőĪ t m‚ÄĖ := norm_nonneg _
  have h_sqrt := Real.sqrt_le_sqrt hSq
  rw [Real.sqrt_sq h_nn] at h_sqrt
  exact h_sqrt

/-! ### ¬ß10.116.F Real-symmetric chain n-step

Mirror of `galerkin_chain_n_step` (¬ß10.104) with real-symmetry and
‚Ąď¬≤-sum conservation tracked through the chain. The ‚Ąď¬≤-sum invariant
`‚ąĎ ‚ÄĖőĪ ŌĄ m‚ÄĖ¬≤ ‚Č§ (R/2)¬≤` is preserved exactly across each step by
`galerkinEnergyH0_const_on_Icc` (¬ß10.110); the pi-norm bound
`‚ÄĖőĪ ŌĄ‚ÄĖ_ŌÄ ‚Č§ R/2` follows pointwise from
`‚ÄĖőĪ ŌĄ m‚ÄĖ¬≤ ‚Č§ ‚ąĎ ‚ÄĖőĪ ŌĄ m'‚ÄĖ¬≤ ‚Č§ (R/2)¬≤`. No external `hInv` required ‚ÄĒ
the invariant is carried in the inductive hypothesis. -/

/-- Helper: ‚Ąď¬≤-sum bound implies pi-norm bound. -/
private lemma piNorm_le_of_sum_sq_le_sq
    {őĻ : Type*} [Fintype őĻ]
    {E : Type*} [NormedAddCommGroup E]
    (c : őĻ ‚Üí E) {B : ‚ĄĚ} (hB : 0 ‚Č§ B)
    (h : (‚ąĎ i : őĻ, ‚ÄĖc i‚ÄĖ ^ 2) ‚Č§ B ^ 2) :
    ‚ÄĖc‚ÄĖ ‚Č§ B := by
  rw [pi_norm_le_iff_of_nonneg hB]
  intro i
  have hSq : ‚ÄĖc i‚ÄĖ ^ 2 ‚Č§ B ^ 2 := (pi_term_sq_le_sum_sq c i).trans h
  have h_nn : (0 : ‚ĄĚ) ‚Č§ ‚ÄĖc i‚ÄĖ := norm_nonneg _
  have h_sqrt := Real.sqrt_le_sqrt hSq
  rwa [Real.sqrt_sq h_nn, Real.sqrt_sq hB] at h_sqrt

theorem galerkin_realSym_chain_n_step
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {R őĶ : ‚ĄĚ} (hR : 0 ‚Č§ R) (hőĶ : 0 < őĶ)
    (hStep : ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚ÄĖ ‚Č§ R / 2 ‚Üí
      (‚ąÄ n ‚ąą S, galerkinExtend S c (-n) = star (galerkinExtend S c n)) ‚Üí
      ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c ‚ąß
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚ąß
        (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n ‚ąą S,
          galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n)))
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ_l2 : (‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) ‚Č§ (R / 2) ^ 2)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S,
      galerkinExtend S c‚āÄ (-n) = star (galerkinExtend S c‚āÄ n))
    (n : ‚Ąē) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ),
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t))
          (Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ)) t) ‚ąß
      (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ), ‚ąÄ m ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-m) = star (galerkinExtend S (őĪ ŌĄ) m)) ‚ąß
      (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ),
        (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ ŌĄ m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) := by
  have h_R2_nn : (0 : ‚ĄĚ) ‚Č§ R / 2 := by linarith
  have hc‚āÄ_bound : ‚ÄĖc‚āÄ‚ÄĖ ‚Č§ R / 2 := piNorm_le_of_sum_sq_le_sq c‚āÄ h_R2_nn hc‚āÄ_l2
  induction n with
  | zero =>
    obtain ‚ü®őĪ‚āÄ, hőĪ‚āÄ0, hőĪ‚āÄD, hőĪ‚āÄR‚ü© := hStep c‚āÄ hc‚āÄ_bound hRealC‚āÄ
    refine ‚ü®őĪ‚āÄ, hőĪ‚āÄ0, ?_, ?_, ?_‚ü©
    ¬∑ intros t ht
      have h_zero : ((0 : ‚Ąē) : ‚ĄĚ) * őĶ = 0 := by simp
      rw [h_zero] at ht
      have h0 : t = 0 := le_antisymm ht.2 ht.1
      subst h0; rw [h_zero]
      have h_sub : Set.Icc (0 : ‚ĄĚ) 0 ‚äÜ Set.Icc (0 : ‚ĄĚ) őĶ :=
        Set.Icc_subset_Icc le_rfl hőĶ.le
      exact (hőĪ‚āÄD 0 ‚ü®le_rfl, hőĶ.le‚ü©).mono h_sub
    ¬∑ intros t ht m hm
      have h_zero : ((0 : ‚Ąē) : ‚ĄĚ) * őĶ = 0 := by simp
      rw [h_zero] at ht
      have h0 : t = 0 := le_antisymm ht.2 ht.1
      subst h0; rw [hőĪ‚āÄ0]; exact hRealC‚āÄ m hm
    ¬∑ intros t ht
      have h_zero : ((0 : ‚Ąē) : ‚ĄĚ) * őĶ = 0 := by simp
      rw [h_zero] at ht
      have h0 : t = 0 := le_antisymm ht.2 ht.1
      subst h0; rw [hőĪ‚āÄ0]
  | succ n ih =>
    obtain ‚ü®őĪ_n, hőĪ_n0, hőĪ_nD, hőĪ_nR, hőĪ_nE‚ü© := ih
    set Tn : ‚ĄĚ := (n : ‚ĄĚ) * őĶ with hTn_def
    set Tn1 : ‚ĄĚ := ((n + 1 : ‚Ąē) : ‚ĄĚ) * őĶ with hTn1_def
    have hTn_nn : 0 ‚Č§ Tn := mul_nonneg (Nat.cast_nonneg _) hőĶ.le
    have hTn_succ : Tn1 = Tn + őĶ := by
      show ((n + 1 : ‚Ąē) : ‚ĄĚ) * őĶ = (n : ‚ĄĚ) * őĶ + őĶ; push_cast; ring
    have hTn_le : Tn ‚Č§ Tn1 := by rw [hTn_succ]; linarith
    have h_őĪTn_E : (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ_n Tn m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2 :=
      hőĪ_nE Tn ‚ü®hTn_nn, le_rfl‚ü©
    have h_őĪTn_sq : (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ_n Tn m‚ÄĖ ^ 2) ‚Č§ (R / 2) ^ 2 := by
      rw [h_őĪTn_E]; exact hc‚āÄ_l2
    have h_őĪTn_bound : ‚ÄĖőĪ_n Tn‚ÄĖ ‚Č§ R / 2 :=
      piNorm_le_of_sum_sq_le_sq (őĪ_n Tn) h_R2_nn h_őĪTn_sq
    have h_őĪTn_realSym : ‚ąÄ m ‚ąą S,
        galerkinExtend S (őĪ_n Tn) (-m) = star (galerkinExtend S (őĪ_n Tn) m) :=
      hőĪ_nR Tn ‚ü®hTn_nn, le_rfl‚ü©
    obtain ‚ü®ő≤, hő≤0, hő≤D, hő≤R‚ü© := hStep (őĪ_n Tn) h_őĪTn_bound h_őĪTn_realSym
    -- ‚Ąď¬≤-sum conservation along ő≤.
    have hő≤E : ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
        (‚ąĎ m : ‚Ü•S, ‚ÄĖő≤ ŌĄ m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖő≤ 0 m‚ÄĖ ^ 2 :=
      fun ŌĄ hŌĄ => galerkinEnergyH0_const_on_Icc hS őĶ ő≤ hő≤D hő≤R ŌĄ hŌĄ
    -- ‚Ąď¬≤-sum along ő≤ matches c‚āÄ.
    have hő≤E_c‚āÄ : ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
        (‚ąĎ m : ‚Ü•S, ‚ÄĖő≤ ŌĄ m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2 := by
      intros ŌĄ hŌĄ
      rw [hő≤E ŌĄ hŌĄ, hő≤0]; exact h_őĪTn_E
    -- Concatenation ő≥.
    set ő≥ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) := fun t => if t ‚Č§ Tn then őĪ_n t else ő≤ (t - Tn)
      with hő≥_def
    have hő≥_left : ‚ąÄ t, t ‚Č§ Tn ‚Üí ő≥ t = őĪ_n t := fun t ht => by
      show (if t ‚Č§ Tn then őĪ_n t else ő≤ (t - Tn)) = őĪ_n t
      rw [if_pos ht]
    have hő≥_right : ‚ąÄ t, Tn ‚Č§ t ‚Üí ő≥ t = ő≤ (t - Tn) := fun t ht => by
      show (if t ‚Č§ Tn then őĪ_n t else ő≤ (t - Tn)) = ő≤ (t - Tn)
      by_cases heq : t = Tn
      ¬∑ subst heq; rw [if_pos le_rfl, sub_self, hő≤0]
      ¬∑ have hlt : Tn < t := lt_of_le_of_ne ht (Ne.symm heq)
        rw [if_neg (not_le.mpr hlt)]
    have hő≥0 : ő≥ 0 = c‚āÄ := by rw [hő≥_left 0 hTn_nn, hőĪ_n0]
    have hő≤_transD : ‚ąÄ t ‚ąą Set.Icc Tn Tn1,
        HasDerivWithinAt (fun y => ő≤ (y - Tn))
          (galerkinVectorField S (ő≤ (t - Tn)))
          (Set.Icc Tn Tn1) t := by
      intros t ht
      have hmem : t - Tn ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := by
        refine ‚ü®sub_nonneg.mpr ht.1, ?_‚ü©
        have := ht.2; rw [hTn_succ] at this; linarith
      have hg : HasDerivWithinAt ő≤ (galerkinVectorField S (ő≤ (t - Tn)))
          (Set.Icc (0 : ‚ĄĚ) őĶ) (t - Tn) := hő≤D _ hmem
      have hh : HasDerivWithinAt (fun y : ‚ĄĚ => y - Tn) 1 (Set.Icc Tn Tn1) t :=
        (hasDerivWithinAt_id t _).sub_const _
      have hst : Set.MapsTo (fun y : ‚ĄĚ => y - Tn) (Set.Icc Tn Tn1)
          (Set.Icc (0 : ‚ĄĚ) őĶ) := by
        intros y hy
        refine ‚ü®sub_nonneg.mpr hy.1, ?_‚ü©
        have := hy.2; rw [hTn_succ] at this; linarith
      have key := hg.scomp t hh hst
      simpa using key
    refine ‚ü®ő≥, hő≥0, ?_, ?_, ?_‚ü©
    ¬∑ -- HasDerivWithinAt ő≥ on Icc 0 Tn1.
      intros t ht
      by_cases ht_le : t ‚Č§ Tn
      ¬∑ have ht_left : t ‚ąą Set.Icc (0 : ‚ĄĚ) Tn := ‚ü®ht.1, ht_le‚ü©
        have hő≥t : ő≥ t = őĪ_n t := hő≥_left t ht_le
        have hő≥_on_left : HasDerivWithinAt ő≥ (galerkinVectorField S (ő≥ t))
            (Set.Icc (0 : ‚ĄĚ) Tn) t := by
          rw [hő≥t]
          refine (hőĪ_nD t ht_left).congr ?_ ?_
          ¬∑ intros y hy; exact hő≥_left y hy.2
          ¬∑ exact hő≥_left t ht_le
        by_cases ht_eq : t = Tn
        ¬∑ subst ht_eq
          have h_ő≤_right_deriv : HasDerivWithinAt ő≥ (galerkinVectorField S (ő≥ Tn))
              (Set.Icc Tn Tn1) Tn := by
            have hő≥t' : ő≥ Tn = ő≤ (Tn - Tn) := hő≥_right Tn le_rfl
            rw [hő≥t']
            refine (hő≤_transD Tn ‚ü®le_rfl, hTn_le‚ü©).congr ?_ ?_
            ¬∑ intros y hy; exact hő≥_right y hy.1
            ¬∑ exact hő≥_right Tn le_rfl
          have h_union : HasDerivWithinAt ő≥ (galerkinVectorField S (ő≥ Tn))
              (Set.Icc (0 : ‚ĄĚ) Tn ‚ą™ Set.Icc Tn Tn1) Tn :=
            hő≥_on_left.union h_ő≤_right_deriv
          rwa [Set.Icc_union_Icc_eq_Icc ht.1 hTn_le] at h_union
        ¬∑ have ht_lt : t < Tn := lt_of_le_of_ne ht_le ht_eq
          have hU_nhds : Set.Iio Tn ‚ąą nhds t := Iio_mem_nhds ht_lt
          rw [‚Üź hasDerivWithinAt_inter hU_nhds]
          have hsub : Set.Icc (0 : ‚ĄĚ) Tn1 ‚ą© Set.Iio Tn ‚äÜ Set.Icc (0 : ‚ĄĚ) Tn :=
            fun x hx => ‚ü®hx.1.1, le_of_lt hx.2‚ü©
          exact hő≥_on_left.mono hsub
      ¬∑ push Not at ht_le
        have ht_right : t ‚ąą Set.Icc Tn Tn1 := ‚ü®le_of_lt ht_le, ht.2‚ü©
        have hő≥t : ő≥ t = ő≤ (t - Tn) := hő≥_right t (le_of_lt ht_le)
        have hő≥_on_right : HasDerivWithinAt ő≥ (galerkinVectorField S (ő≥ t))
            (Set.Icc Tn Tn1) t := by
          rw [hő≥t]
          refine (hő≤_transD t ht_right).congr ?_ ?_
          ¬∑ intros y hy; exact hő≥_right y hy.1
          ¬∑ exact hő≥_right t (le_of_lt ht_le)
        have hU_nhds : Set.Ioi Tn ‚ąą nhds t := Ioi_mem_nhds ht_le
        rw [‚Üź hasDerivWithinAt_inter hU_nhds]
        have hsub : Set.Icc (0 : ‚ĄĚ) Tn1 ‚ą© Set.Ioi Tn ‚äÜ Set.Icc Tn Tn1 :=
          fun x hx => ‚ü®le_of_lt hx.2, hx.1.2‚ü©
        exact hő≥_on_right.mono hsub
    ¬∑ -- Real-symmetry on Icc 0 Tn1.
      intros t ht m hm
      by_cases ht_le : t ‚Č§ Tn
      ¬∑ rw [hő≥_left t ht_le]
        exact hőĪ_nR t ‚ü®ht.1, ht_le‚ü© m hm
      ¬∑ push Not at ht_le
        rw [hő≥_right t (le_of_lt ht_le)]
        have hmem : t - Tn ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := by
          refine ‚ü®sub_nonneg.mpr (le_of_lt ht_le), ?_‚ü©
          have := ht.2; rw [hTn_succ] at this; linarith
        exact hő≤R (t - Tn) hmem m hm
    ¬∑ -- ‚Ąď¬≤-sum conservation on Icc 0 Tn1.
      intros t ht
      by_cases ht_le : t ‚Č§ Tn
      ¬∑ rw [hő≥_left t ht_le]
        exact hőĪ_nE t ‚ü®ht.1, ht_le‚ü©
      ¬∑ push Not at ht_le
        rw [hő≥_right t (le_of_lt ht_le)]
        have hmem : t - Tn ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ := by
          refine ‚ü®sub_nonneg.mpr (le_of_lt ht_le), ?_‚ü©
          have := ht.2; rw [hTn_succ] at this; linarith
        exact hő≤E_c‚āÄ (t - Tn) hmem

/-! ### ¬ß10.116.G Arbitrarily large horizon from real-symmetric initial data

Direct corollary of ¬ß10.116.D + ¬ß10.116.F: for any time horizon `T > 0`,
there is a real-symmetric Galerkin trajectory on `[0, T]` starting
from a real-symmetric `c‚āÄ` with `‚ąĎ ‚ÄĖc‚āÄ m‚ÄĖ¬≤ ‚Č§ (R/2)¬≤`, satisfying
all three invariants (HasDerivWithinAt + real-symmetry + ‚Ąď¬≤-sum
conservation), with no `hInv` hypothesis.

The full globalization onto `Ici 0` (a single `őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)` with
HasDerivWithinAt on `Ici 0` at every `t ‚Č• 0`) requires the
Nat-floor piecewise gluing of ¬ß10.105-¬ß10.107; this interval-wise
form already captures the key unconditional content. -/

theorem galerkin_realSym_existence_on_horizon
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {R : ‚ĄĚ} (hR : 0 < R)
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā) (hc‚āÄ_l2 : (‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) ‚Č§ (R / 2) ^ 2)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S,
      galerkinExtend S c‚āÄ (-n) = star (galerkinExtend S c‚āÄ n))
    (T : ‚ĄĚ) (hT : 0 ‚Č§ T) :
    ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c‚āÄ ‚ąß
      (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) T,
        HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) T) t) ‚ąß
      (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) T, ‚ąÄ m ‚ąą S,
        galerkinExtend S (őĪ ŌĄ) (-m) = star (galerkinExtend S (őĪ ŌĄ) m)) ‚ąß
      (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) T,
        (‚ąĎ m : ‚Ü•S, ‚ÄĖőĪ ŌĄ m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) := by
  obtain ‚ü®őĶ, hőĶ_pos, hStep‚ü© := galerkin_realSym_forward_step S hS hR
  -- Pick n so that n¬∑őĶ ‚Č• T.
  set n : ‚Ąē := ‚ĆąT / őĶ‚ĆČ‚āä with hn_def
  have h_T_őĶ_nn : 0 ‚Č§ T / őĶ := div_nonneg hT hőĶ_pos.le
  have hn_bound : T ‚Č§ (n : ‚ĄĚ) * őĶ := by
    have h_ceil : T / őĶ ‚Č§ (n : ‚ĄĚ) := Nat.le_ceil _
    have := mul_le_mul_of_nonneg_right h_ceil hőĶ_pos.le
    rw [div_mul_cancel‚āÄ T (ne_of_gt hőĶ_pos)] at this
    exact this
  obtain ‚ü®őĪ, hőĪ0, hőĪ_D, hőĪ_R, hőĪ_E‚ü© :=
    galerkin_realSym_chain_n_step S hS (le_of_lt hR) hőĶ_pos hStep c‚āÄ hc‚āÄ_l2 hRealC‚āÄ n
  have h_sub : Set.Icc (0 : ‚ĄĚ) T ‚äÜ Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ) := fun x hx =>
    ‚ü®hx.1, le_trans hx.2 hn_bound‚ü©
  refine ‚ü®őĪ, hőĪ0, ?_, ?_, ?_‚ü©
  ¬∑ intros t ht
    have ht_big : t ‚ąą Set.Icc (0 : ‚ĄĚ) ((n : ‚ĄĚ) * őĶ) := h_sub ht
    exact (hőĪ_D t ht_big).mono h_sub
  ¬∑ intros ŌĄ hŌĄ m hm
    exact hőĪ_R ŌĄ (h_sub hŌĄ) m hm
  ¬∑ intros ŌĄ hŌĄ
    exact hőĪ_E ŌĄ (h_sub hŌĄ)

/-! ### ¬ß10.116.H.1 Chain sequence for the real-symmetric class

Mirror of ¬ß10.105 with real-symmetry + ‚Ąď¬≤-sum invariants carried
through the `Nat.rec` construction. The subtype
`{c : ‚Ü•S ‚Üí ‚Ąā // ‚Ąď¬≤-sum = c‚āÄ ‚ąß real-sym}` holds both invariants,
from which `‚ÄĖc‚ÄĖ ‚Č§ R/2` follows via `piNorm_le_of_sum_sq_le_sq`. -/

theorem galerkin_realSym_chain_sequence
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {R őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ) (hR : 0 ‚Č§ R)
    (hStep : ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚ÄĖ ‚Č§ R / 2 ‚Üí
      (‚ąÄ n ‚ąą S, galerkinExtend S c (-n) = star (galerkinExtend S c n)) ‚Üí
      ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c ‚ąß
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚ąß
        (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n ‚ąą S,
          galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n)))
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā)
    (hc‚āÄ_l2 : (‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) ‚Č§ (R / 2) ^ 2)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S,
      galerkinExtend S c‚āÄ (-n) = star (galerkinExtend S c‚āÄ n)) :
    ‚ąÉ ő∑ : ‚Ąē ‚Üí (‚Ü•S ‚Üí ‚Ąā), ‚ąÉ ő≤ : ‚Ąē ‚Üí ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā),
      ő∑ 0 = c‚āÄ ‚ąß
      (‚ąÄ k, (‚ąĎ m : ‚Ü•S, ‚ÄĖő∑ k m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) ‚ąß
      (‚ąÄ k, ‚ąÄ n ‚ąą S,
          galerkinExtend S (ő∑ k) (-n) = star (galerkinExtend S (ő∑ k) n)) ‚ąß
      (‚ąÄ k, ő≤ k 0 = ő∑ k) ‚ąß
      (‚ąÄ k, ő≤ k őĶ = ő∑ (k + 1)) ‚ąß
      (‚ąÄ k, ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt (ő≤ k) (galerkinVectorField S (ő≤ k t))
            (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚ąß
      (‚ąÄ k, ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n ‚ąą S,
          galerkinExtend S (ő≤ k ŌĄ) (-n) = star (galerkinExtend S (ő≤ k ŌĄ) n)) ‚ąß
      (‚ąÄ k, ‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          (‚ąĎ m : ‚Ü•S, ‚ÄĖő≤ k ŌĄ m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) := by
  classical
  have hR2_nn : (0 : ‚ĄĚ) ‚Č§ R / 2 := by linarith
  -- Invariant bundle carried through the chain.
  let Inv : (‚Ü•S ‚Üí ‚Ąā) ‚Üí Prop := fun c =>
    (‚ąĎ m : ‚Ü•S, ‚ÄĖc m‚ÄĖ ^ 2) = (‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) ‚ąß
    (‚ąÄ n ‚ąą S, galerkinExtend S c (-n) = star (galerkinExtend S c n))
  -- Helper: Inv c ‚áí ‚ÄĖc‚ÄĖ ‚Č§ R/2.
  have inv_bound : ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā, Inv c ‚Üí ‚ÄĖc‚ÄĖ ‚Č§ R / 2 := by
    intros c hinv
    have hsum_le : (‚ąĎ m : ‚Ü•S, ‚ÄĖc m‚ÄĖ ^ 2) ‚Č§ (R / 2) ^ 2 := by
      rw [hinv.1]; exact hc‚āÄ_l2
    exact piNorm_le_of_sum_sq_le_sq c hR2_nn hsum_le
  -- Step function via Classical.choose.
  let stepFn : (c : ‚Ü•S ‚Üí ‚Ąā) ‚Üí Inv c ‚Üí ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā) :=
    fun c hinv => Classical.choose (hStep c (inv_bound c hinv) hinv.2)
  have stepSpec : ‚ąÄ (c : ‚Ü•S ‚Üí ‚Ąā) (hinv : Inv c),
      (stepFn c hinv) 0 = c ‚ąß
      (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
        HasDerivWithinAt (stepFn c hinv)
          (galerkinVectorField S ((stepFn c hinv) t))
          (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚ąß
      (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n ‚ąą S,
        galerkinExtend S ((stepFn c hinv) ŌĄ) (-n) =
          star (galerkinExtend S ((stepFn c hinv) ŌĄ) n)) :=
    fun c hinv => Classical.choose_spec (hStep c (inv_bound c hinv) hinv.2)
  -- Step preserves the invariant: endpoint value of stepFn has Inv.
  have step_preserves_inv : ‚ąÄ (c : ‚Ü•S ‚Üí ‚Ąā) (hinv : Inv c),
      Inv ((stepFn c hinv) őĶ) := by
    intros c hinv
    have hsp := stepSpec c hinv
    have hő≤E : (‚ąĎ m : ‚Ü•S, ‚ÄĖ(stepFn c hinv) őĶ m‚ÄĖ ^ 2) =
        ‚ąĎ m : ‚Ü•S, ‚ÄĖ(stepFn c hinv) 0 m‚ÄĖ ^ 2 :=
      galerkinEnergyH0_const_on_Icc hS őĶ (stepFn c hinv) hsp.2.1
        hsp.2.2 őĶ ‚ü®hőĶ.le, le_rfl‚ü©
    rw [hsp.1] at hő≤E
    refine ‚ü®?_, ?_‚ü©
    ¬∑ rw [hő≤E]; exact hinv.1
    ¬∑ -- Real-symmetry at őĶ from hsp.2.2 at ŌĄ = őĶ.
      have := hsp.2.2 őĶ ‚ü®hőĶ.le, le_rfl‚ü©
      exact this
  -- Chain endpoint sequence via Nat.rec.
  let chainEndpt : ‚Ąē ‚Üí {c : ‚Ü•S ‚Üí ‚Ąā // Inv c} := fun n =>
    Nat.rec (motive := fun _ => {c : ‚Ü•S ‚Üí ‚Ąā // Inv c})
      ‚ü®c‚āÄ, ‚ü®rfl, hRealC‚āÄ‚ü©‚ü©
      (fun _ prev =>
        ‚ü®stepFn prev.val prev.property őĶ,
         step_preserves_inv prev.val prev.property‚ü©)
      n
  refine ‚ü®fun n => (chainEndpt n).val,
          fun n => stepFn (chainEndpt n).val (chainEndpt n).property,
          ?_, ?_, ?_, ?_, ?_, ?_, ?_, ?_‚ü©
  ¬∑ -- ő∑ 0 = c‚āÄ
    rfl
  ¬∑ -- ‚Ąď¬≤-sum preserved at each ő∑ k
    intro k; exact (chainEndpt k).property.1
  ¬∑ -- real-symmetry at each ő∑ k
    intro k; exact (chainEndpt k).property.2
  ¬∑ -- ő≤ k 0 = ő∑ k
    intro k
    exact (stepSpec (chainEndpt k).val (chainEndpt k).property).1
  ¬∑ -- ő≤ k őĶ = ő∑ (k+1)
    intro k; rfl
  ¬∑ -- HasDerivWithinAt ő≤ k on [0, őĶ]
    intro k t ht
    exact (stepSpec (chainEndpt k).val (chainEndpt k).property).2.1 t ht
  ¬∑ -- real-symmetry along ő≤ k on [0, őĶ]
    intro k ŌĄ hŌĄ n hn
    exact (stepSpec (chainEndpt k).val (chainEndpt k).property).2.2 ŌĄ hŌĄ n hn
  ¬∑ -- ‚Ąď¬≤-sum conservation along ő≤ k
    intro k ŌĄ hŌĄ
    have hsp := stepSpec (chainEndpt k).val (chainEndpt k).property
    have hő≤E : (‚ąĎ m : ‚Ü•S, ‚ÄĖ(stepFn (chainEndpt k).val (chainEndpt k).property) ŌĄ m‚ÄĖ ^ 2) =
        ‚ąĎ m : ‚Ü•S, ‚ÄĖ(stepFn (chainEndpt k).val (chainEndpt k).property) 0 m‚ÄĖ ^ 2 :=
      galerkinEnergyH0_const_on_Icc hS őĶ _ hsp.2.1 hsp.2.2 ŌĄ hŌĄ
    rw [hő≤E, hsp.1]
    exact (chainEndpt k).property.1

/-! ### ¬ß10.116.H.2 Global HasDerivWithinAt on `Ici 0`

Mirror of ¬ß10.107 with real-symmetry + ‚Ąď¬≤-sum invariants. Same
Nat-floor piecewise construction of `őĪ t := ő≤ ‚Ćät/őĶ‚Ćč‚āä (t - ‚Ćät/őĶ‚Ćč‚āä¬∑őĶ)`,
same case-splits (strict interior / junction / origin). -/

theorem galerkin_realSym_global_on_Ici
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsSymmetricSupport S)
    {R őĶ : ‚ĄĚ} (hőĶ : 0 < őĶ) (hR : 0 ‚Č§ R)
    (hStep : ‚ąÄ c : ‚Ü•S ‚Üí ‚Ąā, ‚ÄĖc‚ÄĖ ‚Č§ R / 2 ‚Üí
      (‚ąÄ n ‚ąą S, galerkinExtend S c (-n) = star (galerkinExtend S c n)) ‚Üí
      ‚ąÉ őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā), őĪ 0 = c ‚ąß
        (‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ,
          HasDerivWithinAt őĪ (galerkinVectorField S (őĪ t)) (Set.Icc (0 : ‚ĄĚ) őĶ) t) ‚ąß
        (‚ąÄ ŌĄ ‚ąą Set.Icc (0 : ‚ĄĚ) őĶ, ‚ąÄ n ‚ąą S,
          galerkinExtend S (őĪ ŌĄ) (-n) = star (galerkinExtend S (őĪ ŌĄ) n)))
    (c‚āÄ : ‚Ü•S ‚Üí ‚Ąā)
    (hc‚āÄ_l2 : (‚ąĎ m : ‚Ü•S, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) ‚Č§ (R / 2) ^ 2)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S,
      galerkinExtend S c‚āÄ (-n) = star (galerkinExtend S c‚āÄ n)) :
