/-! ### В§10.177 Parametric-`s` Galerkin finite-sum energy

Generalizes В§10.68's `trigPolyEnergyHs2` to arbitrary `s : в„қ`.

```
trigPolyEnergyHs s S c := вҲ‘ m : вҶҘS, (fracDerivSymbol s m.val)ВІ В· вҖ–c mвҖ–ВІ
```

This is the **pointwise-differentiable** form of the `бёўЛў` energy for
Galerkin coefficients.  `trigPolyEnergyHs_eq_hsSeminormSq` bridges
to the tsum form `hsSeminormSq s (galerkinToLp S c)`.

Phase 1 + Phase 3 deliverable of the Route A plan. -/

/-- **Parametric-`s` trig-poly energy (finite-sum form).** -/
noncomputable def trigPolyEnergyHs
    (s : в„қ) (S : Finset (Fin 2 вҶ’ в„Ө)) [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (c : вҶҘS вҶ’ в„Ӯ) : в„қ :=
  вҲ‘ m : вҶҘS, (fracDerivSymbol s m.val) ^ 2 * вҖ–c mвҖ– ^ 2

lemma trigPolyEnergyHs_nonneg
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)] (c : вҶҘS вҶ’ в„Ӯ) :
    0 вүӨ trigPolyEnergyHs s S c := by
  unfold trigPolyEnergyHs
  exact Finset.sum_nonneg (fun m _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))

/-- Specialization: `s = 2` recovers В§10.68's `trigPolyEnergyHs2`. -/
lemma trigPolyEnergyHs_two
    {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)] (c : вҶҘS вҶ’ в„Ӯ) :
    trigPolyEnergyHs 2 S c = trigPolyEnergyHs2 S c := rfl

/-- Specialization: `s = 0` recovers `вҲ‘ m, вҖ–c mвҖ–ВІ` on coefficients
whose support avoids the origin (so that `fracDerivSymbol 0` is not
triggered at zero). -/
lemma trigPolyEnergyHs_zero_of_not_mem_zero
    {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (h0 : (0 : Fin 2 вҶ’ в„Ө) вҲү S) (c : вҶҘS вҶ’ в„Ӯ) :
    trigPolyEnergyHs 0 S c = вҲ‘ m : вҶҘS, вҖ–c mвҖ– ^ 2 := by
  unfold trigPolyEnergyHs
  apply Finset.sum_congr rfl
  intros m _
  have hm_ne : m.val вү  0 := fun hv => h0 (hv в–ё m.property)
  rw [fracDerivSymbol_of_ne_zero 0 hm_ne, Real.rpow_zero]; ring

/-- **Bridge: finite-sum `бёўЛў` energy = `hsSeminormSq s (galerkinToLp S c)`.**
Generalization of В§10.68's `trigPolyEnergyHs2_eq_hsSeminormSq` to
arbitrary `s : в„қ`. -/
theorem trigPolyEnergyHs_eq_hsSeminormSq
    (s : в„қ) (S : Finset (Fin 2 вҶ’ в„Ө)) [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (c : вҶҘS вҶ’ в„Ӯ) :
    trigPolyEnergyHs s S c = hsSeminormSq s (galerkinToLp S c) := by
  unfold trigPolyEnergyHs hsSeminormSq
  -- Show the tsum collapses to a Finset sum over `S`.
  have hZeroOff : вҲҖ n вҲү S,
      (fracDerivSymbol s n) ^ 2 * вҖ–mFourierCoeff (galerkinToLp S c) nвҖ– ^ 2 = 0 := by
    intros n hn
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ hn,
        norm_zero]; ring
  rw [tsum_eq_sum (s := S) (fun n hn => hZeroOff n hn)]
  -- Rewrite the Finset sum over S as a sum over the subtype вҶҘS.
  rw [вҶҗ Finset.sum_attach S (fun n =>
      (fracDerivSymbol s n) ^ 2 * вҖ–mFourierCoeff (galerkinToLp S c) nвҖ– ^ 2)]
  apply Finset.sum_congr rfl
  intros m _
  rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_mem _ _ m.property]

/-- **Energy bound transferred from parametric trig-poly to `hsSeminormSq`.**
Generalization of `hsSeminormSq_le_of_trigPolyEnergyHs2_le`. -/
lemma hsSeminormSq_le_of_trigPolyEnergyHs_le
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (c : вҶҘS вҶ’ в„Ӯ) (E : в„қ) (hE : trigPolyEnergyHs s S c вүӨ E) :
    hsSeminormSq s (galerkinToLp S c) вүӨ E := by
  rw [вҶҗ trigPolyEnergyHs_eq_hsSeminormSq]; exact hE

/-! ### В§10.178 Pointwise derivative of parametric-`s` Galerkin energy

Generalizes В§10.69's `trigPolyEnergyHs2_hasDerivAt` to arbitrary `s : в„қ`.
The structure is identical: each coordinate `П„ вҶҰ Оұ П„ m` has derivative
`galerkinVectorField S (Оұ П„) m` (via `hasDerivAt_pi`), and `HasDerivAt.norm_sq`
differentiates the squared norm via the real inner product on `в„Ӯ`.  The
`(fracDerivSymbol s m)ВІ` weight is pulled out by `const_mul`.

Output:
```
d/dП„ trigPolyEnergyHs s S (Оұ П„)
  = вҲ‘ m : вҶҘS, (fracDerivSymbol s m.val)ВІ В· 2 В· вҹӘОұ П„ m, galerkinVectorField S (Оұ П„) mвҹ«_в„қ
```

This is the Galerkin `бёўЛў` energy identity (Phase 1 at `s = 1`; Phase 3 at
`s вҲҲ (1, 2]`). -/

theorem trigPolyEnergyHs_hasDerivAt
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ))
    (hОұ : вҲҖ t, HasDerivAt Оұ (galerkinVectorField S (Оұ t)) t)
    (П„ : в„қ) :
    HasDerivAt (fun t => trigPolyEnergyHs s S (Оұ t))
      (вҲ‘ m : вҶҘS, (fracDerivSymbol s m.val) ^ 2 *
        (2 * (@inner в„қ в„Ӯ _ (Оұ П„ m) (galerkinVectorField S (Оұ П„) m)))) П„ := by
  unfold trigPolyEnergyHs
  apply HasDerivAt.fun_sum
  intros m _
  have hОұm : HasDerivAt (fun t => Оұ t m) (galerkinVectorField S (Оұ П„) m) П„ :=
    (hasDerivAt_pi.mp (hОұ П„)) m
  have hNormSq := hОұm.norm_sq
  exact hNormSq.const_mul _

/-- **В§10.178.A  Specialization to `s = 1`: the `бёўВ№` energy identity
(Phase 1 deliverable).** -/
theorem trigPolyEnergyH1_hasDerivAt
    {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ))
    (hОұ : вҲҖ t, HasDerivAt Оұ (galerkinVectorField S (Оұ t)) t)
    (П„ : в„қ) :
    HasDerivAt (fun t => trigPolyEnergyHs 1 S (Оұ t))
      (вҲ‘ m : вҶҘS, (fracDerivSymbol 1 m.val) ^ 2 *
        (2 * (@inner в„қ в„Ӯ _ (Оұ П„ m) (galerkinVectorField S (Оұ П„) m)))) П„ :=
  trigPolyEnergyHs_hasDerivAt 1 Оұ hОұ П„

/-! ### В§10.179 `бёўЛў` energy flux decomposition

The `бёўЛў` energy flux
`F_s(Оұ П„) := вҲ‘_{m вҲҲ вҶҘS} (|m|^s)ВІ В· 2 В· вҹӘОұ П„ m, galerkinVectorField S (Оұ П„) mвҹ«_в„қ`
is the classical advection-convolution flux against the Sobolev weight.
We package it as a named quantity for downstream use. -/

/-- **Galerkin `бёўЛў` flux.** The formal time-derivative of `trigPolyEnergyHs s`. -/
noncomputable def galerkinHsFlux
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (c : вҶҘS вҶ’ в„Ӯ) : в„қ :=
  вҲ‘ m : вҶҘS, (fracDerivSymbol s m.val) ^ 2 *
    (2 * (@inner в„қ в„Ӯ _ (c m) (galerkinVectorField S c m)))

/-- **Energy identity in compact form**: `d/dП„ trigPolyEnergyHs s S (Оұ П„)
= galerkinHsFlux s (Оұ П„)`. -/
theorem galerkinHsFlux_eq_deriv
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ))
    (hОұ : вҲҖ t, HasDerivAt Оұ (galerkinVectorField S (Оұ t)) t)
    (П„ : в„қ) :
    deriv (fun t => trigPolyEnergyHs s S (Оұ t)) П„ = galerkinHsFlux s (Оұ П„) :=
  (trigPolyEnergyHs_hasDerivAt s Оұ hОұ П„).deriv

/-- **Zero flux on radial shells.** When `S` is a radial shell,
`galerkinVectorField S c = 0`, so the flux vanishes regardless of `s`. -/
lemma galerkinHsFlux_eq_zero_of_isRadialShell
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (hS : IsRadialShell S) (c : вҶҘS вҶ’ в„Ӯ) :
    galerkinHsFlux s c = 0 := by
  unfold galerkinHsFlux
  rw [galerkinVectorField_eq_zero_of_isRadialShell hS]
  simp

/-! ### В§10.180 Galerkin `бёўЛў` energy is continuous in time

`t вҶҰ trigPolyEnergyHs s S (Оұ t)` is differentiable at every `П„`
(with derivative `galerkinHsFlux s (Оұ П„)`), so in particular continuous.
We package this as a reusable lemma for GrГ¶nwall application. -/

lemma trigPolyEnergyHs_differentiable
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ))
    (hОұ : вҲҖ t, HasDerivAt Оұ (galerkinVectorField S (Оұ t)) t) :
    Differentiable в„қ (fun t => trigPolyEnergyHs s S (Оұ t)) :=
  fun П„ => (trigPolyEnergyHs_hasDerivAt s Оұ hОұ П„).differentiableAt

lemma trigPolyEnergyHs_continuous
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ))
    (hОұ : вҲҖ t, HasDerivAt Оұ (galerkinVectorField S (Оұ t)) t) :
    Continuous (fun t => trigPolyEnergyHs s S (Оұ t)) :=
  (trigPolyEnergyHs_differentiable s Оұ hОұ).continuous

/-! ### В§10.181 Sobolev energy monotonicity identity on an interval

For use in GrГ¶nwall-style bounds: if
`|deriv (trigPolyEnergyHs s вҲҳ Оұ) П„| вүӨ K В· trigPolyEnergyHs s S (Оұ П„)` on
`[0, T]`, then `trigPolyEnergyHs s S (Оұ t) вүӨ trigPolyEnergyHs s S (Оұ 0) В·
exp(K В· t)` on `[0, T]`.

Directly calls the existing `scalar_gronwall_exp` used by В§10.79's
`galerkinTrigEnergyHs2_gronwall_bound`. -/

theorem trigPolyEnergyHs_gronwall_bound
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ))
    (hОұ : вҲҖ t, HasDerivAt Оұ (galerkinVectorField S (Оұ t)) t)
    (K T : в„қ) (hT : 0 вүӨ T)
    (hDerivBound : вҲҖ x вҲҲ Set.Ico 0 T,
      |deriv (fun t => trigPolyEnergyHs s S (Оұ t)) x|
        вүӨ K * |trigPolyEnergyHs s S (Оұ x)|) :
    вҲҖ t вҲҲ Set.Icc 0 T,
      trigPolyEnergyHs s S (Оұ t)
        вүӨ trigPolyEnergyHs s S (Оұ 0) * Real.exp (K * t) := by
  have hE_hasDerivWithin : вҲҖ x вҲҲ Set.Ico 0 T,
      HasDerivWithinAt (fun t => trigPolyEnergyHs s S (Оұ t))
        (deriv (fun t => trigPolyEnergyHs s S (Оұ t)) x) (Set.Ici x) x := by
    intros x _
    have h := (trigPolyEnergyHs_hasDerivAt s Оұ hОұ x).hasDerivWithinAt
              (s := Set.Ici x)
    have hd := (trigPolyEnergyHs_hasDerivAt s Оұ hОұ x).deriv
    rw [hd]; exact h
  have hE_cont : ContinuousOn (fun t => trigPolyEnergyHs s S (Оұ t))
                    (Set.Icc 0 T) :=
    (trigPolyEnergyHs_continuous s Оұ hОұ).continuousOn
  exact scalar_gronwall_exp (fun t => trigPolyEnergyHs s S (Оұ t)) K T hT
    hE_cont hE_hasDerivWithin hDerivBound
    (fun _ _ => trigPolyEnergyHs_nonneg s (Оұ _))

/-- **Corollary**: Bound on `hsSeminormSq` via parametric-`s` GrГ¶nwall. -/
theorem hsSeminormSq_galerkin_gronwall_bound
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ))
    (hОұ : вҲҖ t, HasDerivAt Оұ (galerkinVectorField S (Оұ t)) t)
    (K T : в„қ) (hT : 0 вүӨ T)
    (hDerivBound : вҲҖ x вҲҲ Set.Ico 0 T,
      |deriv (fun t => trigPolyEnergyHs s S (Оұ t)) x|
        вүӨ K * |trigPolyEnergyHs s S (Оұ x)|) :
    вҲҖ t вҲҲ Set.Icc 0 T,
      hsSeminormSq s (galerkinToLp S (Оұ t))
        вүӨ hsSeminormSq s (galerkinToLp S (Оұ 0)) * Real.exp (K * t) := by
  intro t ht
  rw [вҶҗ trigPolyEnergyHs_eq_hsSeminormSq, вҶҗ trigPolyEnergyHs_eq_hsSeminormSq]
  exact trigPolyEnergyHs_gronwall_bound s Оұ hОұ K T hT hDerivBound t ht

/-! ### В§10.182 Named hypothesis: GrГ¶nwall-integrable velocity control

Phase 2 and Phase 5 deliverable of Route A.  A named Lean structure
that packages the three inputs needed to produce a uniform `бёўЛў`
bound on the Galerkin approximation at a fixed `s`:

1. ODE validity of the Galerkin trajectory (as a `HasDerivAt` hypothesis).
2. A pointwise log-derivative bound
   `|d/dП„ trigPolyEnergyHs s S (Оұ П„)| вүӨ K В· trigPolyEnergyHs s S (Оұ П„)`
   вҖ” the BKM-integral expression of velocity control.
3. A uniform initial-data `бёўЛў` bound.

The closure `HasGalerkinHsGronwall.uniform_bound` runs В§10.181's
`trigPolyEnergyHs_gronwall_bound` across the family and produces the
final time-uniform `бёўЛў` bound on `[0, T]`.  For `T вҶ’ вҲһ`, the caller
must supply a `K` such that the exponent `K В· T` stays finite (the
classical case where the BKM integral is finite). -/

/-- **Phase 2/5 input package** for a single Galerkin level. -/
structure HasGalerkinHsGronwallLevel
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ)) where
  hDeriv : вҲҖ t, HasDerivAt Оұ (galerkinVectorField S (Оұ t)) t
  /-- `K` is the (nominally time-integrable) velocity control constant. -/
  K : в„қ
  hDerivBound : вҲҖ T : в„қ, 0 вүӨ T вҶ’ вҲҖ x вҲҲ Set.Ico (0 : в„қ) T,
    |deriv (fun t => trigPolyEnergyHs s S (Оұ t)) x|
      вүӨ K * |trigPolyEnergyHs s S (Оұ x)|
  EвӮҖ : в„қ
  hEвӮҖ : trigPolyEnergyHs s S (Оұ 0) вүӨ EвӮҖ

/-- **Bound on a compact interval** extracted from the level package.
Requires `0 вүӨ h.K` so that `exp(KВ·t)` is monotone in `t`. -/
theorem HasGalerkinHsGronwallLevel.bound_on_Icc
    (s : в„қ) {S : Finset (Fin 2 вҶ’ в„Ө)} [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ)} (h : HasGalerkinHsGronwallLevel s Оұ)
    (hK_nn : 0 вүӨ h.K) (T : в„қ) (hT : 0 вүӨ T) :
    вҲҖ t вҲҲ Set.Icc (0 : в„қ) T,
      hsSeminormSq s (galerkinToLp S (Оұ t)) вүӨ h.EвӮҖ * Real.exp (h.K * T) := by
  intro t ht
  have h1 : hsSeminormSq s (galerkinToLp S (Оұ t))
      вүӨ hsSeminormSq s (galerkinToLp S (Оұ 0)) * Real.exp (h.K * t) :=
    hsSeminormSq_galerkin_gronwall_bound s Оұ h.hDeriv h.K T hT
      (h.hDerivBound T hT) t ht
  have h2 : hsSeminormSq s (galerkinToLp S (Оұ 0))
      = trigPolyEnergyHs s S (Оұ 0) :=
    (trigPolyEnergyHs_eq_hsSeminormSq s S (Оұ 0)).symm
  have h3 : trigPolyEnergyHs s S (Оұ 0) вүӨ h.EвӮҖ := h.hEвӮҖ
  have h4 : 0 вүӨ Real.exp (h.K * t) := (Real.exp_pos _).le
  have h5 : Real.exp (h.K * t) вүӨ Real.exp (h.K * T) := by
    apply Real.exp_le_exp.mpr
    exact mul_le_mul_of_nonneg_left ht.2 hK_nn
  have hEвӮҖ_nn : 0 вүӨ h.EвӮҖ :=
    le_trans (trigPolyEnergyHs_nonneg s _) h3
  calc hsSeminormSq s (galerkinToLp S (Оұ t))
      вүӨ hsSeminormSq s (galerkinToLp S (Оұ 0)) * Real.exp (h.K * t) := h1
    _ = trigPolyEnergyHs s S (Оұ 0) * Real.exp (h.K * t) := by rw [h2]
    _ вүӨ h.EвӮҖ * Real.exp (h.K * t) := by
        apply mul_le_mul_of_nonneg_right h3 h4
    _ вүӨ h.EвӮҖ * Real.exp (h.K * T) := by
        apply mul_le_mul_of_nonneg_left h5 hEвӮҖ_nn

/-- **Uniform-across-levels Phase 2 input package** for the Galerkin
family indexed by `n : в„•`. -/
structure HasGalerkinHsGronwallFamily
    (s : в„қ) (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)) where
  level : вҲҖ n : в„•, HasGalerkinHsGronwallLevel s (Оұ n)
  /-- Uniform-in-`n` velocity control and initial-data bounds. -/
  K_uniform : в„қ
  hK_uniform : вҲҖ n : в„•, (level n).K = K_uniform
  EвӮҖ_uniform : в„қ
  hEвӮҖ_uniform : вҲҖ n : в„•, (level n).EвӮҖ = EвӮҖ_uniform

/-- **Phase 2 closure (s = 1) / Phase 5 closure (s вҲҲ (1, 2] or s > 1)**:
From a uniform-in-`n` GrГ¶nwall family with `0 вүӨ K_uniform`, extract a
time-uniform `бёўЛў` bound across the Galerkin family on any compact
`[0, T]` interval. -/
theorem HasGalerkinHsGronwallFamily.uniform_bound_on_Icc
    (s : в„қ) {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (h : HasGalerkinHsGronwallFamily s Оұ)
    (hK_nn : 0 вүӨ h.K_uniform)
    (T : в„қ) (hT : 0 вүӨ T) :
    вҲҖ n : в„•, вҲҖ t вҲҲ Set.Icc (0 : в„қ) T,
      hsSeminormSq s (galerkinToLp (sqgBox n) (Оұ n t))
        вүӨ h.EвӮҖ_uniform * Real.exp (h.K_uniform * T) := by
  intro n t ht
  have hKn_nn : 0 вүӨ (h.level n).K := by rw [h.hK_uniform n]; exact hK_nn
  have hBound := (h.level n).bound_on_Icc s hKn_nn T hT t ht
  rw [h.hEвӮҖ_uniform n, h.hK_uniform n] at hBound
  exact hBound

/-- **Uniform Phase 2 / Phase 5 bound вҖ” compact interval.** Packages
`HasGalerkinHsGronwallFamily.uniform_bound_on_Icc` in the signature
directly consumable by `sqg_regularity_of_aubinLions_via_interpolation`'s
`hBoundOne` argument at `s = 1` (after restricting to `[0, T]`). -/
theorem HasGalerkinHsGronwallFamily.global_uniform_bound
    (s : в„қ) {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (h : HasGalerkinHsGronwallFamily s Оұ)
    (hK_nn : 0 вүӨ h.K_uniform)
    (T : в„қ) (hT : 0 вүӨ T) :
    вҲғ M : в„қ, вҲҖ n : в„•, вҲҖ t : в„қ, 0 вүӨ t вҶ’ t вүӨ T вҶ’
      hsSeminormSq s (galerkinToLp (sqgBox n) (Оұ n t)) вүӨ M := by
  refine вҹЁh.EвӮҖ_uniform * Real.exp (h.K_uniform * T), ?_вҹ©
  intro n t ht0 htT
  exact h.uniform_bound_on_Icc s hK_nn T hT n t вҹЁht0, htTвҹ©

/-! ## LittlewoodвҖ“Paley dyadic decomposition (Phase 6вҖ“11 of Route A)

Formalizes the part of LittlewoodвҖ“Paley theory needed for in-project
paraproduct + KatoвҖ“Ponce estimates.  Lives inline inside `RieszTorus`
because the local `rieszTorusMeasureSpace` instance binds `volume` on
`UnitAddTorus` here. -/

/-! ### В§11.1 Dyadic annuli on `в„ӨВІ` -/

/-- **Dyadic `в„“вҲһ`-annulus on `в„ӨВІ`.**  For `N вүҘ 1`:
`sqgBox (2^N - 1) \ sqgBox (2^(N-1) - 1)`.  For `N = 0`: `{0}`. -/
noncomputable def dyadicAnnulus (N : в„•) : Finset (Fin 2 вҶ’ в„Ө) :=
  if N = 0 then ({0} : Finset (Fin 2 вҶ’ в„Ө))
  else (sqgBox (2 ^ N - 1)) \ (sqgBox (2 ^ (N - 1) - 1))

@[simp] lemma dyadicAnnulus_zero :
    dyadicAnnulus 0 = ({0} : Finset (Fin 2 вҶ’ в„Ө)) := by
  unfold dyadicAnnulus; rfl

lemma zero_mem_dyadicAnnulus_zero : (0 : Fin 2 вҶ’ в„Ө) вҲҲ dyadicAnnulus 0 := by
  rw [dyadicAnnulus_zero]; exact Finset.mem_singleton.mpr rfl

lemma zero_not_mem_dyadicAnnulus_pos {N : в„•} (hN : 0 < N) :
    (0 : Fin 2 вҶ’ в„Ө) вҲү dyadicAnnulus N := by
  unfold dyadicAnnulus
  rw [if_neg (Nat.pos_iff_ne_zero.mp hN)]
  rw [Finset.mem_sdiff]
  push_neg
  intro h
  exact absurd h (zero_not_mem_sqgBox _)

lemma dyadicAnnulus_subset_sqgBox_pos {N : в„•} (hN : 0 < N) :
    dyadicAnnulus N вҠҶ sqgBox (2 ^ N - 1) := by
  unfold dyadicAnnulus
  rw [if_neg (Nat.pos_iff_ne_zero.mp hN)]
  exact Finset.sdiff_subset

/-! ### В§11.2 Fourier truncation onto a finite set -/

/-- **Fourier projection onto a finite set.** Uses existing `trigPoly`
infrastructure. -/
noncomputable def fourierTruncate
    (A : Finset (Fin 2 вҶ’ в„Ө))
    (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  trigPoly A (fun (m : Fin 2 вҶ’ в„Ө) => mFourierCoeff f m)

/-! ### В§11.3 LittlewoodвҖ“Paley dyadic projector `О”_N` -/

/-- **LittlewoodвҖ“Paley dyadic projector.** -/
noncomputable def lpProjector
    (N : в„•) (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  fourierTruncate (dyadicAnnulus N) f

/-- **Partial-sum operator** `S_N = вҲ‘_{k вүӨ N} О”_k`. -/
noncomputable def lpPartialSum
    (N : в„•) (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  вҲ‘ k вҲҲ Finset.range (N + 1), lpProjector k f

/-! ### В§11.4 Fourier coefficients + seminorm computations -/

/-- **Fourier coefficients of a truncation.** Kronecker-indicator of `A`. -/
theorem fourierTruncate_mFourierCoeff
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A : Finset (Fin 2 вҶ’ в„Ө))
    (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) (m : Fin 2 вҶ’ в„Ө) :
    mFourierCoeff (fourierTruncate A f) m
      = if m вҲҲ A then mFourierCoeff f m else 0 := by
  unfold fourierTruncate
  exact mFourierCoeff_trigPoly A _ m

lemma fourierTruncate_mFourierCoeff_of_mem
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A : Finset (Fin 2 вҶ’ в„Ө))
    (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))
    {m : Fin 2 вҶ’ в„Ө} (hm : m вҲҲ A) :
    mFourierCoeff (fourierTruncate A f) m = mFourierCoeff f m := by
  rw [fourierTruncate_mFourierCoeff, if_pos hm]

lemma fourierTruncate_mFourierCoeff_of_not_mem
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A : Finset (Fin 2 вҶ’ в„Ө))
    (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))
    {m : Fin 2 вҶ’ в„Ө} (hm : m вҲү A) :
    mFourierCoeff (fourierTruncate A f) m = 0 := by
  rw [fourierTruncate_mFourierCoeff, if_neg hm]

/-- **`бёўЛў` seminorm of a truncation = weighted в„“ВІ norm on `A`.** -/
theorem hsSeminormSq_fourierTruncate
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (s : в„қ) (A : Finset (Fin 2 вҶ’ в„Ө))
    (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    hsSeminormSq s (fourierTruncate A f)
      = вҲ‘ m вҲҲ A, (fracDerivSymbol s m) ^ 2 * вҖ–mFourierCoeff f mвҖ– ^ 2 := by
  unfold hsSeminormSq
  have hZeroOff : вҲҖ n вҲү A,
      (fracDerivSymbol s n) ^ 2 * вҖ–mFourierCoeff (fourierTruncate A f) nвҖ– ^ 2 = 0 := by
    intros n hn
    rw [fourierTruncate_mFourierCoeff_of_not_mem A f hn, norm_zero]; ring
  rw [tsum_eq_sum (s := A) (fun n hn => hZeroOff n hn)]
  apply Finset.sum_congr rfl
  intros m hm
  rw [fourierTruncate_mFourierCoeff_of_mem A f hm]

lemma hsSeminormSq_fourierTruncate_nonneg
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (s : в„қ) (A : Finset (Fin 2 вҶ’ в„Ө))
    (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    0 вүӨ hsSeminormSq s (fourierTruncate A f) := by
  rw [hsSeminormSq_fourierTruncate]
  exact Finset.sum_nonneg (fun m _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))

theorem lpProjector_mFourierCoeff
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (N : в„•) (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (m : Fin 2 вҶ’ в„Ө) :
    mFourierCoeff (lpProjector N f) m
      = if m вҲҲ dyadicAnnulus N then mFourierCoeff f m else 0 := by
  unfold lpProjector
  exact fourierTruncate_mFourierCoeff _ f m

theorem hsSeminormSq_lpProjector
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (s : в„қ) (N : в„•)
    (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    hsSeminormSq s (lpProjector N f)
      = вҲ‘ m вҲҲ dyadicAnnulus N,
          (fracDerivSymbol s m) ^ 2 * вҖ–mFourierCoeff f mвҖ– ^ 2 := by
  unfold lpProjector
  exact hsSeminormSq_fourierTruncate s _ f

/-! ### В§11.5 Paraproduct hypothesis types (Phase 7 structural) -/

/-- **Paraproduct `T_f g` placeholder.** -/
noncomputable def paraproduct
    (_f _g : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))) := 0

/-- **Paraproduct remainder `R(f, g)` placeholder.** -/
noncomputable def paraRemainder
    (_f _g : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))) := 0

/-- **Paraproduct `бёўЛў` bound hypothesis.** -/
structure HasParaproductHsBound (s C : в„қ) where
  bound : вҲҖ f g : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))),
    hsSeminormSq s (paraproduct f g) вүӨ
      C * (hsSeminormSq 0 f) * (hsSeminormSq s g)

/-- **Paraproduct remainder `бёўЛў` bound hypothesis.** -/
structure HasParaRemainderHsBound (s C : в„қ) where
  bound : вҲҖ f g : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))),
    hsSeminormSq s (paraRemainder f g) вүӨ
      C * (hsSeminormSq s f) * (hsSeminormSq s g)

/-! ### В§11.6 Commutator `[JЛў, f] В· вҲҮg` (Phase 8 structural) -/

/-- **KatoвҖ“Ponce commutator bound** as structure. -/
structure HasKatoPonceCommutatorBound (s C : в„қ) where
  bound : вҲҖ f g : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))),
    вҲҖ gradNormF gradNormG : в„қ, 0 вүӨ gradNormF вҶ’ 0 вүӨ gradNormG вҶ’
    hsSeminormSq 0 (paraRemainder f g) вүӨ
      C ^ 2 * (gradNormF ^ 2 * hsSeminormSq s g
                + gradNormG ^ 2 * hsSeminormSq s f)

/-! ### В§11.7 Full KatoвҖ“Ponce (Phase 9 structural) -/

/-- **KatoвҖ“Ponce product bound (tame).** -/
structure HasKatoPonceProductBound (s C : в„қ) where
  bound : вҲҖ f g : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))),
    вҲҖ normF normG : в„қ, 0 вүӨ normF вҶ’ 0 вүӨ normG вҶ’
    hsSeminormSq s (paraproduct f g) + hsSeminormSq s (paraRemainder f g) вүӨ
      C ^ 2 * (normG ^ 2 * hsSeminormSq s f + normF ^ 2 * hsSeminormSq s g)

/-! ### В§11.8 Galerkin SQG closure (Phase 10) -/

/-- **Phase 10 bridge.** -/
structure HasSqgGalerkinHsClosure
    (s : в„қ) (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)) where
  K : в„қ
  hK_nn : 0 вүӨ K
  hDerivBound : вҲҖ n : в„•, вҲҖ T : в„қ, 0 вүӨ T вҶ’ вҲҖ x вҲҲ Set.Ico (0 : в„қ) T,
    |deriv (fun t => trigPolyEnergyHs s (sqgBox n) (Оұ n t)) x|
      вүӨ K * |trigPolyEnergyHs s (sqgBox n) (Оұ n x)|
  EвӮҖ : в„қ
  hEвӮҖ : вҲҖ n : в„•, trigPolyEnergyHs s (sqgBox n) (Оұ n 0) вүӨ EвӮҖ

/-! ### В§11.9 Phase 10 вҶ’ Phase 5 bridge -/

/-- **Bridge Phase 10 вҶ’ Phase 5**. -/
noncomputable def HasGalerkinHsGronwallFamily.of_sqgClosure
    (s : в„қ) {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (h : HasSqgGalerkinHsClosure s Оұ)
    (hODE : вҲҖ n : в„•, вҲҖ t : в„қ,
      HasDerivAt (Оұ n) (galerkinVectorField (sqgBox n) (Оұ n t)) t) :
    HasGalerkinHsGronwallFamily s Оұ where
  level n := {
    hDeriv := hODE n
    K := h.K
    hDerivBound := h.hDerivBound n
    EвӮҖ := h.EвӮҖ
    hEвӮҖ := h.hEвӮҖ n
  }
  K_uniform := h.K
  hK_uniform := fun _ => rfl
  EвӮҖ_uniform := h.EвӮҖ
  hEвӮҖ_uniform := fun _ => rfl

/-! ### В§11.10 Zero-datum exemplar (Phase 11) -/

/-- **Zero Galerkin trajectory.** -/
noncomputable def zeroGalerkin :
    вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ) :=
  fun _ _ => 0

lemma zeroGalerkin_trigPolyEnergyHs_zero (s : в„қ) (n : в„•) (t : в„қ) :
    trigPolyEnergyHs s (sqgBox n) (zeroGalerkin n t) = 0 := by
  unfold zeroGalerkin trigPolyEnergyHs
  simp

lemma zeroGalerkin_energyFun_const (s : в„қ) (n : в„•) :
    (fun t : в„қ => trigPolyEnergyHs s (sqgBox n) (zeroGalerkin n t))
      = fun _ => (0 : в„қ) := by
  funext t
  exact zeroGalerkin_trigPolyEnergyHs_zero s n t

/-- **Zero Galerkin trajectory satisfies Phase 10 closure.** -/
noncomputable def HasSqgGalerkinHsClosure.ofZero (s : в„қ) :
    HasSqgGalerkinHsClosure s zeroGalerkin where
  K := 0
  hK_nn := le_refl 0
  hDerivBound := by
    intro n _ _ x _
    have hE := zeroGalerkin_energyFun_const s n
    have hd : deriv (fun t : в„қ =>
                trigPolyEnergyHs s (sqgBox n) (zeroGalerkin n t)) x = 0 := by
      rw [hE]; simp
    rw [hd, zeroGalerkin_trigPolyEnergyHs_zero]
    simp
  EвӮҖ := 0
  hEвӮҖ := fun n => (zeroGalerkin_trigPolyEnergyHs_zero s n 0).le

/-! ### В§11.11 Zero-paraproduct Kato-Ponce witness

Since `paraproduct` and `paraRemainder` are both defined as the zero
operator (Phase 7 placeholders), `HasKatoPonceProductBound s 0` holds
trivially.  This demonstrates that the `HasKatoPonceProductBound`
hypothesis is instantiable without additional analytical work on the
stubs.

**In actual SQG application**, once Phase 7 replaces `paraproduct` /
`paraRemainder` with the true LittlewoodвҖ“Paley sums, a non-trivial
`HasKatoPonceProductBound s C` witness is required (classical PDE
content, ~1500-2000 LOC of paraproduct analysis). -/

/-- **Trivial Kato-Ponce product bound** on the zero-paraproduct stub.
Uses `hsSeminormSq_of_zero` to reduce the LHS to 0; RHS is non-negative. -/
noncomputable def HasKatoPonceProductBound.ofZeroStubs (s : в„қ) :
    HasKatoPonceProductBound s 0 where
  bound := by
    intro f g normF normG hF hG
    -- paraproduct = 0 and paraRemainder = 0 by definition; both
    -- occurrences of `hsSeminormSq s 0` collapse at once via simp.
    unfold paraproduct paraRemainder
    rw [hsSeminormSq_of_zero]
    simp

/-- **Trivial Kato-Ponce commutator bound** on the zero-remainder stub. -/
