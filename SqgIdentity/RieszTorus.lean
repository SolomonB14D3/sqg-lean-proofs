/-! ### В§11.12 Phase 10 capstone вҖ” structural chain from closure to
uniform bound

Composes `HasSqgGalerkinHsClosure` + ODE witness (Phase 10) via
`HasGalerkinHsGronwallFamily.of_sqgClosure` (В§11.9) to produce the
compact-interval uniform `бёўЛў` bound on the Galerkin family.  This is
the direct feed into В§10.174's `hBoundS` hypothesis. -/

/-- **Phase 10 capstone**: from `HasSqgGalerkinHsClosure` + ODE
witnesses, extract a single-scalar uniform `бёўЛў` bound on `[0, T]`. -/
theorem HasSqgGalerkinHsClosure.uniform_bound
    (s : в„қ) {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (h : HasSqgGalerkinHsClosure s Оұ)
    (hODE : вҲҖ n : в„•, вҲҖ t : в„қ,
      HasDerivAt (Оұ n) (galerkinVectorField (sqgBox n) (Оұ n t)) t)
    (T : в„қ) (hT : 0 вүӨ T) :
    вҲғ M : в„қ, вҲҖ n : в„•, вҲҖ t : в„қ, 0 вүӨ t вҶ’ t вүӨ T вҶ’
      hsSeminormSq s (galerkinToLp (sqgBox n) (Оұ n t)) вүӨ M :=
  (HasGalerkinHsGronwallFamily.of_sqgClosure s h hODE).global_uniform_bound
    s h.hK_nn T hT

/-! ### В§11.13 Zero-datum exemplar вҖ” Phase 10 вҶ’ Phase 5 uniform bound -/

/-- **Zero-datum Phase 10 uniform bound.** Exercises В§11.12 on the
zero Galerkin trajectory. -/
theorem HasSqgGalerkinHsClosure.uniform_bound_ofZero
    (s : в„қ) (T : в„қ) (hT : 0 вүӨ T) :
    вҲғ M : в„қ, вҲҖ n : в„•, вҲҖ t : в„қ, 0 вүӨ t вҶ’ t вүӨ T вҶ’
      hsSeminormSq s (galerkinToLp (sqgBox n) (zeroGalerkin n t)) вүӨ M := by
  refine вҹЁ0, ?_вҹ©
  intro n t _ _
  rw [show galerkinToLp (sqgBox n) (zeroGalerkin n t)
        = galerkinToLp (sqgBox n) 0 from by unfold zeroGalerkin; rfl]
  rw [galerkinToLp_zero, hsSeminormSq_of_zero]

/-! ### В§11.14 Low-frequency vanishing of `lpProjector` truncations

For any `m вҲү dyadicAnnulus N`, the `О”_N` projection's `m`-mode is 0.
This is the direct consequence of `fourierTruncate_mFourierCoeff_of_not_mem`. -/

lemma lpProjector_vanishes_off_annulus
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (N : в„•) (f : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))
    {m : Fin 2 вҶ’ в„Ө} (hm : m вҲү dyadicAnnulus N) :
    mFourierCoeff (lpProjector N f) m = 0 := by
  unfold lpProjector
  exact fourierTruncate_mFourierCoeff_of_not_mem _ f hm

/-! ### В§11.15 Zero-function preservation

`fourierTruncate A 0 = 0`, `lpProjector N 0 = 0`. -/

lemma fourierTruncate_zero
    (A : Finset (Fin 2 вҶ’ в„Ө)) :
    fourierTruncate A (0 : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) = 0 := by
  unfold fourierTruncate trigPoly
  apply Finset.sum_eq_zero
  intros n _
  show mFourierCoeff (0 : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) n вҖў
    (mFourierLp 2 n : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) = 0
  rw [mFourierCoeff_zero, zero_smul]

lemma lpProjector_zero
    (N : в„•) :
    lpProjector N (0 : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) = 0 := by
  unfold lpProjector
  exact fourierTruncate_zero _

/-! ### В§11.16 Hs-seminorm vanishing under dyadic projection on zero

Direct specializations used by the zero-datum Kato-Ponce chain. -/

lemma hsSeminormSq_lpProjector_zero
    (s : в„қ) (N : в„•) :
    hsSeminormSq s (lpProjector N (0 : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))) = 0 := by
  rw [lpProjector_zero, hsSeminormSq_of_zero]

lemma hsSeminormSq_fourierTruncate_zero
    (s : в„қ) (A : Finset (Fin 2 вҶ’ в„Ө)) :
    hsSeminormSq s (fourierTruncate A (0 : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))) = 0 := by
  rw [fourierTruncate_zero, hsSeminormSq_of_zero]

/-! ### В§11.17 Finite-Fourier-support pointwise product вҖ” mode convolution

Classical KatoвҖ“Ponce uses pointwise multiplication of functions on `рқ•ӢВІ`.
Since `Lp в„Ӯ 2` is not a ring, we work with `trigPoly`-represented
products via the Fourier convolution formula:
  `(f В· g)МӮ(n) = вҲ‘_{a + b = n} fМӮ(a) В· Дқ(b)`.

On finite-Fourier-support data `f = trigPoly A cf`, `g = trigPoly B cg`,
the convolution is a finite sum, and the product is itself a
trigonometric polynomial supported on the Minkowski sum `A + B`.  This
`trigPoly`-representation is the foundation for the concrete
KatoвҖ“Ponce product bound (В§11.20) on the finite-Fourier-support class,
which is what the Galerkin `sqgBox` provides for В§10.174's `hBoundS`. -/

/-- **Minkowski sum of two finsets on `в„ӨВІ`.**  `sumSet A B = A + B`. -/
def sumSet
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) : Finset (Fin 2 вҶ’ в„Ө) :=
  (A Г—Лў B).image (fun p => p.1 + p.2)

lemma mem_sumSet_iff
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {A B : Finset (Fin 2 вҶ’ в„Ө)} {n : Fin 2 вҶ’ в„Ө} :
    n вҲҲ sumSet A B вҶ” вҲғ a вҲҲ A, вҲғ b вҲҲ B, a + b = n := by
  unfold sumSet
  simp only [Finset.mem_image, Finset.mem_product, Prod.exists]
  constructor
  В· rintro вҹЁa, b, вҹЁha, hbвҹ©, hsumвҹ©
    exact вҹЁa, ha, b, hb, hsumвҹ©
  В· rintro вҹЁa, ha, b, hb, hsumвҹ©
    exact вҹЁa, b, вҹЁha, hbвҹ©, hsumвҹ©

/-- **Mode convolution of two finsupp coefficient sequences on `в„ӨВІ`.**
Fourier-side representation of the pointwise product
`trigPoly A cf В· trigPoly B cg`. -/
noncomputable def modeConvolution
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ :=
  fun n => вҲ‘ a вҲҲ A, вҲ‘ b вҲҲ B, if a + b = n then cf a * cg b else 0

/-- **Modes outside `A + B` contribute 0 to the convolution.** -/
lemma modeConvolution_eq_zero_of_not_mem_sumSet
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {A B : Finset (Fin 2 вҶ’ в„Ө)} {cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ}
    {n : Fin 2 вҶ’ в„Ө} (hn : n вҲү sumSet A B) :
    modeConvolution A B cf cg n = 0 := by
  unfold modeConvolution
  apply Finset.sum_eq_zero
  intros a ha
  apply Finset.sum_eq_zero
  intros b hb
  split_ifs with hsum
  В· exfalso
    exact hn (mem_sumSet_iff.mpr вҹЁa, ha, b, hb, hsumвҹ©)
  В· rfl

/-- **`trigPoly`-representation of the pointwise product of two trig polys.**
Defined as `trigPoly (sumSet A B) (modeConvolution A B cf cg)`.  Its
Fourier coefficients equal the convolution everywhere (В§11.17.B). -/
noncomputable def trigPolyProduct
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  trigPoly (sumSet A B) (modeConvolution A B cf cg)

/-- **В§11.17.A вҖ” Raw Fourier coefficients of the trig-poly product.**
Indicator form. -/
theorem mFourierCoeff_trigPolyProduct_ite
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    mFourierCoeff (trigPolyProduct A B cf cg) n
      = if n вҲҲ sumSet A B then modeConvolution A B cf cg n else 0 := by
  unfold trigPolyProduct
  exact mFourierCoeff_trigPoly (sumSet A B) (modeConvolution A B cf cg) n

/-- **В§11.17.B вҖ” Full-range Fourier coefficients of the trig-poly product.**
For every `n : Fin 2 вҶ’ в„Ө`, the Fourier coefficient equals the mode
convolution.  This is the clean form used downstream. -/
theorem mFourierCoeff_trigPolyProduct
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    mFourierCoeff (trigPolyProduct A B cf cg) n
      = modeConvolution A B cf cg n := by
  rw [mFourierCoeff_trigPolyProduct_ite]
  split_ifs with hn
  В· rfl
  В· exact (modeConvolution_eq_zero_of_not_mem_sumSet hn).symm

/-- **В§11.17.C вҖ” Trig-poly product vanishes outside `sumSet A B`.** -/
lemma mFourierCoeff_trigPolyProduct_eq_zero_of_not_mem
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {A B : Finset (Fin 2 вҶ’ в„Ө)} {cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ}
    {n : Fin 2 вҶ’ в„Ө} (hn : n вҲү sumSet A B) :
    mFourierCoeff (trigPolyProduct A B cf cg) n = 0 := by
  rw [mFourierCoeff_trigPolyProduct]
  exact modeConvolution_eq_zero_of_not_mem_sumSet hn

/-- **Mode convolution with zero left factor is zero.** -/
lemma modeConvolution_zero_left
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    modeConvolution A B (fun _ => (0 : в„Ӯ)) cg = fun _ => (0 : в„Ӯ) := by
  funext n
  unfold modeConvolution
  apply Finset.sum_eq_zero
  intros a _
  apply Finset.sum_eq_zero
  intros b _
  split_ifs
  В· rw [zero_mul]
  В· rfl

/-- **Mode convolution with zero right factor is zero.** -/
lemma modeConvolution_zero_right
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    modeConvolution A B cf (fun _ => (0 : в„Ӯ)) = fun _ => (0 : в„Ӯ) := by
  funext n
  unfold modeConvolution
  apply Finset.sum_eq_zero
  intros a _
  apply Finset.sum_eq_zero
  intros b _
  split_ifs
  В· rw [mul_zero]
  В· rfl

/-- **Trig-poly product with zero left factor is zero.** -/
lemma trigPolyProduct_zero_left
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    trigPolyProduct A B (fun _ => (0 : в„Ӯ)) cg = 0 := by
  unfold trigPolyProduct
  rw [modeConvolution_zero_left]
  unfold trigPoly
  apply Finset.sum_eq_zero
  intros n _
  rw [zero_smul]

/-- **Trig-poly product with zero right factor is zero.** -/
lemma trigPolyProduct_zero_right
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    trigPolyProduct A B cf (fun _ => (0 : в„Ӯ)) = 0 := by
  unfold trigPolyProduct
  rw [modeConvolution_zero_right]
  unfold trigPoly
  apply Finset.sum_eq_zero
  intros n _
  rw [zero_smul]

/-! ### В§11.18 Parseval + CauchyвҖ“Schwarz on `trigPolyProduct`

Parseval identity for the `бёўЛў` seminorm of the trig-poly product, and
a CauchyвҖ“Schwarz bound on the mode convolution that yields a concrete
(support-dependent) `LВІ` bound on the product. -/

/-- **В§11.18.A вҖ” Parseval for the trig-poly product's `бёўЛў` seminorm.**
The tsum over `Fin 2 вҶ’ в„Ө` collapses to a finite sum over `sumSet A B`
because the Fourier coefficients vanish off this set. -/
theorem hsSeminormSq_trigPolyProduct
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (s : в„қ) (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      = вҲ‘ n вҲҲ sumSet A B,
          (fracDerivSymbol s n) ^ 2 * вҖ–modeConvolution A B cf cg nвҖ– ^ 2 := by
  unfold hsSeminormSq
  have hZeroOff : вҲҖ n вҲү sumSet A B,
      (fracDerivSymbol s n) ^ 2
          * вҖ–mFourierCoeff (trigPolyProduct A B cf cg) nвҖ– ^ 2 = 0 := by
    intros n hn
    rw [mFourierCoeff_trigPolyProduct_eq_zero_of_not_mem hn, norm_zero]
    ring
  rw [tsum_eq_sum (s := sumSet A B) (fun n hn => hZeroOff n hn)]
  apply Finset.sum_congr rfl
  intros m _
  rw [mFourierCoeff_trigPolyProduct]

/-- **В§11.18.B вҖ” `modeConvolution` as a single sum over `A Г—Лў B`.**
The double sum `вҲ‘ a вҲҲ A, вҲ‘ b вҲҲ B, ...` equals the single product sum. -/
lemma modeConvolution_eq_prod_sum
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    modeConvolution A B cf cg n
      = вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n then cf p.1 * cg p.2 else 0 := by
  unfold modeConvolution
  rw [Finset.sum_product]

/-- **В§11.18.C вҖ” CauchyвҖ“Schwarz on `modeConvolution`.**
`|вҲ‘ ПҮ В· cf В· cg|ВІ вүӨ (A Г—Лў B).card В· вҲ‘ ПҮ В· |cf|ВІ В· |cg|ВІ`.  The support-
dependent factor `|A|В·|B|` is the coarsest CauchyвҖ“Schwarz constant;
В§11.20 refines with the Peetre inequality to replace it. -/
theorem modeConvolution_normSq_le_card_mul_sum
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (A Г—Лў B).card *
          (вҲ‘ p вҲҲ A Г—Лў B,
              if p.1 + p.2 = n then вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 else 0) := by
  rw [modeConvolution_eq_prod_sum]
  -- Drop to the real-absolute-value form.
  set f : (Fin 2 вҶ’ в„Ө) Г— (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ :=
    fun p => if p.1 + p.2 = n then cf p.1 * cg p.2 else 0 with hf_def
  have hNormSq_term : вҲҖ p : (Fin 2 вҶ’ в„Ө) Г— (Fin 2 вҶ’ в„Ө),
      вҖ–f pвҖ– ^ 2
        = if p.1 + p.2 = n then вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 else 0 := by
    intro p
    simp only [hf_def]
    split_ifs
    В· rw [norm_mul, mul_pow]
    В· rw [norm_zero, pow_two, zero_mul]
  -- Triangle: `вҖ–вҲ‘ f pвҖ– вүӨ вҲ‘ вҖ–f pвҖ–`.
  have hTriangle : вҖ–вҲ‘ p вҲҲ A Г—Лў B, f pвҖ– вүӨ вҲ‘ p вҲҲ A Г—Лў B, вҖ–f pвҖ– :=
    norm_sum_le _ _
  -- CauchyвҖ“Schwarz on real sum: `(вҲ‘ вҖ–fвҖ–)ВІ вүӨ card В· вҲ‘ вҖ–fвҖ–ВІ`.
  have hCS : (вҲ‘ p вҲҲ A Г—Лў B, вҖ–f pвҖ–) ^ 2
      вүӨ (A Г—Лў B).card * вҲ‘ p вҲҲ A Г—Лў B, вҖ–f pвҖ– ^ 2 := by
    have hN_nn : вҲҖ p вҲҲ A Г—Лў B, (0 : в„қ) вүӨ вҖ–f pвҖ– := fun p _ => norm_nonneg _
    -- `(вҲ‘ a)ВІ вүӨ card В· вҲ‘ aВІ` via `Finset.sum_mul_sq_le_sq_mul_sq`
    -- (discrete CauchyвҖ“Schwarz) applied to `a = 1, b = вҖ–fвҖ–`.
    have h_ones : (вҲ‘ p вҲҲ A Г—Лў B, (1 : в„қ) * вҖ–f pвҖ–) ^ 2
        вүӨ (вҲ‘ p вҲҲ A Г—Лў B, (1 : в„қ) ^ 2) * (вҲ‘ p вҲҲ A Г—Лў B, вҖ–f pвҖ– ^ 2) :=
      Finset.sum_mul_sq_le_sq_mul_sq _ _ _
    have h_simpвӮҒ : вҲҖ p, (1 : в„қ) * вҖ–f pвҖ– = вҖ–f pвҖ– := fun _ => one_mul _
    have h_simpвӮӮ : (вҲ‘ p вҲҲ A Г—Лў B, (1 : в„қ) ^ 2) = (A Г—Лў B).card := by
      simp
    rw [Finset.sum_congr rfl (fun p _ => h_simpвӮҒ p)] at h_ones
    rw [h_simpвӮӮ] at h_ones
    exact h_ones
  -- Assemble: `вҖ–вҲ‘ fвҖ–ВІ вүӨ (вҲ‘ вҖ–fвҖ–)ВІ вүӨ card В· вҲ‘ вҖ–fвҖ–ВІ`.
  have hSumNn : (0 : в„қ) вүӨ вҲ‘ p вҲҲ A Г—Лў B, вҖ–f pвҖ– :=
    Finset.sum_nonneg (fun p _ => norm_nonneg _)
  have hSq : вҖ–вҲ‘ p вҲҲ A Г—Лў B, f pвҖ– ^ 2 вүӨ (вҲ‘ p вҲҲ A Г—Лў B, вҖ–f pвҖ–) ^ 2 := by
    exact pow_le_pow_leftвӮҖ (norm_nonneg _) hTriangle 2
  calc вҖ–вҲ‘ p вҲҲ A Г—Лў B, f pвҖ– ^ 2
      вүӨ (вҲ‘ p вҲҲ A Г—Лў B, вҖ–f pвҖ–) ^ 2 := hSq
    _ вүӨ (A Г—Лў B).card * вҲ‘ p вҲҲ A Г—Лў B, вҖ–f pвҖ– ^ 2 := hCS
    _ = (A Г—Лў B).card * вҲ‘ p вҲҲ A Г—Лў B,
          (if p.1 + p.2 = n then вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 else 0) := by
          rw [Finset.sum_congr rfl (fun p _ => hNormSq_term p)]

/-! ### В§11.19 Peetre lattice inequality on `latticeNorm` / `fracDerivSymbol`

For `s вүҘ 1`, the Peetre inequality on `в„ӨВІ` gives
  `вҖ–a + bвҖ–^s вүӨ 2^{s-1} В· (вҖ–aвҖ–^s + вҖ–bвҖ–^s)`.
This is the pointwise Fourier-side input for KatoвҖ“Ponce: the symbol
`Пғ_s(m) = вҖ–mвҖ–^s` splits across the convolution. -/

/-- **В§11.19.A вҖ” Peetre lattice inequality.** For `s вүҘ 1` and
`a, b : в„ӨВІ`:
  `вҖ–a + bвҖ–^s вүӨ 2^{s-1} В· (вҖ–aвҖ–^s + вҖ–bвҖ–^s)`.
Proof: triangle inequality on `latticeNorm` + convexity of `t вҶҰ t^s`
on `[0, вҲһ)` (via `NNReal.rpow_add_le_mul_rpow_add_rpow`). -/
lemma latticeNorm_add_rpow_le
    {s : в„қ} (hs : 1 вүӨ s) (a b : Fin 2 вҶ’ в„Ө) :
    (latticeNorm (a + b)) ^ s
      вүӨ 2 ^ (s - 1) * ((latticeNorm a) ^ s + (latticeNorm b) ^ s) := by
  have h_triangle : latticeNorm (a + b) вүӨ latticeNorm a + latticeNorm b :=
    latticeNorm_add_le a b
  have hs_nn : 0 вүӨ s := le_trans zero_le_one hs
  have h_mono : (latticeNorm (a + b)) ^ s вүӨ (latticeNorm a + latticeNorm b) ^ s :=
    Real.rpow_le_rpow (latticeNorm_nonneg _) h_triangle hs_nn
  -- Convexity: `(x+y)^s вүӨ 2^{s-1}В·(x^s + y^s)` for `s вүҘ 1`, `x, y вүҘ 0`.
  -- Lift to `NNReal` to use `NNReal.rpow_add_le_mul_rpow_add_rpow`.
  have h_jensen : (latticeNorm a + latticeNorm b) ^ s
      вүӨ 2 ^ (s - 1) * ((latticeNorm a) ^ s + (latticeNorm b) ^ s) := by
    set x : в„қ := latticeNorm a with hx_def
    set y : в„қ := latticeNorm b with hy_def
    have hx_nn : 0 вүӨ x := latticeNorm_nonneg _
    have hy_nn : 0 вүӨ y := latticeNorm_nonneg _
    lift x to NNReal using hx_nn with xN
    lift y to NNReal using hy_nn with yN
    have hNN : (xN + yN : NNReal) ^ s
        вүӨ (2 : NNReal) ^ (s - 1) * (xN ^ s + yN ^ s) :=
      NNReal.rpow_add_le_mul_rpow_add_rpow xN yN hs
    exact_mod_cast hNN
  linarith

/-- **В§11.19.B вҖ” Uniform expansion `(Пғ_s x)^2 = вҖ–xвҖ–^{2s}` for `s вүҘ 1`.**
Both branches (`x = 0` and `x вү  0`) evaluate to `(latticeNorm x)^(2s)`
via `Real.zero_rpow` and `Real.rpow_mul`. -/
lemma fracDerivSymbol_sq_eq_latticeNorm_rpow
    {s : в„қ} (hs : 1 вүӨ s) (x : Fin 2 вҶ’ в„Ө) :
    (fracDerivSymbol s x) ^ 2 = (latticeNorm x) ^ (2 * s) := by
  have h2s_pos : (0 : в„қ) < 2 * s := by linarith
  have h2s_ne : (2 * s : в„қ) вү  0 := ne_of_gt h2s_pos
  by_cases hx : x = 0
  В· rw [hx, fracDerivSymbol_zero,
        (latticeNorm_eq_zero_iff (0 : Fin 2 вҶ’ в„Ө)).mpr rfl]
    rw [show (0 : в„қ) ^ 2 = 0 from by ring, Real.zero_rpow h2s_ne]
  В· rw [fracDerivSymbol_of_ne_zero s hx,
        вҶҗ Real.rpow_natCast ((latticeNorm x) ^ s) 2,
        вҶҗ Real.rpow_mul (latticeNorm_nonneg _)]
    ring_nf

/-- **В§11.19.C вҖ” Peetre on `fracDerivSymbol` squared.** For `s вүҘ 1` and
any `a, b : в„ӨВІ`:
  `(Пғ_s(a+b))^2 вүӨ 2^{2s-1} В· ((Пғ_s a)^2 + (Пғ_s b)^2)`. -/
lemma fracDerivSymbol_sq_add_le
    {s : в„қ} (hs : 1 вүӨ s) (a b : Fin 2 вҶ’ в„Ө) :
    (fracDerivSymbol s (a + b)) ^ 2
      вүӨ 2 ^ (2 * s - 1)
          * ((fracDerivSymbol s a) ^ 2 + (fracDerivSymbol s b) ^ 2) := by
  rw [fracDerivSymbol_sq_eq_latticeNorm_rpow hs,
      fracDerivSymbol_sq_eq_latticeNorm_rpow hs,
      fracDerivSymbol_sq_eq_latticeNorm_rpow hs]
  have h_2s : 1 вүӨ 2 * s := by linarith
  exact latticeNorm_add_rpow_le h_2s a b

/-- **В§11.19.D вҖ” бёўЛў seminorm of a trig polynomial** вҖ” direct finite-sum
formula.  The tsum collapses since `mFourierCoeff (trigPoly A a) m = 0`
for `m вҲү A`. -/
theorem hsSeminormSq_trigPoly
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (s : в„қ) (A : Finset (Fin 2 вҶ’ в„Ө)) (a : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq s (trigPoly A a)
      = вҲ‘ m вҲҲ A, (fracDerivSymbol s m) ^ 2 * вҖ–a mвҖ– ^ 2 := by
  unfold hsSeminormSq
  have hZeroOff : вҲҖ n вҲү A,
      (fracDerivSymbol s n) ^ 2 * вҖ–mFourierCoeff (trigPoly A a) nвҖ– ^ 2 = 0 := by
    intros n hn
    rw [mFourierCoeff_trigPoly_eq_zero_of_not_mem A a hn, norm_zero]
    ring
  rw [tsum_eq_sum (s := A) (fun n hn => hZeroOff n hn)]
  apply Finset.sum_congr rfl
  intros m hm
  rw [mFourierCoeff_trigPoly, if_pos hm]

/-! ### В§11.20 Concrete tame KatoвҖ“Ponce on `trigPolyProduct` (support-dependent)

Combines В§11.18.C (CauchyвҖ“Schwarz on `modeConvolution`) with В§11.19.C
(Peetre inequality) to give the first concrete tame product bound on
`trigPolyProduct`:

  `вҖ–fgвҖ–ВІ_{бёўЛў} вүӨ (AГ—B).card В· 2^{2s-1}
                В· ((вҲ‘_a Пғ_s(a)ВІ вҖ–cf aвҖ–ВІ)В·(вҲ‘_b вҖ–cg bвҖ–ВІ)
                   + (вҲ‘_a вҖ–cf aвҖ–ВІ)В·(вҲ‘_b Пғ_s(b)ВІ вҖ–cg bвҖ–ВІ))`

The `(AГ—B).card` factor is the support-dependent CauchyвҖ“Schwarz
constant; a uniform (in support) bound requires Young's в„“В№Г—в„“ВІ вҶ’ в„“ВІ
plus `вҲ‘_{m вҲҲ в„ӨВІ} вҖ–mвҖ–^{-2s}` summability for `s > d/2 = 1`, which is
deferred to a follow-on section. -/

/-- **В§11.20.A вҖ” Sum reorder on `sumSet A B Г— (A Г—Лў B)` indicator sums.**
For every function `X : (Fin 2 вҶ’ в„Ө) Г— (Fin 2 вҶ’ в„Ө) вҶ’ в„қ`, summing the
indicator `ПҮ(p.1 + p.2 = n)` across `n вҲҲ sumSet A B` picks the unique
`n = p.1 + p.2`, collapsing the double sum to `вҲ‘_{p вҲҲ A Г—Лў B} X p`. -/
private lemma sum_sumSet_pair_reorder
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (X : (Fin 2 вҶ’ в„Ө) Г— (Fin 2 вҶ’ в„Ө) вҶ’ в„қ) :
    вҲ‘ n вҲҲ sumSet A B, вҲ‘ p вҲҲ A Г—Лў B, (if p.1 + p.2 = n then X p else 0)
      = вҲ‘ p вҲҲ A Г—Лў B, X p := by
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intros p hp
  rw [Finset.mem_product] at hp
  have hsum : p.1 + p.2 вҲҲ sumSet A B :=
    mem_sumSet_iff.mpr вҹЁp.1, hp.1, p.2, hp.2, rflвҹ©
  rw [Finset.sum_eq_single (p.1 + p.2)]
  В· rw [if_pos rfl]
  В· intros n _ hn_ne
    exact if_neg (Ne.symm hn_ne)
  В· intro h_nm; exact absurd hsum h_nm

/-- **В§11.20.B вҖ” бёўЛў seminorm of the trig-poly product: single-sum form.**
Combines Parseval (В§11.18.A) + CauchyвҖ“Schwarz on `modeConvolution`
(В§11.18.C) + sum reorder (В§11.20.A) to reduce to a single sum over
`A Г—Лў B` with weight `(Пғ_s(a+b))ВІ`. -/
private lemma hsSeminormSq_trigPolyProduct_le_sum_pair
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (s : в„қ) (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      вүӨ (A Г—Лў B).card
          * вҲ‘ p вҲҲ A Г—Лў B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 := by
  rw [hsSeminormSq_trigPolyProduct]
  -- Pointwise: (Пғ_s n)ВІ В· вҖ–modeConv nвҖ–ВІ вүӨ (Пғ_s n)ВІ В· (|AГ—B| В· вҲ‘ ...)
  have hPointwise : вҲҖ n вҲҲ sumSet A B,
      (fracDerivSymbol s n) ^ 2 * вҖ–modeConvolution A B cf cg nвҖ– ^ 2
        вүӨ (fracDerivSymbol s n) ^ 2 *
            ((A Г—Лў B).card * вҲ‘ p вҲҲ A Г—Лў B,
              if p.1 + p.2 = n then вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 else 0) := fun n _ =>
    mul_le_mul_of_nonneg_left
      (modeConvolution_normSq_le_card_mul_sum A B cf cg n)
      (sq_nonneg _)
  have h_sum_step1 := Finset.sum_le_sum hPointwise
  -- Rearrange the upper bound into the target form.
  have h_rearrange :
      вҲ‘ n вҲҲ sumSet A B, (fracDerivSymbol s n) ^ 2 *
        ((A Г—Лў B).card * вҲ‘ p вҲҲ A Г—Лў B,
          if p.1 + p.2 = n then вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 else 0)
      = (A Г—Лў B).card *
          вҲ‘ p вҲҲ A Г—Лў B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 := by
    calc вҲ‘ n вҲҲ sumSet A B, (fracDerivSymbol s n) ^ 2 *
          ((A Г—Лў B).card * вҲ‘ p вҲҲ A Г—Лў B,
            if p.1 + p.2 = n then вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 else 0)
        = вҲ‘ n вҲҲ sumSet A B, (A Г—Лў B).card *
            ((fracDerivSymbol s n) ^ 2 *
              вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n then вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 else 0) := by
              apply Finset.sum_congr rfl; intros n _; ring
      _ = (A Г—Лў B).card *
            вҲ‘ n вҲҲ sumSet A B, (fracDerivSymbol s n) ^ 2 *
              вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n then вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 else 0 := by
              rw [вҶҗ Finset.mul_sum]
      _ = (A Г—Лў B).card *
            вҲ‘ n вҲҲ sumSet A B, вҲ‘ p вҲҲ A Г—Лў B,
              (if p.1 + p.2 = n then
                (fracDerivSymbol s (p.1 + p.2)) ^ 2
                  * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2
               else 0) := by
              congr 1
              apply Finset.sum_congr rfl
              intros n _
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intros p _
              split_ifs with h_eq
              В· rw [h_eq]; ring
              В· ring
      _ = (A Г—Лў B).card *
            вҲ‘ p вҲҲ A Г—Лў B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 := by
              congr 1
              exact sum_sumSet_pair_reorder A B
                (fun p => (fracDerivSymbol s (p.1 + p.2)) ^ 2 *
                  вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2)
  linarith

/-- **В§11.20.C вҖ” Concrete tame KatoвҖ“Ponce bound on `trigPolyProduct`.**
For `s вүҘ 1`, combining В§11.20.B with В§11.19.C Peetre gives
  `вҖ–fgвҖ–ВІ_{бёўЛў} вүӨ K В· 2^{2s-1} В· (EвӮҒВ·NвӮӮ + NвӮҒВ·EвӮӮ)`
where `K = (A Г—Лў B).card`, `E_i = вҲ‘ Пғ_sВІ вҖ–c_iвҖ–ВІ`, `N_i = вҲ‘ вҖ–c_iвҖ–ВІ`. -/
theorem hsSeminormSq_trigPolyProduct_le_kato_ponce
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {s : в„қ} (hs : 1 вүӨ s)
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      вүӨ (A Г—Лў B).card * 2 ^ (2 * s - 1) *
          ((вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
              * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2)
           + (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
              * (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2)) := by
  have h_single := hsSeminormSq_trigPolyProduct_le_sum_pair s A B cf cg
  have h_peetre_pw : вҲҖ p вҲҲ A Г—Лў B,
      (fracDerivSymbol s (p.1 + p.2)) ^ 2
          * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2
        вүӨ 2 ^ (2 * s - 1) *
            (((fracDerivSymbol s p.1) ^ 2 * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2)
             + (вҖ–cf p.1вҖ– ^ 2 * (fracDerivSymbol s p.2) ^ 2 * вҖ–cg p.2вҖ– ^ 2)) := by
    intros p _
    have h_peetre := fracDerivSymbol_sq_add_le hs p.1 p.2
    have h_nn : 0 вүӨ вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    calc (fracDerivSymbol s (p.1 + p.2)) ^ 2 * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2
        = (fracDerivSymbol s (p.1 + p.2)) ^ 2 * (вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2) := by ring
      _ вүӨ (2 ^ (2 * s - 1) *
            ((fracDerivSymbol s p.1) ^ 2 + (fracDerivSymbol s p.2) ^ 2))
          * (вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2) :=
            mul_le_mul_of_nonneg_right h_peetre h_nn
      _ = 2 ^ (2 * s - 1) *
            (((fracDerivSymbol s p.1) ^ 2 * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2)
             + (вҖ–cf p.1вҖ– ^ 2 * (fracDerivSymbol s p.2) ^ 2 * вҖ–cg p.2вҖ– ^ 2)) := by ring
  have h_sum_peetre := Finset.sum_le_sum h_peetre_pw
  -- Distribute and factor.
  have h_simp_sum :
      вҲ‘ p вҲҲ A Г—Лў B, 2 ^ (2 * s - 1) *
        (((fracDerivSymbol s p.1) ^ 2 * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2)
         + (вҖ–cf p.1вҖ– ^ 2 * (fracDerivSymbol s p.2) ^ 2 * вҖ–cg p.2вҖ– ^ 2))
        = 2 ^ (2 * s - 1) *
            ((вҲ‘ p вҲҲ A Г—Лў B,
                (fracDerivSymbol s p.1) ^ 2 * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2)
             + (вҲ‘ p вҲҲ A Г—Лў B,
                вҖ–cf p.1вҖ– ^ 2 * (fracDerivSymbol s p.2) ^ 2 * вҖ–cg p.2вҖ– ^ 2)) := by
    rw [вҶҗ Finset.mul_sum, Finset.sum_add_distrib]
  have h_factorвӮҒ :
      вҲ‘ p вҲҲ A Г—Лў B,
          (fracDerivSymbol s p.1) ^ 2 * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2
        = (вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
            * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by
    calc вҲ‘ p вҲҲ A Г—Лў B,
            (fracDerivSymbol s p.1) ^ 2 * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2
        = вҲ‘ a вҲҲ A, вҲ‘ b вҲҲ B,
            (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2 * вҖ–cg bвҖ– ^ 2 := by
              rw [Finset.sum_product]
      _ = вҲ‘ a вҲҲ A,
            ((fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2) * вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2 := by
              apply Finset.sum_congr rfl
              intros a _
              rw [вҶҗ Finset.mul_sum]
      _ = (вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
            * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by
              rw [вҶҗ Finset.sum_mul]
  have h_factorвӮӮ :
      вҲ‘ p вҲҲ A Г—Лў B,
          вҖ–cf p.1вҖ– ^ 2 * (fracDerivSymbol s p.2) ^ 2 * вҖ–cg p.2вҖ– ^ 2
        = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
            * (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2) := by
    calc вҲ‘ p вҲҲ A Г—Лў B,
            вҖ–cf p.1вҖ– ^ 2 * (fracDerivSymbol s p.2) ^ 2 * вҖ–cg p.2вҖ– ^ 2
        = вҲ‘ a вҲҲ A, вҲ‘ b вҲҲ B,
            вҖ–cf aвҖ– ^ 2 * (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2 := by
              rw [Finset.sum_product]
      _ = вҲ‘ a вҲҲ A,
            вҖ–cf aвҖ– ^ 2 * вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2 := by
              apply Finset.sum_congr rfl
              intros a _
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intros b _
              ring
      _ = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
            * (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2) := by
              rw [вҶҗ Finset.sum_mul]
  have h_card_nn : (0 : в„қ) вүӨ (A Г—Лў B).card := by exact_mod_cast Nat.zero_le _
  -- Assemble.
  calc hsSeminormSq s (trigPolyProduct A B cf cg)
      вүӨ (A Г—Лў B).card
          * вҲ‘ p вҲҲ A Г—Лў B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2 := h_single
    _ вүӨ (A Г—Лў B).card *
          (2 ^ (2 * s - 1) *
            ((вҲ‘ p вҲҲ A Г—Лў B,
                (fracDerivSymbol s p.1) ^ 2 * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2)
             + (вҲ‘ p вҲҲ A Г—Лў B,
                вҖ–cf p.1вҖ– ^ 2 * (fracDerivSymbol s p.2) ^ 2 * вҖ–cg p.2вҖ– ^ 2))) := by
          apply mul_le_mul_of_nonneg_left _ h_card_nn
          calc вҲ‘ p вҲҲ A Г—Лў B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * вҖ–cf p.1вҖ– ^ 2 * вҖ–cg p.2вҖ– ^ 2
              вүӨ _ := h_sum_peetre
            _ = _ := h_simp_sum
    _ = (A Г—Лў B).card * 2 ^ (2 * s - 1) *
          ((вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
              * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2)
           + (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
              * (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2)) := by
          rw [h_factorвӮҒ, h_factorвӮӮ]; ring

/-! ### В§11.21 Concrete trig-poly KatoвҖ“Ponce bound as a hypothesis type

Bundles В§11.20.C into a named hypothesis structure `HasTrigPolyKatoPonceBound`
parallel to `HasKatoPonceProductBound` (В§11.7), but keyed on the
trig-poly pointwise product `trigPolyProduct` rather than the
paraproduct stubs.  Admits a concrete instance with `C = 2^{2s-1}`
for any `s вүҘ 1` via В§11.20.C. -/

/-- **Trig-poly KatoвҖ“Ponce bound** hypothesis.  Bounds the `бёўЛў` seminorm
of `trigPolyProduct A B cf cg` in a Leibniz-style split `бёўЛўВ·LВІ + LВІВ·бёўЛў`,
with the support-dependent factor `(A Г—Лў B).card` absorbed into the
bound body.  `C` is the support-INDEPENDENT constant. -/
structure HasTrigPolyKatoPonceBound (s : в„қ) (C : в„қ) where
  bound : вҲҖ (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ),
    hsSeminormSq s (trigPolyProduct A B cf cg)
      вүӨ C * ((A Г—Лў B).card : в„қ) *
          ((вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
              * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2)
           + (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
              * (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2))

/-- **В§11.21.A вҖ” Concrete `HasTrigPolyKatoPonceBound` from В§11.20.C.**
For `s вүҘ 1`, `HasTrigPolyKatoPonceBound s (2^{2s-1})` holds. -/
noncomputable def HasTrigPolyKatoPonceBound.of_peetre
    {s : в„қ} (hs : 1 вүӨ s) :
    HasTrigPolyKatoPonceBound s (2 ^ (2 * s - 1)) where
  bound := by
    intros A B cf cg
    classical
    have h := hsSeminormSq_trigPolyProduct_le_kato_ponce hs A B cf cg
    -- h : LHS вүӨ (A Г—Лў B).card * 2^(2s-1) * (...)
    -- Goal: LHS вүӨ 2^(2s-1) * ((A Г—Лў B).card : в„қ) * (...)
    -- Same bound modulo NatвҶ’Real coercion + commutativity.
    calc hsSeminormSq s (trigPolyProduct A B cf cg)
        вүӨ (A Г—Лў B).card * 2 ^ (2 * s - 1) *
            ((вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
                * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2)
             + (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
                * (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2)) := h
      _ = 2 ^ (2 * s - 1) * ((A Г—Лў B).card : в„қ) *
            ((вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
                * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2)
             + (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
                * (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2)) := by
            push_cast
            ring

/-! ### В§11.22 Young's в„“В№ Г— в„“ВІ вҶ’ в„“ВІ on `modeConvolution`

The finite-lattice version of Young's convolution inequality:
  `вҲ‘_n |modeConv(A, B, cf, cg)(n)|ВІ вүӨ (вҲ‘_a |cf a|)ВІ В· (вҲ‘_b |cg b|ВІ)`

This is support-independent in the в„“В№ norm of `cf`: the RHS does not
carry the `(A Г—Лў B).card` factor of В§11.20.  Combined with the в„“В№
CauchyвҖ“Schwarz bound `(вҲ‘ |cf a|)ВІ вүӨ C_s В· вҖ–fвҖ–ВІ_{H^s}` (for `s > d/2`,
via lattice summability of `вҲ‘ вҹЁmвҹ©^{-2s}`), this delivers the genuinely
uniform-in-support KatoвҖ“Ponce bound.  This section proves the Young
half; the CauchyвҖ“Schwarz half is В§11.23. -/

/-- **В§11.22.A вҖ” Triangle bound on `modeConvolution`.** -/
private lemma modeConvolution_norm_le_sum_abs
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    вҖ–modeConvolution A B cf cg nвҖ–
      вүӨ вҲ‘ p вҲҲ A Г—Лў B,
          (if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0) := by
  rw [modeConvolution_eq_prod_sum]
  refine le_trans (norm_sum_le _ _) ?_
  apply Finset.sum_le_sum
  intros p _
  by_cases h : p.1 + p.2 = n
  В· rw [if_pos h, if_pos h, norm_mul]
  В· rw [if_neg h, if_neg h, norm_zero]

/-- **В§11.22.B вҖ” Weighted CauchyвҖ“Schwarz on the indicator sum.**
`(вҲ‘ ПҮ В· |cf|В·|cg|)ВІ вүӨ (вҲ‘ ПҮ В· |cf|) В· (вҲ‘ ПҮ В· |cf|В·|cg|ВІ)`.
Applies `Finset.sum_mul_sq_le_sq_mul_sq` with `F = ПҮ В· вҲҡ|cf|` and
`G = ПҮ В· вҲҡ|cf|В·|cg|`. -/
private lemma sum_pair_indicator_sq_le_cs
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    (вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0) ^ 2
      вүӨ (вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n then вҖ–cf p.1вҖ– else 0)
          * (вҲ‘ p вҲҲ A Г—Лў B,
              if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 else 0) := by
  set F : (Fin 2 вҶ’ в„Ө) Г— (Fin 2 вҶ’ в„Ө) вҶ’ в„қ := fun p =>
    if p.1 + p.2 = n then Real.sqrt вҖ–cf p.1вҖ– else 0 with hF_def
  set G : (Fin 2 вҶ’ в„Ө) Г— (Fin 2 вҶ’ в„Ө) вҶ’ в„қ := fun p =>
    if p.1 + p.2 = n then Real.sqrt вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0 with hG_def
  have h_FG : вҲҖ p, F p * G p
      = if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0 := by
    intro p
    simp only [hF_def, hG_def]
    by_cases h : p.1 + p.2 = n
    В· rw [if_pos h, if_pos h, if_pos h]
      rw [вҶҗ mul_assoc, Real.mul_self_sqrt (norm_nonneg _)]
    В· rw [if_neg h, if_neg h, if_neg h]; ring
  have h_F_sq : вҲҖ p, F p ^ 2
      = if p.1 + p.2 = n then вҖ–cf p.1вҖ– else 0 := by
    intro p
    simp only [hF_def]
    by_cases h : p.1 + p.2 = n
    В· rw [if_pos h, if_pos h, Real.sq_sqrt (norm_nonneg _)]
    В· rw [if_neg h, if_neg h]; ring
  have h_G_sq : вҲҖ p, G p ^ 2
      = if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 else 0 := by
    intro p
    simp only [hG_def]
    by_cases h : p.1 + p.2 = n
    В· rw [if_pos h, if_pos h, mul_pow, Real.sq_sqrt (norm_nonneg _)]
    В· rw [if_neg h, if_neg h]; ring
  have hCS := Finset.sum_mul_sq_le_sq_mul_sq (A Г—Лў B) F G
  rw [Finset.sum_congr rfl (fun p _ => h_FG p),
      Finset.sum_congr rfl (fun p _ => h_F_sq p),
      Finset.sum_congr rfl (fun p _ => h_G_sq p)] at hCS
  exact hCS

/-- **В§11.22.C вҖ” First factor bound.** Sum of `ПҮ(a+b=n) В· вҖ–cf aвҖ–`
across `A Г—Лў B` is bounded by `вҲ‘_{a вҲҲ A} вҖ–cf aвҖ–` (independent of `n`). -/
private lemma sum_pair_indicator_first_le_в„“1
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    (вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n then вҖ–cf p.1вҖ– else 0)
      вүӨ вҲ‘ a вҲҲ A, вҖ–cf aвҖ– := by
  calc вҲ‘ p вҲҲ A Г—Лў B, (if p.1 + p.2 = n then вҖ–cf p.1вҖ– else 0)
      = вҲ‘ a вҲҲ A, вҲ‘ b вҲҲ B, (if a + b = n then вҖ–cf aвҖ– else 0) := by
          rw [Finset.sum_product]
    _ вүӨ вҲ‘ a вҲҲ A, вҖ–cf aвҖ– := by
          apply Finset.sum_le_sum
          intros a _
          -- Inner sum: вҲ‘ b вҲҲ B, if a + b = n then вҖ–cf aвҖ– else 0 вүӨ вҖ–cf aвҖ–.
          -- Either n - a вҲҲ B (one term contributes вҖ–cf aвҖ–) or no term contributes.
          by_cases hb : n - a вҲҲ B
          В· -- Express the sum by isolating the unique b = n - a term.
            have h_inner : вҲ‘ b вҲҲ B, (if a + b = n then вҖ–cf aвҖ– else 0) = вҖ–cf aвҖ– := by
              rw [Finset.sum_eq_single (n - a)]
              В· have : a + (n - a) = n := by abel
                rw [if_pos this]
              В· intros b hb_mem hb_ne
                have h_not : В¬ (a + b = n) := by
                  intro h_eq
                  have : b = n - a := by
                    have : a + b - a = n - a := by rw [h_eq]
                    rwa [add_comm a b, add_sub_cancel_right] at this
                  exact hb_ne this
                rw [if_neg h_not]
              В· intros h_nm; exact absurd hb h_nm
            rw [h_inner]
          В· -- All terms are zero.
            have h_inner : вҲ‘ b вҲҲ B, (if a + b = n then вҖ–cf aвҖ– else 0) = 0 := by
              apply Finset.sum_eq_zero
              intros b hb_mem
              have h_not : В¬ (a + b = n) := by
                intro h_eq
                apply hb
                have : b = n - a := by
                  have : a + b - a = n - a := by rw [h_eq]
                  rwa [add_comm a b, add_sub_cancel_right] at this
                rw [вҶҗ this]; exact hb_mem
              rw [if_neg h_not]
            rw [h_inner]
            exact norm_nonneg _

/-- **В§11.22.D вҖ” Inner-sum swap via В§11.20.A pattern.**
`вҲ‘ n вҲҲ sumSet, вҲ‘ p, ПҮ(p.1+p.2=n) В· X(p) = вҲ‘ p, X(p)`.
Specialized form used below. -/
private lemma sum_sumSet_pair_cfcg_reorder
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    вҲ‘ n вҲҲ sumSet A B, вҲ‘ p вҲҲ A Г—Лў B,
        (if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 else 0)
      = вҲ‘ p вҲҲ A Г—Лў B, вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 :=
  sum_sumSet_pair_reorder A B (fun p => вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2)

/-- **В§11.22.E вҖ” Young's в„“В№ Г— в„“ВІ вҶ’ в„“ВІ on `modeConvolution`.**
`вҲ‘_{n вҲҲ sumSet} вҖ–modeConv(n)вҖ–ВІ вүӨ (вҲ‘_a вҖ–cf aвҖ–)ВІ В· (вҲ‘_b вҖ–cg bвҖ–ВІ)`. -/
theorem hsSeminormSq_zero_trigPolyProduct_le_young
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) ^ 2 * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by
  -- Step 1: Pointwise bound via triangle + CS.
  have h_pointwise : вҲҖ n вҲҲ sumSet A B,
      вҖ–modeConvolution A B cf cg nвҖ– ^ 2
        вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–)
            * (вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 else 0) := by
    intros n _
    have h_tri := modeConvolution_norm_le_sum_abs A B cf cg n
    have h_tri_sq : вҖ–modeConvolution A B cf cg nвҖ– ^ 2
        вүӨ (вҲ‘ p вҲҲ A Г—Лў B,
            if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0) ^ 2 :=
      pow_le_pow_leftвӮҖ (norm_nonneg _) h_tri 2
    have h_cs := sum_pair_indicator_sq_le_cs A B cf cg n
    have h_first_bound := sum_pair_indicator_first_le_в„“1 A B cf n
    have h_second_nn : 0 вүӨ вҲ‘ p вҲҲ A Г—Лў B,
        (if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 else 0) :=
      Finset.sum_nonneg (fun p _ => by
        split_ifs
        В· exact mul_nonneg (norm_nonneg _) (sq_nonneg _)
        В· exact le_refl _)
    calc вҖ–modeConvolution A B cf cg nвҖ– ^ 2
        вүӨ (вҲ‘ p вҲҲ A Г—Лў B,
            if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0) ^ 2 := h_tri_sq
      _ вүӨ (вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n then вҖ–cf p.1вҖ– else 0)
            * (вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 else 0) := h_cs
      _ вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–)
            * (вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 else 0) :=
            mul_le_mul_of_nonneg_right h_first_bound h_second_nn
  -- Step 2: Sum over n вҲҲ sumSet A B.
  have h_sum := Finset.sum_le_sum h_pointwise
  -- Step 3: Factor (вҲ‘ вҖ–cfвҖ–) out + apply sum reorder (В§11.22.D).
  have h_factor :
      вҲ‘ n вҲҲ sumSet A B, (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) *
          (вҲ‘ p вҲҲ A Г—Лў B,
              if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 else 0)
        = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) *
            вҲ‘ p вҲҲ A Г—Лў B, вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2 := by
    rw [вҶҗ Finset.mul_sum]
    congr 1
    exact sum_sumSet_pair_cfcg_reorder A B cf cg
  rw [h_factor] at h_sum
  -- Step 4: Factor the product sum.
  have h_factor_prod :
      вҲ‘ p вҲҲ A Г—Лў B, вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2
        = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by
    calc вҲ‘ p вҲҲ A Г—Лў B, вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– ^ 2
        = вҲ‘ a вҲҲ A, вҲ‘ b вҲҲ B, вҖ–cf aвҖ– * вҖ–cg bвҖ– ^ 2 := by
              rw [Finset.sum_product]
      _ = вҲ‘ a вҲҲ A, вҖ–cf aвҖ– * вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2 := by
              apply Finset.sum_congr rfl
              intros a _
              rw [вҶҗ Finset.mul_sum]
      _ = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by
              rw [вҶҗ Finset.sum_mul]
  rw [h_factor_prod] at h_sum
  calc вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) *
          ((вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2)) := h_sum
    _ = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) ^ 2 * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by ring

/-! ### В§11.23 CauchyвҖ“Schwarz bridge: `в„“В№` вҶ’ weighted `в„“ВІ`

For `s > 0` and `0 вҲү A`:
  `(вҲ‘_{a вҲҲ A} вҖ–cf aвҖ–)ВІ вүӨ (вҲ‘_{a вҲҲ A} вҖ–aвҖ–^{-2s}) В· hsSeminormSq s (trigPoly A cf)`.

Combined with В§11.22 (Young `в„“В№ Г— в„“ВІ вҶ’ в„“ВІ`) this yields the genuinely
uniform-in-support KatoвҖ“Ponce bound (В§11.24), because
`вҲ‘_{a вҲҲ A} вҖ–aвҖ–^{-2s} вүӨ вҲ‘_{a вҲҲ в„ӨВІ \ {0}} вҖ–aвҖ–^{-2s} = C_s^{glob} < вҲһ`
for `s > d/2 = 1` on `рқ•ӢВІ` (lattice zeta summability, deferred). -/

/-- **В§11.23.A вҖ” CauchyвҖ“Schwarz bridge.**  For `s > 0` and `0 вҲү A`,
the `в„“В№` norm of `cf` is bounded by the lattice-summability constant
`вҲ‘ вҖ–aвҖ–^{-2s}` times `hsSeminormSq s (trigPoly A cf)`. -/
theorem sum_norm_sq_le_latticeWeight_mul_hsSeminormSq
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {A : Finset (Fin 2 вҶ’ в„Ө)} (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A)
    {s : в„қ} (hs : 0 < s) (cf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) ^ 2
      вүӨ (вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf) := by
  -- CauchyвҖ“Schwarz on reals with F = вҖ–aвҖ–^{-s}, G = вҖ–aвҖ–^s В· вҖ–cf aвҖ–.
  have h_cs := Finset.sum_mul_sq_le_sq_mul_sq A
    (fun a => (latticeNorm a) ^ (-s))
    (fun a => (latticeNorm a) ^ s * вҖ–cf aвҖ–)
  -- Massage the CS factors.
  have h_prod : вҲҖ a вҲҲ A,
      (latticeNorm a) ^ (-s) * ((latticeNorm a) ^ s * вҖ–cf aвҖ–) = вҖ–cf aвҖ– := by
    intros a ha
    have h_ne : a вү  0 := fun h => hA (h в–ё ha)
    have h_pos : 0 < latticeNorm a := latticeNorm_pos h_ne
    rw [вҶҗ mul_assoc, вҶҗ Real.rpow_add h_pos,
        show (-s + s : в„қ) = 0 from by ring,
        Real.rpow_zero, one_mul]
  have h_f_sq : вҲҖ a вҲҲ A,
      ((latticeNorm a) ^ (-s)) ^ 2 = (latticeNorm a) ^ (-(2 * s)) := by
    intros a _
    rw [вҶҗ Real.rpow_natCast ((latticeNorm a) ^ (-s)) 2,
        вҶҗ Real.rpow_mul (latticeNorm_nonneg _)]
    congr 1
    push_cast
    ring
  have h_g_sq : вҲҖ a вҲҲ A,
      ((latticeNorm a) ^ s * вҖ–cf aвҖ–) ^ 2
        = (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2 := by
    intros a ha
    rw [mul_pow]
    congr 1
    have h_ne : a вү  0 := fun h => hA (h в–ё ha)
    rw [fracDerivSymbol_of_ne_zero s h_ne]
  -- Rewrite h_cs to match the goal.
  rw [Finset.sum_congr rfl h_prod,
      Finset.sum_congr rfl h_f_sq,
      Finset.sum_congr rfl h_g_sq] at h_cs
  rw [hsSeminormSq_trigPoly]
  exact h_cs

/-! ### В§11.24 Uniform-in-support LВІ product bound

Combining В§11.22 (Young) + В§11.23 (CS bridge) gives the uniform
finite-lattice LВІ product bound:

  `вҲ‘_n вҖ–modeConv(n)вҖ–ВІ вүӨ C_s(A) В· hsSeminormSq s (trigPoly A cf) В· (вҲ‘_b вҖ–cg bвҖ–ВІ)`

where `C_s(A) = вҲ‘_{a вҲҲ A} вҖ–aвҖ–^{-2s}` is bounded by the (lattice)
zeta `вҲ‘_{a вҲҲ в„ӨВІ \ {0}} вҖ–aвҖ–^{-2s}` which is finite for `s > d/2 = 1`.
For the Galerkin scheme at `A = sqgBox n` (`0 вҲү sqgBox n`), this
delivers the uniform-in-`n` `LВІ` product bound. -/

/-- **В§11.24 вҖ” Uniform-in-support LВІ product bound.** -/
theorem l2_trigPolyProduct_le_uniform
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {A B : Finset (Fin 2 вҶ’ в„Ө)} (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A)
    {s : в„қ} (hs : 0 < s) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf)
          * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by
  have h_young := hsSeminormSq_zero_trigPolyProduct_le_young A B cf cg
  have h_cs := sum_norm_sq_le_latticeWeight_mul_hsSeminormSq hA hs cf
  have h_cg_nn : 0 вүӨ вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2 :=
    Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  calc вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) ^ 2 * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := h_young
    _ вүӨ ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf))
        * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) :=
          mul_le_mul_of_nonneg_right h_cs h_cg_nn
    _ = (вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf)
          * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by ring

/-! ### В§11.25 Symmetry of `modeConvolution` + symmetric Young

The mode convolution is commutative in its two factors:
`modeConvolution A B cf cg n = modeConvolution B A cg cf n`.
Combined with `sumSet A B = sumSet B A`, this symmetry lets us apply
В§11.22 with factors swapped to get the symmetric Young direction:
`вҲ‘_n вҖ–modeConv(n)вҖ–ВІ вүӨ (вҲ‘_a вҖ–cf aвҖ–ВІ) В· (вҲ‘_b вҖ–cg bвҖ–)ВІ`. -/

/-- **В§11.25.AвӮҒ вҖ” `sumSet` is symmetric.** -/
lemma sumSet_symm
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) :
    sumSet A B = sumSet B A := by
  ext n
  rw [mem_sumSet_iff, mem_sumSet_iff]
  constructor
  В· rintro вҹЁa, ha, b, hb, hsumвҹ©
    exact вҹЁb, hb, a, ha, by rw [вҶҗ hsum]; abelвҹ©
  В· rintro вҹЁb, hb, a, ha, hsumвҹ©
    exact вҹЁa, ha, b, hb, by rw [вҶҗ hsum]; abelвҹ©

/-- **В§11.25.AвӮӮ вҖ” `modeConvolution` is commutative in its factors.** -/
lemma modeConvolution_symm
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    modeConvolution A B cf cg n = modeConvolution B A cg cf n := by
  unfold modeConvolution
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intros b _
  apply Finset.sum_congr rfl
  intros a _
  by_cases h : a + b = n
  В· rw [if_pos h, if_pos (show b + a = n from by rw [add_comm]; exact h)]
    ring
  В· rw [if_neg h, if_neg (show В¬ (b + a = n) from fun h' => h (by rw [add_comm]; exact h'))]

/-- **В§11.25.B вҖ” Symmetric Young on `modeConvolution`.**  Apply В§11.22
with the roles of `cf` and `cg` swapped (plus В§11.25.A symmetries). -/
theorem hsSeminormSq_zero_trigPolyProduct_le_young_symm
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ–) ^ 2 := by
  -- Reduce to В§11.22 applied to (B, A, cg, cf).
  have h_young := hsSeminormSq_zero_trigPolyProduct_le_young B A cg cf
  -- Transform the LHS via symmetries.
  have h_lhs : вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      = вҲ‘ n вҲҲ sumSet B A, вҖ–modeConvolution B A cg cf nвҖ– ^ 2 := by
    rw [sumSet_symm A B]
    apply Finset.sum_congr rfl
    intros n _
    rw [modeConvolution_symm A B cf cg n]
  -- Transform the RHS to match В§11.25.B's target form.
  have h_rhs : (вҲ‘ b вҲҲ B, вҖ–cg bвҖ–) ^ 2 * (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
      = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ–) ^ 2 := by ring
  calc вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      = вҲ‘ n вҲҲ sumSet B A, вҖ–modeConvolution B A cg cf nвҖ– ^ 2 := h_lhs
    _ вүӨ (вҲ‘ b вҲҲ B, вҖ–cg bвҖ–) ^ 2 * (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2) := h_young
    _ = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ–) ^ 2 := h_rhs

/-! ### В§11.25.C Peetre-weighted Young via complex embedding

For the Peetre-weighted sub-convolution
`T_1'(n) = вҲ‘_{a+b=n} Пғ_s(a) В· вҖ–cf(a)вҖ– В· вҖ–cg(b)вҖ–`,
Young's inequality (В§11.25.B direction) delivers:
  `вҲ‘_n T_1'(n)ВІ вүӨ hsSeminormSq s (trigPoly A cf) В· (вҲ‘_b вҖ–cg bвҖ–)ВІ`.

The proof embeds the real nonneg weighted sequences into `в„Ӯ` via
`Complex.ofReal`, reducing to В§11.25.B on the embedded data. -/

/-- **В§11.25.C вҖ” Peetre-weighted Young (first-factor weight on `cf`).** -/
private theorem young_peetre_weighted_left
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (s : в„қ) (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    вҲ‘ n вҲҲ sumSet A B,
      (вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
        then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0) ^ 2
      вүӨ (вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
          * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ–) ^ 2 := by
  -- Embed the real nonneg weighted factors into в„Ӯ.
  set wcf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ := fun a =>
    ((fracDerivSymbol s a * вҖ–cf aвҖ– : в„қ) : в„Ӯ) with hwcf_def
  set acg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ := fun b => ((вҖ–cg bвҖ– : в„қ) : в„Ӯ) with hacg_def
  have h_wcf_nn : вҲҖ a, 0 вүӨ fracDerivSymbol s a * вҖ–cf aвҖ– :=
    fun a => mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _)
  have h_wcf_norm : вҲҖ a, вҖ–wcf aвҖ– = fracDerivSymbol s a * вҖ–cf aвҖ– := by
    intro a
    simp only [hwcf_def, Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_nonneg (h_wcf_nn a)
  have h_acg_norm : вҲҖ b, вҖ–acg bвҖ– = вҖ–cg bвҖ– := by
    intro b
    simp only [hacg_def, Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_nonneg (norm_nonneg _)
  -- modeConv A B wcf acg n is real nonneg.
  have h_modeConv_eq : вҲҖ n,
      modeConvolution A B wcf acg n
        = ((вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
            then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0 : в„қ) : в„Ӯ) := by
    intro n
    rw [modeConvolution_eq_prod_sum]
    rw [show ((вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
        then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0 : в„қ) : в„Ӯ)
        = вҲ‘ p вҲҲ A Г—Лў B, ((if p.1 + p.2 = n
          then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0 : в„қ) : в„Ӯ) from by
      push_cast; rfl]
    apply Finset.sum_congr rfl
    intros p _
    simp only [hwcf_def, hacg_def]
    by_cases hp : p.1 + p.2 = n
    В· rw [if_pos hp, if_pos hp]
      push_cast; ring
    В· rw [if_neg hp, if_neg hp]
      push_cast; rfl
  have h_sum_nn : вҲҖ n, 0 вүӨ вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
      then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0 := by
    intro n
    apply Finset.sum_nonneg
    intros p _
    split_ifs
    В· exact mul_nonneg (h_wcf_nn _) (norm_nonneg _)
    В· exact le_refl _
  have h_norm_eq : вҲҖ n,
      вҖ–modeConvolution A B wcf acg nвҖ–
        = вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
          then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0 := by
    intro n
    rw [h_modeConv_eq n, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (h_sum_nn n)]
  -- Apply В§11.25.B.
  have h_young := hsSeminormSq_zero_trigPolyProduct_le_young_symm A B wcf acg
  -- Transform LHS of h_young using h_norm_eq.
  have h_lhs_eq :
      (вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B wcf acg nвҖ– ^ 2)
        = вҲ‘ n вҲҲ sumSet A B, (вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
            then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0) ^ 2 := by
    apply Finset.sum_congr rfl
    intros n _
    rw [h_norm_eq n]
  rw [h_lhs_eq] at h_young
  -- Transform RHS of h_young using h_wcf_norm, h_acg_norm.
  have h_rhs_cf :
      (вҲ‘ a вҲҲ A, вҖ–wcf aвҖ– ^ 2)
        = вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2 := by
    apply Finset.sum_congr rfl
    intros a _
    rw [h_wcf_norm a, mul_pow]
  have h_rhs_cg :
      (вҲ‘ b вҲҲ B, вҖ–acg bвҖ–) = вҲ‘ b вҲҲ B, вҖ–cg bвҖ– := by
    apply Finset.sum_congr rfl
    intros b _
    rw [h_acg_norm b]
  rw [h_rhs_cf, h_rhs_cg] at h_young
  exact h_young

/-- **В§11.25.CвӮӮ вҖ” Linear-form (sqrt) Peetre inequality.**  Taking
square roots in В§11.19.C:
  `Пғ_s(a+b) вүӨ вҲҡ(2^{2s-1}) В· (Пғ_s a + Пғ_s b)` for `s вүҘ 1`. -/
lemma fracDerivSymbol_add_le_sqrt
    {s : в„қ} (hs : 1 вүӨ s) (a b : Fin 2 вҶ’ в„Ө) :
    fracDerivSymbol s (a + b)
      вүӨ Real.sqrt (2 ^ (2 * s - 1))
          * (fracDerivSymbol s a + fracDerivSymbol s b) := by
  have h_sq := fracDerivSymbol_sq_add_le hs a b
  have ha_nn := fracDerivSymbol_nonneg s a
  have hb_nn := fracDerivSymbol_nonneg s b
  have h_lhs_nn := fracDerivSymbol_nonneg s (a + b)
  have h_sum_nn : 0 вүӨ fracDerivSymbol s a + fracDerivSymbol s b := add_nonneg ha_nn hb_nn
  -- (Пғ_s a)ВІ + (Пғ_s b)ВІ вүӨ (Пғ_s a + Пғ_s b)ВІ
  have h_subadd : (fracDerivSymbol s a) ^ 2 + (fracDerivSymbol s b) ^ 2
      вүӨ (fracDerivSymbol s a + fracDerivSymbol s b) ^ 2 := by
    nlinarith [mul_nonneg ha_nn hb_nn]
  have h_pow_nn : (0 : в„қ) вүӨ (2 : в„қ) ^ (2 * s - 1) :=
    Real.rpow_nonneg (by norm_num) _
  -- (Пғ_s(a+b))ВІ вүӨ 2^{2s-1} В· (Пғ_s a + Пғ_s b)ВІ
  have h_combined : (fracDerivSymbol s (a + b)) ^ 2
      вүӨ 2 ^ (2 * s - 1) * (fracDerivSymbol s a + fracDerivSymbol s b) ^ 2 := by
    calc (fracDerivSymbol s (a + b)) ^ 2
        вүӨ 2 ^ (2 * s - 1) *
            ((fracDerivSymbol s a) ^ 2 + (fracDerivSymbol s b) ^ 2) := h_sq
      _ вүӨ 2 ^ (2 * s - 1) *
            (fracDerivSymbol s a + fracDerivSymbol s b) ^ 2 :=
          mul_le_mul_of_nonneg_left h_subadd h_pow_nn
  -- Take sqrt on both sides.
  have h_rhs_sq :
      (Real.sqrt (2 ^ (2 * s - 1))
          * (fracDerivSymbol s a + fracDerivSymbol s b)) ^ 2
        = 2 ^ (2 * s - 1) * (fracDerivSymbol s a + fracDerivSymbol s b) ^ 2 := by
    rw [mul_pow, Real.sq_sqrt h_pow_nn]
  have h_rhs_nn :
      0 вүӨ Real.sqrt (2 ^ (2 * s - 1))
            * (fracDerivSymbol s a + fracDerivSymbol s b) :=
    mul_nonneg (Real.sqrt_nonneg _) h_sum_nn
  have h_sq_cmp :
      (fracDerivSymbol s (a + b)) ^ 2
        вүӨ (Real.sqrt (2 ^ (2 * s - 1))
            * (fracDerivSymbol s a + fracDerivSymbol s b)) ^ 2 := by
    rw [h_rhs_sq]; exact h_combined
  have h_sqrt_mono := Real.sqrt_le_sqrt h_sq_cmp
  rw [Real.sqrt_sq h_lhs_nn, Real.sqrt_sq h_rhs_nn] at h_sqrt_mono
  exact h_sqrt_mono

/-- **В§11.25.D вҖ” Peetre-weighted Young (second-factor weight on `cg`).**
Symmetric form of В§11.25.C via В§11.22 direction (`в„“В№ Г— в„“ВІ`). -/
private theorem young_peetre_weighted_right
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (s : в„қ) (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    вҲ‘ n вҲҲ sumSet A B,
      (вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
        then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–) else 0) ^ 2
      вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) ^ 2
          * (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2) := by
  -- Embed the real nonneg (weighted) factors into в„Ӯ.
  set acf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ := fun a => ((вҖ–cf aвҖ– : в„қ) : в„Ӯ) with hacf_def
  set wcg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ := fun b =>
    ((fracDerivSymbol s b * вҖ–cg bвҖ– : в„қ) : в„Ӯ) with hwcg_def
  have h_wcg_nn : вҲҖ b, 0 вүӨ fracDerivSymbol s b * вҖ–cg bвҖ– :=
    fun b => mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _)
  have h_acf_norm : вҲҖ a, вҖ–acf aвҖ– = вҖ–cf aвҖ– := by
    intro a
    simp only [hacf_def, Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_nonneg (norm_nonneg _)
  have h_wcg_norm : вҲҖ b, вҖ–wcg bвҖ– = fracDerivSymbol s b * вҖ–cg bвҖ– := by
    intro b
    simp only [hwcg_def, Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_nonneg (h_wcg_nn b)
  have h_modeConv_eq : вҲҖ n,
      modeConvolution A B acf wcg n
        = ((вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
          then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–) else 0 : в„қ) : в„Ӯ) := by
    intro n
    rw [modeConvolution_eq_prod_sum]
    rw [show ((вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
        then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–) else 0 : в„қ) : в„Ӯ)
        = вҲ‘ p вҲҲ A Г—Лў B, ((if p.1 + p.2 = n
          then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–) else 0 : в„қ) : в„Ӯ) from by
      push_cast; rfl]
    apply Finset.sum_congr rfl
    intros p _
    simp only [hacf_def, hwcg_def]
    by_cases hp : p.1 + p.2 = n
    В· rw [if_pos hp, if_pos hp]
      push_cast; ring
    В· rw [if_neg hp, if_neg hp]
      push_cast; rfl
  have h_sum_nn : вҲҖ n, 0 вүӨ вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
      then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–) else 0 := by
    intro n
    apply Finset.sum_nonneg
    intros p _
    split_ifs
    В· exact mul_nonneg (norm_nonneg _) (h_wcg_nn _)
    В· exact le_refl _
  have h_norm_eq : вҲҖ n,
      вҖ–modeConvolution A B acf wcg nвҖ–
        = вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
          then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–) else 0 := by
    intro n
    rw [h_modeConv_eq n, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (h_sum_nn n)]
  have h_young := hsSeminormSq_zero_trigPolyProduct_le_young A B acf wcg
  have h_lhs_eq :
      (вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B acf wcg nвҖ– ^ 2)
        = вҲ‘ n вҲҲ sumSet A B, (вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
            then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–) else 0) ^ 2 := by
    apply Finset.sum_congr rfl
    intros n _
    rw [h_norm_eq n]
  rw [h_lhs_eq] at h_young
  have h_rhs_cf :
      (вҲ‘ a вҲҲ A, вҖ–acf aвҖ–) = вҲ‘ a вҲҲ A, вҖ–cf aвҖ– := by
    apply Finset.sum_congr rfl
    intros a _
    rw [h_acf_norm a]
  have h_rhs_cg :
      (вҲ‘ b вҲҲ B, вҖ–wcg bвҖ– ^ 2)
        = вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2 := by
    apply Finset.sum_congr rfl
    intros b _
    rw [h_wcg_norm b, mul_pow]
  rw [h_rhs_cf, h_rhs_cg] at h_young
  exact h_young

/-! ### В§11.25.E Banach-algebra `бёўЛў` product bound

Final assembly of В§11.25.C (Peetre-weighted Young, left) + В§11.25.D
(Peetre-weighted Young, right) + В§11.25.CвӮӮ (sqrt-Peetre) + В§11.23
(CauchyвҖ“Schwarz bridge `в„“В№ вҶ’ weighted в„“ВІ`) into the full
Banach-algebra estimate:

  `вҖ–fgвҖ–ВІ_{бёўЛў} вүӨ 2^{2s} В· (C_s(A) + C_s(B)) В· вҖ–fвҖ–ВІ_{бёўЛў} В· вҖ–gвҖ–ВІ_{бёўЛў}`

for `s вүҘ 1`, `0 вҲү A`, `0 вҲү B`, where
`C_s(A) = вҲ‘_{a вҲҲ A} вҖ–aвҖ–^{-2s}`.

Combined with global lattice zeta summability
`вҲ‘_{a вҲҲ в„ӨВІ \ {0}} вҖ–aвҖ–^{-2s} < вҲһ` for `s > d/2 = 1` on `рқ•ӢВІ`
(standard, deferred), the weights `C_s(A)`, `C_s(B)` are uniformly
bounded, delivering the support-independent Banach-algebra product
bound.  For the Galerkin scheme at `A = B = sqgBox n`, this is
uniform in `n` and discharges `hBoundS` in В§10.174's AubinвҖ“Lions
interpolation.

**Proof strategy:**
1. Pointwise sqrt-Peetre: `Пғ_s(n) В· вҖ–modeConv(n)вҖ– вүӨ вҲҡ(2^{2s-1})В·(TвӮҒ'(n) + TвӮӮ'(n))`
   where `TвӮҒ'(n), TвӮӮ'(n)` are the indicator sums on `A Г—Лў B` that
   В§11.25.C and В§11.25.D bound.
2. Square and use `(x+y)ВІ вүӨ 2В·(xВІ + yВІ)` to get
   `(Пғ_s n)ВІ В· вҖ–modeConvвҖ–ВІ вүӨ 2^{2s} В· (TвӮҒ'(n)ВІ + TвӮӮ'(n)ВІ)`.
3. Sum over `n вҲҲ sumSet A B`, apply В§11.25.C + В§11.25.D.
4. Discharge the `в„“В№` factors via В§11.23 (CauchyвҖ“Schwarz bridge).
-/

/-- **В§11.25.EвӮҒ вҖ” Linear sqrt-Peetre bound on `Пғ_s В· вҖ–modeConvвҖ–`.**
From the triangle inequality for `modeConvolution` (В§11.22.A),
the replacement `Пғ_s(n) = Пғ_s(p.1 + p.2)` under the indicator, and
В§11.25.CвӮӮ (sqrt-Peetre on `Пғ_s(a+b)`):

  `Пғ_s(n) В· вҖ–modeConv A B cf cg nвҖ–
    вүӨ вҲҡ(2^{2s-1}) В· (TвӮҒ'(n) + TвӮӮ'(n))`

where

  `TвӮҒ'(n) = вҲ‘_{(a,b) вҲҲ AГ—B, a+b=n} Пғ_s(a) В· вҖ–cf aвҖ– В· вҖ–cg bвҖ–`
  `TвӮӮ'(n) = вҲ‘_{(a,b) вҲҲ AГ—B, a+b=n} вҖ–cf aвҖ– В· (Пғ_s(b) В· вҖ–cg bвҖ–)`. -/
private lemma fracDerivSymbol_mul_modeConvolution_norm_le_sqrt_peetre
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {s : в„қ} (hs : 1 вүӨ s) (A B : Finset (Fin 2 вҶ’ в„Ө))
    (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) (n : Fin 2 вҶ’ в„Ө) :
    fracDerivSymbol s n * вҖ–modeConvolution A B cf cg nвҖ–
      вүӨ Real.sqrt (2 ^ (2 * s - 1))
          * ((вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n
                  then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
                  else 0)
             + (вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n
                  then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–)
                  else 0)) := by
  have h_tri := modeConvolution_norm_le_sum_abs A B cf cg n
  have h_sigma_nn : 0 вүӨ fracDerivSymbol s n := fracDerivSymbol_nonneg _ _
  have h_mul : fracDerivSymbol s n * вҖ–modeConvolution A B cf cg nвҖ–
      вүӨ fracDerivSymbol s n
          * вҲ‘ p вҲҲ A Г—Лў B,
              (if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0) :=
    mul_le_mul_of_nonneg_left h_tri h_sigma_nn
  -- Distribute Пғ_s n into the sum, and use Пғ_s n = Пғ_s(p.1 + p.2) inside ПҮ.
  have h_rewrite : fracDerivSymbol s n
      * вҲ‘ p вҲҲ A Г—Лў B,
          (if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0)
      = вҲ‘ p вҲҲ A Г—Лў B,
          (if p.1 + p.2 = n
             then fracDerivSymbol s (p.1 + p.2) * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
             else 0) := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intros p _
    by_cases hp : p.1 + p.2 = n
    В· rw [if_pos hp, if_pos hp, вҶҗ hp]; ring
    В· rw [if_neg hp, if_neg hp, mul_zero]
  -- Elementwise sqrt-Peetre via В§11.25.CвӮӮ.
  have h_peetre : вҲҖ p вҲҲ A Г—Лў B,
      (if p.1 + p.2 = n
         then fracDerivSymbol s (p.1 + p.2) * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
         else 0)
        вүӨ Real.sqrt (2 ^ (2 * s - 1))
            * (if p.1 + p.2 = n
                 then (fracDerivSymbol s p.1 + fracDerivSymbol s p.2)
                        * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
                 else 0) := by
    intros p _
    by_cases hp : p.1 + p.2 = n
    В· rw [if_pos hp, if_pos hp]
      have h_peetre_pt := fracDerivSymbol_add_le_sqrt hs p.1 p.2
      have h_prod_nn : 0 вүӨ вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– :=
        mul_nonneg (norm_nonneg _) (norm_nonneg _)
      calc fracDerivSymbol s (p.1 + p.2) * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
          = fracDerivSymbol s (p.1 + p.2) * (вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–) := by ring
        _ вүӨ (Real.sqrt (2 ^ (2 * s - 1))
              * (fracDerivSymbol s p.1 + fracDerivSymbol s p.2))
            * (вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–) :=
              mul_le_mul_of_nonneg_right h_peetre_pt h_prod_nn
        _ = Real.sqrt (2 ^ (2 * s - 1))
              * ((fracDerivSymbol s p.1 + fracDerivSymbol s p.2)
                  * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–) := by ring
    В· rw [if_neg hp, if_neg hp, mul_zero]
  have h_sum_peetre := Finset.sum_le_sum h_peetre
  -- Factor вҲҡ(2^{2s-1}) out and split the (Пғ_s p.1 + Пғ_s p.2) term.
  have h_split : вҲ‘ p вҲҲ A Г—Лў B,
        Real.sqrt (2 ^ (2 * s - 1))
          * (if p.1 + p.2 = n
               then (fracDerivSymbol s p.1 + fracDerivSymbol s p.2)
                      * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
               else 0)
      = Real.sqrt (2 ^ (2 * s - 1))
          * ((вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n
                  then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
                  else 0)
             + (вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n
                  then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–)
                  else 0)) := by
    rw [вҶҗ Finset.mul_sum]
    congr 1
    rw [вҶҗ Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intros p _
    by_cases hp : p.1 + p.2 = n
    В· rw [if_pos hp, if_pos hp, if_pos hp]; ring
    В· rw [if_neg hp, if_neg hp, if_neg hp]; ring
  calc fracDerivSymbol s n * вҖ–modeConvolution A B cf cg nвҖ–
      вүӨ fracDerivSymbol s n
          * вҲ‘ p вҲҲ A Г—Лў B,
              (if p.1 + p.2 = n then вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0) := h_mul
    _ = вҲ‘ p вҲҲ A Г—Лў B,
          (if p.1 + p.2 = n
             then fracDerivSymbol s (p.1 + p.2) * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
             else 0) := h_rewrite
    _ вүӨ вҲ‘ p вҲҲ A Г—Лў B,
          Real.sqrt (2 ^ (2 * s - 1))
            * (if p.1 + p.2 = n
                 then (fracDerivSymbol s p.1 + fracDerivSymbol s p.2)
                        * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
                 else 0) := h_sum_peetre
    _ = Real.sqrt (2 ^ (2 * s - 1))
          * ((вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n
                  then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ–
                  else 0)
             + (вҲ‘ p вҲҲ A Г—Лў B,
                if p.1 + p.2 = n
                  then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–)
                  else 0)) := h_split

/-- **В§11.25.E вҖ” Banach-algebra `бёўЛў` product bound on `trigPolyProduct`.**
For `s вүҘ 1`, `0 вҲү A`, `0 вҲү B`:

  `hsSeminormSq s (trigPolyProduct A B cf cg)
    вүӨ 2^{2s} В· (C_s(A) + C_s(B))
        В· hsSeminormSq s (trigPoly A cf)
        В· hsSeminormSq s (trigPoly B cg)`

where `C_s(A) = вҲ‘_{a вҲҲ A} вҖ–aвҖ–^{-2s}`.  Assembly of the В§11.25.AвҖ“D +
CвӮӮ + В§11.23 building blocks. -/
theorem hsSeminormSq_trigPolyProduct_le_banach_algebra
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {s : в„қ} (hs : 1 вүӨ s) {A B : Finset (Fin 2 вҶ’ в„Ө)}
    (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A) (hB : (0 : Fin 2 вҶ’ в„Ө) вҲү B)
    (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      вүӨ 2 ^ (2 * s)
          * ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
              + (вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by
  have hs_pos : 0 < s := lt_of_lt_of_le one_pos hs
  -- Abbreviations for the T_i'(n) indicator sums.
  set T1 : (Fin 2 вҶ’ в„Ө) вҶ’ в„қ := fun n =>
    вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
      then fracDerivSymbol s p.1 * вҖ–cf p.1вҖ– * вҖ–cg p.2вҖ– else 0 with hT1_def
  set T2 : (Fin 2 вҶ’ в„Ө) вҶ’ в„қ := fun n =>
    вҲ‘ p вҲҲ A Г—Лў B, if p.1 + p.2 = n
      then вҖ–cf p.1вҖ– * (fracDerivSymbol s p.2 * вҖ–cg p.2вҖ–) else 0 with hT2_def
  have h_T1_nn : вҲҖ n, 0 вүӨ T1 n := fun n => by
    apply Finset.sum_nonneg
    intros p _
    split_ifs
    В· exact mul_nonneg (mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _))
        (norm_nonneg _)
    В· exact le_refl _
  have h_T2_nn : вҲҖ n, 0 вүӨ T2 n := fun n => by
    apply Finset.sum_nonneg
    intros p _
    split_ifs
    В· exact mul_nonneg (norm_nonneg _)
        (mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _))
    В· exact le_refl _
  -- Step 1: Pointwise bound.
  have h_pow_2s_1_nn : (0 : в„қ) вүӨ (2 : в„қ) ^ (2 * s - 1) :=
    Real.rpow_nonneg (by norm_num) _
  have h_pow_2s_nn : (0 : в„қ) вүӨ (2 : в„қ) ^ (2 * s) :=
    Real.rpow_nonneg (by norm_num) _
  have h_sqrt_sq : (Real.sqrt (2 ^ (2 * s - 1))) ^ 2 = 2 ^ (2 * s - 1) := by
    rw [sq, Real.mul_self_sqrt h_pow_2s_1_nn]
  have h_2s_eq : (2 : в„қ) ^ (2 * s) = 2 * 2 ^ (2 * s - 1) := by
    have h2 : (2 : в„қ) ^ (2 * s) = 2 ^ (2 * s - 1 + 1) := by
      congr 1; ring
    rw [h2, Real.rpow_add (by norm_num : (2 : в„қ) > 0), Real.rpow_one]
    ring
  have h_pointwise : вҲҖ n вҲҲ sumSet A B,
      (fracDerivSymbol s n) ^ 2 * вҖ–modeConvolution A B cf cg nвҖ– ^ 2
        вүӨ 2 ^ (2 * s) * (T1 n ^ 2 + T2 n ^ 2) := by
    intros n _
    have h_linbound :=
      fracDerivSymbol_mul_modeConvolution_norm_le_sqrt_peetre hs A B cf cg n
    have h_lhs_nn : 0 вүӨ fracDerivSymbol s n * вҖ–modeConvolution A B cf cg nвҖ– :=
      mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _)
    have h_sum_nn : 0 вүӨ T1 n + T2 n := add_nonneg (h_T1_nn n) (h_T2_nn n)
    have h_rhs_nn : 0 вүӨ Real.sqrt (2 ^ (2 * s - 1)) * (T1 n + T2 n) :=
      mul_nonneg (Real.sqrt_nonneg _) h_sum_nn
    have h_sq : (fracDerivSymbol s n * вҖ–modeConvolution A B cf cg nвҖ–) ^ 2
        вүӨ (Real.sqrt (2 ^ (2 * s - 1)) * (T1 n + T2 n)) ^ 2 :=
      pow_le_pow_leftвӮҖ h_lhs_nn h_linbound 2
    have h_sq_expand :
        (Real.sqrt (2 ^ (2 * s - 1)) * (T1 n + T2 n)) ^ 2
          = 2 ^ (2 * s - 1) * (T1 n + T2 n) ^ 2 := by
      rw [mul_pow, h_sqrt_sq]
    have h_T_sq_le : (T1 n + T2 n) ^ 2 вүӨ 2 * (T1 n ^ 2 + T2 n ^ 2) := by
      nlinarith [sq_nonneg (T1 n - T2 n)]
    calc (fracDerivSymbol s n) ^ 2 * вҖ–modeConvolution A B cf cg nвҖ– ^ 2
        = (fracDerivSymbol s n * вҖ–modeConvolution A B cf cg nвҖ–) ^ 2 := by ring
      _ вүӨ (Real.sqrt (2 ^ (2 * s - 1)) * (T1 n + T2 n)) ^ 2 := h_sq
      _ = 2 ^ (2 * s - 1) * (T1 n + T2 n) ^ 2 := h_sq_expand
      _ вүӨ 2 ^ (2 * s - 1) * (2 * (T1 n ^ 2 + T2 n ^ 2)) :=
            mul_le_mul_of_nonneg_left h_T_sq_le h_pow_2s_1_nn
      _ = 2 ^ (2 * s) * (T1 n ^ 2 + T2 n ^ 2) := by rw [h_2s_eq]; ring
  -- Step 2: Sum over n вҲҲ sumSet A B.
  rw [hsSeminormSq_trigPolyProduct]
  have h_sum := Finset.sum_le_sum h_pointwise
  -- Factor 2^{2s} out.
  have h_factor_2s :
      вҲ‘ n вҲҲ sumSet A B, 2 ^ (2 * s) * (T1 n ^ 2 + T2 n ^ 2)
        = 2 ^ (2 * s) *
            ((вҲ‘ n вҲҲ sumSet A B, T1 n ^ 2)
              + (вҲ‘ n вҲҲ sumSet A B, T2 n ^ 2)) := by
    rw [вҶҗ Finset.mul_sum, Finset.sum_add_distrib]
  rw [h_factor_2s] at h_sum
  -- Step 3: Apply В§11.25.C and В§11.25.D.
  have h_T1_bound := young_peetre_weighted_left s A B cf cg
  have h_T2_bound := young_peetre_weighted_right s A B cf cg
  -- Rewrite h_T1/T2 bound's RHS via hsSeminormSq_trigPoly.
  have h_hsA : (вҲ‘ a вҲҲ A, (fracDerivSymbol s a) ^ 2 * вҖ–cf aвҖ– ^ 2)
      = hsSeminormSq s (trigPoly A cf) := (hsSeminormSq_trigPoly s A cf).symm
  have h_hsB : (вҲ‘ b вҲҲ B, (fracDerivSymbol s b) ^ 2 * вҖ–cg bвҖ– ^ 2)
      = hsSeminormSq s (trigPoly B cg) := (hsSeminormSq_trigPoly s B cg).symm
  -- Rephrase in terms of T1, T2, and hsSeminormSq.
  have h_T1_rephrased : (вҲ‘ n вҲҲ sumSet A B, T1 n ^ 2)
        вүӨ hsSeminormSq s (trigPoly A cf) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ–) ^ 2 := by
    simp only [hT1_def] at h_T1_bound вҠў
    rw [вҶҗ h_hsA]
    exact h_T1_bound
  have h_T2_rephrased : (вҲ‘ n вҲҲ sumSet A B, T2 n ^ 2)
        вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) ^ 2 * hsSeminormSq s (trigPoly B cg) := by
    simp only [hT2_def] at h_T2_bound вҠў
    rw [вҶҗ h_hsB]
    exact h_T2_bound
  -- Step 4: Apply В§11.23 CS bridge to в„“В№ factors.
  have h_CS_A := sum_norm_sq_le_latticeWeight_mul_hsSeminormSq hA hs_pos cf
  have h_CS_B := sum_norm_sq_le_latticeWeight_mul_hsSeminormSq hB hs_pos cg
  -- Combine.
  have h_hsA_nn : 0 вүӨ hsSeminormSq s (trigPoly A cf) := hsSeminormSq_nonneg_any _ _
  have h_hsB_nn : 0 вүӨ hsSeminormSq s (trigPoly B cg) := hsSeminormSq_nonneg_any _ _
  have h_T1_final : (вҲ‘ n вҲҲ sumSet A B, T1 n ^ 2)
      вүӨ hsSeminormSq s (trigPoly A cf)
          * ((вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s)))
              * hsSeminormSq s (trigPoly B cg)) :=
    le_trans h_T1_rephrased (mul_le_mul_of_nonneg_left h_CS_B h_hsA_nn)
  have h_T2_final : (вҲ‘ n вҲҲ sumSet A B, T2 n ^ 2)
      вүӨ ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf))
          * hsSeminormSq s (trigPoly B cg) :=
    le_trans h_T2_rephrased (mul_le_mul_of_nonneg_right h_CS_A h_hsB_nn)
  have h_sum_final :
      (вҲ‘ n вҲҲ sumSet A B, T1 n ^ 2) + (вҲ‘ n вҲҲ sumSet A B, T2 n ^ 2)
        вүӨ ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
            + (вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by
    have h_combined :
        (вҲ‘ n вҲҲ sumSet A B, T1 n ^ 2) + (вҲ‘ n вҲҲ sumSet A B, T2 n ^ 2)
          вүӨ hsSeminormSq s (trigPoly A cf)
              * ((вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s)))
                  * hsSeminormSq s (trigPoly B cg))
            + ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
                * hsSeminormSq s (trigPoly A cf))
              * hsSeminormSq s (trigPoly B cg) :=
      add_le_add h_T1_final h_T2_final
    have h_rearrange :
        hsSeminormSq s (trigPoly A cf)
            * ((вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s)))
                * hsSeminormSq s (trigPoly B cg))
          + ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
              * hsSeminormSq s (trigPoly A cf))
            * hsSeminormSq s (trigPoly B cg)
        = ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
            + (вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by ring
    linarith [h_combined, h_rearrange.le, h_rearrange.ge]
  calc вҲ‘ n вҲҲ sumSet A B,
          (fracDerivSymbol s n) ^ 2 * вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ 2 ^ (2 * s) *
          ((вҲ‘ n вҲҲ sumSet A B, T1 n ^ 2)
            + (вҲ‘ n вҲҲ sumSet A B, T2 n ^ 2)) := h_sum
    _ вүӨ 2 ^ (2 * s) *
          (((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
              + (вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s))))
            * hsSeminormSq s (trigPoly A cf)
            * hsSeminormSq s (trigPoly B cg)) :=
          mul_le_mul_of_nonneg_left h_sum_final h_pow_2s_nn
    _ = 2 ^ (2 * s)
          * ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
              + (вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by ring

/-! ### В§11.25.F Lattice zeta bound hypothesis + support-independent form

Parametrises В§11.25.E on a uniform lattice zeta bound so the final
`бёўЛў` Banach-algebra estimate carries a support-INDEPENDENT constant,
matching the Galerkin need (uniform in `n` for `A = B = sqgBox n`).

The hypothesis type `HasLatticeZetaBound s C` packages the claim
"every nonzero-lattice finset `A вҠҶ в„ӨВІ \ {0}` has `вҲ‘_a вҖ–aвҖ–^{-2s} вүӨ C`."
A concrete witness requires the global summability
`Summable (fun a : в„ӨВІ \ {0} вҶҰ вҖ–aвҖ–^{-2s})` for `s > d/2 = 1` вҖ” a
standard 2D real-analysis fact, deferred to a follow-on section
(or mathlib contribution). -/

/-- **В§11.25.FвӮҒ вҖ” Lattice zeta bound hypothesis.**  The uniform bound
on nonzero-lattice finite sums `вҲ‘_{a вҲҲ A} вҖ–aвҖ–^{-2s} вүӨ C` for every
`A вҠҶ в„ӨВІ \ {0}` (finite).  Concrete instance for `s > 1` uses global
lattice zeta summability on `в„ӨВІ \ {0}`. -/
structure HasLatticeZetaBound (s : в„қ) (C : в„қ) : Prop where
  nonneg : 0 вүӨ C
  bound : вҲҖ (A : Finset (Fin 2 вҶ’ в„Ө)),
    (0 : Fin 2 вҶ’ в„Ө) вҲү A вҶ’
      (вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s))) вүӨ C

/-- **В§11.25.F вҖ” Support-independent Banach-algebra `бёўЛў` bound.**  For
`s вүҘ 1` with `HasLatticeZetaBound s C`, the finite-lattice Banach-
algebra bound has constant `2C` (uniform in `A, B вҠҶ в„ӨВІ \ {0}`):

  `вҖ–fgвҖ–ВІ_{бёўЛў} вүӨ 2^{2s} В· 2C В· вҖ–fвҖ–ВІ_{бёўЛў} В· вҖ–gвҖ–ВІ_{бёўЛў}`

Composes В§11.25.E with the lattice-zeta hypothesis to discharge the
support-dependent `C_s(A) + C_s(B)` factor. -/
theorem hsSeminormSq_trigPolyProduct_le_uniform_banach_algebra
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {s : в„қ} (hs : 1 вүӨ s) {A B : Finset (Fin 2 вҶ’ в„Ө)}
    (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A) (hB : (0 : Fin 2 вҶ’ в„Ө) вҲү B)
    {C : в„қ} (hC : HasLatticeZetaBound s C)
    (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      вүӨ 2 ^ (2 * s) * (2 * C)
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by
  have h_E := hsSeminormSq_trigPolyProduct_le_banach_algebra hs hA hB cf cg
  have h_A := hC.bound A hA
  have h_B := hC.bound B hB
  have h_sum : (вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
      + (вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s))) вүӨ 2 * C := by linarith
  have h_pow_2s_nn : (0 : в„қ) вүӨ (2 : в„қ) ^ (2 * s) :=
    Real.rpow_nonneg (by norm_num) _
  have h_hsA_nn : 0 вүӨ hsSeminormSq s (trigPoly A cf) := hsSeminormSq_nonneg_any _ _
  have h_hsB_nn : 0 вүӨ hsSeminormSq s (trigPoly B cg) := hsSeminormSq_nonneg_any _ _
  have h_prod_nn : 0 вүӨ hsSeminormSq s (trigPoly A cf)
      * hsSeminormSq s (trigPoly B cg) :=
    mul_nonneg h_hsA_nn h_hsB_nn
  have h_factor_nn : 0 вүӨ 2 ^ (2 * s)
      * (hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg)) :=
    mul_nonneg h_pow_2s_nn h_prod_nn
  calc hsSeminormSq s (trigPolyProduct A B cf cg)
      вүӨ 2 ^ (2 * s)
          * ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
              + (вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := h_E
    _ = 2 ^ (2 * s)
          * (hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg))
          * ((вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
              + (вҲ‘ b вҲҲ B, (latticeNorm b) ^ (-(2 * s)))) := by ring
    _ вүӨ 2 ^ (2 * s)
          * (hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg))
          * (2 * C) :=
          mul_le_mul_of_nonneg_left h_sum h_factor_nn
    _ = 2 ^ (2 * s) * (2 * C)
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by ring

/-! ### В§11.25.G Banach-algebra bound packaged as hypothesis structure

Parallels `HasTrigPolyKatoPonceBound` (В§11.21, Leibniz split form) but
carries the Banach-algebra form `C В· вҖ–fвҖ–ВІ_{бёўЛў} В· вҖ–gвҖ–ВІ_{бёўЛў}` directly.
Built via `В§11.25.F` + `HasLatticeZetaBound`. -/

/-- **В§11.25.GвӮҒ вҖ” `HasTrigPolyBanachAlgebraBound` hypothesis.**
Bundles `вҖ–fgвҖ–ВІ_{бёўЛў} вүӨ C В· вҖ–fвҖ–ВІ_{бёўЛў} В· вҖ–gвҖ–ВІ_{бёўЛў}` for every finite
support `A, B вҠҶ в„ӨВІ \ {0}` into a structural hypothesis.  Constructed
via В§11.25.F from `HasLatticeZetaBound` (В§11.25.FвӮҒ). -/
structure HasTrigPolyBanachAlgebraBound (s : в„қ) (C : в„қ) : Prop where
  nonneg : 0 вүӨ C
  bound : вҲҖ (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ),
    (0 : Fin 2 вҶ’ в„Ө) вҲү A вҶ’ (0 : Fin 2 вҶ’ в„Ө) вҲү B вҶ’
    hsSeminormSq s (trigPolyProduct A B cf cg)
      вүӨ C * hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg)

/-- **В§11.25.G вҖ” `HasTrigPolyBanachAlgebraBound` from `HasLatticeZetaBound`.**
Concrete instance at `C = 2^{2s} В· (2В·C_z)` for `s вүҘ 1`.

**Note on `DecidableEq`:** earlier attempts carried an explicit
`[DecidableEq (Fin 2 вҶ’ в„Ө)]` hypothesis and then invoked В§11.25.F
inside the body, but the structure `HasTrigPolyBanachAlgebraBound`
has its `bound` field elaborated with the DEFAULT `decidablePiFintype`
instance (synthesized at structure-declaration time), whereas an
explicit class parameter injects a fresh `instвңқ`.  The resulting
`@trigPolyProduct instвңқ A B cf cg` vs
`@trigPolyProduct decidablePiFintype A B cf cg` mismatch triggered
`isDefEq` timeout, then `linarith failure`, then `type mismatch` as
we tried various workarounds.  Removing the class parameter lets
instance synthesis pick `decidablePiFintype` uniformly, matching the
structure's field type exactly. -/
theorem HasTrigPolyBanachAlgebraBound.of_latticeZeta
    {s : в„қ} (hs : 1 вүӨ s) {C_z : в„қ} (hC : HasLatticeZetaBound s C_z) :
    HasTrigPolyBanachAlgebraBound s (2 ^ (2 * s) * (2 * C_z)) := by
  have h_pow_nn : (0 : в„қ) вүӨ (2 : в„қ) ^ (2 * s) :=
    Real.rpow_nonneg (by norm_num) _
  have h_2c_nn : (0 : в„қ) вүӨ 2 * C_z := by linarith [hC.nonneg]
  have h_nonneg : (0 : в„қ) вүӨ 2 ^ (2 * s) * (2 * C_z) := mul_nonneg h_pow_nn h_2c_nn
  refine вҹЁh_nonneg, ?_вҹ©
  intros A B cf cg hA hB
  exact hsSeminormSq_trigPolyProduct_le_uniform_banach_algebra hs hA hB hC cf cg

/-! ### В§11.25.H Zero-coefficient exemplar

Whenever one factor's coefficient sequence is zero, `trigPolyProduct`
vanishes and so does its `бёўЛў` seminorm.  Uses the SAME default
`decidablePiFintype` instance as the structure-field elaboration to
avoid the class-parameter mismatch diagnosed in В§11.25.G. -/

/-- **В§11.25.HвӮҒ вҖ” Zero left-factor trig-poly product has zero `бёўЛў`
seminorm.** -/
theorem hsSeminormSq_trigPolyProduct_zero_left
    (s : в„қ) (A B : Finset (Fin 2 вҶ’ в„Ө)) (cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq s (trigPolyProduct A B (fun _ => (0 : в„Ӯ)) cg) = 0 := by
  rw [trigPolyProduct_zero_left]
  exact hsSeminormSq_of_zero s

/-- **В§11.25.HвӮӮ вҖ” Zero right-factor trig-poly product has zero `бёўЛў`
seminorm.** -/
theorem hsSeminormSq_trigPolyProduct_zero_right
    (s : в„қ) (A B : Finset (Fin 2 вҶ’ в„Ө)) (cf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq s (trigPolyProduct A B cf (fun _ => (0 : в„Ӯ))) = 0 := by
  rw [trigPolyProduct_zero_right]
  exact hsSeminormSq_of_zero s

/-! ### В§11.25.I Monotonicity of `HasLatticeZetaBound` in the constant

Utility lemma: if `HasLatticeZetaBound s C` holds and `C вүӨ C'`, then
`HasLatticeZetaBound s C'` also holds.  Useful for combining witnesses
from different sources. -/

/-- **В§11.25.I вҖ” Monotonicity of `HasLatticeZetaBound` in C.** -/
theorem HasLatticeZetaBound.mono
    {s : в„қ} {C C' : в„қ} (hC : HasLatticeZetaBound s C) (hCC' : C вүӨ C') :
    HasLatticeZetaBound s C' where
  nonneg := le_trans hC.nonneg hCC'
  bound := fun A hA => le_trans (hC.bound A hA) hCC'

/-! ### В§11.26 Prerequisites for the concrete lattice zeta bound

Building up the ingredients needed for an explicit `HasLatticeZetaBound
s C` witness at `s > 1` (i.e., `s > d/2 = 1` on `рқ•ӢВІ`).

**Strategy:** partition `в„ӨВІ \ {0}` by `в„“вҲһ`-radius into annular shells.
On shell `k` (radius-k `в„“вҲһ`-boundary), `|shell| вүӨ 8k` and `вҖ–aвҖ–_{в„“ВІ} вүҘ k`,
so `вҲ‘_{a вҲҲ shell_k} вҖ–aвҖ–^{-2s} вүӨ 8k В· k^{-2s} = 8 k^{1-2s}`.  Sum over
`k вүҘ 1`: `8 вҲ‘_{k вүҘ 1} k^{1-2s}`, summable for `s > 1` via mathlib's
`Real.summable_one_div_nat_rpow` at `p = 2s - 1`. -/

/-- **В§11.26.A вҖ” 1D p-series for shell-weighted lattice zeta.**
`Summable (fun n : в„• => 1 / (n : в„қ) ^ (2 * s - 1))` for `s > 1`.
Direct application of mathlib's `Real.summable_one_div_nat_rpow` at
`p = 2s - 1`.  Used in В§11.26 downstream for the annular-shell
lattice-zeta bound. -/
theorem summable_one_div_nat_rpow_at_two_s_sub_one
    {s : в„қ} (hs : 1 < s) :
    Summable (fun n : в„• => 1 / (n : в„қ) ^ (2 * s - 1)) := by
  rw [Real.summable_one_div_nat_rpow]
  linarith

/-- **В§11.26.B вҖ” Coordinate absolute value bounded by lattice norm.**
For every index `j`, `|(n j : в„қ)| вүӨ latticeNorm n`.  Follows from
`sq_le_latticeNorm_sq` (componentwise square bound) by taking sqrt. -/
lemma abs_coord_le_latticeNorm {d : Type*} [Fintype d]
    (n : d вҶ’ в„Ө) (j : d) :
    |(n j : в„қ)| вүӨ latticeNorm n := by
  have h_sq := sq_le_latticeNorm_sq n j
  have h_nn : 0 вүӨ latticeNorm n := latticeNorm_nonneg n
  rw [show |(n j : в„қ)| = Real.sqrt ((n j : в„қ) ^ 2) from (Real.sqrt_sq_eq_abs _).symm]
  calc Real.sqrt ((n j : в„қ) ^ 2)
      вүӨ Real.sqrt ((latticeNorm n) ^ 2) := Real.sqrt_le_sqrt h_sq
    _ = latticeNorm n := Real.sqrt_sq h_nn

/-- **В§11.26.BвӮӮ вҖ” `в„“вҲһ` вүӨ `в„“ВІ` on `Fin 2 вҶ’ в„Ө`.**  The maximum of
`|m 0|` and `|m 1|` is bounded by `latticeNorm m`. -/
lemma max_abs_coord_le_latticeNorm (m : Fin 2 вҶ’ в„Ө) :
    max (|(m 0 : в„қ)|) (|(m 1 : в„қ)|) вүӨ latticeNorm m :=
  max_le (abs_coord_le_latticeNorm m 0) (abs_coord_le_latticeNorm m 1)

/-! ### В§11.26.C Annular shell on `в„ӨВІ` -/

/-- **В§11.26.C вҖ” Annular shell at `в„“вҲһ`-radius `k`.**  Subset of `в„ӨВІ`
with `max |m 0| |m 1| = k` and `m вү  0`.  For `k = 0` this is empty
(only `m = 0` has `max = 0`, excluded by nonzero constraint).  For
`k вүҘ 1`, contains at most `8k + 4` points. -/
noncomputable def annularShell (k : в„•) : Finset (Fin 2 вҶ’ в„Ө) :=
  (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө)).filter
    (fun m => m вү  0 вҲ§ (|m 0| = (k : в„Ө) вҲЁ |m 1| = (k : в„Ө)))

/-- **В§11.26.CвӮҒ вҖ” Shell membership characterization.** -/
lemma mem_annularShell_iff (k : в„•) (m : Fin 2 вҶ’ в„Ө) :
    m вҲҲ annularShell k вҶ”
      (вҲҖ i : Fin 2, |m i| вүӨ (k : в„Ө)) вҲ§ m вү  0
        вҲ§ (|m 0| = (k : в„Ө) вҲЁ |m 1| = (k : в„Ө)) := by
  unfold annularShell
  simp only [Finset.mem_filter, Fintype.mem_piFinset, Finset.mem_Icc]
  constructor
  В· rintro вҹЁh_Icc, h_ne, h_maxвҹ©
    refine вҹЁfun i => abs_le.mpr (h_Icc i), h_ne, h_maxвҹ©
  В· rintro вҹЁh_max, h_ne, h_eqвҹ©
    refine вҹЁfun i => ?_, h_ne, h_eqвҹ©
    have := h_max i
    exact вҹЁ(abs_le.mp this).1, (abs_le.mp this).2вҹ©

/-- **В§11.26.CвӮӮ вҖ” On shell at level `k`, `latticeNorm m вүҘ k`.**  Each
shell member has one coordinate with `|m i| = k`, so by В§11.26.B
`latticeNorm m вүҘ |m i| = k`. -/
lemma latticeNorm_ge_of_mem_annularShell (k : в„•) (m : Fin 2 вҶ’ в„Ө)
    (hm : m вҲҲ annularShell k) :
    (k : в„қ) вүӨ latticeNorm m := by
  rw [mem_annularShell_iff] at hm
  rcases hm.2.2 with h0 | h1
  В· have h_abs : |(m 0 : в„қ)| = (k : в„қ) := by
      have h_cast : ((|m 0| : в„Ө) : в„қ) = ((k : в„Ө) : в„қ) := by exact_mod_cast h0
      simpa [Int.cast_abs] using h_cast
    calc (k : в„қ) = |(m 0 : в„қ)| := h_abs.symm
      _ вүӨ latticeNorm m := abs_coord_le_latticeNorm m 0
  В· have h_abs : |(m 1 : в„қ)| = (k : в„қ) := by
      have h_cast : ((|m 1| : в„Ө) : в„қ) = ((k : в„Ө) : в„қ) := by exact_mod_cast h1
      simpa [Int.cast_abs] using h_cast
    calc (k : в„қ) = |(m 1 : в„қ)| := h_abs.symm
      _ вүӨ latticeNorm m := abs_coord_le_latticeNorm m 1

/-- **В§11.26.CвӮғ вҖ” Shell at level `0` is empty.**  Only `m = 0` has
`max |m 0| |m 1| = 0`, and the shell definition excludes `m = 0`.
Sanity check on the annular shell partition. -/
lemma annularShell_zero : annularShell 0 = вҲ… := by
  unfold annularShell
  apply Finset.eq_empty_of_forall_notMem
  intros m hm
  rw [Finset.mem_filter, Fintype.mem_piFinset] at hm
  obtain вҹЁh_Icc, h_ne, _вҹ© := hm
  apply h_ne
  funext i
  have h := h_Icc i
  rw [Finset.mem_Icc, Nat.cast_zero, neg_zero] at h
  exact le_antisymm h.2 h.1

/-- **В§11.26.D вҖ” Cardinality bound: `|shell k| вүӨ 8k + 4`.**

Bound via the union-of-filters decomposition:
`annularShell k вҠҶ {m | |m 0| = k} вҲӘ {m | |m 1| = k}` in the piFinset.
Each side has cardinality `вүӨ 2 В· (2k+1) = 4k+2` via
`Fintype.card_filter_piFinset_eq_of_mem` + `abs_eq`-split into
`m i = k` and `m i = -k`.  Sum: `(4k+2) + (4k+2) = 8k+4`.

Tight bound (`8k` exact) requires inclusion-exclusion; the loose
`8k+4` bound suffices for lattice zeta summability at `s > 1`. -/
lemma card_annularShell_le (k : в„•) :
    (annularShell k).card вүӨ 8 * k + 4 := by
  classical
  unfold annularShell
  -- Step 1: drop m вү  0 (enlarges set)
  have h_sub :
      (Finset.filter (fun m : Fin 2 вҶ’ в„Ө => m вү  0 вҲ§ (|m 0| = (k : в„Ө) вҲЁ |m 1| = (k : в„Ө)))
        (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө))).card
      вүӨ (Finset.filter (fun m : Fin 2 вҶ’ в„Ө => |m 0| = (k : в„Ө) вҲЁ |m 1| = (k : в„Ө))
          (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө))).card := by
    apply Finset.card_le_card
    intro m hm
    simp only [Finset.mem_filter] at hm вҠў
    exact вҹЁhm.1, hm.2.2вҹ©
  refine le_trans h_sub ?_
  -- Step 2: split (P вҲЁ Q) filter via filter_or
  rw [Finset.filter_or]
  refine le_trans (Finset.card_union_le _ _) ?_
  -- Step 3: each sub-filter вүӨ 4k+2
  have h_each : вҲҖ (i : Fin 2),
      (Finset.filter (fun m : Fin 2 вҶ’ в„Ө => |m i| = (k : в„Ө))
        (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө))).card
        вүӨ 4 * k + 2 := by
    intro i
    -- |m i| = k вҶ” m i = k вҲЁ m i = -k (since k вүҘ 0)
    have h_filter_split :
        Finset.filter (fun m : Fin 2 вҶ’ в„Ө => |m i| = (k : в„Ө))
          (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө))
        = Finset.filter (fun m : Fin 2 вҶ’ в„Ө => m i = (k : в„Ө) вҲЁ m i = -(k : в„Ө))
          (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө)) := by
      apply Finset.filter_congr
      intros m _
      rw [abs_eq (by positivity : (0 : в„Ө) вүӨ (k : в„Ө))]
    rw [h_filter_split, Finset.filter_or]
    refine le_trans (Finset.card_union_le _ _) ?_
    -- Each inner (m i = a) filter: card вүӨ 2k+1 via card_filter_piFinset_eq_of_mem
    have h_card_pt : вҲҖ a : в„Ө,
        (Finset.filter (fun m : Fin 2 вҶ’ в„Ө => m i = a)
          (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө))).card
          вүӨ 2 * k + 1 := by
      intro a
      by_cases ha : a вҲҲ Finset.Icc (-(k : в„Ө)) (k : в„Ө)
      В· rw [Fintype.card_filter_piFinset_eq_of_mem
          (s := fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө)) i ha]
        rw [Finset.prod_const]
        have h_erase_card : ((Finset.univ : Finset (Fin 2)).erase i).card = 1 := by
          rw [Finset.card_erase_of_mem (Finset.mem_univ i), Finset.card_univ,
              Fintype.card_fin]
        rw [h_erase_card, pow_one, Int.card_Icc]
        omega
      В· have h_empty : Finset.filter (fun m : Fin 2 вҶ’ в„Ө => m i = a)
            (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө)) = вҲ… :=
          Fintype.filter_piFinset_of_notMem
            (fun _ : Fin 2 => Finset.Icc (-(k : в„Ө)) (k : в„Ө)) i a ha
        rw [h_empty, Finset.card_empty]
        omega
    have h_k := h_card_pt (k : в„Ө)
    have h_neg_k := h_card_pt (-(k : в„Ө))
    linarith
  linarith [h_each 0, h_each 1]

/-- **В§11.26.E вҖ” Shell-sum bound.**  For `k вүҘ 1` and `s > 0`:
`вҲ‘_{m вҲҲ annularShell k} вҖ–mвҖ–^{-2s} вүӨ (8k + 4) В· k^{-2s}`.  Combines
`latticeNorm_ge_of_mem_annularShell` (`вҖ–mвҖ– вүҘ k`) with the cardinality
bound (`|shell| вүӨ 8k + 4`).  Sum over `k вүҘ 1`: `(8k+4) В· k^{-2s} =
8 k^{1-2s} + 4 k^{-2s}`, both summable for `s > 1` via
`Real.summable_one_div_nat_rpow`. -/
lemma sum_annularShell_rpow_le {s : в„қ} (hs_pos : 0 < s) {k : в„•} (hk : 1 вүӨ k) :
    вҲ‘ m вҲҲ annularShell k, (latticeNorm m) ^ (-(2 * s))
      вүӨ ((8 * k + 4 : в„•) : в„қ) * ((k : в„қ) ^ (-(2 * s))) := by
  have h_k_pos : 0 < (k : в„қ) := by exact_mod_cast hk
  have h_k_nn : 0 вүӨ (k : в„қ) := le_of_lt h_k_pos
  have h_2s_nn : 0 вүӨ 2 * s := by linarith
  -- Pointwise bound: for m вҲҲ shell k, (latticeNorm m)^{-2s} вүӨ k^{-2s}
  have h_pointwise : вҲҖ m вҲҲ annularShell k,
      (latticeNorm m) ^ (-(2 * s)) вүӨ ((k : в„қ) ^ (-(2 * s))) := by
    intros m hm
    have h_lb : (k : в„қ) вүӨ latticeNorm m := latticeNorm_ge_of_mem_annularShell k m hm
    have h_m_pos : 0 < latticeNorm m := lt_of_lt_of_le h_k_pos h_lb
    -- latticeNorm m вүҘ k > 0, so (latticeNorm m)^{2s} вүҘ k^{2s}, hence
    -- (latticeNorm m)^{-2s} = 1/(latticeNorm m)^{2s} вүӨ 1/k^{2s} = k^{-2s}
    rw [Real.rpow_neg h_k_nn, Real.rpow_neg (le_of_lt h_m_pos)]
    apply inv_antiвӮҖ (Real.rpow_pos_of_pos h_k_pos _)
    exact Real.rpow_le_rpow h_k_nn h_lb h_2s_nn
  -- Sum over shell.
  calc вҲ‘ m вҲҲ annularShell k, (latticeNorm m) ^ (-(2 * s))
      вүӨ вҲ‘ _ вҲҲ annularShell k, ((k : в„қ) ^ (-(2 * s))) := Finset.sum_le_sum h_pointwise
    _ = (annularShell k).card * ((k : в„қ) ^ (-(2 * s))) := by
        rw [Finset.sum_const, nsmul_eq_mul]
    _ вүӨ ((8 * k + 4 : в„•) : в„қ) * ((k : в„қ) ^ (-(2 * s))) := by
        apply mul_le_mul_of_nonneg_right
        В· exact_mod_cast card_annularShell_le k
        В· exact Real.rpow_nonneg h_k_nn _

/-! ### В§11.26.F Concrete lattice-zeta constant

Define the ambient lattice-zeta constant as the tsum of the shell-
bounded series over `k вүҘ 1`:
`latticeZetaConst s := 8В·вҲ‘_{k вүҘ 1} k^{1-2s} + 4В·вҲ‘_{k вүҘ 1} k^{-2s}`.

For `s > 1`, both tsums are finite via `Real.summable_one_div_nat_rpow`.
The full `HasLatticeZetaBound s (latticeZetaConst s)` proof is deferred
(requires shell-partition of arbitrary `A вҠҶ в„ӨВІ \ {0}` + disjoint
biUnion + partial-sum вүӨ tsum bookkeeping; see В§11.26.F next-session
entry).  Infrastructure in-tree for downstream use. -/

/-- **В§11.26.FвӮҒ вҖ” Lattice-zeta constant `latticeZetaConst s`.**
Tsum of the shell-bounded series: `8В·О¶(2s-1) + 4В·О¶(2s)` over `k : в„•`.
The `k = 0` terms vanish (since `1/0^p = 0` for `p > 0`), so this
matches the Riemann zeta summation from `k = 1`.  For `s > 1`, both
tsums are finite via `Real.summable_one_div_nat_rpow` and this
provides a uniform upper bound on `вҲ‘_{a вҲҲ A} вҖ–aвҖ–^{-2s}` for every
finite `A вҠҶ в„ӨВІ \ {0}` (see В§11.26.H). -/
noncomputable def latticeZetaConst (s : в„қ) : в„қ :=
  8 * вҲ‘' (k : в„•), 1 / ((k : в„қ) ^ (2 * s - 1)) +
  4 * вҲ‘' (k : в„•), 1 / ((k : в„қ) ^ (2 * s))

/-- **В§11.26.FвӮӮ вҖ” `latticeZetaConst s вүҘ 0`.** -/
lemma latticeZetaConst_nonneg (s : в„қ) : 0 вүӨ latticeZetaConst s := by
  unfold latticeZetaConst
  apply add_nonneg
  В· apply mul_nonneg (by norm_num : (0 : в„қ) вүӨ 8)
    apply tsum_nonneg
    intros k
    apply div_nonneg (by norm_num : (0 : в„қ) вүӨ 1)
    exact Real.rpow_nonneg (Nat.cast_nonneg _) _
  В· apply mul_nonneg (by norm_num : (0 : в„қ) вүӨ 4)
    apply tsum_nonneg
    intros k
    apply div_nonneg (by norm_num : (0 : в„қ) вүӨ 1)
    exact Real.rpow_nonneg (Nat.cast_nonneg _) _

/-! ### В§11.26.G Shell-index preliminaries

The `в„“вҲһ`-radius `shellOf m := max(|m 0|.toNat, |m 1|.toNat)` gives
the annular-shell level of `m вү  0`.  Three facts for the main bound:
1. `shellOf m вүҘ 1` for `m вү  0` (В§11.26.GвӮҒ).
2. `m вҲҲ annularShell (shellOf m)` for `m вү  0` (В§11.26.GвӮӮ).
3. Distinct shells are disjoint (В§11.26.GвӮғ). -/

/-- **В§11.26.G вҖ” Shell-index function.** -/
def shellOf (m : Fin 2 вҶ’ в„Ө) : в„• := max (|m 0|).toNat (|m 1|).toNat

/-- **В§11.26.GвӮҒ вҖ” Positivity of `shellOf` on nonzero lattice points.** -/
lemma shellOf_pos_of_ne_zero (m : Fin 2 вҶ’ в„Ө) (hm : m вү  0) :
    1 вүӨ shellOf m := by
  unfold shellOf
  by_cases h0 : m 0 = 0
  В· by_cases h1 : m 1 = 0
    В· exact absurd (funext fun i => by fin_cases i <;> [exact h0; exact h1]) hm
    В· have ha : 0 < |m 1| := abs_pos.mpr h1
      have hb : 1 вүӨ (|m 1|).toNat := by omega
      exact le_trans hb (le_max_right _ _)
  В· have ha : 0 < |m 0| := abs_pos.mpr h0
    have hb : 1 вүӨ (|m 0|).toNat := by omega
    exact le_trans hb (le_max_left _ _)

/-- **В§11.26.GвӮӮ вҖ” Each `m вү  0` lies in `annularShell (shellOf m)`.** -/
lemma mem_annularShell_shellOf (m : Fin 2 вҶ’ в„Ө) (hm : m вү  0) :
    m вҲҲ annularShell (shellOf m) := by
  rw [mem_annularShell_iff]
  refine вҹЁ?_, hm, ?_вҹ©
  В· intro i
    fin_cases i
    В· have h_cast : ((|m 0|).toNat : в„Ө) = |m 0| :=
        Int.toNat_of_nonneg (abs_nonneg _)
      have h_le : (|m 0|).toNat вүӨ shellOf m := le_max_left _ _
      calc |m 0| = ((|m 0|).toNat : в„Ө) := h_cast.symm
        _ вүӨ ((shellOf m : в„•) : в„Ө) := by exact_mod_cast h_le
    В· have h_cast : ((|m 1|).toNat : в„Ө) = |m 1| :=
        Int.toNat_of_nonneg (abs_nonneg _)
      have h_le : (|m 1|).toNat вүӨ shellOf m := le_max_right _ _
      calc |m 1| = ((|m 1|).toNat : в„Ө) := h_cast.symm
        _ вүӨ ((shellOf m : в„•) : в„Ө) := by exact_mod_cast h_le
  В· rcases max_choice (|m 0|).toNat (|m 1|).toNat with h | h
    В· left
      have h_cast : ((|m 0|).toNat : в„Ө) = |m 0| :=
        Int.toNat_of_nonneg (abs_nonneg _)
      unfold shellOf
      calc |m 0| = ((|m 0|).toNat : в„Ө) := h_cast.symm
        _ = ((max (|m 0|).toNat (|m 1|).toNat : в„•) : в„Ө) := by
            exact_mod_cast h.symm
    В· right
      have h_cast : ((|m 1|).toNat : в„Ө) = |m 1| :=
        Int.toNat_of_nonneg (abs_nonneg _)
      unfold shellOf
      calc |m 1| = ((|m 1|).toNat : в„Ө) := h_cast.symm
        _ = ((max (|m 0|).toNat (|m 1|).toNat : в„•) : в„Ө) := by
            exact_mod_cast h.symm

/-- **В§11.26.GвӮғ вҖ” Annular shells at distinct indices are disjoint.** -/
lemma annularShell_disjoint {kвӮҒ kвӮӮ : в„•} (hne : kвӮҒ вү  kвӮӮ) :
    Disjoint (annularShell kвӮҒ) (annularShell kвӮӮ) := by
  rw [Finset.disjoint_left]
  intros m hm1 hm2
  rw [mem_annularShell_iff] at hm1 hm2
  obtain вҹЁh_Icc1, _, h_max1вҹ© := hm1
  obtain вҹЁh_Icc2, _, h_max2вҹ© := hm2
  apply hne
  have h1_0 : |m 0| вүӨ (kвӮҒ : в„Ө) := h_Icc1 0
  have h1_1 : |m 1| вүӨ (kвӮҒ : в„Ө) := h_Icc1 1
  have h2_0 : |m 0| вүӨ (kвӮӮ : в„Ө) := h_Icc2 0
  have h2_1 : |m 1| вүӨ (kвӮӮ : в„Ө) := h_Icc2 1
  rcases h_max1 with hвӮҒ | hвӮҒ <;> rcases h_max2 with hвӮӮ | hвӮӮ <;>
    В· have h_int : (kвӮҒ : в„Ө) = (kвӮӮ : в„Ө) := by omega
      exact_mod_cast h_int

/-! ### В§11.26.H Concrete lattice-zeta bound

Unconditional witness of `HasLatticeZetaBound s (latticeZetaConst s)`
for `s > 1`.  Partition any finite `A вҠҶ в„ӨВІ \ {0}` by `shellOf`,
decompose via disjoint `biUnion`, bound each shell sum via В§11.26.E,
then bridge the finite shell sum to the `tsum` defining
`latticeZetaConst` via `Summable.sum_le_tsum` on the two p-series. -/

/-- **В§11.26.H вҖ” Concrete `HasLatticeZetaBound s (latticeZetaConst s)`
for `s > 1`.**  This closes the lattice-zeta leg of Route A Item 5.A
(В§11.25.F/FвӮҒ/G/GвӮҒ composed with this witness gives the full
support-independent Banach-algebra `бёўЛў` bound). -/
theorem hasLatticeZetaBound_latticeZetaConst {s : в„қ} (hs : 1 < s) :
    HasLatticeZetaBound s (latticeZetaConst s) := by
  refine вҹЁlatticeZetaConst_nonneg s, ?_вҹ©
  classical
  intros A hA0
  -- Index set: image of A under shellOf.
  set K : Finset в„• := A.image shellOf with hK_def
  -- Step 1 (cover): A вҠҶ K.biUnion annularShell
  have h_sub : A вҠҶ K.biUnion annularShell := by
    intros m hm
    have hm_ne : m вү  0 := fun h => hA0 (h в–ё hm)
    rw [Finset.mem_biUnion]
    exact вҹЁshellOf m, Finset.mem_image.mpr вҹЁm, hm, rflвҹ©,
      mem_annularShell_shellOf m hm_neвҹ©
  -- Step 2: extend sum to biUnion (non-neg summands).
  have h_nn_term : вҲҖ a : Fin 2 вҶ’ в„Ө, 0 вүӨ (latticeNorm a) ^ (-(2 * s)) :=
    fun a => Real.rpow_nonneg (latticeNorm_nonneg a) _
  have h_ext : вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s))
      вүӨ вҲ‘ a вҲҲ K.biUnion annularShell, (latticeNorm a) ^ (-(2 * s)) :=
    Finset.sum_le_sum_of_subset_of_nonneg h_sub
      (fun a _ _ => h_nn_term a)
  -- Step 3: decompose biUnion via pairwise-disjoint shells.
  have h_pairwise : (вҶ‘K : Set в„•).PairwiseDisjoint annularShell :=
    fun _ _ _ _ hne => annularShell_disjoint hne
  have h_biUnion :
      вҲ‘ a вҲҲ K.biUnion annularShell, (latticeNorm a) ^ (-(2 * s))
        = вҲ‘ k вҲҲ K, вҲ‘ a вҲҲ annularShell k, (latticeNorm a) ^ (-(2 * s)) :=
    Finset.sum_biUnion h_pairwise
  rw [h_biUnion] at h_ext
  -- Step 4: k вүҘ 1 for k вҲҲ K.
  have h_k_pos : вҲҖ k вҲҲ K, 1 вүӨ k := by
    intros k hk
    rw [hK_def, Finset.mem_image] at hk
    obtain вҹЁm, hm, rflвҹ© := hk
    exact shellOf_pos_of_ne_zero m (fun h => hA0 (h в–ё hm))
  -- Step 5: per-shell bound via В§11.26.E.
  have h_shell_bd : вҲҖ k вҲҲ K,
      вҲ‘ a вҲҲ annularShell k, (latticeNorm a) ^ (-(2 * s))
        вүӨ ((8 * k + 4 : в„•) : в„қ) * ((k : в„қ) ^ (-(2 * s))) :=
    fun k hk => sum_annularShell_rpow_le (by linarith : (0 : в„қ) < s)
      (h_k_pos k hk)
  have h_shell_sum :
      вҲ‘ k вҲҲ K, вҲ‘ a вҲҲ annularShell k, (latticeNorm a) ^ (-(2 * s))
        вүӨ вҲ‘ k вҲҲ K, ((8 * k + 4 : в„•) : в„қ) * ((k : в„қ) ^ (-(2 * s))) :=
    Finset.sum_le_sum h_shell_bd
  -- Step 6: algebraic split (8k+4)В·k^{-2s} = 8В·k^{1-2s} + 4В·k^{-2s}.
  have h_term_split : вҲҖ k вҲҲ K,
      ((8 * k + 4 : в„•) : в„қ) * ((k : в„қ) ^ (-(2 * s)))
        = 8 * ((k : в„қ) ^ (1 - 2 * s)) + 4 * ((k : в„қ) ^ (-(2 * s))) := by
    intros k hk
    have hk_pos : (0 : в„қ) < k := by exact_mod_cast h_k_pos k hk
    have h_rpow : (k : в„қ) ^ (1 - 2 * s) = (k : в„қ) * (k : в„қ) ^ (-(2 * s)) := by
      rw [show (1 - 2 * s) = (1 : в„қ) + (-(2 * s)) from by ring,
          Real.rpow_add hk_pos, Real.rpow_one]
    push_cast
    rw [h_rpow]
    ring
  have h_split_sum :
      вҲ‘ k вҲҲ K, ((8 * k + 4 : в„•) : в„қ) * ((k : в„қ) ^ (-(2 * s)))
        = 8 * (вҲ‘ k вҲҲ K, ((k : в„қ) ^ (1 - 2 * s)))
          + 4 * (вҲ‘ k вҲҲ K, ((k : в„қ) ^ (-(2 * s)))) := by
    calc вҲ‘ k вҲҲ K, ((8 * k + 4 : в„•) : в„қ) * ((k : в„қ) ^ (-(2 * s)))
        = вҲ‘ k вҲҲ K, (8 * ((k : в„қ) ^ (1 - 2 * s))
            + 4 * ((k : в„қ) ^ (-(2 * s)))) := Finset.sum_congr rfl h_term_split
      _ = (вҲ‘ k вҲҲ K, 8 * ((k : в„қ) ^ (1 - 2 * s)))
            + (вҲ‘ k вҲҲ K, 4 * ((k : в„қ) ^ (-(2 * s)))) := Finset.sum_add_distrib
      _ = 8 * (вҲ‘ k вҲҲ K, ((k : в„қ) ^ (1 - 2 * s)))
            + 4 * (вҲ‘ k вҲҲ K, ((k : в„қ) ^ (-(2 * s)))) := by
            rw [вҶҗ Finset.mul_sum, вҶҗ Finset.mul_sum]
  -- Step 7: bridge (k:в„қ)^p form to 1/(k:в„қ)^p form on K.
  have h_rw1 : вҲҖ k вҲҲ K,
      ((k : в„қ) ^ (1 - 2 * s)) = 1 / ((k : в„қ) ^ (2 * s - 1)) := by
    intros k hk
    have hk_pos : (0 : в„қ) < k := by exact_mod_cast h_k_pos k hk
    rw [show (1 - 2 * s) = -(2 * s - 1) from by ring,
        Real.rpow_neg (le_of_lt hk_pos), inv_eq_one_div]
  have h_rw2 : вҲҖ k вҲҲ K,
      ((k : в„қ) ^ (-(2 * s))) = 1 / ((k : в„қ) ^ (2 * s)) := by
    intros k hk
    have hk_pos : (0 : в„қ) < k := by exact_mod_cast h_k_pos k hk
    rw [Real.rpow_neg (le_of_lt hk_pos), inv_eq_one_div]
  have h_sum_eq1 : вҲ‘ k вҲҲ K, ((k : в„қ) ^ (1 - 2 * s))
      = вҲ‘ k вҲҲ K, 1 / ((k : в„қ) ^ (2 * s - 1)) :=
    Finset.sum_congr rfl h_rw1
  have h_sum_eq2 : вҲ‘ k вҲҲ K, ((k : в„қ) ^ (-(2 * s)))
      = вҲ‘ k вҲҲ K, 1 / ((k : в„қ) ^ (2 * s)) :=
    Finset.sum_congr rfl h_rw2
  -- Step 8: finite sums bounded by tsum via summability.
  have h_summ1 : Summable (fun k : в„• => 1 / ((k : в„қ) ^ (2 * s - 1))) := by
    rw [Real.summable_one_div_nat_rpow]; linarith
  have h_summ2 : Summable (fun k : в„• => 1 / ((k : в„қ) ^ (2 * s))) := by
    rw [Real.summable_one_div_nat_rpow]; linarith
  have h_nn_f1 : вҲҖ k : в„•, 0 вүӨ 1 / ((k : в„қ) ^ (2 * s - 1)) := fun k =>
    div_nonneg zero_le_one (Real.rpow_nonneg (Nat.cast_nonneg _) _)
  have h_nn_f2 : вҲҖ k : в„•, 0 вүӨ 1 / ((k : в„қ) ^ (2 * s)) := fun k =>
    div_nonneg zero_le_one (Real.rpow_nonneg (Nat.cast_nonneg _) _)
  have h_tsum1 : вҲ‘ k вҲҲ K, 1 / ((k : в„қ) ^ (2 * s - 1))
      вүӨ вҲ‘' (k : в„•), 1 / ((k : в„қ) ^ (2 * s - 1)) :=
    h_summ1.sum_le_tsum K (fun k _ => h_nn_f1 k)
  have h_tsum2 : вҲ‘ k вҲҲ K, 1 / ((k : в„қ) ^ (2 * s))
      вүӨ вҲ‘' (k : в„•), 1 / ((k : в„қ) ^ (2 * s)) :=
    h_summ2.sum_le_tsum K (fun k _ => h_nn_f2 k)
  -- Step 9: assemble.
  calc вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s))
      вүӨ вҲ‘ k вҲҲ K, вҲ‘ a вҲҲ annularShell k, (latticeNorm a) ^ (-(2 * s)) := h_ext
    _ вүӨ вҲ‘ k вҲҲ K, ((8 * k + 4 : в„•) : в„қ) * ((k : в„қ) ^ (-(2 * s))) := h_shell_sum
    _ = 8 * (вҲ‘ k вҲҲ K, ((k : в„қ) ^ (1 - 2 * s)))
        + 4 * (вҲ‘ k вҲҲ K, ((k : в„қ) ^ (-(2 * s)))) := h_split_sum
    _ = 8 * (вҲ‘ k вҲҲ K, 1 / ((k : в„қ) ^ (2 * s - 1)))
        + 4 * (вҲ‘ k вҲҲ K, 1 / ((k : в„қ) ^ (2 * s))) := by
          rw [h_sum_eq1, h_sum_eq2]
    _ вүӨ 8 * (вҲ‘' (k : в„•), 1 / ((k : в„қ) ^ (2 * s - 1)))
        + 4 * (вҲ‘' (k : в„•), 1 / ((k : в„қ) ^ (2 * s))) := by
          apply add_le_add
          В· exact mul_le_mul_of_nonneg_left h_tsum1 (by norm_num : (0 : в„қ) вүӨ 8)
          В· exact mul_le_mul_of_nonneg_left h_tsum2 (by norm_num : (0 : в„қ) вүӨ 4)
    _ = latticeZetaConst s := by rw [latticeZetaConst]

/-! ### В§11.27 Fully unconditional Banach-algebra `бёўЛў` product bound

Composition of В§11.26.H (concrete `HasLatticeZetaBound s (latticeZetaConst s)`
for `s > 1`) with В§11.25.G `HasTrigPolyBanachAlgebraBound.of_latticeZeta`
(concrete Banach-algebra bound from a lattice-zeta witness) yields an
**unconditional** `HasTrigPolyBanachAlgebraBound` witness for every
`s > 1` with concrete constant `2^{2s}В·(2В·latticeZetaConst s)`.

This is the first Banach-algebra product bound in the project with
zero open hypotheses вҖ” the entire lattice-zeta leg of Route A
Item 5.A is now unconditional. -/

/-- **В§11.27 вҖ” Unconditional `HasTrigPolyBanachAlgebraBound` for `s > 1`.**
Concrete witness with constant `2^{2s}В·(2В·latticeZetaConst s)`.
Compose В§11.25.G `.of_latticeZeta` with В§11.26.H
`hasLatticeZetaBound_latticeZetaConst`. -/
theorem hasTrigPolyBanachAlgebraBound_of_gt_one {s : в„қ} (hs : 1 < s) :
    HasTrigPolyBanachAlgebraBound s
      (2 ^ (2 * s) * (2 * latticeZetaConst s)) :=
  HasTrigPolyBanachAlgebraBound.of_latticeZeta (le_of_lt hs)
    (hasLatticeZetaBound_latticeZetaConst hs)

/-- **В§11.27.A вҖ” Explicit zero-coefficient exemplar on the
unconditional bound.**  Exercises В§11.27 on the zero left factor:
`hsSeminormSq s (trigPolyProduct A B 0 cg) = 0 вүӨ 2^{2s}В·(2В·latticeZetaConst s)
    В· hsSeminormSq s (trigPoly A 0) В· hsSeminormSq s (trigPoly B cg)`.

Since the LHS is zero (via В§11.25.HвӮҒ) and the RHS is a product of
non-negative reals, the inequality holds trivially.  Sanity check
that the unconditional bound reduces correctly on zero factors. -/
theorem hasTrigPolyBanachAlgebraBound_of_gt_one_zero_left
    {s : в„қ} (hs : 1 < s)
    (A B : Finset (Fin 2 вҶ’ в„Ө)) (cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ)
    (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A) (hB : (0 : Fin 2 вҶ’ в„Ө) вҲү B) :
    hsSeminormSq s (trigPolyProduct A B (fun _ => (0 : в„Ӯ)) cg)
      вүӨ (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * hsSeminormSq s (trigPoly A (fun _ => (0 : в„Ӯ)))
          * hsSeminormSq s (trigPoly B cg) := by
  exact (hasTrigPolyBanachAlgebraBound_of_gt_one hs).bound A B _ cg hA hB

/-! ### В§11.28 Self-product specialization

When `A = B` and `cf = cg`, В§11.27 reduces to a bound on the бёўЛў norm
of the self-square `вҖ–fВІвҖ–ВІ_{бёўЛў} вүӨ C В· (вҖ–fвҖ–ВІ_{бёўЛў})ВІ`.  This is the
natural form used in Gronwall energy estimates for quadratic
nonlinearities (e.g., Burgers `вҲӮ_t Оё + Оё В· вҲӮ_x Оё = 0`). -/

/-- **В§11.28 вҖ” Self-product Banach-algebra bound.**
For `s > 1` and `0 вҲү A`:
  `вҖ–fВІвҖ–ВІ_{бёўЛў} вүӨ 2^{2s}В·(2В·latticeZetaConst s) В· (вҖ–fвҖ–ВІ_{бёўЛў})ВІ`
where `f = trigPoly A cf` and `fВІ = trigPolyProduct A A cf cf`. -/
theorem hsSeminormSq_trigPolyProduct_self_le {s : в„қ} (hs : 1 < s)
    (A : Finset (Fin 2 вҶ’ в„Ө)) (cf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ)
    (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A) :
    hsSeminormSq s (trigPolyProduct A A cf cf)
      вүӨ (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * (hsSeminormSq s (trigPoly A cf)) ^ 2 := by
  have h := (hasTrigPolyBanachAlgebraBound_of_gt_one hs).bound A A cf cf hA hA
  calc hsSeminormSq s (trigPolyProduct A A cf cf)
      вүӨ (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly A cf) := h
    _ = (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * (hsSeminormSq s (trigPoly A cf)) ^ 2 := by ring

/-! ### В§11.30 Unconditional `в„“В№ вҶ’ бёўЛў` CauchyвҖ“Schwarz bound (`s > 1`)

Direct composition of В§11.23 (`в„“В№` CauchyвҖ“Schwarz with lattice weight)
and В§11.26.H (concrete `HasLatticeZetaBound`) gives an unconditional
bound

  `(вҲ‘_a вҖ–cf aвҖ–)ВІ вүӨ latticeZetaConst s В· hsSeminormSq s (trigPoly A cf)`

for `s > 1`, `0 вҲү A`.  This is the Fourier-side form of the classical
Sobolev embedding `бёўЛў вҠӮ LвҲһ` on `рқ•ӢВІ` for `s > d/2 = 1`: the `в„“В№`
coefficient norm bounds the `LвҲһ` norm of the trig polynomial
(`|trigPoly A cf (x)| вүӨ вҲ‘_a вҖ–cf aвҖ–`), and this lemma bounds the
`в„“В№` coefficient norm by the `бёўЛў` seminorm with an explicit
(uniform-in-support) constant. -/

/-- **В§11.30 вҖ” Unconditional `в„“В№` CauchyвҖ“Schwarz bound on trig polys.**
For `s > 1`, `0 вҲү A`: `(вҲ‘_a вҖ–cf aвҖ–)ВІ вүӨ latticeZetaConst s В· вҖ–fвҖ–ВІ_{бёўЛў}`
where `f = trigPoly A cf`.  Composition of В§11.23.A with В§11.26.H. -/
theorem sum_norm_sq_le_latticeZeta_mul_hsSeminormSq
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {s : в„қ} (hs : 1 < s) {A : Finset (Fin 2 вҶ’ в„Ө)}
    (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A) (cf : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) ^ 2
      вүӨ latticeZetaConst s * hsSeminormSq s (trigPoly A cf) := by
  have h_cs := sum_norm_sq_le_latticeWeight_mul_hsSeminormSq
    hA (by linarith : (0 : в„қ) < s) cf
  have h_zeta := (hasLatticeZetaBound_latticeZetaConst hs).bound A hA
  have h_seminorm_nn : 0 вүӨ hsSeminormSq s (trigPoly A cf) :=
    hsSeminormSq_nonneg_any _ _
  calc (вҲ‘ a вҲҲ A, вҖ–cf aвҖ–) ^ 2
      вүӨ (вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf) := h_cs
    _ вүӨ latticeZetaConst s * hsSeminormSq s (trigPoly A cf) :=
        mul_le_mul_of_nonneg_right h_zeta h_seminorm_nn

/-! ### В§11.31 Unconditional uniform `LВІ` product bound (`s > 1`)

Composition of В§11.24 (uniform-in-support LВІ product bound,
parametrised on the lattice weight `C_s(A) = вҲ‘_a вҖ–aвҖ–^{-2s}`) with
В§11.26.H (concrete `HasLatticeZetaBound` witness at `s > 1`) gives
the unconditional bound

  `вҲ‘_n вҖ–modeConv(n)вҖ–ВІ вүӨ latticeZetaConst s В· вҖ–fвҖ–ВІ_{бёўЛў} В· (вҲ‘_b вҖ–cg bвҖ–ВІ)`

for every finite `A вҠҶ в„ӨВІ \ {0}`, `B вҠҶ в„ӨВІ`, `s > 1`.  The constant
`latticeZetaConst s` is uniform in `A` and `B`.  On the SQG Galerkin
scheme at `A = sqgBox n`, this delivers the uniform-in-`n`
`LВІ Г— бёўЛў вҶ’ LВІ` product bound. -/

/-- **В§11.31 вҖ” Unconditional uniform LВІ product bound for `s > 1`.**
Direct composition of В§11.24 with В§11.26.H. -/
theorem l2_trigPolyProduct_le_latticeZeta
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {s : в„қ} (hs : 1 < s) {A B : Finset (Fin 2 вҶ’ в„Ө)}
    (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ latticeZetaConst s * hsSeminormSq s (trigPoly A cf)
          * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by
  have h_u := l2_trigPolyProduct_le_uniform (A := A) (B := B) hA
    (by linarith : (0 : в„қ) < s) cf cg
  have h_zeta := (hasLatticeZetaBound_latticeZetaConst hs).bound A hA
  have h_seminorm_nn : 0 вүӨ hsSeminormSq s (trigPoly A cf) :=
    hsSeminormSq_nonneg_any _ _
  have h_cg_nn : 0 вүӨ вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2 :=
    Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  have h_nn_prod : 0 вүӨ hsSeminormSq s (trigPoly A cf) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) :=
    mul_nonneg h_seminorm_nn h_cg_nn
  calc вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf)
          * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := h_u
    _ = (вҲ‘ a вҲҲ A, (latticeNorm a) ^ (-(2 * s)))
          * (hsSeminormSq s (trigPoly A cf) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2)) := by ring
    _ вүӨ latticeZetaConst s
          * (hsSeminormSq s (trigPoly A cf) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2)) :=
          mul_le_mul_of_nonneg_right h_zeta h_nn_prod
    _ = latticeZetaConst s * hsSeminormSq s (trigPoly A cf)
          * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ– ^ 2) := by ring

/-! ### В§11.32 Symmetric unconditional uniform `LВІ` product bound

Swapped variant of В§11.31 via В§11.25.B (symmetric Young): в„“ВІ on `cf`,
в„“В№ on `cg` (instead of В§11.22's в„“В№ on `cf`, в„“ВІ on `cg`).  Combined
with В§11.30 applied to `B` gives the unconditional

  `вҲ‘_n вҖ–modeConv(n)вҖ–ВІ вүӨ (вҲ‘_a вҖ–cf aвҖ–ВІ) В· latticeZetaConst s В· вҖ–gвҖ–ВІ_{бёўЛў}`

for `s > 1`, `0 вҲү B`.  This is the `LВІ Г— бёўЛў вҶ’ LВІ` bound with бёўЛў
control on the SECOND factor rather than the first. -/

/-- **В§11.32 вҖ” Symmetric form of В§11.31.**  For `s > 1`, `0 вҲү B`:
`вҲ‘_n вҖ–modeConv(n)вҖ–ВІ вүӨ (вҲ‘_a вҖ–cf aвҖ–ВІ) В· latticeZetaConst s В· вҖ–gвҖ–ВІ_{бёўЛў}`
via В§11.25.B (swapped Young) + В§11.30 on `B`. -/
theorem l2_trigPolyProduct_le_latticeZeta_symm
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {s : в„қ} (hs : 1 < s) {A B : Finset (Fin 2 вҶ’ в„Ө)}
    (hB : (0 : Fin 2 вҶ’ в„Ө) вҲү B) (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2) * latticeZetaConst s
          * hsSeminormSq s (trigPoly B cg) := by
  have h_young :=
    hsSeminormSq_zero_trigPolyProduct_le_young_symm A B cf cg
  have h_cs_B :=
    sum_norm_sq_le_latticeZeta_mul_hsSeminormSq hs hB cg
  have h_cf_nn : 0 вүӨ вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2 :=
    Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  calc вҲ‘ n вҲҲ sumSet A B, вҖ–modeConvolution A B cf cg nвҖ– ^ 2
      вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2) * (вҲ‘ b вҲҲ B, вҖ–cg bвҖ–) ^ 2 := h_young
    _ вүӨ (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2)
          * (latticeZetaConst s * hsSeminormSq s (trigPoly B cg)) :=
          mul_le_mul_of_nonneg_left h_cs_B h_cf_nn
    _ = (вҲ‘ a вҲҲ A, вҖ–cf aвҖ– ^ 2) * latticeZetaConst s
          * hsSeminormSq s (trigPoly B cg) := by ring

/-! ### В§11.33 бёўбө— interpolation form of the Banach-algebra bound

The В§11.27 bound at exponent `s > 1` implies a бёўбө— bound at every
`t вҲҲ [0, s]` via `hsSeminormSq_mono_of_le` (monotonicity in the
exponent).  Useful when the consumer needs the product's `бёўбө—`
seminorm controlled by the factors' `бёўЛў` seminorms at a lower
regularity `t`, e.g. `t = 1` with `s = 3/2` for SQG energy. -/

/-- **В§11.33 вҖ” Banach-algebra `бёўбө—` bound for `t вҲҲ [0, s]`, `s > 1`.**
  Interpolation of В§11.27 via `hsSeminormSq_mono_of_le`.

  **Note:** `[DecidableEq (Fin 2 вҶ’ в„Ө)]` is OMITTED from the signature
  (uses the structure's default `decidablePiFintype`), matching the
  diagnostic pattern codified in В§11.25.G вҖ” an explicit class parameter
  creates a fresh `instвңқ` that mismatches the structure field's
  default-synthesized instance, triggering an `isDefEq`/`whnf` timeout. -/
theorem hsSeminormSq_trigPolyProduct_le_latticeZeta_interp
    {s t : в„қ} (hs : 1 < s) (hts : t вүӨ s)
    {A B : Finset (Fin 2 вҶ’ в„Ө)}
    (hA : (0 : Fin 2 вҶ’ в„Ө) вҲү A) (hB : (0 : Fin 2 вҶ’ в„Ө) вҲү B)
    (cf cg : (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ) :
    hsSeminormSq t (trigPolyProduct A B cf cg)
      вүӨ (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by
  classical
  -- Summability at s via finite-support of trigPolyProduct on sumSet A B.
  have h_supp : вҲҖ n вҲү sumSet A B,
      mFourierCoeff (trigPolyProduct A B cf cg) n = 0 :=
    fun n hn => mFourierCoeff_trigPolyProduct_eq_zero_of_not_mem hn
  have h_summable_s : Summable (fun n : Fin 2 вҶ’ в„Ө =>
      (fracDerivSymbol s n) ^ 2 * вҖ–mFourierCoeff (trigPolyProduct A B cf cg) nвҖ– ^ 2) :=
    hsSeminormSq_summable_of_finite_support s _ (sumSet A B) h_supp
  have h_mono : hsSeminormSq t (trigPolyProduct A B cf cg)
      вүӨ hsSeminormSq s (trigPolyProduct A B cf cg) :=
    hsSeminormSq_mono_of_le hts _ h_summable_s
  have h_prod := (hasTrigPolyBanachAlgebraBound_of_gt_one hs).bound A B cf cg hA hB
  exact le_trans h_mono h_prod

/-! ### В§11.34 Parametric-`s` global Galerkin `бёўЛў` bound hypothesis

Packages a time-global uniform `бёўЛў` Galerkin bound `Ms(s)` across
every `s > 1` into a single hypothesis consumable by В§10.174's
`hBoundS`.  Complements В§11.8's `HasSqgGalerkinHsClosure` (which is
local-in-time via GrГ¶nwall) with the `вҲҖ t вүҘ 0` form В§10.174 expects.

**Relationship to В§11.8:** `HasSqgGalerkinHsClosure s Оұ` gives
`|вҲӮ_t E| вүӨ K В· |E|` on `[0, T]`, yielding `E(t) вүӨ EвӮҖ В· exp(KВ·T)` вҖ”
T-dependent.  For В§10.174's global `hBoundS`, we need `E(t) вүӨ Ms s`
uniform in `t`, which requires either strict conservation (K = 0,
the zero-data case) or BKM-integral finiteness.  This structure
abstracts that global bound directly. -/

/-- **В§11.34 вҖ” Parametric-`s` global uniform Galerkin `бёўЛў` bound.**
Packages the uniform-in-`n`-and-`t` `бёўЛў` bound at every `s > 1`.

Not `Prop`-valued: `MвӮҒ : в„қ` and `Ms : в„қ вҶ’ в„қ` are data fields. -/
structure HasSqgGalerkinAllSBound
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)) where
  MвӮҒ : в„қ
  hBoundOne : вҲҖ n : в„•, вҲҖ t : в„қ, 0 вүӨ t вҶ’
    hsSeminormSq 1 (galerkinToLp (sqgBox n) (Оұ n t)) вүӨ MвӮҒ
  Ms : в„қ вҶ’ в„қ
  hBoundS : вҲҖ n : в„•, вҲҖ t : в„қ, 0 вүӨ t вҶ’ вҲҖ s : в„қ, 1 < s вҶ’
    hsSeminormSq s (galerkinToLp (sqgBox n) (Оұ n t)) вүӨ Ms s

/-! ### В§11.35 Zero-datum witness of `HasSqgGalerkinAllSBound`

The zero Galerkin trajectory trivially satisfies the global uniform
`бёўЛў` bound at every `s > 1` with `MвӮҒ = 0, Ms s = 0`.  Parallels
В§10.176 but packaged as a `HasSqgGalerkinAllSBound` witness. -/

/-- **В§11.35 вҖ” Zero-datum `HasSqgGalerkinAllSBound` witness.** -/
noncomputable def HasSqgGalerkinAllSBound.ofZero :
    HasSqgGalerkinAllSBound (fun _ _ _ => (0 : в„Ӯ)) where
  MвӮҒ := 0
  hBoundOne := fun n t _ => (hsSeminormSq_zero_galerkin_of_trinary_zero 1 n t).le
  Ms := fun _ => 0
  hBoundS := fun n t _ s _ =>
    (hsSeminormSq_zero_galerkin_of_trinary_zero s n t).le

/-! ### В§11.36 Full-range Theorem 3 from `HasSqgGalerkinAllSBound`

Structural capstone: given a `HasSqgGalerkinAllSBound Оұ` hypothesis
+ an Aubin-Lions extraction + `SqgEvolutionAxioms` on the limit,
the full-range Theorem 3 conclusion follows via В§10.174.
This is the "Path A" structural closure of Item 5: hypothesis-
keyed at the level of a global Galerkin `бёўЛў` bound, which
discharges unconditionally on zero data (В§11.35) and classically
via commutator KatoвҖ“Ponce + BKM-integral + GrГ¶nwall for general
data (the remaining Path B classical content). -/

/-- **В§11.36 вҖ” Full-range Theorem 3 via `HasSqgGalerkinAllSBound`.** -/
theorem sqg_regularity_of_allSBound
    {Оё : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (ext : HasAubinLionsExtraction Оё Оұ)
    (hAllS : HasSqgGalerkinAllSBound Оұ)
    (hE : SqgEvolutionAxioms ext.Оё_lim) :
    вҲҖ s : в„қ, 0 вүӨ s вҶ’
      вҲғ M' : в„қ, вҲҖ t : в„қ, 0 вүӨ t вҶ’ hsSeminormSq s (ext.Оё_lim t) вүӨ M' :=
  sqg_regularity_of_aubinLions_via_interpolation
    ext hAllS.MвӮҒ hAllS.Ms hAllS.hBoundOne hAllS.hBoundS hE

/-! ### В§11.37 End-to-end `SqgSolution` + Theorem 3 via
