      (fracDerivSymbol 3 n) ^ 2 * ‚ÄĖmFourierCoeff
        ((GalerkinLimitTrajectory.ofZero).őł_lim 0) n‚ÄĖ ^ 2 = 0 := by
    intro n; rw [hZero n]; simp
  rw [show (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol 3 n) ^ 2 * ‚ÄĖmFourierCoeff
        ((GalerkinLimitTrajectory.ofZero).őł_lim 0) n‚ÄĖ ^ 2)
    = (fun _ : Fin 2 ‚Üí ‚Ą§ => (0 : ‚ĄĚ)) from funext this]
