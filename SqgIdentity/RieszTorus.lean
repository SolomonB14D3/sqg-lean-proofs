/-- **őĪ-fracHeat-smoothed SQG velocity ŠłĘňĘ integrated.** For `őĪ > 0, t ‚Č• 0`:

    `‚ÄĖfracHeat(őĪ,¬∑) u_j‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘňĘ}`

No gain in Sobolev level since both Riesz and fracHeat contract. -/
theorem fracHeat_smoothed_sqg_velocity_Hs_integrated
    (s : ‚ĄĚ) {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 ‚Č§ t)
    (j : Fin 2)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) *
        (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) *
        mFourierCoeff őł n)
    (hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq s őł := by
  unfold hsSeminormSq
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2
      ‚Č§ fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n]
    exact fracHeat_smoothed_sqg_velocity_mode s hőĪ ht n j (mFourierCoeff őł n)
  apply Summable.tsum_le_tsum hmode
  ¬∑ exact hsum.of_nonneg_of_le (fun n ‚Ü¶ mul_nonneg (sq_nonneg _) (sq_nonneg _)) hmode
  ¬∑ exact hsum

/-- **őĪ-fracHeat-smoothed SQG vorticity ŠłĘňĘ integrated (contractive).**
For `őĪ > 0, t ‚Č• 0`:

    `‚ÄĖfracHeat(őĪ,¬∑) ŌČ‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}`

Uses fracHeat ‚Č§ 1 and `‚ÄĖŌČŐā(n)‚ÄĖ = ‚ÄĖn‚ÄĖ = ŌÉ_1(n)` to get level shift by 1. -/
theorem fracHeat_smoothed_vorticity_Hs_integrated (s : ‚ĄĚ) {őĪ t : ‚ĄĚ}
    (hőĪ : 0 < őĪ) (ht : 0 ‚Č§ t)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * mFourierCoeff őł n)
    (hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq (s + 1) őł := by
  unfold hsSeminormSq
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2
      ‚Č§ fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n]
    by_cases hn : n = 0
    ¬∑ subst hn
      have hŌČ0 : sqgVorticitySymbol 0 = 0 := by
        unfold sqgVorticitySymbol sqgGradSymbol derivSymbol rieszSymbol; simp
      rw [hŌČ0, mul_zero, zero_mul, norm_zero]
      have h0sq : (0 : ‚ĄĚ) ^ 2 = 0 := by norm_num
      rw [h0sq, mul_zero]
      exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
        Real.norm_of_nonneg (fracHeatSymbol_nonneg őĪ t n),
        sqgVorticitySymbol_norm hn]
      have hf_nn : 0 ‚Č§ fracHeatSymbol őĪ t n := fracHeatSymbol_nonneg őĪ t n
      have hf_le : fracHeatSymbol őĪ t n ‚Č§ 1 := fracHeatSymbol_le_one hőĪ ht n
      have hf_sq_le : (fracHeatSymbol őĪ t n) ^ 2 ‚Č§ 1 :=
        pow_le_one‚āÄ hf_nn hf_le
      have hfrac := fracDerivSymbol_add_sq s 1 n
      have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
        rw [fracDerivSymbol_one_eq hn]
      calc (fracDerivSymbol s n) ^ 2 *
            ((fracHeatSymbol őĪ t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
          = (fracHeatSymbol őĪ t n) ^ 2 *
            ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
            ring
        _ ‚Č§ 1 *
            ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
            mul_le_mul_of_nonneg_right hf_sq_le (by positivity)
        _ = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
            rw [hfrac, hfrac1]; ring
  apply Summable.tsum_le_tsum hmode
  ¬∑ exact hsum.of_nonneg_of_le (fun n ‚Ü¶ mul_nonneg (sq_nonneg _) (sq_nonneg _)) hmode
  ¬∑ exact hsum

