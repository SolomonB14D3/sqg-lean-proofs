set_option maxHeartbeats 800000 in
/-- **Strong-LВІ convergence lifts to `hsSeminormSq 0` convergence when
zero mode vanishes both on the sequence and on the limit.** The key
primitive used in Route B `l2Conservation`. -/
theorem tendsto_hsSeminormSq_of_tendsto_L2sub_torus
    {О№ : Type*} {l : Filter О№}
    {f : О№ вҶ’ Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {g : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hL2 : Filter.Tendsto (fun i => вҲ« x, вҖ–f i x - g xвҖ– ^ 2) l (nhds 0))
    (hZero_f : вҲҖ i, mFourierCoeff (f i) (0 : Fin 2 вҶ’ в„Ө) = 0)
    (hZero_g : mFourierCoeff g (0 : Fin 2 вҶ’ в„Ө) = 0) :
    Filter.Tendsto (fun i => hsSeminormSq 0 (f i)) l
      (nhds (hsSeminormSq 0 g)) := by
  have h_lim := tendsto_integral_norm_sq_of_tendsto_L2sub_torus hL2
  have h_eq_g : (вҲ« x, вҖ–g xвҖ– ^ 2) = hsSeminormSq 0 g :=
    integral_norm_sq_eq_hsSeminormSq_zero_of_zero_fourier_zero g hZero_g
  rw [h_eq_g] at h_lim
  exact h_lim.congr (fun i =>
    integral_norm_sq_eq_hsSeminormSq_zero_of_zero_fourier_zero (f i) (hZero_f i))

-- Un-bundled (raw) helpers вҖ” the theorems below take `nsub`, `Оё_lim`,
-- `tendsto_L2_proof` as independent arguments rather than projecting
-- from a `HasAubinLionsExtraction` structure. Eliminating structure
-- projection removes the whnf bottleneck that previously caused
-- 1.6M-heartbeat timeouts in the bundled capstone.

/-- **Raw per-time strong-LВІ limit.** No `HasAubinLionsExtraction`. -/
theorem tendsto_integral_norm_sq_galerkinToLp_raw
    (nsub : в„• вҶ’ в„•)
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ))
    (Оё_lim : в„қ вҶ’ Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (tendsto_L2_proof : вҲҖ t : в„қ, 0 вүӨ t вҶ’
      Filter.Tendsto
        (fun k : в„• =>
          вҲ« x, вҖ–galerkinToLp (sqgBox (nsub k)) (Оұ (nsub k) t) x
                - Оё_lim t xвҖ– ^ 2)
        Filter.atTop (nhds 0))
    (t : в„қ) (ht : 0 вүӨ t) :
    Filter.Tendsto
      (fun k : в„• =>
        вҲ« x, вҖ–galerkinToLp (sqgBox (nsub k)) (Оұ (nsub k) t) xвҖ– ^ 2)
      Filter.atTop (nhds (вҲ« x, вҖ–Оё_lim t xвҖ– ^ 2)) :=
  tendsto_integral_norm_sq_of_tendsto_L2sub (tendsto_L2_proof t ht)

-- Diagnostic run revealed the whnf bottleneck: `Int.rec` unfolded 3.5M
-- times + `List.range.loop` 162k times during isDefEq on `sqgBox (nsub k)`
-- for symbolic `nsub k`.  `sqgBox n = Fintype.piFinset (Icc (-(n+1)) (n+1))
-- .erase 0` вҖ” Lean kept expanding integer ranges trying to reduce with a
-- symbolic index.  Mark `sqgBox` locally irreducible in this section so
