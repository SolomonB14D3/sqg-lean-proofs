        = hsSeminormSq 0 (galerkinToLp (sqgBox n) (Оұ n 0))) :
    вҲҖ t, 0 вүӨ t вҶ’
      hsSeminormSq 0 (ext.Оё_lim t) = hsSeminormSq 0 (ext.Оё_lim 0) := by
  refine l2Conservation_of_aubinLions_raw ext.nsub Оұ ext.Оё_lim ?_ hLevel ?_
  В· -- `ext.tendsto_L2` may have a different `DecidableEq` instance than
    -- what the raw expects under `attribute [local irreducible] sqgBox`;
    -- `convert` bridges via subsingleton on the instance.
    convert ext.tendsto_L2
  В· intro t ht
    exact mFourierCoeff_aubinLionsLimit_zero ext
      (fun n П„ _ => mFourierCoeff_galerkin_sqgBox_zero_any n (Оұ n П„)) ht

