structure HasThermostatBound
    (_őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) where
  /-- The thermostat upper bound `őĪ‚čÜ`. -/
  őĪ_star : ‚ĄĚ
  /-- `őĪ‚čÜ < 1`: the key inequality of the thermostat hypothesis. -/
  őĪ_star_lt_one : őĪ_star < 1

/-- **(H-őĪ) zero-datum witness.**  The zero solution trivially satisfies
