    hsSeminormSq s S00 + hsSeminormSq s S01 ‚Č§ hsSeminormSq (s + 1) őł / 2 := by
  have h00 := heat_smoothed_sqgStrain_00_Hs_integrated_tight s ht őł S00 hcoeff0 hsum
  have h01 := heat_smoothed_sqgStrain_01_Hs_integrated_tight s ht őł S01 hcoeff1 hsum
  linarith

/-- **Poisson-smoothed SQG vorticity L¬≤ mode bound.** For `n ‚Č† 0`, `t > 0`:

    `‚ÄĖP_t¬∑ŌČŐā¬∑c‚ÄĖ¬≤ ‚Č§ exp(-2)/t¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤`

The Poisson smoothing is sharper than heat at vorticity level because
Poisson gains 1 derivative per t (heat gains 2). So `P_t ¬∑ L ‚Č§ e^{-1}/t`
squared gives `P_t¬≤¬∑L¬≤ ‚Č§ e^{-2}/t¬≤`. -/
theorem poisson_smoothed_vorticity_L2_mode {t : ‚ĄĚ} (ht : 0 < t)
    {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) (c : ‚Ąā) :
    ‚ÄĖ((poissonSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * c‚ÄĖ ^ 2
    ‚Č§ Real.exp (-2) / t ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (poissonSymbol_nonneg t n),
    sqgVorticitySymbol_norm hn]
  -- Goal: p¬≤ ¬∑ L¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤ ‚Č§ exp(-2)/t¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤
  -- Use: (p ¬∑ L)¬≤ ‚Č§ (exp(-1)/t)¬≤ = exp(-2)/t¬≤
  have hmain := latticeNorm_mul_poisson_le ht n
  -- hmain: L ¬∑ p ‚Č§ exp(-1)/t
  have hp_nn : 0 ‚Č§ poissonSymbol t n := poissonSymbol_nonneg t n
  have hL_nn : 0 ‚Č§ (latticeNorm n : ‚ĄĚ) := latticeNorm_nonneg n
  have hLp_nn : 0 ‚Č§ (latticeNorm n : ‚ĄĚ) * poissonSymbol t n :=
    mul_nonneg hL_nn hp_nn
  have hexp_nn : 0 ‚Č§ Real.exp (-1) / t :=
    div_nonneg (Real.exp_pos _).le ht.le
  have hmain' : (latticeNorm n * poissonSymbol t n) ^ 2 ‚Č§ (Real.exp (-1) / t) ^ 2 :=
    sq_le_sq' (by linarith) hmain
  have hsq_eq : (Real.exp (-1) / t) ^ 2 = Real.exp (-2) / t ^ 2 := by
    rw [div_pow]
    congr 1
    rw [sq, ‚Üź Real.exp_add]
    congr 1; ring
  rw [hsq_eq] at hmain'
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  calc (poissonSymbol t n) ^ 2 * (latticeNorm n : ‚ĄĚ) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
      = (latticeNorm n * poissonSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by ring
    _ ‚Č§ Real.exp (-2) / t ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 :=
        mul_le_mul_of_nonneg_right hmain' hc_nn

/-- **Poisson-smoothed SQG vorticity L¬≤ integrated bound.** For `t > 0`:

    `‚ÄĖP_t ŌČ‚ÄĖ¬≤_{L¬≤} ‚Č§ exp(-2)/t¬≤ ¬∑ ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}` -/
theorem poisson_smoothed_vorticity_L2_integrated {t : ‚ĄĚ} (ht : 0 < t)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((poissonSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * mFourierCoeff őł n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
    ‚Č§ Real.exp (-2) / t ^ 2 * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
  rw [show Real.exp (-2) / t ^ 2 *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        Real.exp (-2) / t ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 from
    (tsum_mul_left).symm]
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2 ‚Č§
      Real.exp (-2) / t ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n]
    by_cases hn : n = 0
