    0 ‚Č§ trigPolyEnergyHs s S c := by
  unfold trigPolyEnergyHs
  exact Finset.sum_nonneg (fun m _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))

/-- Specialization: `s = 2` recovers ¬ß10.68's `trigPolyEnergyHs2`. -/
lemma trigPolyEnergyHs_two
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)] (c : ‚Ü•S ‚Üí ‚Ąā) :
