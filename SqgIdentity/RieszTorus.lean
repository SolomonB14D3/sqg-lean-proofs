  ¬∑ exact hsum.mul_left _

/-- **Heat-smoothed SQG vorticity ŠłĘňĘ integrated bound.** For `t ‚Č• 0`:

    `‚ÄĖe^{tőĒ} ŌČ‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}`

where `u` has Fourier coefficients `heat(t,n) ¬∑ sqgVorticitySymbol(n) ¬∑ őłŐā(n)`.
Combines heat ŠłĘňĘ-contractivity with vorticity ŠłĘňĘ-ŠłĘňĘ‚Āļ¬Ļ bound. -/
theorem heat_smoothed_vorticity_Hs_integrated (s : ‚ĄĚ) {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * mFourierCoeff őł n)
    (hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq (s + 1) őł := by
  unfold hsSeminormSq
  -- Extract the mode-level bound once
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2
      ‚Č§ fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n]
    by_cases hn : n = 0
    ¬∑ subst hn
      have hŌČ0 : sqgVorticitySymbol 0 = 0 := by
        unfold sqgVorticitySymbol sqgGradSymbol derivSymbol rieszSymbol; simp
      rw [hŌČ0, mul_zero, zero_mul, norm_zero]
      have h0sq : (0 : ‚ĄĚ) ^ 2 = 0 := by norm_num
      rw [h0sq, mul_zero]
      exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
        Real.norm_of_nonneg (heatSymbol_nonneg t n),
        sqgVorticitySymbol_norm hn]
      have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
      have hheat_le : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht n
      have hheat_sq_le : (heatSymbol t n) ^ 2 ‚Č§ 1 :=
        pow_le_one‚āÄ hheat_nn hheat_le
      have hfrac := fracDerivSymbol_add_sq s 1 n
      have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
        rw [fracDerivSymbol_one_eq hn]
      calc (fracDerivSymbol s n) ^ 2 *
            ((heatSymbol t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
          = (heatSymbol t n) ^ 2 *
            ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
            ring
        _ ‚Č§ 1 *
            ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
            mul_le_mul_of_nonneg_right hheat_sq_le (by positivity)
        _ = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
            rw [hfrac, hfrac1]; ring
  apply Summable.tsum_le_tsum hmode
  ¬∑ exact hsum.of_nonneg_of_le (fun n ‚Ü¶ mul_nonneg (sq_nonneg _) (sq_nonneg _)) hmode
  ¬∑ exact hsum

/-- **Heat-smoothed SQG gradient ŠłĘňĘ integrated bound.** For `t ‚Č• 0`:

    `‚ÄĖe^{tőĒ} ‚ąā_i u_j‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}` -/
theorem heat_smoothed_sqgGrad_Hs_integrated (s : ‚ĄĚ) {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (i j : Fin 2)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgGradSymbol i j n * mFourierCoeff őł n)
    (hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq (s + 1) őł := by
  unfold hsSeminormSq
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2
      ‚Č§ fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n]
    by_cases hn : n = 0
    ¬∑ subst hn
      have hg0 : sqgGradSymbol i j 0 = 0 := by
        unfold sqgGradSymbol derivSymbol rieszSymbol; simp
      rw [hg0, mul_zero, zero_mul, norm_zero]
      have h0sq : (0 : ‚ĄĚ) ^ 2 = 0 := by norm_num
      rw [h0sq, mul_zero]
      exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
        Real.norm_of_nonneg (heatSymbol_nonneg t n)]
      have hgrad := sqgGrad_norm_le hn i j
      have hgrad_sq_le : ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
        sq_le_sq' (by linarith [norm_nonneg (sqgGradSymbol i j n)]) hgrad
      have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
      have hheat_le : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht n
      have hheat_sq_le : (heatSymbol t n) ^ 2 ‚Č§ 1 :=
        pow_le_one‚āÄ hheat_nn hheat_le
      have hfrac := fracDerivSymbol_add_sq s 1 n
      have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
        rw [fracDerivSymbol_one_eq hn]
      calc (fracDerivSymbol s n) ^ 2 *
            ((heatSymbol t n) ^ 2 * ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
          ‚Č§ (fracDerivSymbol s n) ^ 2 *
            ((heatSymbol t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
            apply mul_le_mul_of_nonneg_left _ (sq_nonneg _)
            apply mul_le_mul_of_nonneg_right _ (sq_nonneg _)
            exact mul_le_mul_of_nonneg_left hgrad_sq_le (sq_nonneg _)
        _ = (heatSymbol t n) ^ 2 *
            ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
            ring
        _ ‚Č§ 1 *
            ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
            mul_le_mul_of_nonneg_right hheat_sq_le (by positivity)
        _ = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
            rw [hfrac, hfrac1]; ring
  apply Summable.tsum_le_tsum hmode
  ¬∑ exact hsum.of_nonneg_of_le (fun n ‚Ü¶ mul_nonneg (sq_nonneg _) (sq_nonneg _)) hmode
  ¬∑ exact hsum

/-- **Heat-smoothed SQG strain ŠłĘňĘ integrated bound.** For `t ‚Č• 0`:

    `‚ÄĖe^{tőĒ} S_{ij}‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}` -/
theorem heat_smoothed_sqgStrain_Hs_integrated (s : ‚ĄĚ) {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (i j : Fin 2)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol i j n * mFourierCoeff őł n)
    (hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq (s + 1) őł := by
  unfold hsSeminormSq
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2
      ‚Č§ fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n]
    by_cases hn : n = 0
    ¬∑ subst hn
      have hs0 : sqgStrainSymbol i j 0 = 0 := by
        unfold sqgStrainSymbol sqgGradSymbol derivSymbol rieszSymbol; simp
      rw [hs0, mul_zero, zero_mul, norm_zero]
      have h0sq : (0 : ‚ĄĚ) ^ 2 = 0 := by norm_num
      rw [h0sq, mul_zero]
      exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
        Real.norm_of_nonneg (heatSymbol_nonneg t n)]
      have hstrain := sqgStrain_norm_le hn i j
      have hstrain_sq_le : ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
        sq_le_sq' (by linarith [norm_nonneg (sqgStrainSymbol i j n)]) hstrain
      have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
      have hheat_le : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht n
      have hheat_sq_le : (heatSymbol t n) ^ 2 ‚Č§ 1 :=
        pow_le_one‚āÄ hheat_nn hheat_le
      have hfrac := fracDerivSymbol_add_sq s 1 n
      have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
        rw [fracDerivSymbol_one_eq hn]
      calc (fracDerivSymbol s n) ^ 2 *
            ((heatSymbol t n) ^ 2 * ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
          ‚Č§ (fracDerivSymbol s n) ^ 2 *
            ((heatSymbol t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
            apply mul_le_mul_of_nonneg_left _ (sq_nonneg _)
            apply mul_le_mul_of_nonneg_right _ (sq_nonneg _)
            exact mul_le_mul_of_nonneg_left hstrain_sq_le (sq_nonneg _)
        _ = (heatSymbol t n) ^ 2 *
            ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
            ring
        _ ‚Č§ 1 *
            ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
            mul_le_mul_of_nonneg_right hheat_sq_le (by positivity)
        _ = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
            rw [hfrac, hfrac1]; ring
  apply Summable.tsum_le_tsum hmode
  ¬∑ exact hsum.of_nonneg_of_le (fun n ‚Ü¶ mul_nonneg (sq_nonneg _) (sq_nonneg _)) hmode
  ¬∑ exact hsum

/-- **Heat-smoothed SQG velocity ŠłĘňĘ integrated bound.** For `t ‚Č• 0`:

    `‚ÄĖe^{tőĒ} u_j‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘňĘ}`

where velocity `u_j = (R‚āĀőł, -R‚āÄőł)` and heat acts diagonally.
No gain in Sobolev level ‚ÄĒ both Riesz and heat are contractive. -/
theorem heat_smoothed_sqg_velocity_Hs_integrated (s : ‚ĄĚ) {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (j : Fin 2)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) *
        (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) *
        mFourierCoeff őł n)
    (hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq s őł := by
  unfold hsSeminormSq
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2
      ‚Č§ fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n]
    apply mul_le_mul_of_nonneg_left _ (sq_nonneg _)
    -- ‚ÄĖheat¬∑R¬∑c‚ÄĖ¬≤ ‚Č§ ‚ÄĖc‚ÄĖ¬≤  using heat ‚Č§ 1 and |R| ‚Č§ 1
    rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
      Real.norm_of_nonneg (heatSymbol_nonneg t n)]
    have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
    have hheat_le : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht n
    have hheat_sq_le : (heatSymbol t n) ^ 2 ‚Č§ 1 :=
      pow_le_one‚āÄ hheat_nn hheat_le
    have hR_le : ‚ÄĖ(if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n)‚ÄĖ ^ 2 ‚Č§ 1 := by
      by_cases hn : n = 0
      ¬∑ subst hn
        by_cases hj : j = 0
        ¬∑ simp [hj]
        ¬∑ simp [hj]
      ¬∑ have hpyth := rieszSymbol_sum_sq hn
        simp only [Fin.sum_univ_two] at hpyth
        by_cases hj : j = 0
        ¬∑ simp [hj]; nlinarith [sq_nonneg ‚ÄĖrieszSymbol 0 n‚ÄĖ]
        ¬∑ simp [hj, norm_neg]; nlinarith [sq_nonneg ‚ÄĖrieszSymbol 1 n‚ÄĖ]
    have hc_nn : 0 ‚Č§ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := sq_nonneg _
    calc (heatSymbol t n) ^ 2 *
          ‚ÄĖ(if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n)‚ÄĖ ^ 2 *
          ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2
        ‚Č§ 1 * 1 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          exact mul_le_mul hheat_sq_le hR_le (sq_nonneg _) (by linarith)
      _ = ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by ring
  apply Summable.tsum_le_tsum hmode
  ¬∑ exact hsum.of_nonneg_of_le (fun n ‚Ü¶ mul_nonneg (sq_nonneg _) (sq_nonneg _)) hmode
  ¬∑ exact hsum

/-- **Heat-smoothed S‚āÄ‚āÄ ŠłĘňĘ integrated TIGHT bound (4√ó sharper).**

    `‚ÄĖe^{tőĒ} S‚āÄ‚āÄ‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}} / 4` -/
theorem heat_smoothed_sqgStrain_00_Hs_integrated_tight (s : ‚ĄĚ) {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
