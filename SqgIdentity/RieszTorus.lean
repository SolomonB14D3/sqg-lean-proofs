### ¬ß10.172.A Cauchy‚ÄďSchwarz in `Fin 2` (real and complex-weight)

The `galerkinKKernel` bound uses `‚ÄĖ‚ąĎ_j ŌÉ_j(‚Ąď) ¬∑ m_j‚ÄĖ ‚Č§ latticeNorm m`.
We prove the underlying 2-dimensional Cauchy‚ÄďSchwarz elementarily. -/

/-- **Real 2D Cauchy‚ÄďSchwarz (squared form).**  Follows from
`(a‚āÄ b‚āÄ + a‚āĀ b‚āĀ)¬≤ + (a‚āÄ b‚āĀ - a‚āĀ b‚āÄ)¬≤ = (a‚āÄ¬≤ + a‚āĀ¬≤)(b‚āÄ¬≤ + b‚āĀ¬≤)`. -/
lemma fin_two_CS_real_sq (a‚āÄ a‚āĀ b‚āÄ b‚āĀ : ‚ĄĚ) :
    (a‚āÄ * b‚āÄ + a‚āĀ * b‚āĀ) ^ 2 ‚Č§ (a‚āÄ ^ 2 + a‚āĀ ^ 2) * (b‚āÄ ^ 2 + b‚āĀ ^ 2) := by
  nlinarith [sq_nonneg (a‚āÄ * b‚āĀ - a‚āĀ * b‚āÄ)]

/-- **Complex 2-vector √ó real 2-vector Cauchy‚ÄďSchwarz (squared form).**
Decomposes each complex coefficient into real + imaginary parts and
applies `fin_two_CS_real_sq` to each. -/
lemma fin_two_CS_complex_real_sq (z‚āÄ z‚āĀ : ‚Ąā) (a‚āÄ a‚āĀ : ‚ĄĚ) :
    ‚ÄĖz‚āÄ * ((a‚āÄ : ‚ĄĚ) : ‚Ąā) + z‚āĀ * ((a‚āĀ : ‚ĄĚ) : ‚Ąā)‚ÄĖ ^ 2
      ‚Č§ (‚ÄĖz‚āÄ‚ÄĖ ^ 2 + ‚ÄĖz‚āĀ‚ÄĖ ^ 2) * (a‚āÄ ^ 2 + a‚āĀ ^ 2) := by
  have h_re : (z‚āÄ * ((a‚āÄ : ‚ĄĚ) : ‚Ąā) + z‚āĀ * ((a‚āĀ : ‚ĄĚ) : ‚Ąā)).re =
              z‚āÄ.re * a‚āÄ + z‚āĀ.re * a‚āĀ := by
    simp [Complex.add_re, Complex.mul_re, Complex.ofReal_re, Complex.ofReal_im]
  have h_im : (z‚āÄ * ((a‚āÄ : ‚ĄĚ) : ‚Ąā) + z‚āĀ * ((a‚āĀ : ‚ĄĚ) : ‚Ąā)).im =
              z‚āÄ.im * a‚āÄ + z‚āĀ.im * a‚āĀ := by
    simp [Complex.add_im, Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im]
  have h_norm_sq : ‚ÄĖz‚āÄ * ((a‚āÄ : ‚ĄĚ) : ‚Ąā) + z‚āĀ * ((a‚āĀ : ‚ĄĚ) : ‚Ąā)‚ÄĖ ^ 2 =
      (z‚āÄ.re * a‚āÄ + z‚āĀ.re * a‚āĀ) ^ 2 + (z‚āÄ.im * a‚āÄ + z‚āĀ.im * a‚āĀ) ^ 2 := by
    rw [Complex.sq_norm, Complex.normSq_apply, h_re, h_im]; ring
  have h_z0 : ‚ÄĖz‚āÄ‚ÄĖ ^ 2 = z‚āÄ.re ^ 2 + z‚āÄ.im ^ 2 := by
    rw [Complex.sq_norm, Complex.normSq_apply]; ring
  have h_z1 : ‚ÄĖz‚āĀ‚ÄĖ ^ 2 = z‚āĀ.re ^ 2 + z‚āĀ.im ^ 2 := by
    rw [Complex.sq_norm, Complex.normSq_apply]; ring
  rw [h_norm_sq, h_z0, h_z1]
  nlinarith [fin_two_CS_real_sq z‚āÄ.re z‚āĀ.re a‚āÄ a‚āĀ,
             fin_two_CS_real_sq z‚āÄ.im z‚āĀ.im a‚āÄ a‚āĀ,
             sq_nonneg a‚āÄ, sq_nonneg a‚āĀ,
             sq_nonneg z‚āÄ.re, sq_nonneg z‚āÄ.im,
             sq_nonneg z‚āĀ.re, sq_nonneg z‚āĀ.im]

/-- **`ŌÉ(‚Ąď) ¬∑ m` coordinate norm bound.**
`‚ÄĖ‚ąĎ_j ŌÉ_j(‚Ąď) ¬∑ (m_j : ‚Ąā)‚ÄĖ ‚Č§ latticeNorm m`.  Combines `fin_two_CS_complex_real_sq`
with `sqgVelocitySymbol_sum_sq` (giving `‚ąĎ_j ‚ÄĖŌÉ_j(‚Ąď)‚ÄĖ¬≤ = 1` for `‚Ąď ‚Č† 0`). -/
lemma sqgVelocitySymbol_dot_coord_norm_le
    (‚Ąď m : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * (((m j : ‚ĄĚ)) : ‚Ąā)‚ÄĖ
      ‚Č§ latticeNorm m := by
  rcases eq_or_ne ‚Ąď (0 : Fin 2 ‚Üí ‚Ą§) with h‚Ąď | h‚Ąď
  ¬∑ subst h‚Ąď
    simp only [Fin.sum_univ_two, sqgVelocitySymbol_zero, zero_mul, add_zero,
      norm_zero]
    exact latticeNorm_nonneg m
  ¬∑ rw [Fin.sum_univ_two]
    have h_sig_sq : ‚ÄĖsqgVelocitySymbol 0 ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖsqgVelocitySymbol 1 ‚Ąď‚ÄĖ ^ 2 = 1 :=
      sqgVelocitySymbol_sum_sq h‚Ąď
    have h_latt_sq : (m 0 : ‚ĄĚ) ^ 2 + (m 1 : ‚ĄĚ) ^ 2 = (latticeNorm m) ^ 2 := by
      rw [latticeNorm_sq, Fin.sum_univ_two]
    have h_CS := fin_two_CS_complex_real_sq
      (sqgVelocitySymbol 0 ‚Ąď) (sqgVelocitySymbol 1 ‚Ąď) (m 0 : ‚ĄĚ) (m 1 : ‚ĄĚ)
    rw [h_sig_sq, one_mul, h_latt_sq] at h_CS
    have h_latt_nn : 0 ‚Č§ latticeNorm m := latticeNorm_nonneg m
    have := Real.sqrt_le_sqrt h_CS
    rwa [Real.sqrt_sq (norm_nonneg _), Real.sqrt_sq h_latt_nn] at this

/-! ### ¬ß10.172.B `galerkinKKernel` norm bound via divergence-free

`galerkinKKernel ‚Ąď (m - ‚Ąď) = ‚ąĎ_j ŌÉ_j(‚Ąď) ¬∑ derivSymbol j (m - ‚Ąď) =
i ¬∑ ‚ąĎ_j ŌÉ_j(‚Ąď) ¬∑ ((m - ‚Ąď) j : ‚Ąā) = i ¬∑ (‚ąĎ_j ŌÉ_j(‚Ąď) ¬∑ m_j - ‚ąĎ_j ŌÉ_j(‚Ąď) ¬∑ ‚Ąď_j)
= i ¬∑ ‚ąĎ_j ŌÉ_j(‚Ąď) ¬∑ m_j` (by div-free).  Apply ¬ß10.172.A. -/

/-- **`galerkinKKernel ‚Ąď (m-‚Ąď)` uniform-in-`‚Ąď` norm bound.**
`‚ÄĖgalerkinKKernel ‚Ąď (m-‚Ąď)‚ÄĖ ‚Č§ latticeNorm m`.  Consequence of the
divergence-free identity `ŌÉ(‚Ąď) ¬∑ ‚Ąď = 0` plus ¬ß10.172.A. -/
lemma galerkinKKernel_norm_le_latticeNorm (‚Ąď m : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖgalerkinKKernel ‚Ąď (m - ‚Ąď)‚ÄĖ ‚Č§ latticeNorm m := by
  unfold galerkinKKernel
  have h_term : ‚ąÄ j : Fin 2,
      sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď) =
      I * (sqgVelocitySymbol j ‚Ąď * (((m j : ‚ĄĚ)) : ‚Ąā)) -
      I * (sqgVelocitySymbol j ‚Ąď * (((‚Ąď j : ‚ĄĚ)) : ‚Ąā)) := by
    intro j
    unfold derivSymbol
    have h_pi : ((m - ‚Ąď) j : ‚Ą§) = m j - ‚Ąď j := Pi.sub_apply m ‚Ąď j
    have h_cast : ((((m - ‚Ąď) j : ‚Ą§) : ‚ĄĚ) : ‚Ąā) =
                  (((m j : ‚ĄĚ)) : ‚Ąā) - (((‚Ąď j : ‚ĄĚ)) : ‚Ąā) := by
      rw [h_pi]; push_cast; ring
    rw [h_cast]
    ring
  have h_expand :
      ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď) =
      I * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * (((m j : ‚ĄĚ)) : ‚Ąā)) -
      I * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * (((‚Ąď j : ‚ĄĚ)) : ‚Ąā)) := by
    calc ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)
        = ‚ąĎ j : Fin 2, (I * (sqgVelocitySymbol j ‚Ąď * (((m j : ‚ĄĚ)) : ‚Ąā)) -
                        I * (sqgVelocitySymbol j ‚Ąď * (((‚Ąď j : ‚ĄĚ)) : ‚Ąā))) :=
          Finset.sum_congr rfl (fun j _ => h_term j)
      _ = (‚ąĎ j : Fin 2, I * (sqgVelocitySymbol j ‚Ąď * (((m j : ‚ĄĚ)) : ‚Ąā))) -
          (‚ąĎ j : Fin 2, I * (sqgVelocitySymbol j ‚Ąď * (((‚Ąď j : ‚ĄĚ)) : ‚Ąā))) :=
          Finset.sum_sub_distrib
            (fun j => I * (sqgVelocitySymbol j ‚Ąď * (((m j : ‚ĄĚ)) : ‚Ąā)))
            (fun j => I * (sqgVelocitySymbol j ‚Ąď * (((‚Ąď j : ‚ĄĚ)) : ‚Ąā)))
      _ = I * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * (((m j : ‚ĄĚ)) : ‚Ąā)) -
          I * (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * (((‚Ąď j : ‚ĄĚ)) : ‚Ąā)) := by
          rw [‚Üź Finset.mul_sum, ‚Üź Finset.mul_sum]
  have h_div_free : ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * (((‚Ąď j : ‚ĄĚ)) : ‚Ąā) = 0 := by
    have h := sqgVelocitySymbol_divergence_free ‚Ąď 1
    simp only [mul_one] at h
    rw [Fin.sum_univ_two]
    have h_swap : sqgVelocitySymbol 0 ‚Ąď * (((‚Ąď 0 : ‚ĄĚ)) : ‚Ąā) +
                  sqgVelocitySymbol 1 ‚Ąď * (((‚Ąď 1 : ‚ĄĚ)) : ‚Ąā) =
                  (((‚Ąď 0 : ‚ĄĚ)) : ‚Ąā) * sqgVelocitySymbol 0 ‚Ąď +
                  (((‚Ąď 1 : ‚ĄĚ)) : ‚Ąā) * sqgVelocitySymbol 1 ‚Ąď := by ring
    rw [h_swap]; exact h
  rw [h_expand, h_div_free, mul_zero, sub_zero, norm_mul, Complex.norm_I, one_mul]
  exact sqgVelocitySymbol_dot_coord_norm_le ‚Ąď m

/-! ### ¬ß10.172.C Pointwise `galerkinRHS` bound from `L¬≤` sum

Combines ¬ß10.172.B with Young's inequality on the finite Fourier
convolution to bound `‚ÄĖgalerkinRHS S c m‚ÄĖ` by `latticeNorm m ¬∑ ‚ąĎ_n ‚ÄĖc n‚ÄĖ¬≤`. -/

/-- **Pointwise `galerkinRHS` bound.**
`‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ‚Č§ latticeNorm m ¬∑ ‚ąĎ_{n ‚ąą ‚Ü•S} ‚ÄĖc n‚ÄĖ¬≤`. -/
theorem galerkinRHS_norm_le_latticeNorm_mul_l2_sum
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) (m : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ
      ‚Č§ latticeNorm m * ‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2 := by
  unfold galerkinRHS
  rw [norm_neg]
  -- Step 1: triangle + per-term bound via ¬ß10.172.B.
  have h_per_term : ‚ąÄ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
      ‚ÄĖgalerkinExtend S c ‚Ąď * galerkinExtend S c (m - ‚Ąď) *
       (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))‚ÄĖ
        ‚Č§ ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ * latticeNorm m := by
    intros ‚Ąď _
    rw [norm_mul, norm_mul]
    have h_K : ‚ÄĖ‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď)‚ÄĖ
        ‚Č§ latticeNorm m := by
      have := galerkinKKernel_norm_le_latticeNorm ‚Ąď m
      unfold galerkinKKernel at this
      exact this
    exact mul_le_mul_of_nonneg_left h_K
      (mul_nonneg (norm_nonneg _) (norm_nonneg _))
  -- Step 2: triangle on the sum.
  have h_tri_bound :
      ‚ÄĖ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
        galerkinExtend S c ‚Ąď * galerkinExtend S c (m - ‚Ąď) *
        (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))‚ÄĖ
      ‚Č§ ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
        ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ * latticeNorm m := by
    refine (norm_sum_le _ _).trans ?_
    exact Finset.sum_le_sum h_per_term
  -- Step 3: factor out latticeNorm m.
  have h_factor :
      ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
        ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ * latticeNorm m
      = (‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ) * latticeNorm m := by
    rw [‚Üź Finset.sum_mul]
  -- Step 4: Cauchy‚ÄďSchwarz on the convolution sum bounds it by ‚ąĎ_S ‚ÄĖc‚ÄĖ¬≤.
  have h_CS_conv :
      ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
        ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ
      ‚Č§ ‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2 := by
    -- Bound each |c(‚Ąď)||c(m-‚Ąď)| by Young's (|c(‚Ąď)|¬≤ + |c(m-‚Ąď)|¬≤)/2,
    -- then sum: result ‚Č§ ‚ąĎ_S |c|¬≤ using reindexing ‚Ąď ‚Ü¶ m-‚Ąď.
    -- Specifically: ‚ąĎ_{filter} (|c(‚Ąď)|¬≤ + |c(m-‚Ąď)|¬≤)/2 ‚Č§
    --              (‚ąĎ_{‚Ąď‚ąąS} |c(‚Ąď)|¬≤)/2 + (‚ąĎ_{k‚ąąS} |c(k)|¬≤)/2 = ‚ąĎ_S |c|¬≤.
    have h_young_term : ‚ąÄ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
        ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ‚Č§
        (‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2) / 2 := by
      intros ‚Ąď _
      have := two_mul_le_add_sq ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ
      linarith
    have h_young : ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ
        ‚Č§ ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          (‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2) / 2 :=
      Finset.sum_le_sum h_young_term
    -- Extend filter to S (nonneg summand).
    have h_ext : ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          (‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2) / 2
        ‚Č§ ‚ąĎ ‚Ąď ‚ąą S,
          (‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2) / 2 := by
      refine Finset.sum_le_sum_of_subset_of_nonneg (Finset.filter_subset _ _) ?_
      intros ‚Ąď _ _
      have h_nn : 0 ‚Č§ (‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 +
                       ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2) / 2 := by
        have := add_nonneg (sq_nonneg ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ)
                           (sq_nonneg ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ)
        linarith
      exact h_nn
    -- Split ‚ąĎ_S (a+b)/2 = (‚ąĎ_S a + ‚ąĎ_S b)/2.
    have h_split : ‚ąĎ ‚Ąď ‚ąą S,
          (‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 + ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2) / 2
        = ((‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2) +
           (‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2)) / 2 := by
      rw [‚Üź Finset.sum_add_distrib, ‚Üź Finset.sum_div]
    -- Bound first part: ‚ąĎ_{‚Ąď ‚ąą S} ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ¬≤ = ‚ąĎ_{n : ‚Ü•S} ‚ÄĖc n‚ÄĖ¬≤.
    have h_first : (‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2) = ‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2 := by
      rw [‚Üź Finset.sum_attach S (fun ‚Ąď => ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2)]
      apply Finset.sum_congr rfl
      intros n _
      rw [galerkinExtend_apply_of_mem S c n.2]
    -- Bound second: ‚ąĎ_{‚Ąď ‚ąą S} ‚ÄĖgalerkinExtend S c (m-‚Ąď)‚ÄĖ¬≤ ‚Č§ ‚ąĎ_{n : ‚Ü•S} ‚ÄĖc n‚ÄĖ¬≤.
    have h_second : (‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2)
        ‚Č§ ‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2 := by
      -- For ‚Ąď ‚ąą S with m - ‚Ąď ‚ąČ S, term is 0.  Restrict to filter.
      have h_filter_eq : (‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2) =
          ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S), ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2 := by
        rw [Finset.sum_filter]
        apply Finset.sum_congr rfl
        intros ‚Ąď h‚Ąď
        by_cases hm‚Ąď : m - ‚Ąď ‚ąą S
        ¬∑ simp [hm‚Ąď]
        ¬∑ rw [if_neg hm‚Ąď, galerkinExtend_apply_of_not_mem _ _ hm‚Ąď, norm_zero,
              pow_two, mul_zero]
      rw [h_filter_eq]
      -- Reindex ‚Ąď ‚Ü¶ m - ‚Ąď via Finset.sum_image.  The image of
      -- `S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S)` under `‚Ąď ‚Ü¶ m - ‚Ąď` is the same filter
      -- (since the map is involutive).
      have h_sub_inj : ‚ąÄ ‚Ąď‚āĀ ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          ‚ąÄ ‚Ąď‚āā ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          (fun ‚Ąď : Fin 2 ‚Üí ‚Ą§ => m - ‚Ąď) ‚Ąď‚āĀ = (fun ‚Ąď => m - ‚Ąď) ‚Ąď‚āā ‚Üí ‚Ąď‚āĀ = ‚Ąď‚āā := by
        intros ‚Ąď‚āĀ _ ‚Ąď‚āā _ heq
        -- heq : (fun ‚Ąď => m - ‚Ąď) ‚Ąď‚āĀ = (fun ‚Ąď => m - ‚Ąď) ‚Ąď‚āā; ő≤-reduce.
        dsimp only at heq
        -- heq : m - ‚Ąď‚āĀ = m - ‚Ąď‚āā; apply (m - ¬∑) to both sides to get ‚Ąď‚āĀ = ‚Ąď‚āā.
        calc ‚Ąď‚āĀ = m - (m - ‚Ąď‚āĀ) := (sub_sub_cancel m ‚Ąď‚āĀ).symm
          _ = m - (m - ‚Ąď‚āā) := by rw [heq]
          _ = ‚Ąď‚āā := sub_sub_cancel m ‚Ąď‚āā
      have h_image_eq : (S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S)).image (fun ‚Ąď => m - ‚Ąď) =
          S.filter (fun k => m - k ‚ąą S) := by
        ext x
        simp only [Finset.mem_image, Finset.mem_filter]
        constructor
        ¬∑ rintro ‚ü®‚Ąď, ‚ü®h‚Ąď, hm‚Ąď‚ü©, rfl‚ü©
          refine ‚ü®hm‚Ąď, ?_‚ü©
          rw [sub_sub_cancel]; exact h‚Ąď
        ¬∑ rintro ‚ü®hxS, hmx‚ü©
          refine ‚ü®m - x, ‚ü®hmx, ?_‚ü©, ?_‚ü©
          ¬∑ rw [sub_sub_cancel]; exact hxS
          ¬∑ exact sub_sub_cancel m x
      have h_sum_img : ‚ąĎ ‚Ąď ‚ąą (S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S)).image (fun ‚Ąď => m - ‚Ąď),
          ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2 =
          ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2 :=
        Finset.sum_image h_sub_inj
      rw [‚Üź h_sum_img, h_image_eq]
      -- Bound: ‚ąĎ_{filter} ‚ÄĖgalerkinExtend S c k‚ÄĖ¬≤ ‚Č§ ‚ąĎ_{S} ‚ÄĖgalerkinExtend S c k‚ÄĖ¬≤
      --      = ‚ąĎ_{n : ‚Ü•S} ‚ÄĖc n‚ÄĖ¬≤ (by h_first above).
      calc ‚ąĎ k ‚ąą S.filter (fun k => m - k ‚ąą S), ‚ÄĖgalerkinExtend S c k‚ÄĖ ^ 2
          ‚Č§ ‚ąĎ k ‚ąą S, ‚ÄĖgalerkinExtend S c k‚ÄĖ ^ 2 := by
            refine Finset.sum_le_sum_of_subset_of_nonneg
              (Finset.filter_subset _ _) ?_
            intros _ _ _; exact sq_nonneg _
        _ = ‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2 := h_first
    have h_sum_bd : ((‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ ^ 2) +
                    (‚ąĎ ‚Ąď ‚ąą S, ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ ^ 2)) / 2
        ‚Č§ ‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2 := by
      have hnn : 0 ‚Č§ (‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2) :=
        Finset.sum_nonneg (fun _ _ => sq_nonneg _)
      rw [h_first]
      linarith [h_second]
    linarith [h_young, h_ext, h_split.le.trans h_sum_bd]
  -- Step 5: combine.
  calc ‚ÄĖ‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
        galerkinExtend S c ‚Ąď * galerkinExtend S c (m - ‚Ąď) *
        (‚ąĎ j : Fin 2, sqgVelocitySymbol j ‚Ąď * derivSymbol j (m - ‚Ąď))‚ÄĖ
      ‚Č§ _ := h_tri_bound
    _ = (‚ąĎ ‚Ąď ‚ąą S.filter (fun ‚Ąď => m - ‚Ąď ‚ąą S),
          ‚ÄĖgalerkinExtend S c ‚Ąď‚ÄĖ * ‚ÄĖgalerkinExtend S c (m - ‚Ąď)‚ÄĖ)
        * latticeNorm m := h_factor
    _ ‚Č§ (‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2) * latticeNorm m :=
        mul_le_mul_of_nonneg_right h_CS_conv (latticeNorm_nonneg m)
    _ = latticeNorm m * ‚ąĎ n : ‚Ü•S, ‚ÄĖc n‚ÄĖ ^ 2 := by ring

/-! ### ¬ß10.172.D `HasModeLipschitzFamily` from `L¬≤` conservation

Applies ¬ß10.172.C's pointwise bound + ¬ß10.153.B's mean-value theorem +
¬ß10.97's `L¬≤` conservation hypothesis to produce a per-mode Lipschitz
constant `L(m) = ‚ÄĖőł‚āÄ‚ÄĖ¬≤_{L¬≤} ¬∑ latticeNorm m` uniform in `n`.  Plugs
directly into `HasModeLipschitzFamily.ofSqgGalerkinBounds` (¬ß10.152). -/

/-- **Per-mode Lipschitz family from `L¬≤` conservation.**
Discharges the remaining `hH2`-style analytic hypothesis of ¬ß10.153.C
**structurally**.  The Lipschitz constant `L(m) = M¬≤ ¬∑ latticeNorm m`
is uniform in `n`, where `M¬≤ := ‚ąę x, ‚ÄĖőł‚āÄ x‚ÄĖ¬≤` (the `L¬≤` norm squared
of the initial datum). -/
theorem sqgGalerkin_modeLipschitz_from_l2_conservation
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hEnergy : ‚ąÄ n t, 0 ‚Č§ t ‚Üí
      (‚ąĎ m : ‚Ü•(sqgBox n), ‚ÄĖőĪ n t m‚ÄĖ ^ 2)
        ‚Č§ ‚ąę x, ‚ÄĖőł‚āÄ x‚ÄĖ ^ 2)
    (hDeriv : ‚ąÄ (n : ‚Ąē) (ŌĄ : ‚ĄĚ), 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§), m ‚ąą sqgBox n ‚Üí
      HasDerivWithinAt (fun ŌÉ => galerkinExtend (sqgBox n) (őĪ n ŌÉ) m)
        (galerkinRHS (sqgBox n) (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m)
        (Set.Ici ŌĄ) ŌĄ)
    (hCont : ‚ąÄ (n : ‚Ąē) (m : Fin 2 ‚Üí ‚Ą§), m ‚ąą sqgBox n ‚Üí ‚ąÄ (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
      ContinuousOn (fun ŌÉ => galerkinExtend (sqgBox n) (őĪ n ŌÉ) m)
        (Set.Icc s t)) :
    ‚ąÄ (n : ‚Ąē) (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí 0 ‚Č§ t ‚Üí
      ‚ÄĖgalerkinExtend (sqgBox n) (őĪ n t) m - galerkinExtend (sqgBox n) (őĪ n s) m‚ÄĖ
        ‚Č§ (‚ąę x, ‚ÄĖőł‚āÄ x‚ÄĖ ^ 2) * latticeNorm m * |t - s| := by
  intros n m s t hs ht
  set M‚āā : ‚ĄĚ := ‚ąę x, ‚ÄĖőł‚āÄ x‚ÄĖ ^ 2 with hM‚āā_def
  have hM‚āā_nn : 0 ‚Č§ M‚āā := by
    rw [hM‚āā_def]; exact integral_nonneg (fun _ => sq_nonneg _)
  by_cases hm : m ‚ąą sqgBox n
  ¬∑ rcases le_total s t with hst | hts
    ¬∑ -- s ‚Č§ t: direct MVT application.
      have h_abs : |t - s| = t - s := abs_of_nonneg (sub_nonneg.mpr hst)
      rw [h_abs]
      have h_bound : ‚ąÄ ŌĄ ‚ąą Set.Ico s t,
          ‚ÄĖgalerkinRHS (sqgBox n) (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m‚ÄĖ
            ‚Č§ M‚āā * latticeNorm m := by
        intros ŌĄ hŌĄ
        have h_ŌĄ_nn : 0 ‚Č§ ŌĄ := le_trans hs hŌĄ.1
        have h_pt := galerkinRHS_norm_le_latticeNorm_mul_l2_sum (sqgBox n) (őĪ n ŌĄ) m
        have h_l2 := hEnergy n ŌĄ h_ŌĄ_nn
        calc ‚ÄĖgalerkinRHS (sqgBox n) (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m‚ÄĖ
            ‚Č§ latticeNorm m * ‚ąĎ m' : ‚Ü•(sqgBox n), ‚ÄĖőĪ n ŌĄ m'‚ÄĖ ^ 2 := h_pt
          _ ‚Č§ latticeNorm m * M‚āā :=
              mul_le_mul_of_nonneg_left h_l2 (latticeNorm_nonneg m)
          _ = M‚āā * latticeNorm m := by ring
      have h_deriv_local : ‚ąÄ ŌĄ ‚ąą Set.Ico s t,
          HasDerivWithinAt (fun ŌÉ => galerkinExtend (sqgBox n) (őĪ n ŌÉ) m)
            (galerkinRHS (sqgBox n)
              (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m)
            (Set.Ici ŌĄ) ŌĄ := fun ŌĄ hŌĄ =>
        hDeriv n ŌĄ (le_trans hs hŌĄ.1) m hm
      have h_lip := galerkinExtend_mode_lipschitz_of_ODE_bound
        (sqgBox n) (őĪ n) m (M‚āā * latticeNorm m) hst
        h_deriv_local (hCont n m hm s t hs hst) h_bound
      calc ‚ÄĖgalerkinExtend (sqgBox n) (őĪ n t) m - galerkinExtend (sqgBox n) (őĪ n s) m‚ÄĖ
          ‚Č§ M‚āā * latticeNorm m * (t - s) := h_lip
        _ = M‚āā * latticeNorm m * (t - s) := rfl
    ¬∑ -- t ‚Č§ s: reverse.
      have h_abs : |t - s| = s - t := by
        rw [abs_of_nonpos (sub_nonpos.mpr hts), neg_sub]
      rw [h_abs]
      have h_bound : ‚ąÄ ŌĄ ‚ąą Set.Ico t s,
          ‚ÄĖgalerkinRHS (sqgBox n) (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m‚ÄĖ
            ‚Č§ M‚āā * latticeNorm m := by
        intros ŌĄ hŌĄ
        have h_ŌĄ_nn : 0 ‚Č§ ŌĄ := le_trans ht hŌĄ.1
        have h_pt := galerkinRHS_norm_le_latticeNorm_mul_l2_sum (sqgBox n) (őĪ n ŌĄ) m
        have h_l2 := hEnergy n ŌĄ h_ŌĄ_nn
        calc ‚ÄĖgalerkinRHS (sqgBox n) (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m‚ÄĖ
            ‚Č§ latticeNorm m * ‚ąĎ m' : ‚Ü•(sqgBox n), ‚ÄĖőĪ n ŌĄ m'‚ÄĖ ^ 2 := h_pt
          _ ‚Č§ latticeNorm m * M‚āā :=
              mul_le_mul_of_nonneg_left h_l2 (latticeNorm_nonneg m)
          _ = M‚āā * latticeNorm m := by ring
      have h_deriv_local : ‚ąÄ ŌĄ ‚ąą Set.Ico t s,
          HasDerivWithinAt (fun ŌÉ => galerkinExtend (sqgBox n) (őĪ n ŌÉ) m)
            (galerkinRHS (sqgBox n)
              (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m)
            (Set.Ici ŌĄ) ŌĄ := fun ŌĄ hŌĄ =>
        hDeriv n ŌĄ (le_trans ht hŌĄ.1) m hm
      have h_lip := galerkinExtend_mode_lipschitz_of_ODE_bound
        (sqgBox n) (őĪ n) m (M‚āā * latticeNorm m) hts
        h_deriv_local (hCont n m hm t s ht hts) h_bound
      rw [norm_sub_rev]
      exact h_lip
  ¬∑ -- m ‚ąČ sqgBox n: both galerkinExtend values are 0.
