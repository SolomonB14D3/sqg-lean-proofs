/-! ### В§11.29 Monotone constant form

For any `C вүҘ 2^{2s}В·(2В·latticeZetaConst s)`, the Banach-algebra bound
holds with constant `C`.  Useful for unifying constants across multiple
terms. -/

/-- **В§11.29 вҖ” Monotonicity of the concrete Banach-algebra constant.**
If `C вүҘ 2^{2s}В·(2В·latticeZetaConst s)`, then
`HasTrigPolyBanachAlgebraBound s C` holds.  Built from В§11.27 +
monotonicity of the bound structure. -/
theorem hasTrigPolyBanachAlgebraBound_of_gt_one_mono
    {s : в„қ} (hs : 1 < s) {C : в„қ}
    (hC : 2 ^ (2 * s) * (2 * latticeZetaConst s) вүӨ C) :
    HasTrigPolyBanachAlgebraBound s C where
  nonneg := le_trans
    (mul_nonneg (Real.rpow_nonneg (by norm_num : (0 : в„қ) вүӨ 2) _)
      (mul_nonneg (by norm_num : (0 : в„қ) вүӨ 2) (latticeZetaConst_nonneg s))) hC
  bound := by
    intros A B cf cg hA hB
    have h := (hasTrigPolyBanachAlgebraBound_of_gt_one hs).bound A B cf cg hA hB
    have h_nnA : 0 вүӨ hsSeminormSq s (trigPoly A cf) := hsSeminormSq_nonneg_any _ _
    have h_nnB : 0 вүӨ hsSeminormSq s (trigPoly B cg) := hsSeminormSq_nonneg_any _ _
    have h_prod_nn : 0 вүӨ hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg) :=
      mul_nonneg h_nnA h_nnB
    calc hsSeminormSq s (trigPolyProduct A B cf cg)
        вүӨ (2 ^ (2 * s) * (2 * latticeZetaConst s))
            * hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg) := h
      _ = (2 ^ (2 * s) * (2 * latticeZetaConst s))
            * (hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg)) := by ring
      _ вүӨ C * (hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg)) :=
          mul_le_mul_of_nonneg_right hC h_prod_nn
      _ = C * hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg) := by ring

end SqgIdentity
