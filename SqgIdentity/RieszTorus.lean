    exact heat_smoothed_sqgStrain_L2_mode ht n i j (mFourierCoeff őł n)
  ¬∑ apply (hsum.mul_left (Real.exp (-1) / t)).of_nonneg_of_le
    ¬∑ intro n; exact sq_nonneg _
    ¬∑ intro n
      rw [hcoeff n]
      exact heat_smoothed_sqgStrain_L2_mode ht n i j (mFourierCoeff őł n)
  ¬∑ exact hsum.mul_left _

/-- **Heat-smoothed SQG strain tight integrated L¬≤ bound (4√ó sharper).**

    `‚ÄĖe^{tőĒ} S‚āÄ‚āÄ‚ÄĖ¬≤_{L¬≤} ‚Č§ exp(-1)/(4t) ¬∑ ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}` -/
theorem heat_smoothed_sqgStrain_00_L2_integrated_tight {t : ‚ĄĚ} (ht : 0 < t)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol 0 0 n * mFourierCoeff őł n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
    ‚Č§ Real.exp (-1) / (4 * t) * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
  rw [show Real.exp (-1) / (4 * t) *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        Real.exp (-1) / (4 * t) * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 from
