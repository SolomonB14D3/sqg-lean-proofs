        В· simp [hj, norm_neg]; nlinarith [sq_nonneg вҖ–rieszSymbol 1 nвҖ–]
    have hc_nn : 0 вүӨ вҖ–mFourierCoeff Оё nвҖ– ^ 2 := sq_nonneg _
