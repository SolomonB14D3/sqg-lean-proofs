/-- **őĪ-fracHeat-smoothed S‚āÄ‚āÄ L¬≤ mode tight bound.** For `őĪ > 0, t > 0, n ‚Č† 0`:

    `‚ÄĖfracHeat(őĪ,t,n) ¬∑ S‚āÄ‚āÄ(n) ¬∑ c‚ÄĖ¬≤ ‚Č§ (1/őĪ)^{1/őĪ}¬∑exp(-1/őĪ)/(4¬∑t^{1/őĪ}) ¬∑ ‚ÄĖc‚ÄĖ¬≤`

4√ó sharper than the generic strain bound via tight `|S‚āÄ‚āÄ(n)|¬≤ ‚Č§ ‚ÄĖn‚ÄĖ¬≤/4`. -/
theorem fracHeat_smoothed_sqgStrain_00_L2_mode_tight
    {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol 0 0 n * c‚ÄĖ ^ 2
    ‚Č§ ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / (4 * t ^ (1 / őĪ))) * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have hs0 : sqgStrainSymbol 0 0 0 = 0 := by
      unfold sqgStrainSymbol sqgGradSymbol derivSymbol rieszSymbol; simp
    rw [hs0, mul_zero, zero_mul, norm_zero, sq, mul_zero]
    have h1őĪ : 0 < 1 / őĪ := div_pos one_pos hőĪ
    have htőĪ : 0 < t ^ (1 / őĪ) := Real.rpow_pos_of_pos ht _
    have h1kk : 0 < (1 / őĪ) ^ (1 / őĪ) := Real.rpow_pos_of_pos h1őĪ _
    exact mul_nonneg (by positivity) (sq_nonneg _)
  ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
      Real.norm_of_nonneg (fracHeatSymbol_nonneg őĪ t n)]
    have hstrain := sqgStrain_00_sq_le_quarter hn
    have hf_nn : 0 ‚Č§ fracHeatSymbol őĪ t n := fracHeatSymbol_nonneg őĪ t n
    have hf_le : fracHeatSymbol őĪ t n ‚Č§ 1 := fracHeatSymbol_le_one hőĪ ht.le n
    have hmain : (fracDerivSymbol 1 n) ^ 2 * fracHeatSymbol őĪ t n
        ‚Č§ (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ) :=
      fracDerivSymbol_sq_mul_fracHeat_le hőĪ one_pos ht n
    have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
      rw [fracDerivSymbol_one_eq hn]
    rw [hfrac1] at hmain
    have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
    have hfactor_nn : 0 ‚Č§ (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ) := by
      have h1őĪ : 0 < 1 / őĪ := div_pos one_pos hőĪ
      have htőĪ : 0 < t ^ (1 / őĪ) := Real.rpow_pos_of_pos ht _
      have h1kk : 0 < (1 / őĪ) ^ (1 / őĪ) := Real.rpow_pos_of_pos h1őĪ _
      positivity
    calc (fracHeatSymbol őĪ t n) ^ 2 * ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
        ‚Č§ (fracHeatSymbol őĪ t n) ^ 2 * ((latticeNorm n) ^ 2 / 4) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          exact mul_le_mul_of_nonneg_left hstrain (sq_nonneg _)
      _ = fracHeatSymbol őĪ t n *
          ((latticeNorm n) ^ 2 * fracHeatSymbol őĪ t n) / 4 * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [sq]; ring
      _ ‚Č§ fracHeatSymbol őĪ t n *
          ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) / 4 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply div_le_div_of_nonneg_right _ (by linarith : (0 : ‚ĄĚ) ‚Č§ 4)
          exact mul_le_mul_of_nonneg_left hmain hf_nn
      _ ‚Č§ 1 *
          ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) / 4 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          apply div_le_div_of_nonneg_right _ (by linarith : (0 : ‚ĄĚ) ‚Č§ 4)
          exact mul_le_mul_of_nonneg_right hf_le hfactor_nn
      _ = (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / (4 * t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [one_mul]; field_simp

