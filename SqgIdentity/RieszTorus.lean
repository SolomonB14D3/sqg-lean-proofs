/-- **Route B `SqgEvolutionAxioms` without the `hL2` hypothesis.** -/
theorem SqgEvolutionAxioms.of_aubinLions_and_galerkin_energy
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {Оё : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (ext : HasAubinLionsExtraction Оё Оұ)
    (hLevel : вҲҖ n t, 0 вүӨ t вҶ’
      hsSeminormSq 0 (galerkinToLp (sqgBox n) (Оұ n t))
        = hsSeminormSq 0 (galerkinToLp (sqgBox n) (Оұ n 0)))
    {u : Fin 2 вҶ’ в„қ вҶ’ Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hu : HasGalerkinLimitVelocity ext.Оё_lim u) :
    SqgEvolutionAxioms ext.Оё_lim :=
  SqgEvolutionAxioms.of_aubinLions ext
    (l2Conservation_of_aubinLions ext hLevel) hu

/-- **Route B headline: `SqgSolution` from AubinвҖ“Lions + Galerkin
energy conservation + velocity witness + smooth initial data.** The
`hL2` hypothesis of В§10.145 is now internally discharged from the
per-level Galerkin energy conservation (В§10.97). -/
theorem exists_sqgSolution_via_RouteB_from_galerkin_energy
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {Оё : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (ext : HasAubinLionsExtraction Оё Оұ)
    (hLevel : вҲҖ n t, 0 вүӨ t вҶ’
      hsSeminormSq 0 (galerkinToLp (sqgBox n) (Оұ n t))
        = hsSeminormSq 0 (galerkinToLp (sqgBox n) (Оұ n 0)))
    {u : Fin 2 вҶ’ в„қ вҶ’ Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hu : HasGalerkinLimitVelocity ext.Оё_lim u)
    (hSmooth : вҲғ s : в„қ, 2 < s вҲ§
      Summable (fun n : Fin 2 вҶ’ в„Ө =>
        (fracDerivSymbol s n) ^ 2 * вҖ–mFourierCoeff (ext.Оё_lim 0) nвҖ– ^ 2)) :
    вҲғ sol : SqgSolution, sol.Оё = ext.Оё_lim :=
  exists_sqgSolution_via_RouteB ext
    (l2Conservation_of_aubinLions ext hLevel) hu hSmooth

/-! ### В§10.149 Per-mode compactness ingredients for `HasAubinLionsExtraction`

Classical AubinвҖ“Lions extraction from uniformly bounded Galerkin
trajectories on рқ•ӢВІ admits a Fourier-specific simplification: at each
mode `m вҲҲ в„ӨВІ`, the time-dependent Fourier coefficient
`Оұ n t m` (extended by zero for `m вҲү sqgBox n`) is uniformly bounded
(from the uniform `LВІ` bound, В§10.122вҖ“В§10.123) and uniformly
Lipschitz-in-time (from the uniform `HвҒ»ВІ` bound on the time-derivative,
В§10.138, tested against individual Fourier modes).

Package these two inputs as `HasModeLipschitzFamily`.  Classical
ArzelГ вҖ“Ascoli applied mode-wise + Cantor diagonal across `в„ӨВІ \ {0}`
(В§10.150) lifts this to a single subsequence converging pointwise-in-t
at every mode.  Parseval + dominated convergence on `в„“ВІ(в„ӨВІ)` (В§10.151)
then lifts per-mode pointwise convergence to strong `LВІ` convergence,
producing `HasAubinLionsExtraction`. -/

/-- **Per-mode uniform bound + per-mode Lipschitz witness.**
Packages the Fourier-side ingredients of classical compactness for
AubinвҖ“Lions extraction on рқ•ӢВІ. -/
structure HasModeLipschitzFamily
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)) where
  /-- Universal mode-value function extending `Оұ` to every mode.  Extended
  by zero outside `sqgBox n`.  Use `galerkinExtend (sqgBox n) (Оұ n t)` as
  the canonical choice. -/
  modeCoeff : в„• вҶ’ в„қ вҶ’ (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ
  /-- Consistency with `Оұ` on `sqgBox n`. -/
  modeCoeff_eq : вҲҖ (n : в„•) (t : в„қ) (m : Fin 2 вҶ’ в„Ө) (hm : m вҲҲ sqgBox n),
    modeCoeff n t m = Оұ n t вҹЁm, hmвҹ©
  /-- Modes outside `sqgBox n` give `0`. -/
  modeCoeff_off : вҲҖ (n : в„•) (t : в„қ) (m : Fin 2 вҶ’ в„Ө),
    m вҲү sqgBox n вҶ’ modeCoeff n t m = 0
  /-- Per-mode uniform bound: `|modeCoeff n t m| вүӨ modeBound t` for every
  `(n, m)` at forward time `t вүҘ 0`.  Weak (mode-independent) bound вҖ”
  in the SQG application, the uniform `LВІ` bound from В§10.123 combined
  with Parseval.  Restricted to `t вүҘ 0` because the Galerkin ODE only
  runs forward. -/
  modeBound : в„қ вҶ’ в„қ
  modeBound_nonneg : вҲҖ t : в„қ, 0 вүӨ modeBound t
  modeBound_holds : вҲҖ (n : в„•) (t : в„қ) (m : Fin 2 вҶ’ в„Ө),
    0 вүӨ t вҶ’ вҖ–modeCoeff n t mвҖ– вүӨ modeBound t
  /-- Per-mode Lipschitz constant in time.  For SQG this comes from the
  `HвҒ»ВІ` time-derivative bound (В§10.138) tested against `e^{-imВ·x}`. -/
  modeLipschitz : (Fin 2 вҶ’ в„Ө) вҶ’ в„қ
  modeLipschitz_nonneg : вҲҖ m : Fin 2 вҶ’ в„Ө, 0 вүӨ modeLipschitz m
  /-- Per-mode Lipschitz-in-time estimate.  The bound is uniform in `n`
  but the constant depends on `m` (typically `вҲј |m|ВІ` for an `HвҒ»ВІ`
  time-derivative input). -/
  modeLipschitz_holds : вҲҖ (n : в„•) (m : Fin 2 вҶ’ в„Ө) (s t : в„қ),
    0 вүӨ s вҶ’ 0 вүӨ t вҶ’
    вҖ–modeCoeff n t m - modeCoeff n s mвҖ– вүӨ modeLipschitz m * |t - s|

/-- **Canonical `modeCoeff` for a Galerkin family: `galerkinExtend`.** -/
noncomputable def galerkinModeCoeff
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)) :
    в„• вҶ’ в„қ вҶ’ (Fin 2 вҶ’ в„Ө) вҶ’ в„Ӯ :=
  fun n t m => galerkinExtend (sqgBox n) (Оұ n t) m

/-- **`galerkinModeCoeff` agrees with `Оұ` on `sqgBox n`.** -/
theorem galerkinModeCoeff_eq_of_mem
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ))
    (n : в„•) (t : в„қ) (m : Fin 2 вҶ’ в„Ө) (hm : m вҲҲ sqgBox n) :
    galerkinModeCoeff Оұ n t m = Оұ n t вҹЁm, hmвҹ© :=
  galerkinExtend_apply_of_mem _ _ hm

/-- **`galerkinModeCoeff` is zero off `sqgBox n`.** -/
theorem galerkinModeCoeff_eq_zero_of_not_mem
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ))
    (n : в„•) (t : в„қ) (m : Fin 2 вҶ’ в„Ө) (hm : m вҲү sqgBox n) :
    galerkinModeCoeff Оұ n t m = 0 :=
  galerkinExtend_apply_of_not_mem _ _ hm

/-! ### В§10.150 `HasPerModeLimit`: output of ArzelГ вҖ“Ascoli + Cantor diagonal

Packages the OUTPUT of classical ArzelГ вҖ“Ascoli (mode-wise on `[0, T]`
for each `T > 0`) + Cantor diagonal across modes `m вҲҲ в„ӨВІ \ {0}`:
a single subsequence `nsub` and a per-mode limit function
`b : (Fin 2 вҶ’ в„Ө) вҶ’ в„қ вҶ’ в„Ӯ` such that for every mode `m` and every
forward time `t вүҘ 0`,

  `galerkinExtend (sqgBox (nsub k)) (Оұ (nsub k) t) m вҶ’ b m t`  as `k вҶ’ вҲһ`.

The structural reduction: given `HasModeLipschitzFamily Оұ` (В§10.149),
classical ArzelГ вҖ“Ascoli produces `HasPerModeLimit Оұ`.  This predicate
isolates the compactness-extraction step as a named hypothesis. -/

/-- **Per-mode limit along an extracted subsequence.** -/
structure HasPerModeLimit
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)) where
  /-- Extracted subsequence indices. -/
  nsub : в„• вҶ’ в„•
  /-- Subsequence is strictly increasing. -/
  strictMono : StrictMono nsub
  /-- Per-mode limit function. -/
  b : (Fin 2 вҶ’ в„Ө) вҶ’ в„қ вҶ’ в„Ӯ
  /-- Per-mode pointwise-in-t convergence along the subsequence. -/
  tendsto_modeCoeff : вҲҖ (m : Fin 2 вҶ’ в„Ө) (t : в„қ), 0 вүӨ t вҶ’
    Filter.Tendsto
      (fun k : в„• => galerkinExtend (sqgBox (nsub k)) (Оұ (nsub k) t) m)
      Filter.atTop (nhds (b m t))

/-- **Zero-mode triviality for per-mode limits.**  Since `0 вҲү sqgBox n`
for every `n`, the per-mode limit at the zero mode is automatically
`0`. -/
theorem HasPerModeLimit.b_zero_mode
    {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (per : HasPerModeLimit Оұ)
    {t : в„қ} (ht : 0 вүӨ t) :
    per.b (0 : Fin 2 вҶ’ в„Ө) t = 0 := by
  have h := per.tendsto_modeCoeff (0 : Fin 2 вҶ’ в„Ө) t ht
  -- Sequence is constantly zero since 0 вҲү sqgBox (nsub k).
  have h_const : вҲҖ k : в„•,
      galerkinExtend (sqgBox (per.nsub k)) (Оұ (per.nsub k) t)
        (0 : Fin 2 вҶ’ в„Ө) = 0 :=
    fun k => galerkinExtend_apply_of_not_mem _ _ (zero_not_mem_sqgBox _)
  have h_eq : (fun k : в„• =>
      galerkinExtend (sqgBox (per.nsub k)) (Оұ (per.nsub k) t)
        (0 : Fin 2 вҶ’ в„Ө)) = fun _ => (0 : в„Ӯ) :=
    funext h_const
  rw [h_eq] at h
  exact tendsto_nhds_unique h tendsto_const_nhds

/-! ### В§10.151 Parseval synthesis: `HasPerModeLimit` вҶ’ `HasAubinLionsExtraction`

Given per-mode pointwise convergence (`HasPerModeLimit`) + uniform в„“ВІ
bound (Fatou gives в„“ВІ-summability of the limit modes) + strong-LВІ
convergence of the Fourier-truncation to the initial data, Parseval
+ dominated convergence lifts the per-mode limit to strong LВІ
convergence of the full Galerkin trajectory.

This step requires two extra analytical inputs beyond `HasPerModeLimit`:

1. A Fourier-synthesis witness: the per-mode limit function `b В· t`
   yields an honest `Lp в„Ӯ 2` element `Оё_lim t` for every `t вүҘ 0`.
2. Strong-LВІ convergence of the extracted sequence to that `Оё_lim`,
   discharged from per-mode convergence + uniform в„“ВІ control.

Package both as `HasFourierSynthesis`; the capstone then builds
`HasAubinLionsExtraction` from the combined hypotheses. -/

/-- **Fourier synthesis of the per-mode limit.**  Given
`HasPerModeLimit Оұ`, a synthesis witness provides the `Lp`-valued
limit trajectory + strong-LВІ convergence to it.  In the non-zero
case this requires classical dominated-convergence-on-в„“ВІ input;
we package it as a named hypothesis. -/
structure HasFourierSynthesis
    {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (per : HasPerModeLimit Оұ)
    (Оё : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))) where
  /-- The `Lp`-valued limit trajectory. -/
  Оё_lim : в„қ вҶ’ Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))
  /-- Initial-data match: at `t = 0` the limit is the provided `Оё`. -/
  init_eq : Оё_lim 0 = Оё
  /-- Fourier-coefficient match: the `Lp` element's coefficients coincide
  with the per-mode limit. -/
  mFourierCoeff_eq : вҲҖ (m : Fin 2 вҶ’ в„Ө) (t : в„қ), 0 вүӨ t вҶ’
    mFourierCoeff (Оё_lim t) m = per.b m t
  /-- Strong-LВІ pointwise-in-t convergence of the extracted Galerkin
  sequence to `Оё_lim`. -/
  tendsto_L2 : вҲҖ (t : в„қ), 0 вүӨ t вҶ’
    Filter.Tendsto
      (fun k : в„• =>
        вҲ« x, вҖ–galerkinToLp (sqgBox (per.nsub k)) (Оұ (per.nsub k) t) x
              - Оё_lim t xвҖ– ^ 2)
      Filter.atTop (nhds 0)

/-- **Route B AubinвҖ“Lions extraction from per-mode limit + Fourier
synthesis witness.**  Assembles `HasAubinLionsExtraction Оё Оұ` from
a `HasPerModeLimit` witness + a `HasFourierSynthesis` witness. -/
noncomputable def HasAubinLionsExtraction.ofPerModeLimit
    {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    {Оё : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (per : HasPerModeLimit Оұ)
    (syn : HasFourierSynthesis per Оё) :
    HasAubinLionsExtraction Оё Оұ where
  nsub := per.nsub
  strictMono := per.strictMono
  Оё_lim := syn.Оё_lim
  init_eq := syn.init_eq
  tendsto_L2 := syn.tendsto_L2

/-! ### В§10.152 Discharge `HasModeLipschitzFamily` for the SQG Galerkin family

Constructs `HasModeLipschitzFamily Оұ` from the uniform-`LВІ` per-mode
bound (В§10.123's `sq_galerkinExtend_le_L2Sq`) + a per-mode Lipschitz
witness (classically from the uniform `HвҒ»ВІ` bound В§10.138 integrated
against the ODE `dОұ/dt = galerkinRHS` via `вҲ«_s^t`, producing
`modeLipschitz m вҲј вҲҡK В· (|m|ВІ)`).

The Lipschitz witness is taken as a named hypothesis here вҖ” its
discharge from В§10.138 + В§10.116's Galerkin ODE existence is the
final execution step.  The structural chain through В§10.149вҖ“В§10.152
reduces Item 1's analytical closure to exactly this single explicit
per-mode integration. -/

/-- **SQG Galerkin `HasModeLipschitzFamily` discharge.**  Takes the
per-mode uniform `LВІ` bound (via В§10.123's energy-preservation
hypothesis) + a per-mode Lipschitz bound (from integrating the
`HвҒ»ВІ`-controlled time-derivative against `e^{-imВ·x}`), produces a
`HasModeLipschitzFamily` witness for `Оұ`. -/
noncomputable def HasModeLipschitzFamily.ofSqgGalerkinBounds
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    {Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ)}
    (ОёвӮҖ : Lp в„Ӯ 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hEnergy : вҲҖ n t, 0 вүӨ t вҶ’
      (вҲ‘ m : вҶҘ(sqgBox n), вҖ–Оұ n t mвҖ– ^ 2)
        = вҲ‘ m : вҶҘ(sqgBox n), вҖ–fourierRestrict n ОёвӮҖ mвҖ– ^ 2)
    (L : (Fin 2 вҶ’ в„Ө) вҶ’ в„қ)
    (hL_nonneg : вҲҖ m : Fin 2 вҶ’ в„Ө, 0 вүӨ L m)
    (hL_holds : вҲҖ (n : в„•) (m : Fin 2 вҶ’ в„Ө) (s t : в„қ), 0 вүӨ s вҶ’ 0 вүӨ t вҶ’
      вҖ–galerkinExtend (sqgBox n) (Оұ n t) m
          - galerkinExtend (sqgBox n) (Оұ n s) mвҖ– вүӨ L m * |t - s|) :
    HasModeLipschitzFamily Оұ where
  modeCoeff := galerkinModeCoeff Оұ
  modeCoeff_eq := galerkinModeCoeff_eq_of_mem Оұ
  modeCoeff_off := galerkinModeCoeff_eq_zero_of_not_mem Оұ
  modeBound := fun _ => Real.sqrt (вҲ« x, вҖ–ОёвӮҖ xвҖ– ^ 2)
  modeBound_nonneg := fun _ => Real.sqrt_nonneg _
  modeBound_holds := by
    intro n t m ht
    -- Produce the bound in a form that uses the same DecidableEq
    -- instance as `sq_galerkinExtend_le_L2Sq` (i.e. the theorem's
    -- `[DecidableEq]` parameter), then `convert` bridges to the
    -- auto-synthesized instance at the `galerkinModeCoeff` call site.
    have h_sq := sq_galerkinExtend_le_L2Sq ОёвӮҖ n (Оұ n) (hEnergy n) ht m
    have h_norm_nn : (0 : в„қ) вүӨ вҖ–galerkinExtend (sqgBox n) (Оұ n t) mвҖ– :=
      norm_nonneg _
    have h_bound : вҖ–galerkinExtend (sqgBox n) (Оұ n t) mвҖ–
        вүӨ Real.sqrt (вҲ« x, вҖ–ОёвӮҖ xвҖ– ^ 2) := by
      calc вҖ–galerkinExtend (sqgBox n) (Оұ n t) mвҖ–
          = Real.sqrt (вҖ–galerkinExtend (sqgBox n) (Оұ n t) mвҖ– ^ 2) :=
            (Real.sqrt_sq h_norm_nn).symm
        _ вүӨ Real.sqrt (вҲ« x, вҖ–ОёвӮҖ xвҖ– ^ 2) := Real.sqrt_le_sqrt h_sq
    show вҖ–galerkinModeCoeff Оұ n t mвҖ– вүӨ Real.sqrt (вҲ« x, вҖ–ОёвӮҖ xвҖ– ^ 2)
    unfold galerkinModeCoeff
    convert h_bound
  modeLipschitz := L
  modeLipschitz_nonneg := hL_nonneg
  modeLipschitz_holds := by
    intro n m s t hs ht
    show вҖ–galerkinModeCoeff Оұ n t m - galerkinModeCoeff Оұ n s mвҖ–
      вүӨ L m * |t - s|
    unfold galerkinModeCoeff
    -- `convert` bridges DecidableEq instance mismatch between
    -- `hL_holds`'s explicit instance and the auto-synthesized
    -- `Fintype.decidablePiFintype` at this call site.
    convert hL_holds n m s t hs ht

/-! ### В§10.153 Per-mode Lipschitz from `HвҒ»ВІ` bound + Galerkin ODE (FTC)

Derives the per-mode Lipschitz constant `L m = вҲҡK В· ОӣВІ(m)` for
`HasModeLipschitzFamily.ofSqgGalerkinBounds` (В§10.152), via:

* **В§10.153.A** Per-mode upper bound on `galerkinRHS` at non-zero
  modes from the summable `HвҒ»ВІ` tsum.
* **В§10.153.B** Mean-Value Theorem (via `norm_image_sub_le_of_norm_deriv_right_le_segment`)
  on the per-mode trajectory `П„ вҶҰ galerkinExtend S (Оұ П„) m`, turning
  the upper bound on the derivative into a Lipschitz bound on the
  trajectory.
-/

/-- **В§10.153.A** Per-mode upper bound on `galerkinRHS` at non-zero
modes.  If `вҲ‘' m, (ОӣвҒ»ВІ m)ВІ В· вҖ–galerkinRHS mвҖ–ВІ вүӨ K` then
`вҖ–galerkinRHS mвҖ– вүӨ вҲҡK В· ОӣВІ(m)` for every `m вү  0`.  (For `m = 0` the
bound holds trivially when `0 вҲү S` but is not asserted here.) -/
theorem galerkinRHS_mode_bound_of_HsNeg2Bound_ne_zero
    (S : Finset (Fin 2 вҶ’ в„Ө)) [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (c : вҶҘS вҶ’ в„Ӯ) (K : в„қ) (hK : 0 вүӨ K)
    (hBound : GalerkinRHSHsNegSqBound S c 2 K)
    {m : Fin 2 вҶ’ в„Ө} (hm : m вү  0) :
    вҖ–galerkinRHS S (galerkinExtend S c) mвҖ–
      вүӨ Real.sqrt K * fracDerivSymbol 2 m := by
  obtain вҹЁhSumm, hTsumвҹ© := hBound
  have hTerm : (fracDerivSymbol (-2) m) ^ 2
      * вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– ^ 2 вүӨ K := by
    have hLe := hSumm.le_tsum m
      (fun _ _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))
    exact le_trans hLe hTsum
  have hFDS2_pos : 0 < fracDerivSymbol 2 m := fracDerivSymbol_pos 2 hm
  have hFDS2_nn : 0 вүӨ fracDerivSymbol 2 m := le_of_lt hFDS2_pos
  have hSqInv : (fracDerivSymbol (-2) m) ^ 2 * (fracDerivSymbol 2 m) ^ 2 = 1 :=
    fracDerivSymbol_sq_neg_inv hm
  have hNormSq : вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– ^ 2
      вүӨ K * (fracDerivSymbol 2 m) ^ 2 := by
    calc вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– ^ 2
        = ((fracDerivSymbol (-2) m) ^ 2 * (fracDerivSymbol 2 m) ^ 2)
            * вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– ^ 2 := by rw [hSqInv]; ring
      _ = (fracDerivSymbol (-2) m) ^ 2
            * вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– ^ 2
            * (fracDerivSymbol 2 m) ^ 2 := by ring
      _ вүӨ K * (fracDerivSymbol 2 m) ^ 2 :=
          mul_le_mul_of_nonneg_right hTerm (sq_nonneg _)
  -- Take square roots.
  have hNn : 0 вүӨ вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– := norm_nonneg _
  have hSqrtMul : Real.sqrt (K * (fracDerivSymbol 2 m) ^ 2)
      = Real.sqrt K * fracDerivSymbol 2 m := by
    rw [Real.sqrt_mul hK, Real.sqrt_sq hFDS2_nn]
  have hAbsSq : Real.sqrt (вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– ^ 2)
      = вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– := Real.sqrt_sq hNn
  calc вҖ–galerkinRHS S (galerkinExtend S c) mвҖ–
      = Real.sqrt (вҖ–galerkinRHS S (galerkinExtend S c) mвҖ– ^ 2) := hAbsSq.symm
    _ вүӨ Real.sqrt (K * (fracDerivSymbol 2 m) ^ 2) := Real.sqrt_le_sqrt hNormSq
    _ = Real.sqrt K * fracDerivSymbol 2 m := hSqrtMul

/-- **В§10.153.B** Mean-Value Theorem on the per-mode Galerkin
trajectory: given a uniform upper bound on the mode's time-derivative
over `[s, t]`, the coefficient value changes by at most bound Г— time
interval. -/
theorem galerkinExtend_mode_lipschitz_of_ODE_bound
    (S : Finset (Fin 2 вҶ’ в„Ө)) [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : в„қ вҶ’ (вҶҘS вҶ’ в„Ӯ))
    (m : Fin 2 вҶ’ в„Ө) (M : в„қ)
    {s t : в„қ} (hst : s вүӨ t)
    (hDeriv : вҲҖ П„ вҲҲ Set.Ico s t,
      HasDerivWithinAt (fun Пғ => galerkinExtend S (Оұ Пғ) m)
        (galerkinRHS S (galerkinExtend S (Оұ П„)) m) (Set.Ici П„) П„)
    (hCont : ContinuousOn (fun Пғ => galerkinExtend S (Оұ Пғ) m) (Set.Icc s t))
    (hBound : вҲҖ П„ вҲҲ Set.Ico s t,
      вҖ–galerkinRHS S (galerkinExtend S (Оұ П„)) mвҖ– вүӨ M) :
    вҖ–galerkinExtend S (Оұ t) m - galerkinExtend S (Оұ s) mвҖ– вүӨ M * (t - s) := by
  have h := norm_image_sub_le_of_norm_deriv_right_le_segment
    (f := fun Пғ => galerkinExtend S (Оұ Пғ) m)
    (f' := fun П„ => galerkinRHS S (galerkinExtend S (Оұ П„)) m)
    (C := M) hCont hDeriv hBound t вҹЁhst, le_refl tвҹ©
  exact h

