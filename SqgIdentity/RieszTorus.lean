/-! ### ¬ß10.131 Concrete construction of `IsGalerkinLimitData` +
`GalerkinLimitTrajectory` for finite Fourier-support initial data

Closes the v0.4.30 conditional chain on the finite-Fourier-support
class by instantiating the packaged hypotheses directly from
¬ß10.116.H.3's time-global Galerkin trajectory.

Given a symmetric, zero-excluding support `S‚āÄ`, an `R > 0`, and a
real-symmetric initial coefficient vector `c‚āÄ : ‚Ü•S‚āÄ ‚Üí ‚Ąā` with
`‚ąĎ ‚ÄĖc‚āÄ m‚ÄĖ¬≤ ‚Č§ (R/2)¬≤`, the ¬ß10.116 capstone produces a trajectory
`őĪ : ‚ĄĚ ‚Üí (‚Ü•S‚āÄ ‚Üí ‚Ąā)`. Define:

* `b m t := galerkinExtend S‚āÄ (őĪ t) m` ‚ÄĒ the zero-extended Fourier
  coefficients at time `t` and mode `m`.
* `őł_lim t := galerkinToLp S‚āÄ (őĪ t)` ‚ÄĒ the lifted `L¬≤` trajectory.

We check all five clauses of `IsGalerkinLimitData` and the three
fields of `GalerkinLimitTrajectory` directly. Feeds ¬ß10.129 to yield
an honest `SqgSolution` through the new v0.4.30 pipeline (a parallel
construction of the ¬ß10.117 result, now routed through ¬ß10.125‚Äď¬ß10.130). -/

/-- **Galerkin-limit data from a finite-support time-global
trajectory.** Bundles the five invariants of `IsGalerkinLimitData`
for the zero-extended Fourier coefficients of `őĪ`. -/
theorem isGalerkinLimitData_of_galerkin_realSym
    {S‚āÄ : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S‚āÄ)
    (hS : IsSymmetricSupport S‚āÄ)
    (c‚āÄ : ‚Ü•S‚āÄ ‚Üí ‚Ąā)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S‚āÄ ‚Üí ‚Ąā))
    (hőĪ0 : őĪ 0 = c‚āÄ)
    (hConserve : ‚ąÄ t, 0 ‚Č§ t ‚Üí
      (‚ąĎ m : ‚Ü•S‚āÄ, ‚ÄĖőĪ t m‚ÄĖ ^ 2) = ‚ąĎ m : ‚Ü•S‚āÄ, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2)
    (hRealSym : ‚ąÄ t, 0 ‚Č§ t ‚Üí ‚ąÄ n ‚ąą S‚āÄ,
      galerkinExtend S‚āÄ (őĪ t) (-n) = star (galerkinExtend S‚āÄ (őĪ t) n)) :
    IsGalerkinLimitData (galerkinToLp S‚āÄ c‚āÄ)
      (fun m t => galerkinExtend S‚āÄ (őĪ t) m) where
  zeroMode := fun _ _ => galerkinExtend_apply_of_not_mem _ _ h0
  initial := fun m => by
    show galerkinExtend S‚āÄ (őĪ 0) m = mFourierCoeff (galerkinToLp S‚āÄ c‚āÄ) m
    rw [mFourierCoeff_galerkinToLp, hőĪ0]
  summable := fun t _ => by
    apply summable_of_ne_finset_zero (s := S‚āÄ)
    intros n hn
    rw [galerkinExtend_apply_of_not_mem _ _ hn, norm_zero]
    simp
  conservation := fun t ht => by
    have hLHS : (‚ąĎ' m : Fin 2 ‚Üí ‚Ą§, ‚ÄĖgalerkinExtend S‚āÄ (őĪ t) m‚ÄĖ ^ 2)
          = ‚ąĎ m ‚ąą S‚āÄ, ‚ÄĖgalerkinExtend S‚āÄ (őĪ t) m‚ÄĖ ^ 2 := by
      apply tsum_eq_sum
      intros n hn
      rw [galerkinExtend_apply_of_not_mem _ _ hn, norm_zero]; simp
    have hRHS : (‚ąĎ' m : Fin 2 ‚Üí ‚Ą§, ‚ÄĖgalerkinExtend S‚āÄ (őĪ 0) m‚ÄĖ ^ 2)
          = ‚ąĎ m ‚ąą S‚āÄ, ‚ÄĖgalerkinExtend S‚āÄ (őĪ 0) m‚ÄĖ ^ 2 := by
      apply tsum_eq_sum
      intros n hn
      rw [galerkinExtend_apply_of_not_mem _ _ hn, norm_zero]; simp
    rw [hLHS, hRHS]
    have hSum_t : (‚ąĎ m ‚ąą S‚āÄ, ‚ÄĖgalerkinExtend S‚āÄ (őĪ t) m‚ÄĖ ^ 2)
        = ‚ąĎ m : ‚Ü•S‚āÄ, ‚ÄĖőĪ t m‚ÄĖ ^ 2 := by
      rw [show ((Finset.univ : Finset ‚Ü•S‚āÄ)) = S‚āÄ.attach from
        Finset.univ_eq_attach S‚āÄ,
        ‚Üź Finset.sum_attach S‚āÄ (fun m => ‚ÄĖgalerkinExtend S‚āÄ (őĪ t) m‚ÄĖ ^ 2)]
      apply Finset.sum_congr rfl
      intros m _
      rw [galerkinExtend_apply_of_mem _ _ m.property]
    have hSum_0 : (‚ąĎ m ‚ąą S‚āÄ, ‚ÄĖgalerkinExtend S‚āÄ (őĪ 0) m‚ÄĖ ^ 2)
        = ‚ąĎ m : ‚Ü•S‚āÄ, ‚ÄĖőĪ 0 m‚ÄĖ ^ 2 := by
      rw [show ((Finset.univ : Finset ‚Ü•S‚āÄ)) = S‚āÄ.attach from
        Finset.univ_eq_attach S‚āÄ,
        ‚Üź Finset.sum_attach S‚āÄ (fun m => ‚ÄĖgalerkinExtend S‚āÄ (őĪ 0) m‚ÄĖ ^ 2)]
      apply Finset.sum_congr rfl
      intros m _
      rw [galerkinExtend_apply_of_mem _ _ m.property]
    rw [hSum_t, hSum_0, hőĪ0]
    exact hConserve t ht
  realSym := fun t ht m => by
    by_cases hm : m ‚ąą S‚āÄ
    ¬∑ exact hRealSym t ht m hm
    ¬∑ have hnegm : -m ‚ąČ S‚āÄ := by
        intro hneg
        apply hm
        have : -(-m) ‚ąą S‚āÄ := hS _ hneg
        simpa using this
      rw [galerkinExtend_apply_of_not_mem _ _ hm,
          galerkinExtend_apply_of_not_mem _ _ hnegm, star_zero]

/-- **Synthesized `L¬≤` trajectory from a finite-support time-global
Galerkin trajectory.** The trajectory is `t ‚Ü¶ galerkinToLp S‚āÄ (őĪ t)`;
Fourier coefficients match `galerkinExtend S‚āÄ (őĪ t) m` on every mode. -/
noncomputable def galerkinLimitTrajectory_of_galerkin
    {S‚āÄ : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c‚āÄ : ‚Ü•S‚āÄ ‚Üí ‚Ąā)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S‚āÄ ‚Üí ‚Ąā))
    (hőĪ0 : őĪ 0 = c‚āÄ) :
    GalerkinLimitTrajectory (galerkinToLp S‚āÄ c‚āÄ)
      (fun m t => galerkinExtend S‚āÄ (őĪ t) m) where
  őł_lim := fun ŌĄ => galerkinToLp S‚āÄ (őĪ ŌĄ)
  coeff := fun _ _ m => mFourierCoeff_galerkinToLp _ _ m
  init_eq := by
    show galerkinToLp S‚āÄ (őĪ 0) = galerkinToLp S‚āÄ c‚āÄ
    rw [hőĪ0]

/-- **Velocity witness for the finite-support Galerkin limit.**
`u j ŌĄ := shellVelocity S‚āÄ (galerkinExtend S‚āÄ (őĪ ŌĄ)) j` ‚ÄĒ identical
to ¬ß10.98 / ¬ß10.117's choice. -/
theorem hasGalerkinLimitVelocity_of_galerkin
    {S‚āÄ : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c‚āÄ : ‚Ü•S‚āÄ ‚Üí ‚Ąā)
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S‚āÄ ‚Üí ‚Ąā))
    (hőĪ0 : őĪ 0 = c‚āÄ) :
    HasGalerkinLimitVelocity
      (galerkinLimitTrajectory_of_galerkin c‚āÄ őĪ hőĪ0).őł_lim
      (fun j ŌĄ => shellVelocity S‚āÄ (galerkinExtend S‚āÄ (őĪ ŌĄ)) j) := by
  intros j ŌĄ
  show IsSqgVelocityComponent
      (galerkinToLp S‚āÄ (őĪ ŌĄ))
      (shellVelocity S‚āÄ (galerkinExtend S‚āÄ (őĪ ŌĄ)) j) j
  exact isSqgVelocityComponent_shellMode S‚āÄ (galerkinExtend S‚āÄ (őĪ ŌĄ)) j

/-! ### ¬ß10.132 Capstone: `SqgSolution` on the finite-support class
through the v0.4.30 conditional chain

Combines ¬ß10.131 with ¬ß10.116.H.3 and ¬ß10.129 to produce, from a
real-symmetric ‚Ąď¬≤-bounded `c‚āÄ : ‚Ü•S‚āÄ ‚Üí ‚Ąā`, an honest `SqgSolution`
routed through the v0.4.30 pipeline. Parallel construction of the
v0.4.28 `exists_sqgSolution_of_galerkin_realSym` result (which uses
the direct ¬ß10.117 packaging). -/

/-- **`SqgSolution` from finite-support initial data via the
v0.4.30 conditional chain.** For any symmetric support `S‚āÄ ‚äÜ ‚Ą§¬≤`
with `0 ‚ąČ S‚āÄ`, any `R > 0`, and any real-symmetric `c‚āÄ : ‚Ü•S‚āÄ ‚Üí ‚Ąā`
with `‚ąĎ ‚ÄĖc‚āÄ m‚ÄĖ¬≤ ‚Č§ (R/2)¬≤`, there exists an `SqgSolution` whose
time-zero slice is `galerkinToLp S‚āÄ c‚āÄ`. Closes the v0.4.30
conditional chain on the finite-Fourier-support class. -/
theorem exists_sqgSolution_via_galerkinLimit_of_finite_support
    (S‚āÄ : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S‚āÄ)
    (hS : IsSymmetricSupport S‚āÄ)
    {R : ‚ĄĚ} (hR : 0 < R)
    (c‚āÄ : ‚Ü•S‚āÄ ‚Üí ‚Ąā)
    (hc‚āÄ_l2 : (‚ąĎ m : ‚Ü•S‚āÄ, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) ‚Č§ (R / 2) ^ 2)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S‚āÄ,
      galerkinExtend S‚āÄ c‚āÄ (-n) = star (galerkinExtend S‚āÄ c‚āÄ n)) :
    ‚ąÉ sol : SqgSolution, sol.őł 0 = galerkinToLp S‚āÄ c‚āÄ := by
  obtain ‚ü®őĪ, hőĪ0, _hderiv, hL2_const, hRealSym, _hpinorm‚ü© :=
    galerkin_time_global_unconditional_realSym S‚āÄ hS hR c‚āÄ hc‚āÄ_l2 hRealC‚āÄ
  have hData : IsGalerkinLimitData (galerkinToLp S‚āÄ c‚āÄ)
      (fun m t => galerkinExtend S‚āÄ (őĪ t) m) :=
    isGalerkinLimitData_of_galerkin_realSym h0 hS c‚āÄ őĪ hőĪ0 hL2_const hRealSym
  set traj : GalerkinLimitTrajectory (galerkinToLp S‚āÄ c‚āÄ)
      (fun m t => galerkinExtend S‚āÄ (őĪ t) m) :=
    galerkinLimitTrajectory_of_galerkin c‚āÄ őĪ hőĪ0 with htraj
  have hVel : HasGalerkinLimitVelocity traj.őł_lim
      (fun j ŌĄ => shellVelocity S‚āÄ (galerkinExtend S‚āÄ (őĪ ŌĄ)) j) :=
    hasGalerkinLimitVelocity_of_galerkin c‚āÄ őĪ hőĪ0
  have hSmooth : ‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
      Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (traj.őł_lim 0) n‚ÄĖ ^ 2) := by
    refine ‚ü®3, by norm_num, ?_‚ü©
    apply hsSeminormSq_summable_of_finite_support 3 (traj.őł_lim 0) S‚āÄ
    intros n hn
    show mFourierCoeff (galerkinToLp S‚āÄ (őĪ 0)) n = 0
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ hn]
  obtain ‚ü®sol, hsol‚ü© :=
    exists_sqgSolution_of_galerkinLimit hData traj hVel hSmooth
  refine ‚ü®sol, ?_‚ü©
  show sol.őł 0 = galerkinToLp S‚āÄ c‚āÄ
  rw [hsol]
  exact traj.init_eq

/-! ### ¬ß10.133 `Ici 0`-variant of the strong-axioms Duhamel chain

The ¬ß10.91 ‚Üí ¬ß10.92 ‚Üí ¬ß10.94 chain discharges
`SqgEvolutionAxioms_strong` from a Galerkin trajectory with
`HasDerivAt` on all of `‚ĄĚ`. ¬ß10.116.H.3 only delivers
`HasDerivWithinAt ... (Set.Ici 0) t` for `t ‚Č• 0`, so ¬ß10.94 could not
be fed directly from the ¬ß10.116 / ¬ß10.132 trajectory. This section
ports the chain to consume the `Ici 0` hypothesis using
`intervalIntegral.integral_eq_sub_of_hasDeriv_right_of_le`, which
takes the `HasDerivWithinAt ... (Ioi x) x` shape obtainable from the
`Ici 0` derivative via `HasDerivWithinAt.mono`.

Since `IsSqgWeakSolutionOnSupport` only asks the Duhamel identity at
`s ‚Č• 0`, only the per-mode FTC step (¬ß10.91 internals) actually
requires the `Ici 0` adaptation ‚ÄĒ the downstream `of_galerkin_dynamics_on_support`
and `of_galerkin_dynamics_with_L_inf_bound_on_support` reassemble without
further changes once the Ici-0 weak-solution witness is in hand.

Capstone: `exists_sqgSolution_strong_of_galerkin_realSym` parallels
`exists_sqgSolution_via_galerkinLimit_of_finite_support` (¬ß10.132) but
produces `SqgEvolutionAxioms_strong` instead of `SqgEvolutionAxioms`.
Closes item 2 of the open-items list. -/

/-- **¬ß10.133.A ‚ÄĒ Per-mode FTC for `Ici 0` Galerkin trajectories.**
Parallel to `galerkin_mode_FTC` (¬ß10.55), consuming
`HasDerivWithinAt ... (Ici 0)` at every `ŌĄ ‚Č• 0` rather than
`HasDerivAt` at every `ŌĄ ‚ąą ‚ĄĚ`. The conclusion is the same per-mode
FTC identity on any forward interval `[s, t]` with `s ‚Č• 0`. -/
theorem galerkin_mode_FTC_Ici
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ ŌĄ)) (Set.Ici 0) ŌĄ)
    (m : ‚Ü•S) {s t : ‚ĄĚ} (hs : 0 ‚Č§ s) (hst : s ‚Č§ t) :
    őĪ t m - őĪ s m = ‚ąę ŌĄ in s..t, (galerkinVectorField S (őĪ ŌĄ)) m := by
  have hIcc_sub : Set.Icc s t ‚äÜ Set.Ici 0 := fun x hx => le_trans hs hx.1
  -- Continuity of őĪ on [s, t] from the within-derivative on Ici 0.
  have hCont_őĪ : ContinuousOn őĪ (Set.Icc s t) := fun x hx => by
    have hx_nn : 0 ‚Č§ x := le_trans hs hx.1
    exact ((hőĪ x hx_nn).continuousWithinAt).mono hIcc_sub
  -- Continuity of the m-projection of őĪ on [s, t].
  have hCont_őĪm : ContinuousOn (fun ŌĄ => őĪ ŌĄ m) (Set.Icc s t) :=
    (continuous_apply m).comp_continuousOn hCont_őĪ
  -- Continuity of the integrand (galerkinVectorField ‚ąė őĪ projected to m).
  have hCont_integrand :
      ContinuousOn (fun ŌĄ => (galerkinVectorField S (őĪ ŌĄ)) m) (Set.Icc s t) :=
    (continuous_apply m).comp_continuousOn
      ((galerkinVectorField_continuous S).comp_continuousOn hCont_őĪ)
  -- Integrability of the integrand on [s, t].
  have hIntegrable :
      IntervalIntegrable (fun ŌĄ => (galerkinVectorField S (őĪ ŌĄ)) m) volume s t :=
    hCont_integrand.intervalIntegrable_of_Icc hst
  -- Per-coordinate right-derivative on Ioi x for x ‚ąą Ioo s t.
  have hDerivRight : ‚ąÄ x ‚ąą Set.Ioo s t,
      HasDerivWithinAt (fun ŌĄ => őĪ ŌĄ m)
        ((galerkinVectorField S (őĪ x)) m) (Set.Ioi x) x := by
    intro x hx
    have hx_nn : 0 ‚Č§ x := le_of_lt (lt_of_le_of_lt hs hx.1)
    have hIoi_sub : Set.Ioi x ‚äÜ Set.Ici 0 := fun y hy => le_of_lt (lt_of_le_of_lt hx_nn hy)
    have h_within_Ioi : HasDerivWithinAt őĪ (galerkinVectorField S (őĪ x)) (Set.Ioi x) x :=
      (hőĪ x hx_nn).mono hIoi_sub
    exact (hasDerivWithinAt_pi.mp h_within_Ioi) m
  -- Apply the HasDeriv_right FTC.
  symm
  exact intervalIntegral.integral_eq_sub_of_hasDeriv_right_of_le hst hCont_őĪm
    hDerivRight hIntegrable

/-- **¬ß10.133.B ‚ÄĒ `IsSqgWeakSolutionOnSupport` from an `Ici 0` Galerkin
trajectory.** Mirror of ¬ß10.91 consuming the within-derivative on
`Ici 0`. Uses ¬ß10.133.A at every `(s, t)` with `0 ‚Č§ s ‚Č§ t`, then
chains through ¬ß10.48's `galerkinRHS_eq_neg_sqgNonlinearFlux`
identification to package the Duhamel identity against the
`sqgNonlinearFlux`. -/
theorem IsSqgWeakSolutionOnSupport.of_galerkin_dynamics_Ici
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ ŌĄ)) (Set.Ici 0) ŌĄ) :
    IsSqgWeakSolutionOnSupport S
      (fun ŌĄ => galerkinToLp S (őĪ ŌĄ))
      (fun j ŌĄ => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) := by
  intro m hm s t hs hst
  -- Step 1: LHS to őĪ-coefficient difference.
  have hLHS :
      mFourierCoeff (galerkinToLp S (őĪ t)) m -
          mFourierCoeff (galerkinToLp S (őĪ s)) m
        = őĪ t ‚ü®m, hm‚ü© - őĪ s ‚ü®m, hm‚ü© := by
    rw [mFourierCoeff_galerkinToLp, mFourierCoeff_galerkinToLp,
        galerkinExtend_apply_of_mem _ _ hm, galerkinExtend_apply_of_mem _ _ hm]
  -- Step 2: FTC (¬ß10.133.A) turns the őĪ-difference into the interval integral.
  have hFTC : őĪ t ‚ü®m, hm‚ü© - őĪ s ‚ü®m, hm‚ü©
      = ‚ąę ŌĄ in s..t, (galerkinVectorField S (őĪ ŌĄ)) ‚ü®m, hm‚ü© :=
    galerkin_mode_FTC_Ici őĪ hőĪ ‚ü®m, hm‚ü© hs hst
  -- Step 3: ¬ß10.48 identifies the integrand as `-sqgNonlinearFlux`.
  have h_vf : ‚ąÄ ŌĄ : ‚ĄĚ,
      (galerkinVectorField S (őĪ ŌĄ)) ‚ü®m, hm‚ü©
        = -sqgNonlinearFlux (galerkinToLp S (őĪ ŌĄ))
            (fun j => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) m := fun ŌĄ =>
    galerkinRHS_eq_neg_sqgNonlinearFlux S (őĪ ŌĄ) m
  have h_integrand :
      ‚ąę ŌĄ in s..t, (galerkinVectorField S (őĪ ŌĄ)) ‚ü®m, hm‚ü©
        = ‚ąę ŌĄ in s..t, -sqgNonlinearFlux (galerkinToLp S (őĪ ŌĄ))
            (fun j => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) m :=
    intervalIntegral.integral_congr (fun ŌĄ _ => h_vf ŌĄ)
  -- Step 4: Chain + factor -1.
  rw [hLHS, hFTC, h_integrand, intervalIntegral.integral_neg]
  -- Step 5: Interval integral ‚Üí Icc integral.
  congr 1
  rw [intervalIntegral.integral_of_le hst,
      ‚Üź MeasureTheory.integral_Icc_eq_integral_Ioc]

/-- **¬ß10.133.C ‚ÄĒ `SqgEvolutionAxioms_strong` from an `Ici 0` Galerkin
trajectory + per-mode flux bound.** Mirror of ¬ß10.92 (line 14320) with
the derivative hypothesis relaxed to `HasDerivWithinAt ... (Ici 0)` at
every `ŌĄ ‚Č• 0`. Composes ¬ß10.133.B with ¬ß10.90 (on-support Duhamel ‚Üí
strong axioms). -/
theorem SqgEvolutionAxioms_strong.of_galerkin_dynamics_on_support_Ici
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ ŌĄ)) (Set.Ici 0) ŌĄ)
    (hE : SqgEvolutionAxioms (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)))
    (hFluxBound : ‚ąÄ m ‚ąą S, ‚ąÉ K : ‚ĄĚ, 0 ‚Č§ K ‚ąß
      ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí
        ‚ÄĖsqgNonlinearFlux (galerkinToLp S (őĪ ŌĄ))
            (fun j => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) m‚ÄĖ ‚Č§ K) :
    SqgEvolutionAxioms_strong (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) := by
  have hSupport : ‚ąÄ ŌĄ : ‚ĄĚ, ‚ąÄ n ‚ąČ S,
      mFourierCoeff (galerkinToLp S (őĪ ŌĄ)) n = 0 := fun ŌĄ n hn => by
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ hn]
  exact SqgEvolutionAxioms_strong.of_finite_support_weak_on_support
    (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) S hSupport hE
    (fun j ŌĄ => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j)
    hFluxBound
    (IsSqgWeakSolutionOnSupport.of_galerkin_dynamics_Ici őĪ hőĪ)

/-- **¬ß10.133.D ‚ÄĒ `SqgEvolutionAxioms_strong` from an `Ici 0` Galerkin
trajectory + uniform L‚ąě coefficient bound.** Mirror of ¬ß10.94
(line 14480) consuming the `Ici 0` derivative. Internally discharges
`hFluxBound` via ¬ß10.93's `sqgNonlinearFlux_galerkin_bounded_of_L_inf`. -/
theorem SqgEvolutionAxioms_strong.of_galerkin_dynamics_with_L_inf_bound_on_support_Ici
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ ŌĄ, 0 ‚Č§ ŌĄ ‚Üí
      HasDerivWithinAt őĪ (galerkinVectorField S (őĪ ŌĄ)) (Set.Ici 0) ŌĄ)
    (hE : SqgEvolutionAxioms (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)))
    {M : ‚ĄĚ}
    (hBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖgalerkinExtend S (őĪ ŌĄ) n‚ÄĖ ‚Č§ M) :
    SqgEvolutionAxioms_strong (fun ŌĄ => galerkinToLp S (őĪ ŌĄ)) := by
  set K : ‚ĄĚ := M ^ 2 * (S.card : ‚ĄĚ)
    + M ^ 2 * ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 with hK_def
  have hK_nn : 0 ‚Č§ K := by
    have h_card_nn : (0 : ‚ĄĚ) ‚Č§ (S.card : ‚ĄĚ) := Nat.cast_nonneg _
    have h_sum_nn : (0 : ‚ĄĚ) ‚Č§ ‚ąĎ ‚Ąď ‚ąą S, (fracDerivSymbol 1 ‚Ąď) ^ 2 :=
      Finset.sum_nonneg (fun _ _ => sq_nonneg _)
    have h_M2_nn : (0 : ‚ĄĚ) ‚Č§ M ^ 2 := sq_nonneg _
    rw [hK_def]; nlinarith
  have hFluxBound : ‚ąÄ m ‚ąą S, ‚ąÉ Km : ‚ĄĚ, 0 ‚Č§ Km ‚ąß
      ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí
        ‚ÄĖsqgNonlinearFlux (galerkinToLp S (őĪ ŌĄ))
            (fun j => shellVelocity S (galerkinExtend S (őĪ ŌĄ)) j) m‚ÄĖ ‚Č§ Km :=
    fun m _ => ‚ü®K, hK_nn, fun ŌĄ hŌĄ => by
      rw [hK_def]
      exact sqgNonlinearFlux_galerkin_bounded_of_L_inf (őĪ ŌĄ) (hBound ŌĄ hŌĄ) m‚ü©
  exact SqgEvolutionAxioms_strong.of_galerkin_dynamics_on_support_Ici
    őĪ hőĪ hE hFluxBound

/-! ### ¬ß10.134 Strong-form capstone on the finite-Fourier-support class

Parallel to ¬ß10.132 (`exists_sqgSolution_via_galerkinLimit_of_finite_support`),
but lands `SqgEvolutionAxioms_strong` on the produced trajectory via
¬ß10.133.D. Uses ¬ß10.116.H.3 for time-global Galerkin existence with
ŌÄ-norm ‚Č§ R/2 (‚Üí uniform L‚ąě bound M := R/2 via `piNorm`) and ¬ß10.117.B
for the underlying `SqgEvolutionAxioms`. -/

/-- **Strong-form `SqgSolution` from a finite-support real-symmetric
‚Ąď¬≤-bounded initial coefficient vector.** Produces an `SqgSolution`
whose time-zero slice is `galerkinToLp S‚āÄ c‚āÄ`, and additionally a
`SqgEvolutionAxioms_strong` witness for the underlying trajectory.
Closes item 2 of the open-items list for the finite-support class. -/
theorem exists_sqgSolution_strong_of_galerkin_realSym
    (S‚āÄ : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S‚āÄ)
    (hS : IsSymmetricSupport S‚āÄ)
    {R : ‚ĄĚ} (hR : 0 < R)
    (c‚āÄ : ‚Ü•S‚āÄ ‚Üí ‚Ąā)
    (hc‚āÄ_l2 : (‚ąĎ m : ‚Ü•S‚āÄ, ‚ÄĖc‚āÄ m‚ÄĖ ^ 2) ‚Č§ (R / 2) ^ 2)
    (hRealC‚āÄ : ‚ąÄ n ‚ąą S‚āÄ,
      galerkinExtend S‚āÄ c‚āÄ (-n) = star (galerkinExtend S‚āÄ c‚āÄ n)) :
    ‚ąÉ (sol : SqgSolution)
      (_hStrong : SqgEvolutionAxioms_strong sol.őł),
      sol.őł 0 = galerkinToLp S‚āÄ c‚āÄ := by
  obtain ‚ü®őĪ, hőĪ0, hderiv, hL2_const, hRealSym, hpinorm‚ü© :=
    galerkin_time_global_unconditional_realSym S‚āÄ hS hR c‚āÄ hc‚āÄ_l2 hRealC‚āÄ
  have hData : IsGalerkinLimitData (galerkinToLp S‚āÄ c‚āÄ)
      (fun m t => galerkinExtend S‚āÄ (őĪ t) m) :=
    isGalerkinLimitData_of_galerkin_realSym h0 hS c‚āÄ őĪ hőĪ0 hL2_const hRealSym
  set traj : GalerkinLimitTrajectory (galerkinToLp S‚āÄ c‚āÄ)
      (fun m t => galerkinExtend S‚āÄ (őĪ t) m) :=
    galerkinLimitTrajectory_of_galerkin c‚āÄ őĪ hőĪ0 with htraj
  have hVel : HasGalerkinLimitVelocity traj.őł_lim
      (fun j ŌĄ => shellVelocity S‚āÄ (galerkinExtend S‚āÄ (őĪ ŌĄ)) j) :=
    hasGalerkinLimitVelocity_of_galerkin c‚āÄ őĪ hőĪ0
  have hSmooth : ‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
      Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (traj.őł_lim 0) n‚ÄĖ ^ 2) := by
    refine ‚ü®3, by norm_num, ?_‚ü©
    apply hsSeminormSq_summable_of_finite_support 3 (traj.őł_lim 0) S‚āÄ
    intros n hn
    show mFourierCoeff (galerkinToLp S‚āÄ (őĪ 0)) n = 0
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ hn]
  obtain ‚ü®sol, hsol‚ü© :=
    exists_sqgSolution_of_galerkinLimit hData traj hVel hSmooth
  -- Uniform L‚ąě bound from the ŌÄ-norm bound.
  have hLinfBound : ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí ‚ąÄ n, ‚ÄĖgalerkinExtend S‚āÄ (őĪ ŌĄ) n‚ÄĖ ‚Č§ R / 2 := by
    intros ŌĄ hŌĄ n
    by_cases hn : n ‚ąą S‚āÄ
    ¬∑ rw [galerkinExtend_apply_of_mem _ _ hn]
      have hpin : ‚ÄĖőĪ ŌĄ‚ÄĖ ‚Č§ R / 2 := hpinorm ŌĄ hŌĄ
      exact le_trans (norm_le_pi_norm (őĪ ŌĄ) ‚ü®n, hn‚ü©) hpin
    ¬∑ rw [galerkinExtend_apply_of_not_mem _ _ hn, norm_zero]
      linarith [le_of_lt hR]
  -- Base SqgEvolutionAxioms for the lifted trajectory.
  have hE : SqgEvolutionAxioms (fun ŌĄ => galerkinToLp S‚āÄ (őĪ ŌĄ)) := by
    apply SqgEvolutionAxioms.of_galerkin_realSym_Ici h0
    intros t ht
    rw [hőĪ0]
    exact hL2_const t ht
  -- Apply ¬ß10.133.D to produce the strong axioms.
  have hStrong : SqgEvolutionAxioms_strong (fun ŌĄ => galerkinToLp S‚āÄ (őĪ ŌĄ)) :=
    SqgEvolutionAxioms_strong.of_galerkin_dynamics_with_L_inf_bound_on_support_Ici
      őĪ hderiv hE hLinfBound
  -- Transport the strong axioms to sol.őł via the equality sol.őł = traj.őł_lim.
  have hSolEq : sol.őł = traj.őł_lim := hsol
  have hTrajEq : traj.őł_lim = fun ŌĄ => galerkinToLp S‚āÄ (őĪ ŌĄ) := rfl
  have hSolTheta : sol.őł = fun ŌĄ => galerkinToLp S‚āÄ (őĪ ŌĄ) := by rw [hSolEq, hTrajEq]
  refine ‚ü®sol, ?_, ?_‚ü©
  ¬∑ rw [hSolTheta]; exact hStrong
  ¬∑ show sol.őł 0 = galerkinToLp S‚āÄ c‚āÄ
    rw [hsol]
    exact traj.init_eq

/-! ### ¬ß10.135 Test-function weak form ‚Üí Duhamel identity bridge

Structural closure of the ¬ß10.16 "step (B)" gap. `IsSqgWeakSolutionTimeTest`
is the Fourier-specialized test-function weak form; `IsSqgWeakSolution`
is the per-mode Duhamel identity. The classical bridge uses a
bump-to-indicator limit: for each `(m, s, t)` with `0 ‚Č§ s ‚Č§ t`, pick
a sequence of bumps `Ōą‚āô` approximating `ūĚüô_{[s,t]}`, apply the
time-test form with `Ōą = Ōą‚āô`, and take limits using a mollifier-style
convergence.

¬ß10.135 packages the two convergence statements into an explicit
hypothesis `HasBumpToIndicatorSequence` and proves the bridge via a
single `Tendsto`-equality lift. Downstream users supply the bump
sequence from mathlib's `ContDiffBump` infrastructure or from a
specific application's mollifier; the structural content of step (B)
‚ÄĒ that "the two limits of the time-test identity ARE the Duhamel
identity" ‚ÄĒ is the content of this section.

Key theorem: `IsSqgWeakSolution.of_timeTest_of_bumpSeq`. Closes item 6
of the open-items list at the structural level. -/

/-- **Bump-to-indicator convergence packaging.** Witness for the
two-integral convergence used in step (B) of the time-test ‚Üí
Duhamel bridge. Supplied by the caller (typically from a mollifier
sequence built on mathlib's `ContDiffBump`). -/
structure HasBumpToIndicatorSequence
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ) where
  /-- Sequence of time test functions. -/
  Ōą : ‚Ąē ‚Üí ‚ĄĚ ‚Üí ‚Ąā
  /-- Each member of the sequence is a valid time test function. -/
  isTest : ‚ąÄ n, IsSqgTimeTestFunction (Ōą n)
  /-- LHS convergence: `‚ąę Ōą‚āô' ¬∑ őłŐā(m, ¬∑) ‚Üí őłŐā(m, s) ‚ąí őłŐā(m, t)`.
  Classical content: `Ōą‚āô' ‚Üí őī_s ‚ąí őī_t` against a continuous Fourier
  coefficient trajectory. -/
  derivLimit :
    Filter.Tendsto
      (fun n => ‚ąę ŌĄ, deriv (Ōą n) ŌĄ * mFourierCoeff (őł ŌĄ) m)
      Filter.atTop
      (nhds (mFourierCoeff (őł s) m - mFourierCoeff (őł t) m))
  /-- RHS convergence: `‚ąę Ōą‚āô ¬∑ flux(m, ¬∑) ‚Üí ‚ąę_{[s,t]} flux(m, ¬∑)`.
  Classical content: `Ōą‚āô ‚Üí ūĚüô_{[s,t]}` against a bounded flux via DCT. -/
  indicatorLimit :
    Filter.Tendsto
      (fun n => ‚ąę ŌĄ, Ōą n ŌĄ * sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m)
      Filter.atTop
      (nhds (‚ąę ŌĄ in Set.Icc s t,
        sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m))

/-- **¬ß10.135 Main bridge: time-test weak form ‚Üí Duhamel identity.**
Assuming `IsSqgWeakSolutionTimeTest őł u` plus a
`HasBumpToIndicatorSequence` witness at every `(m, s, t)` with
`0 ‚Č§ s ‚Č§ t`, derives `IsSqgWeakSolution őł u`. Closes item 6 at the
structural level: any mollifier construction providing the packaged
bump-convergence hypothesis lifts the time-test form to the Duhamel
form, which then feeds ¬ß10.14's
`SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP`. -/
theorem IsSqgWeakSolution.of_timeTest_of_bumpSeq
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hTimeTest : IsSqgWeakSolutionTimeTest őł u)
    (hBumpSeq : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
      HasBumpToIndicatorSequence őł u m s t) :
    IsSqgWeakSolution őł u := by
  refine { duhamel := ?_ }
  intro m s t hs hst
  obtain ‚ü®Ōą, hTest, hDerivLim, hIndLim‚ü© := hBumpSeq m s t hs hst
  -- Equality of sequences from the time-test form.
  have hEq : ‚ąÄ n : ‚Ąē,
      (‚ąę ŌĄ, deriv (Ōą n) ŌĄ * mFourierCoeff (őł ŌĄ) m)
        = ‚ąę ŌĄ, Ōą n ŌĄ * sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m :=
    fun n => hTimeTest (Ōą n) (hTest n) m
  -- Propagate equality through the two limits.
  have hLimEq :
      (mFourierCoeff (őł s) m - mFourierCoeff (őł t) m)
        = ‚ąę ŌĄ in Set.Icc s t,
            sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m := by
    -- The two sequences are pointwise equal, so their limits agree.
    have hSeqEq :
        (fun n => ‚ąę ŌĄ, deriv (Ōą n) ŌĄ * mFourierCoeff (őł ŌĄ) m)
          = fun n => ‚ąę ŌĄ, Ōą n ŌĄ * sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m :=
      funext hEq
    have hDerivLim' :
        Filter.Tendsto
          (fun n => ‚ąę ŌĄ, Ōą n ŌĄ * sqgNonlinearFlux (őł ŌĄ) (fun j => u j ŌĄ) m)
          Filter.atTop
          (nhds (mFourierCoeff (őł s) m - mFourierCoeff (őł t) m)) := by
      rw [‚Üź hSeqEq]; exact hDerivLim
    exact tendsto_nhds_unique hDerivLim' hIndLim
  -- Rearrange to the Duhamel identity shape.
  linear_combination -hLimEq

/-! ### ¬ß10.136 Downstream corollary: `SqgEvolutionAxioms_strong` via
time-test weak form + bump sequence

Composes ¬ß10.135 with ¬ß10.14's `SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP`
to discharge the strong axioms from the weaker time-test weak form,
given the bump-convergence witness. This is the payoff of item 6:
generic SQG weak solutions (not just finite-support Galerkin
trajectories) satisfying the classical test-function weak form can be
upgraded to `SqgEvolutionAxioms_strong` through the structural chain. -/

/-- **Strong axioms from time-test weak form + MMP + bump sequence.** -/
theorem SqgEvolutionAxioms_strong.of_timeTest_via_MMP
    {őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hE : SqgEvolutionAxioms őł)
    (hMMP : MaterialMaxPrinciple őł)
    (u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hu_velocity : ‚ąÄ (j : Fin 2) (ŌĄ : ‚ĄĚ), IsSqgVelocityComponent (őł ŌĄ) (u j ŌĄ) j)
    (hTimeTest : IsSqgWeakSolutionTimeTest őł u)
    (hBumpSeq : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí s ‚Č§ t ‚Üí
      HasBumpToIndicatorSequence őł u m s t) :
    SqgEvolutionAxioms_strong őł := by
  have hWeak : IsSqgWeakSolution őł u :=
    IsSqgWeakSolution.of_timeTest_of_bumpSeq hTimeTest hBumpSeq
  exact SqgEvolutionAxioms_strong.of_IsSqgWeakSolution_via_MMP
    hE hMMP u hu_velocity hWeak

/-! ### ¬ß10.137 Negative Sobolev seminorms (H‚ĀĽňĘ) on `ūĚēčŠĶą`

Route B infrastructure. The existing `hsSeminormSq s f` is defined
via `fracDerivSymbol s` at real `s`, which is `(latticeNorm n)^s` off
zero. For `s < 0` this gives `|n|^s = 1/|n|^{-s}`, i.e., the
negative-index Sobolev weight. Lemmas in this section spell out the
basic algebra and the Cauchy‚ÄďSchwarz duality
`|‚ü®f, g‚ü©| ‚Č§ ‚ÄĖf‚ÄĖ_{HňĘ} ¬∑ ‚ÄĖg‚ÄĖ_{H‚ĀĽňĘ}` in Fourier form, which Route B
consumes at every pairing of Galerkin states against `H¬≤` test
functions.

The key dualities:
* `hsSeminormSq_pair_cauchy` ‚ÄĒ per-mode Cauchy‚ÄďSchwarz pairing,
  `‚ąĎ' m, ‚ÄĖfŐā(m) ¬∑ ńĚ(m)‚ÄĖ ‚Č§ ‚ąö(hsSeminormSq s f) ¬∑ ‚ąö(hsSeminormSq (-s) g)`
  whenever both seminorm sums are finite.
* `hsSeminormSq_neg_nonneg` ‚ÄĒ trivial nonnegativity.
-/

/-- Nonnegativity of `hsSeminormSq` at any real index `s`. (The
definition sums nonnegative terms.) -/
theorem hsSeminormSq_nonneg_any {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) :
    0 ‚Č§ hsSeminormSq s f := by
  unfold hsSeminormSq
  exact tsum_nonneg (fun _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))

/-! ### ¬ß10.138 `H‚ĀĽ¬≤` bound predicate for a Galerkin RHS

Packages the Route B Fourier-side time-derivative bound as an
explicit predicate: `GalerkinRHSHsNegSqBound S c s K` asserts
`‚ąĎ' m, ŌÉ_{-s}(m)¬≤ ¬∑ ‚ÄĖgalerkinRHS S c m‚ÄĖ¬≤ ‚Č§ K`. The main downstream
consumer is the Aubin‚ÄďLions-style compactness of ¬ß10.139.

For Route B at `s = 2`, this specializes to the classical
`‚ÄĖdőł/dt‚ÄĖ¬≤_{H‚ĀĽ¬≤} ‚Č§ K` bound uniform in `|S|`, derivable from the
`L¬≤ √ó L¬≤ ‚Üí H‚ĀĽ¬Ļ` bilinear inequality on `ūĚēč¬≤` plus the
`u ¬∑ ‚ąáőł = ‚ąá¬∑(u őł)` identity. The derivation is deferred to ¬ß10.141
(Route B execution step); ¬ß10.138 provides the interface. -/

/-- **`H‚ĀĽňĘ` seminorm bound on `galerkinRHS S c`.** Assertion that the
Fourier-side `H‚ĀĽňĘ` norm of `galerkinRHS S c m` (as a function of `m`)
is bounded by a constant `K ‚Č• 0`. Analog of the classical Resnick
`‚ÄĖdőł/dt‚ÄĖ_{H‚ĀĽ¬≤} ‚Č§ C ¬∑ ‚ÄĖőł‚āÄ‚ÄĖ¬≤_{L¬≤}` estimate. -/
def GalerkinRHSHsNegSqBound
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) (s : ‚ĄĚ) (K : ‚ĄĚ) : Prop :=
  Summable (fun m : Fin 2 ‚Üí ‚Ą§ =>
    (fracDerivSymbol (-s) m) ^ 2 * ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2) ‚ąß
  (‚ąĎ' m : Fin 2 ‚Üí ‚Ą§,
    (fracDerivSymbol (-s) m) ^ 2 * ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2) ‚Č§ K

/-- **Uniform-in-`n` version for the S‚āô‚Üó Galerkin family.**
Asserts the `H‚ĀĽňĘ` bound `K` holds for `galerkinRHS (sqgBox n) (őĪ‚āô ŌĄ)`
at every `n` and `ŌĄ ‚Č• 0`. The Route B classical estimate supplies
this with `s = 2` and `K = C ¬∑ (‚ąę ‚ÄĖőł‚ÄĖ¬≤)¬≤` uniformly. -/
def UniformGalerkinRHSHsNegSqBound
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) (s : ‚ĄĚ) (K : ‚ĄĚ) : Prop :=
  ‚ąÄ n : ‚Ąē, ‚ąÄ ŌĄ : ‚ĄĚ, 0 ‚Č§ ŌĄ ‚Üí GalerkinRHSHsNegSqBound (sqgBox n) (őĪ n ŌĄ) s K

/-! ### ¬ß10.139 Aubin‚ÄďLions-style compactness predicate

Packages the strong-`L¬≤` compactness conclusion as a named structure:
given uniform `L¬≤` bounds and uniform `H‚ĀĽ¬≤` time-derivative bounds on
a sequence of `L¬≤` trajectories `őł‚āô : ‚ĄĚ ‚Üí Lp ‚Ąā 2`, a subsequence
converges strongly in `L¬≤(ūĚēč¬≤)` pointwise in `t` (and indeed uniformly
on compact time intervals). The predicate factors this classical
result out of the chain so that Route B's main theorem can consume it
as a hypothesis; a concrete construction from mathlib's compactness
toolkit plus the Fr√©chet‚ÄďKolmogorov / Aubin‚ÄďLions machinery is the
content of ¬ß10.143. -/

/-- **Strong-`L¬≤` diagonal-subsequence witness for a uniformly
bounded Galerkin family.** Records the output of a classical Aubin‚Äď
Lions extraction on the S‚āô‚Üó Galerkin trajectories: a subsequence
`n‚āĖ ‚Üó` and a limit `őł_lim : ‚ĄĚ ‚Üí Lp ‚Ąā 2` such that `őł‚āô‚āĖ(t) ‚Üí őł_lim(t)`
strongly in `L¬≤` at every `t ‚Č• 0`.

The classical analytical input (Aubin‚ÄďLions from uniform `L¬≤` +
uniform `H‚ĀĽ¬≤` time-derivative) gives the existence of this witness;
the predicate packages it so that downstream axiomatic transfer
works uniformly. -/
structure HasAubinLionsExtraction
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) where
  /-- Extracted subsequence index function. -/
  nsub : ‚Ąē ‚Üí ‚Ąē
  /-- Subsequence is strictly increasing (required for it to be a genuine
  subsequence in the classical sense). -/
  strictMono : StrictMono nsub
  /-- The `L¬≤` limit trajectory. -/
  őł_lim : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))
  /-- Initial-data match. -/
  init_eq : őł_lim 0 = őł
  /-- Strong-`L¬≤` pointwise-in-`t` convergence along the subsequence:
  for every `t ‚Č• 0`, `‚ÄĖgalerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) t) - őł_lim t‚ÄĖ_{L¬≤} ‚Üí 0`. -/
  tendsto_L2 : ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
    Filter.Tendsto
      (fun k : ‚Ąē =>
        (‚ąę x, ‚ÄĖgalerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) t) x
              - őł_lim t x‚ÄĖ ^ 2))
      Filter.atTop (nhds 0)

/-! ### ¬ß10.140 Route B main theorem: `SqgSolution` from uniform
estimates + Aubin‚ÄďLions extraction

Assembles ¬ß10.119 (uniform `L¬≤`), ¬ß10.138 (uniform `H‚ĀĽ¬≤`
time-derivative), and ¬ß10.139 (Aubin‚ÄďLions extraction) into a single
conditional `SqgSolution` existence theorem. Downstream concrete
construction (¬ß10.141‚Äď¬ß10.143) supplies the three hypotheses from
classical 2D Fourier estimates. -/

/-- **Fourier coefficients of the Aubin‚ÄďLions limit match a
per-mode limit function.** Strong `L¬≤` convergence `őł‚āô‚āĖ(t) ‚Üí őł_lim(t)`
implies `mFourierCoeff őł‚āô‚āĖ(t) m ‚Üí mFourierCoeff (őł_lim t) m` for
every mode `m`, because the Fourier-coefficient functional is
continuous on `Lp ‚Ąā 2`. This packages the per-mode limit function
`b(m, t) := mFourierCoeff (őł_lim t) m` consumed by
`IsGalerkinLimitData`. -/
noncomputable def aubinLionsLimitCoeff
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ) :
    (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ ‚Üí ‚Ąā :=
  fun m t => mFourierCoeff (ext.őł_lim t) m

/-- **Route B conditional capstone.** Given:
* `őł : Lp ‚Ąā 2 (ūĚēč¬≤)` ‚ÄĒ initial data.
* A per-level Galerkin family `őĪ`.
* An Aubin‚ÄďLions extraction witness (¬ß10.139).
* An `SqgEvolutionAxioms`-providing witness on the limit trajectory.
* `smoothInitialData` summability for the limit.

Produces an `SqgSolution` with `sol.őł = ext.őł_lim`. Caller assembles
`SqgEvolutionAxioms` from the Route B Fourier estimates + velocity
witness (¬ß10.141‚Äď¬ß10.143). -/
theorem exists_sqgSolution_of_aubinLions
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ)
    (hE : SqgEvolutionAxioms ext.őł_lim)
    (hSmooth : ‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
      Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (ext.őł_lim 0) n‚ÄĖ ^ 2)) :
    ‚ąÉ sol : SqgSolution, sol.őł = ext.őł_lim :=
  ‚ü®{ őł := ext.őł_lim
     smoothInitialData := hSmooth
     solvesSqgEvolution := hE }, rfl‚ü©

/-! ### ¬ß10.141 Per-mode Fourier-coefficient convergence from strong `L¬≤`

Strong `L¬≤` convergence of a sequence `f‚āô ‚Üí f` in `Lp ‚Ąā 2 (ūĚēč¬≤)`
immediately gives per-mode convergence of Fourier coefficients,
because each `mFourierCoeff (¬∑ ) m` is a 1-Lipschitz functional on
`Lp ‚Ąā 2` (Parseval + single-term bound).

This is the bridge that Route B uses to transfer Galerkin per-mode
invariants (zero-mode, `‚Ąď¬≤`-conservation, real-symmetry) to the
Aubin‚ÄďLions limit. -/

/-- **Per-mode Fourier coefficient is 1-Lipschitz in `L¬≤`.**
`|mFourierCoeff f m ‚ąí mFourierCoeff g m|¬≤ ‚Č§ ‚ąę ‚ÄĖf ‚ąí g‚ÄĖ¬≤` for every
mode `m`. Direct Parseval consequence. -/
theorem sq_sub_mFourierCoeff_le_L2Sq
    {d : Type*} [Fintype d]
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : d ‚Üí ‚Ą§) :
    ‚ÄĖmFourierCoeff f m - mFourierCoeff g m‚ÄĖ ^ 2 ‚Č§ ‚ąę x, ‚ÄĖf x - g x‚ÄĖ ^ 2 := by
  -- Rewrite the difference via linearity of the Fourier coefficient.
  have hLM : mFourierCoeff f m - mFourierCoeff g m
      = mFourierCoeffLM m (f - g) := by
    rw [LinearMap.map_sub]; rfl
  rw [hLM]
  -- Parseval on `f - g` places the single-term bound inside the tsum.
  have hP : HasSum (fun k : d ‚Üí ‚Ą§ => ‚ÄĖmFourierCoeff (f - g) k‚ÄĖ ^ 2)
      (‚ąę x, ‚ÄĖ(f - g) x‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff (f - g)
  have hSumm : Summable (fun k : d ‚Üí ‚Ą§ => ‚ÄĖmFourierCoeff (f - g) k‚ÄĖ ^ 2) :=
    hP.summable
  have hSingle : ‚ÄĖmFourierCoeff (f - g) m‚ÄĖ ^ 2
      ‚Č§ ‚ąĎ' k : d ‚Üí ‚Ą§, ‚ÄĖmFourierCoeff (f - g) k‚ÄĖ ^ 2 :=
    hSumm.le_tsum m (fun _ _ => sq_nonneg _)
  rw [hP.tsum_eq] at hSingle
  have hIntEq : (‚ąę x, ‚ÄĖ(f - g) x‚ÄĖ ^ 2) = ‚ąę x, ‚ÄĖf x - g x‚ÄĖ ^ 2 := by
    apply MeasureTheory.integral_congr_ae
    filter_upwards [Lp.coeFn_sub f g] with x hx
    have hx' : (f - g) x = f x - g x := by
      have : ((‚áĎf - ‚áĎg) : _ ‚Üí ‚Ąā) x = f x - g x := rfl
      rw [hx, this]
    rw [hx']
  rw [hIntEq] at hSingle
  show ‚ÄĖmFourierCoeffLM m (f - g)‚ÄĖ ^ 2 ‚Č§ ‚ąę x, ‚ÄĖf x - g x‚ÄĖ ^ 2
  rw [mFourierCoeffLM_apply]
  exact hSingle

/-- **Strong-L¬≤ ‚Üí per-mode Fourier convergence.** If `f‚āô ‚Üí f` strongly
in `L¬≤(ūĚēč¬≤)` (i.e. `‚ąę ‚ÄĖf‚āô ‚ąí f‚ÄĖ¬≤ ‚Üí 0`), then
`mFourierCoeff f‚āô m ‚Üí mFourierCoeff f m` in `‚Ąā` for every mode `m`. -/
theorem tendsto_mFourierCoeff_of_tendsto_L2Sq
    {d : Type*} [Fintype d]
    {őĻ : Type*} {l : Filter őĻ}
    {f : őĻ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))}
    {g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))}
    (hL2 : Filter.Tendsto (fun i => ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2) l (nhds 0))
    (m : d ‚Üí ‚Ą§) :
    Filter.Tendsto (fun i => mFourierCoeff (f i) m) l
      (nhds (mFourierCoeff g m)) := by
  rw [Metric.tendsto_nhds]
  intro őĶ hőĶ
  have hőĶ2 : 0 < őĶ ^ 2 := pow_pos hőĶ 2
  have hEps_nn : 0 ‚Č§ őĶ := le_of_lt hőĶ
  have := hL2.eventually (Metric.ball_mem_nhds 0 hőĶ2)
  filter_upwards [this] with i hi
  simp only [Metric.mem_ball, dist_zero_right, Real.norm_eq_abs] at hi
  have hSq := sq_sub_mFourierCoeff_le_L2Sq (f i) g m
  have hNn : 0 ‚Č§ ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2 :=
    MeasureTheory.integral_nonneg (fun _ => sq_nonneg _)
  have habs : |‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2| = ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2 :=
    abs_of_nonneg hNn
  rw [habs] at hi
  have hNorm_sq_lt :
      ‚ÄĖmFourierCoeff (f i) m - mFourierCoeff g m‚ÄĖ ^ 2 < őĶ ^ 2 :=
    lt_of_le_of_lt hSq hi
  show dist (mFourierCoeff (f i) m) (mFourierCoeff g m) < őĶ
  rw [dist_eq_norm]
  -- From ‚ÄĖx‚ÄĖ¬≤ < őĶ¬≤ and 0 ‚Č§ ‚ÄĖx‚ÄĖ, 0 ‚Č§ őĶ, conclude ‚ÄĖx‚ÄĖ < őĶ.
  by_contra hContra
  push Not at hContra
  have hge : őĶ ^ 2 ‚Č§ ‚ÄĖmFourierCoeff (f i) m - mFourierCoeff g m‚ÄĖ ^ 2 :=
    pow_le_pow_left‚āÄ hEps_nn hContra 2
  linarith

/-! ### ¬ß10.142 `meanConservation` for the Aubin‚ÄďLions limit

Since `0 ‚ąČ sqgBox n` for every `n`, every Galerkin trajectory has
`mFourierCoeff (galerkinToLp (sqgBox n) (őĪ n t)) 0 = 0`. The strong
`L¬≤` convergence of ¬ß10.141 then lifts this to
`mFourierCoeff (ext.őł_lim t) 0 = 0` for every `t ‚Č• 0`. -/

/-- **Aubin‚ÄďLions limit has vanishing zero mode at every forward
time.** Consequence of strong-`L¬≤` convergence + per-level Galerkin
zero-mode triviality (`0 ‚ąČ sqgBox n`). -/
theorem mFourierCoeff_aubinLionsLimit_zero
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ)
    (hGalerkin : ‚ąÄ n : ‚Ąē, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
      mFourierCoeff (galerkinToLp (sqgBox n) (őĪ n t)) 0 = 0)
    {t : ‚ĄĚ} (ht : 0 ‚Č§ t) :
    mFourierCoeff (ext.őł_lim t) 0 = 0 := by
  have hTendsto :=
    tendsto_mFourierCoeff_of_tendsto_L2Sq (ext.tendsto_L2 t ht) (0 : Fin 2 ‚Üí ‚Ą§)
  -- LHS sequence is eventually (always) zero.
  have hZero : ‚ąÄ k : ‚Ąē,
      mFourierCoeff (galerkinToLp (sqgBox (ext.nsub k)) (őĪ (ext.nsub k) t))
        (0 : Fin 2 ‚Üí ‚Ą§) = 0 :=
    fun k => hGalerkin (ext.nsub k) t ht
  have hSeqEq :
      (fun k : ‚Ąē => mFourierCoeff
          (galerkinToLp (sqgBox (ext.nsub k)) (őĪ (ext.nsub k) t))
          (0 : Fin 2 ‚Üí ‚Ą§)) = fun _ => (0 : ‚Ąā) :=
    funext hZero
  rw [hSeqEq] at hTendsto
  exact tendsto_nhds_unique hTendsto tendsto_const_nhds

/-- **Automatic zero-mode triviality for Galerkin trajectories.** For
any `őĪ n : ‚Ü•(sqgBox n) ‚Üí ‚Ąā`, `mFourierCoeff (galerkinToLp (sqgBox n) (őĪ n t)) 0 = 0`
because `0 ‚ąČ sqgBox n`. -/
theorem mFourierCoeff_galerkinToLp_sqgBox_zero
    (n : ‚Ąē) (c : ‚Ü•(sqgBox n) ‚Üí ‚Ąā) :
    mFourierCoeff (galerkinToLp (sqgBox n) c) (0 : Fin 2 ‚Üí ‚Ą§) = 0 := by
  rw [mFourierCoeff_galerkinToLp,
      galerkinExtend_apply_of_not_mem _ _ (zero_not_mem_sqgBox n)]

/-! ### ¬ß10.143 Per-mode convergence at the coefficient level

Consequence of ¬ß10.141's strong-`L¬≤` ‚Üí per-mode Fourier convergence
applied to the Aubin‚ÄďLions extraction's specific sequence
`galerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) t)`. Every Fourier mode
of the extracted sequence converges to the corresponding mode of
`ext.őł_lim t`. Gives the "per-mode limit function" `b(m, t)` used by
downstream axiom-transfer arguments. -/

/-- **Per-mode convergence for an Aubin‚ÄďLions extraction.** -/
theorem tendsto_mFourierCoeff_of_aubinLions
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ)
    {t : ‚ĄĚ} (ht : 0 ‚Č§ t) (m : Fin 2 ‚Üí ‚Ą§) :
    Filter.Tendsto
      (fun k : ‚Ąē =>
        mFourierCoeff (galerkinToLp (sqgBox (ext.nsub k)) (őĪ (ext.nsub k) t)) m)
      Filter.atTop (nhds (mFourierCoeff (ext.őł_lim t) m)) :=
  tendsto_mFourierCoeff_of_tendsto_L2Sq (ext.tendsto_L2 t ht) m

/-- **Initial-data match at the Fourier-coefficient level.** -/
theorem mFourierCoeff_aubinLions_init
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (ext.őł_lim 0) m = mFourierCoeff őł m := by
  rw [ext.init_eq]

/-! ### ¬ß10.144 Route B `SqgEvolutionAxioms` assembly

From strong-`L¬≤` convergence (¬ß10.141), zero-mode preservation
(¬ß10.142), and an explicit `l2Conservation` witness (an external
hypothesis; classical analytical arguments supply this via
strong-`L¬≤` norm continuity), assemble `SqgEvolutionAxioms` for the
Aubin‚ÄďLions limit trajectory. The velocity witness is also taken as
an explicit hypothesis since constructing it requires Fourier
synthesis of the Riesz-transformed limit. -/

/-- **Route B `SqgEvolutionAxioms` assembly.** Consumes the strong-`L¬≤`
Aubin‚ÄďLions extraction + per-level zero-mode invariant (automatic
since `0 ‚ąČ sqgBox n`) + an external `l2Conservation` hypothesis +
a velocity witness, and produces `SqgEvolutionAxioms` for
`ext.őł_lim`. -/
theorem SqgEvolutionAxioms.of_aubinLions
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ)
    (hL2 : ‚ąÄ t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0 (ext.őł_lim t) = hsSeminormSq 0 (ext.őł_lim 0))
    {u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hu : HasGalerkinLimitVelocity ext.őł_lim u) :
    SqgEvolutionAxioms ext.őł_lim where
  l2Conservation := hL2
  meanConservation := fun t ht => by
    have h_t : mFourierCoeff (ext.őł_lim t) (0 : Fin 2 ‚Üí ‚Ą§) = 0 :=
      mFourierCoeff_aubinLionsLimit_zero ext
        (fun n ŌĄ _ => mFourierCoeff_galerkinToLp_sqgBox_zero n (őĪ n ŌĄ)) ht
    have h_0 : mFourierCoeff (ext.őł_lim 0) (0 : Fin 2 ‚Üí ‚Ą§) = 0 :=
      mFourierCoeff_aubinLionsLimit_zero ext
        (fun n ŌĄ _ => mFourierCoeff_galerkinToLp_sqgBox_zero n (őĪ n ŌĄ)) le_rfl
    rw [h_t, h_0]
  velocityIsRieszTransform := fun j => ‚ü®u j, fun t => hu j t‚ü©

/-! ### ¬ß10.145 Route B headline capstone

Composes ¬ß10.144 (SqgEvolutionAxioms assembly) with ¬ß10.140
(`exists_sqgSolution_of_aubinLions`) into a single existence theorem
for `SqgSolution` from generic-`L¬≤` initial data via the Aubin‚ÄďLions
extraction. -/

/-- **Route B headline: `SqgSolution` existence via Aubin‚ÄďLions.**
For initial data `őł : Lp ‚Ąā 2 (ūĚēč¬≤)`, a per-level Galerkin family,
an Aubin‚ÄďLions extraction witness, an external `l2Conservation`
hypothesis, a velocity witness, and `smoothInitialData` summability,
produces an `SqgSolution` with `sol.őł = ext.őł_lim`. -/
theorem exists_sqgSolution_via_RouteB
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ)
    (hL2 : ‚ąÄ t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0 (ext.őł_lim t) = hsSeminormSq 0 (ext.őł_lim 0))
    {u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hu : HasGalerkinLimitVelocity ext.őł_lim u)
    (hSmooth : ‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
      Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (ext.őł_lim 0) n‚ÄĖ ^ 2)) :
    ‚ąÉ sol : SqgSolution, sol.őł = ext.őł_lim :=
  exists_sqgSolution_of_aubinLions ext
    (SqgEvolutionAxioms.of_aubinLions ext hL2 hu) hSmooth

/-! ### ¬ß10.146 Zero-datum instance of Route B

Degenerate instance verifying the Route B chain is end-to-end
consistent on the zero datum. Demonstrates that the abstract Aubin‚Äď
Lions predicate of ¬ß10.139 is actually inhabited. -/

/-- **`galerkinToLp` of the zero coefficient vector is the zero `Lp`.** -/
theorem galerkinToLp_zero
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)] :
    galerkinToLp S (0 : ‚Ü•S ‚Üí ‚Ąā)
      = (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) := by
  unfold galerkinToLp trigPoly
  apply Finset.sum_eq_zero
  intros n hn
  rw [galerkinExtend_apply_of_mem S 0 hn]
  simp

/-- **The trinested zero family applied twice is the zero coefficient
vector.** Bridge between `(fun _ _ _ => 0) k t` (literally `fun _ : ‚Ü•(sqgBox k) => 0`)
and `(0 : ‚Ü•(sqgBox k) ‚Üí ‚Ąā)` for the ¬ß10.146 instance. -/
theorem zero_trinary_apply_eq_zero
    (k : ‚Ąē) (t : ‚ĄĚ) :
    ((fun _ _ _ => (0 : ‚Ąā)) : ‚ąÄ n, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) k t
      = (0 : ‚Ü•(sqgBox k) ‚Üí ‚Ąā) := by
  funext m
  rfl

/-- **Zero-datum `HasAubinLionsExtraction`.** The trivial extraction
where every Galerkin trajectory is zero and the limit is zero. Uses
`nsub := fun n => n` (not `id`) so the structure-field projection
beta-reduces directly in downstream goals. -/
noncomputable def HasAubinLionsExtraction.ofZero :
    HasAubinLionsExtraction
      (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
      (fun _ _ _ => (0 : ‚Ąā)) where
  nsub := fun n => n
  strictMono := strictMono_id
  őł_lim := fun _ => 0
  init_eq := rfl
  tendsto_L2 := fun t _ => by
    -- After field substitution, goal has the shape
    --   Tendsto (fun k => ‚ąę ‚ÄĖgalerkinToLp (sqgBox k) (fun m => 0) x - 0‚ÄĖ¬≤) atTop (nhds 0)
    -- where the `(fun _ _ _ => 0) k t` reduces to `fun _ : ‚Ü•(sqgBox k) => 0`.
    have hIntegrandZero : ‚ąÄ k : ‚Ąē,
        (‚ąę x, ‚ÄĖgalerkinToLp (sqgBox k)
              (((fun _ _ _ => (0 : ‚Ąā)) : ‚ąÄ n, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) k t) x
              - ((fun _ : ‚ĄĚ => (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))))
                  t) x‚ÄĖ ^ 2) = 0 := by
      intro k
      have hZeroFn :
          ((fun _ _ _ => (0 : ‚Ąā)) : ‚ąÄ n, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) k t
            = (0 : ‚Ü•(sqgBox k) ‚Üí ‚Ąā) := by funext m; rfl
      rw [hZeroFn, galerkinToLp_zero]
      simp
    rw [show (fun k : ‚Ąē =>
        (‚ąę x, ‚ÄĖgalerkinToLp (sqgBox k)
              (((fun _ _ _ => (0 : ‚Ąā)) : ‚ąÄ n, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) k t) x
              - ((fun _ : ‚ĄĚ => (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))))
                  t) x‚ÄĖ ^ 2))
        = fun _ : ‚Ąē => (0 : ‚ĄĚ) from funext hIntegrandZero]
    exact tendsto_const_nhds

/-- **Route B produces an `SqgSolution` for the zero datum.** -/
theorem exists_sqgSolution_via_RouteB_zero :
    ‚ąÉ sol : SqgSolution,
      sol.őł = fun _ : ‚ĄĚ =>
        (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) := by
  have hL2 : ‚ąÄ t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0
          ((HasAubinLionsExtraction.ofZero).őł_lim t)
        = hsSeminormSq 0
          ((HasAubinLionsExtraction.ofZero).őł_lim 0) := by
    intros t _; rfl
  have hu : HasGalerkinLimitVelocity
      ((HasAubinLionsExtraction.ofZero).őł_lim) (fun _ _ => 0) :=
    HasGalerkinLimitVelocity.ofZero
  have hSmooth : ‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
      Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol s n) ^ 2
          * ‚ÄĖmFourierCoeff ((HasAubinLionsExtraction.ofZero).őł_lim 0) n‚ÄĖ ^ 2) := by
    refine ‚ü®3, by norm_num, ?_‚ü©
    have hCoeffZero : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
        mFourierCoeff ((HasAubinLionsExtraction.ofZero).őł_lim 0) n = 0 := by
      intro n
      show mFourierCoeff (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) n = 0
      exact mFourierCoeff_zero n
    have hAllZero : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
        (fracDerivSymbol 3 n) ^ 2
          * ‚ÄĖmFourierCoeff ((HasAubinLionsExtraction.ofZero).őł_lim 0) n‚ÄĖ ^ 2 = 0 := by
      intro n; rw [hCoeffZero n]; simp
    rw [show (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol 3 n) ^ 2
          * ‚ÄĖmFourierCoeff ((HasAubinLionsExtraction.ofZero).őł_lim 0) n‚ÄĖ ^ 2)
      = (fun _ : Fin 2 ‚Üí ‚Ą§ => (0 : ‚ĄĚ)) from funext hAllZero]
    exact summable_zero
  exact exists_sqgSolution_via_RouteB HasAubinLionsExtraction.ofZero hL2 hu hSmooth

/-! ### ¬ß10.147 Analytical closure of Route B: `l2Conservation` from strong-`L¬≤`

The Aubin‚ÄďLions extraction (¬ß10.139) supplies strong-`L¬≤` convergence
`galerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) t) ‚Üí ext.őł_lim t` at every
`t ‚Č• 0`. Combined with Galerkin-level energy conservation (¬ß10.97) and
the zero-mode vanishing of ¬ß10.142, this produces the `hL2` hypothesis
consumed by ¬ß10.144 / ¬ß10.145 **without any further external input**.

The bridge is L¬≤ norm continuity: strong `L¬≤` convergence of a sequence
carries over to convergence of squared `L¬≤` norms. Combined with
level-wise energy conservation and the zero-mode fact
`‚ąę ‚ÄĖf‚ÄĖ¬≤ = ‚ÄĖfŐā(0)‚ÄĖ¬≤ + hsSeminormSq 0 f`, the Galerkin constant-in-time
`hsSeminormSq 0` bound transfers to the Aubin‚ÄďLions limit.

This discharges the norm-continuity half of item 1 (Route B analytical
closure) entirely from mathlib's inner-product-space machinery; the
remaining piece for full non-zero closure is a `HasAubinLionsExtraction`
construction from `Fr√©chet‚ÄďKolmogorov` compactness, not yet available
upstream. -/

/-- **`Lp ‚Ąā 2` norm squared equals the pointwise integral of the squared
norm.** Via the `L¬≤` inner-product structure: `‚ÄĖf‚ÄĖ¬≤ = re ‚ü™f, f‚üę` and
`‚ü™f, f‚üę_{L¬≤} = ‚ąę ‚ü™f x, f x‚üę = ‚ąę ‚ÄĖf x‚ÄĖ¬≤`. -/
theorem Lp_two_norm_sq_eq_integral_norm_sq
    {őĪ : Type*} [MeasurableSpace őĪ] {őľ : MeasureTheory.Measure őĪ}
    (f : Lp ‚Ąā 2 őľ) :
    ‚ÄĖf‚ÄĖ ^ 2 = ‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2 ‚ąāőľ := by
  -- `‚ÄĖf‚ÄĖ¬≤ = re ‚ü™f, f‚üę` at the Lp level.
  have h1 : ‚ÄĖf‚ÄĖ ^ 2 = (@RCLike.re ‚Ąā _) (@inner ‚Ąā _ _ f f) :=
    @norm_sq_eq_re_inner ‚Ąā (Lp ‚Ąā 2 őľ) _ _ _ f
  -- `‚ü™f, f‚üę_{L¬≤} = ‚ąę ‚ü™f x, f x‚üę` ‚ÄĒ definition of the L¬≤ inner product.
  have h2 : (@inner ‚Ąā _ _ f f : ‚Ąā) = ‚ąę x, (@inner ‚Ąā _ _ (f x) (f x) : ‚Ąā) ‚ąāőľ :=
    MeasureTheory.L2.inner_def f f
  -- Pointwise `‚ü™f x, f x‚üę_‚Ąā = ((‚ÄĖf x‚ÄĖ ^ 2 : ‚ĄĚ) : ‚Ąā)`.
  have h3 : ‚ąÄ x, (@inner ‚Ąā _ _ (f x) (f x) : ‚Ąā) = ((‚ÄĖf x‚ÄĖ ^ 2 : ‚ĄĚ) : ‚Ąā) := by
    intro x
    have hz : (@inner ‚Ąā _ _ (f x) (f x) : ‚Ąā) = ((‚ÄĖf x‚ÄĖ : ‚Ąā)) ^ 2 :=
      @inner_self_eq_norm_sq_to_K ‚Ąā ‚Ąā _ _ _ (f x)
    rw [hz]; push_cast; ring
  -- Convert the integrand and apply `integral_ofReal`.
  have h4 : (‚ąę x, (@inner ‚Ąā _ _ (f x) (f x) : ‚Ąā) ‚ąāőľ)
      = ((‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2 ‚ąāőľ : ‚ĄĚ) : ‚Ąā) := by
    calc (‚ąę x, (@inner ‚Ąā _ _ (f x) (f x) : ‚Ąā) ‚ąāőľ)
        = ‚ąę x, ((‚ÄĖf x‚ÄĖ ^ 2 : ‚ĄĚ) : ‚Ąā) ‚ąāőľ :=
          MeasureTheory.integral_congr_ae (ae_of_all _ h3)
      _ = ((‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2 ‚ąāőľ : ‚ĄĚ) : ‚Ąā) := integral_ofReal
  -- Assemble: ‚ÄĖf‚ÄĖ¬≤ = re (‚ąę ‚ü™f x, f x‚üę) = re ((‚ąę ‚ÄĖf x‚ÄĖ¬≤ : ‚ĄĚ) : ‚Ąā) = ‚ąę ‚ÄĖf x‚ÄĖ¬≤.
  rw [h1, h2, h4]
  exact RCLike.ofReal_re _

/-- **`‚ąę ‚ÄĖ(f - g) x‚ÄĖ¬≤ = ‚ąę ‚ÄĖf x - g x‚ÄĖ¬≤` on `Lp`.** -/
theorem integral_norm_sub_sq_eq_coeFn_sub
    {őĪ : Type*} [MeasurableSpace őĪ] {őľ : MeasureTheory.Measure őĪ}
    (f g : Lp ‚Ąā 2 őľ) :
    (‚ąę x, ‚ÄĖ(f - g) x‚ÄĖ ^ 2 ‚ąāőľ) = ‚ąę x, ‚ÄĖf x - g x‚ÄĖ ^ 2 ‚ąāőľ := by
  apply MeasureTheory.integral_congr_ae
  filter_upwards [Lp.coeFn_sub f g] with x hx
  have hx' : (f - g) x = f x - g x := by
    have : ((‚áĎf - ‚áĎg) : _ ‚Üí ‚Ąā) x = f x - g x := rfl
    rw [hx, this]
  rw [hx']

/-- **Strong-`L¬≤` convergence of `f_k x - g x` lifts to `Lp` norm
convergence of `f_k - g`.** If `‚ąę ‚ÄĖf_k x - g x‚ÄĖ¬≤ ‚Üí 0` then `‚ÄĖf_k - g‚ÄĖ ‚Üí 0`
in `Lp ‚Ąā 2 őľ`. -/
theorem tendsto_Lp_two_norm_sub_of_tendsto_integral_sq
    {őĪ : Type*} [MeasurableSpace őĪ] {őľ : MeasureTheory.Measure őĪ}
    {őĻ : Type*} {l : Filter őĻ}
    {f : őĻ ‚Üí Lp ‚Ąā 2 őľ} {g : Lp ‚Ąā 2 őľ}
    (h : Filter.Tendsto (fun i => ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2 ‚ąāőľ) l (nhds 0)) :
    Filter.Tendsto (fun i => ‚ÄĖf i - g‚ÄĖ) l (nhds 0) := by
  -- Reduce to `‚ÄĖf i - g‚ÄĖ¬≤ ‚Üí 0`.
  have h1 : Filter.Tendsto (fun i => ‚ÄĖf i - g‚ÄĖ ^ 2) l (nhds 0) := by
    have hEq : ‚ąÄ i, ‚ÄĖf i - g‚ÄĖ ^ 2 = ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2 ‚ąāőľ := by
      intro i
      rw [Lp_two_norm_sq_eq_integral_norm_sq (f i - g),
        integral_norm_sub_sq_eq_coeFn_sub]
    rw [show (fun i => ‚ÄĖf i - g‚ÄĖ ^ 2) = fun i => ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2 ‚ąāőľ
        from funext hEq]
    exact h
  -- `a¬≤ ‚Üí 0 ‚üĻ a ‚Üí 0` for non-negative `a`.
  rw [Metric.tendsto_nhds] at h1 ‚äĘ
  intro őĶ hőĶ
  have hőĶ2 : 0 < őĶ ^ 2 := pow_pos hőĶ 2
  filter_upwards [h1 (őĶ ^ 2) hőĶ2] with i hi
  simp only [Real.dist_eq, sub_zero] at hi ‚äĘ
  have habs : |‚ÄĖf i - g‚ÄĖ ^ 2| = ‚ÄĖf i - g‚ÄĖ ^ 2 := abs_of_nonneg (sq_nonneg _)
  rw [habs] at hi
  have hnn : 0 ‚Č§ ‚ÄĖf i - g‚ÄĖ := norm_nonneg _
  rw [abs_of_nonneg hnn]
  -- From ‚ÄĖx‚ÄĖ¬≤ < őĶ¬≤ + x ‚Č• 0 + őĶ > 0 ‚Üí ‚ÄĖx‚ÄĖ < őĶ.
  by_contra hContra
  push Not at hContra
  have hge : őĶ ^ 2 ‚Č§ ‚ÄĖf i - g‚ÄĖ ^ 2 :=
    pow_le_pow_left‚āÄ hőĶ.le hContra 2
  linarith

/-- **Continuity of squared `L¬≤` norm under strong-`L¬≤` convergence.**
If `‚ąę ‚ÄĖf_k x - g x‚ÄĖ¬≤ ‚Üí 0` then `‚ąę ‚ÄĖf_k x‚ÄĖ¬≤ ‚Üí ‚ąę ‚ÄĖg x‚ÄĖ¬≤`. -/
theorem tendsto_integral_norm_sq_of_tendsto_L2sub
    {őĪ : Type*} [MeasurableSpace őĪ] {őľ : MeasureTheory.Measure őĪ}
    {őĻ : Type*} {l : Filter őĻ}
    {f : őĻ ‚Üí Lp ‚Ąā 2 őľ} {g : Lp ‚Ąā 2 őľ}
    (h : Filter.Tendsto (fun i => ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2 ‚ąāőľ) l (nhds 0)) :
    Filter.Tendsto (fun i => ‚ąę x, ‚ÄĖf i x‚ÄĖ ^ 2 ‚ąāőľ) l
      (nhds (‚ąę x, ‚ÄĖg x‚ÄĖ ^ 2 ‚ąāőľ)) := by
  -- Rewrite both integrals via the Lp-norm identity.
  have h_fg : ‚ąÄ i, (‚ąę x, ‚ÄĖf i x‚ÄĖ ^ 2 ‚ąāőľ) = ‚ÄĖf i‚ÄĖ ^ 2 := fun i =>
    (Lp_two_norm_sq_eq_integral_norm_sq (f i)).symm
  have h_g : (‚ąę x, ‚ÄĖg x‚ÄĖ ^ 2 ‚ąāőľ) = ‚ÄĖg‚ÄĖ ^ 2 :=
    (Lp_two_norm_sq_eq_integral_norm_sq g).symm
  rw [show (fun i => ‚ąę x, ‚ÄĖf i x‚ÄĖ ^ 2 ‚ąāőľ) = fun i => ‚ÄĖf i‚ÄĖ ^ 2 from funext h_fg,
      h_g]
  -- `‚ÄĖf_k - g‚ÄĖ ‚Üí 0 ‚üĻ f_k ‚Üí g in Lp ‚üĻ ‚ÄĖf_k‚ÄĖ ‚Üí ‚ÄĖg‚ÄĖ ‚üĻ ‚ÄĖf_k‚ÄĖ¬≤ ‚Üí ‚ÄĖg‚ÄĖ¬≤`.
  have h_sub : Filter.Tendsto (fun i => ‚ÄĖf i - g‚ÄĖ) l (nhds 0) :=
    tendsto_Lp_two_norm_sub_of_tendsto_integral_sq h
  -- Upgrade to convergence of `f_k` to `g` in Lp.
  have h_toLp : Filter.Tendsto f l (nhds g) := by
    rw [Metric.tendsto_nhds] at h_sub ‚äĘ
    intro őĶ hőĶ
    filter_upwards [h_sub őĶ hőĶ] with i hi
    simpa [dist_eq_norm] using hi
  -- Continuity of the norm and squaring.
  have h_norm : Filter.Tendsto (fun i => ‚ÄĖf i‚ÄĖ) l (nhds ‚ÄĖg‚ÄĖ) :=
    (continuous_norm.tendsto g).comp h_toLp
  exact h_norm.pow 2

/-- **Zero-mode vanishes on Aubin‚ÄďLions-limit trajectories (Galerkin
per-level).** Convenience wrapper bundling `0 ‚ąČ sqgBox n` with
`mFourierCoeff_galerkinToLp_sqgBox_zero`. -/
lemma mFourierCoeff_galerkin_sqgBox_zero_any
    (n : ‚Ąē) (c : ‚Ü•(sqgBox n) ‚Üí ‚Ąā) :
    mFourierCoeff (galerkinToLp (sqgBox n) c) (0 : Fin 2 ‚Üí ‚Ą§) = 0 :=
  mFourierCoeff_galerkinToLp_sqgBox_zero n c

-- Torus/volume-specialized bridge lemmas.  These eliminate the
-- `{őĪ : Type*} [MeasurableSpace őĪ] {őľ}` inference cascade at call sites
-- inside the Route B conservation chain, which was causing whnf
-- heartbeat exhaustion even at 800k.

/-- **Torus-specialized `Lp ‚Ąā 2`-norm ‚ÜĒ integral bridge.** -/
theorem Lp_two_norm_sq_eq_integral_norm_sq_torus
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    ‚ÄĖf‚ÄĖ ^ 2 = ‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2 :=
  Lp_two_norm_sq_eq_integral_norm_sq f

/-- **Torus-specialized `‚ąę ‚ÄĖ(f - g) x‚ÄĖ¬≤ = ‚ąę ‚ÄĖf x - g x‚ÄĖ¬≤`.** -/
theorem integral_norm_sub_sq_eq_coeFn_sub_torus
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    (‚ąę x, ‚ÄĖ(f - g) x‚ÄĖ ^ 2) = ‚ąę x, ‚ÄĖf x - g x‚ÄĖ ^ 2 :=
  integral_norm_sub_sq_eq_coeFn_sub f g

/-- **Torus-specialized strong-L¬≤-sub ‚Üí Lp-norm-sub convergence.** -/
theorem tendsto_Lp_two_norm_sub_of_tendsto_integral_sq_torus
    {őĻ : Type*} {l : Filter őĻ}
    {f : őĻ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (h : Filter.Tendsto (fun i => ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2) l (nhds 0)) :
    Filter.Tendsto (fun i => ‚ÄĖf i - g‚ÄĖ) l (nhds 0) :=
  tendsto_Lp_two_norm_sub_of_tendsto_integral_sq h

/-- **Torus-specialized squared L¬≤ norm continuity.** -/
theorem tendsto_integral_norm_sq_of_tendsto_L2sub_torus
    {őĻ : Type*} {l : Filter őĻ}
    {f : őĻ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (h : Filter.Tendsto (fun i => ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2) l (nhds 0)) :
    Filter.Tendsto (fun i => ‚ąę x, ‚ÄĖf i x‚ÄĖ ^ 2) l
      (nhds (‚ąę x, ‚ÄĖg x‚ÄĖ ^ 2)) :=
  tendsto_integral_norm_sq_of_tendsto_L2sub h

set_option maxHeartbeats 400000 in
/-- **When the zero mode vanishes, `‚ąę ‚ÄĖf‚ÄĖ¬≤ = hsSeminormSq 0 f`.**
Localized helper so the capstone avoids heavy `rw` against
`l2_integral_eq_fourier_zero_sq_plus_hsSeminormSq_zero`. -/
theorem integral_norm_sq_eq_hsSeminormSq_zero_of_zero_fourier_zero
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (h : mFourierCoeff f (0 : Fin 2 ‚Üí ‚Ą§) = 0) :
    (‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2) = hsSeminormSq 0 f := by
  have hEq := l2_integral_eq_fourier_zero_sq_plus_hsSeminormSq_zero f
  rw [h, norm_zero, zero_pow (by norm_num : (2 : ‚Ąē) ‚Č† 0), zero_add] at hEq
  exact hEq

/-- **Per-level integral norm squared equals `hsSeminormSq 0`.**
Specialized form of `integral_norm_sq_eq_hsSeminormSq_zero_of_zero_fourier_zero`
applied to Galerkin trajectories on `sqgBox n`. -/
theorem integral_norm_sq_galerkinToLp_sqgBox
    (n : ‚Ąē) (c : ‚Ü•(sqgBox n) ‚Üí ‚Ąā) :
    (‚ąę x, ‚ÄĖgalerkinToLp (sqgBox n) c x‚ÄĖ ^ 2)
      = hsSeminormSq 0 (galerkinToLp (sqgBox n) c) :=
  integral_norm_sq_eq_hsSeminormSq_zero_of_zero_fourier_zero
    (galerkinToLp (sqgBox n) c)
    (mFourierCoeff_galerkin_sqgBox_zero_any n c)

set_option maxHeartbeats 800000 in
/-- **Strong-L¬≤ convergence lifts to `hsSeminormSq 0` convergence when
zero mode vanishes both on the sequence and on the limit.** The key
primitive used in Route B `l2Conservation`. -/
theorem tendsto_hsSeminormSq_of_tendsto_L2sub_torus
    {őĻ : Type*} {l : Filter őĻ}
    {f : őĻ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hL2 : Filter.Tendsto (fun i => ‚ąę x, ‚ÄĖf i x - g x‚ÄĖ ^ 2) l (nhds 0))
    (hZero_f : ‚ąÄ i, mFourierCoeff (f i) (0 : Fin 2 ‚Üí ‚Ą§) = 0)
    (hZero_g : mFourierCoeff g (0 : Fin 2 ‚Üí ‚Ą§) = 0) :
    Filter.Tendsto (fun i => hsSeminormSq 0 (f i)) l
      (nhds (hsSeminormSq 0 g)) := by
  have h_lim := tendsto_integral_norm_sq_of_tendsto_L2sub_torus hL2
  have h_eq_g : (‚ąę x, ‚ÄĖg x‚ÄĖ ^ 2) = hsSeminormSq 0 g :=
    integral_norm_sq_eq_hsSeminormSq_zero_of_zero_fourier_zero g hZero_g
  rw [h_eq_g] at h_lim
  exact h_lim.congr (fun i =>
    integral_norm_sq_eq_hsSeminormSq_zero_of_zero_fourier_zero (f i) (hZero_f i))

-- Un-bundled (raw) helpers ‚ÄĒ the theorems below take `nsub`, `őł_lim`,
-- `tendsto_L2_proof` as independent arguments rather than projecting
-- from a `HasAubinLionsExtraction` structure. Eliminating structure
-- projection removes the whnf bottleneck that previously caused
-- 1.6M-heartbeat timeouts in the bundled capstone.

/-- **Raw per-time strong-L¬≤ limit.** No `HasAubinLionsExtraction`. -/
theorem tendsto_integral_norm_sq_galerkinToLp_raw
    (nsub : ‚Ąē ‚Üí ‚Ąē)
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā))
    (őł_lim : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (tendsto_L2_proof : ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
      Filter.Tendsto
        (fun k : ‚Ąē =>
          ‚ąę x, ‚ÄĖgalerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) t) x
                - őł_lim t x‚ÄĖ ^ 2)
        Filter.atTop (nhds 0))
    (t : ‚ĄĚ) (ht : 0 ‚Č§ t) :
    Filter.Tendsto
      (fun k : ‚Ąē =>
        ‚ąę x, ‚ÄĖgalerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) t) x‚ÄĖ ^ 2)
      Filter.atTop (nhds (‚ąę x, ‚ÄĖőł_lim t x‚ÄĖ ^ 2)) :=
  tendsto_integral_norm_sq_of_tendsto_L2sub (tendsto_L2_proof t ht)

-- Diagnostic run revealed the whnf bottleneck: `Int.rec` unfolded 3.5M
-- times + `List.range.loop` 162k times during isDefEq on `sqgBox (nsub k)`
-- for symbolic `nsub k`.  `sqgBox n = Fintype.piFinset (Icc (-(n+1)) (n+1))
-- .erase 0` ‚ÄĒ Lean kept expanding integer ranges trying to reduce with a
-- symbolic index.  Mark `sqgBox` locally irreducible in this section so
-- isDefEq treats it atomically.
attribute [local irreducible] sqgBox

set_option maxHeartbeats 400000 in
/-- **Raw Route B `l2Conservation`.**  Uses
`tendsto_hsSeminormSq_of_tendsto_L2sub_torus` to get
`Tendsto (hsSeminormSq 0 ‚ąė f_k) ‚Üí hsSeminormSq 0 g` at both t and 0,
then `Tendsto.congr` against `hLevel` + `tendsto_nhds_unique`. -/
theorem l2Conservation_of_aubinLions_raw
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (nsub : ‚Ąē ‚Üí ‚Ąē)
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā))
    (őł_lim : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (tendsto_L2_proof : ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
      Filter.Tendsto
        (fun k : ‚Ąē =>
          ‚ąę x, ‚ÄĖgalerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) t) x
                - őł_lim t x‚ÄĖ ^ 2)
        Filter.atTop (nhds 0))
    (hLevel : ‚ąÄ n t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0 (galerkinToLp (sqgBox n) (őĪ n t))
        = hsSeminormSq 0 (galerkinToLp (sqgBox n) (őĪ n 0)))
    (hZero : ‚ąÄ t, 0 ‚Č§ t ‚Üí
      mFourierCoeff (őł_lim t) (0 : Fin 2 ‚Üí ‚Ą§) = 0) :
    ‚ąÄ t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0 (őł_lim t) = hsSeminormSq 0 (őł_lim 0) := by
  intro t ht
  -- Name the Galerkin sequences at times t and 0 so Lean treats them
  -- as atomic terms (avoids repeated HOU / instance resolution on the
  -- full `galerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) _)` expression).
  let Ft : ‚Ąē ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
    fun k => galerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) t)
  let F0 : ‚Ąē ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
    fun k => galerkinToLp (sqgBox (nsub k)) (őĪ (nsub k) 0)
  have h_zero_Ft : ‚ąÄ k : ‚Ąē, mFourierCoeff (Ft k) (0 : Fin 2 ‚Üí ‚Ą§) = 0 := by
    intro k
    -- `convert` bridges DecidableEq instance mismatch (helper auto-synthesizes
    -- `Fintype.decidablePiFintype`, raw's `[DecidableEq]` is `inst‚úĚ`; both are
    -- subsingleton-equal but not defeq under irreducible sqgBox).
    convert mFourierCoeff_galerkin_sqgBox_zero_any (nsub k) (őĪ (nsub k) t)
  have h_zero_F0 : ‚ąÄ k : ‚Ąē, mFourierCoeff (F0 k) (0 : Fin 2 ‚Üí ‚Ą§) = 0 := by
    intro k
    convert mFourierCoeff_galerkin_sqgBox_zero_any (nsub k) (őĪ (nsub k) 0)
  have h_L2_t : Filter.Tendsto
      (fun k : ‚Ąē => ‚ąę x, ‚ÄĖFt k x - őł_lim t x‚ÄĖ ^ 2)
      Filter.atTop (nhds 0) := tendsto_L2_proof t ht
  have h_L2_0 : Filter.Tendsto
      (fun k : ‚Ąē => ‚ąę x, ‚ÄĖF0 k x - őł_lim 0 x‚ÄĖ ^ 2)
      Filter.atTop (nhds 0) := tendsto_L2_proof 0 le_rfl
  -- Strong-L¬≤ ‚Üí hsSeminormSq Tendsto at both t and 0.
  have h_lim_t : Filter.Tendsto (fun k : ‚Ąē => hsSeminormSq 0 (Ft k))
      Filter.atTop (nhds (hsSeminormSq 0 (őł_lim t))) :=
    tendsto_hsSeminormSq_of_tendsto_L2sub_torus h_L2_t h_zero_Ft (hZero t ht)
  have h_lim_0 : Filter.Tendsto (fun k : ‚Ąē => hsSeminormSq 0 (F0 k))
      Filter.atTop (nhds (hsSeminormSq 0 (őł_lim 0))) :=
    tendsto_hsSeminormSq_of_tendsto_L2sub_torus h_L2_0 h_zero_F0 (hZero 0 le_rfl)
  -- Per-k equality `hsSeminormSq 0 (Ft k) = hsSeminormSq 0 (F0 k)` from hLevel.
  have h_pointwise : ‚ąÄ k : ‚Ąē,
      hsSeminormSq 0 (Ft k) = hsSeminormSq 0 (F0 k) :=
    fun k => hLevel (nsub k) t ht
  -- Transport h_lim_t's sequence via hLevel.
  have h_lim_t' : Filter.Tendsto (fun k : ‚Ąē => hsSeminormSq 0 (F0 k))
      Filter.atTop (nhds (hsSeminormSq 0 (őł_lim t))) :=
    h_lim_t.congr h_pointwise
  -- Limit uniqueness.
  exact tendsto_nhds_unique h_lim_t' h_lim_0

set_option maxHeartbeats 400000 in
/-- **Route B `l2Conservation` from Aubin‚ÄďLions (bundled wrapper).**
Thin wrapper around `l2Conservation_of_aubinLions_raw` ‚ÄĒ projects
`HasAubinLionsExtraction` at the single call site below. -/
theorem l2Conservation_of_aubinLions
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ)
    (hLevel : ‚ąÄ n t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0 (galerkinToLp (sqgBox n) (őĪ n t))
        = hsSeminormSq 0 (galerkinToLp (sqgBox n) (őĪ n 0))) :
    ‚ąÄ t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0 (ext.őł_lim t) = hsSeminormSq 0 (ext.őł_lim 0) := by
  refine l2Conservation_of_aubinLions_raw ext.nsub őĪ ext.őł_lim ?_ hLevel ?_
  ¬∑ -- `ext.tendsto_L2` may have a different `DecidableEq` instance than
    -- what the raw expects under `attribute [local irreducible] sqgBox`;
    -- `convert` bridges via subsingleton on the instance.
    convert ext.tendsto_L2
  ¬∑ intro t ht
    exact mFourierCoeff_aubinLionsLimit_zero ext
      (fun n ŌĄ _ => mFourierCoeff_galerkin_sqgBox_zero_any n (őĪ n ŌĄ)) ht

/-! ### ¬ß10.148 Route B capstone without the `hL2` hypothesis

Compose ¬ß10.147's `l2Conservation_of_aubinLions` with ¬ß10.144's
`SqgEvolutionAxioms.of_aubinLions` and ¬ß10.145's Route B headline
to produce an `SqgSolution` from only:

* the Aubin‚ÄďLions extraction witness,
* per-level Galerkin energy conservation (¬ß10.97),
* a velocity witness,
* `smoothInitialData` summability.

The `l2Conservation` hypothesis of ¬ß10.145 is now discharged internally.
This is the clean form of Route B: Item 1's analytical closure reduces
exactly to constructing a `HasAubinLionsExtraction` witness (the second
multi-session piece). -/

/-- **Route B `SqgEvolutionAxioms` without the `hL2` hypothesis.** -/
theorem SqgEvolutionAxioms.of_aubinLions_and_galerkin_energy
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ)
    (hLevel : ‚ąÄ n t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0 (galerkinToLp (sqgBox n) (őĪ n t))
        = hsSeminormSq 0 (galerkinToLp (sqgBox n) (őĪ n 0)))
    {u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hu : HasGalerkinLimitVelocity ext.őł_lim u) :
    SqgEvolutionAxioms ext.őł_lim :=
  SqgEvolutionAxioms.of_aubinLions ext
    (l2Conservation_of_aubinLions ext hLevel) hu

/-- **Route B headline: `SqgSolution` from Aubin‚ÄďLions + Galerkin
energy conservation + velocity witness + smooth initial data.** The
`hL2` hypothesis of ¬ß10.145 is now internally discharged from the
per-level Galerkin energy conservation (¬ß10.97). -/
theorem exists_sqgSolution_via_RouteB_from_galerkin_energy
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (ext : HasAubinLionsExtraction őł őĪ)
    (hLevel : ‚ąÄ n t, 0 ‚Č§ t ‚Üí
      hsSeminormSq 0 (galerkinToLp (sqgBox n) (őĪ n t))
        = hsSeminormSq 0 (galerkinToLp (sqgBox n) (őĪ n 0)))
    {u : Fin 2 ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (hu : HasGalerkinLimitVelocity ext.őł_lim u)
    (hSmooth : ‚ąÉ s : ‚ĄĚ, 2 < s ‚ąß
      Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (ext.őł_lim 0) n‚ÄĖ ^ 2)) :
    ‚ąÉ sol : SqgSolution, sol.őł = ext.őł_lim :=
  exists_sqgSolution_via_RouteB ext
    (l2Conservation_of_aubinLions ext hLevel) hu hSmooth

/-! ### ¬ß10.149 Per-mode compactness ingredients for `HasAubinLionsExtraction`

Classical Aubin‚ÄďLions extraction from uniformly bounded Galerkin
trajectories on ūĚēč¬≤ admits a Fourier-specific simplification: at each
mode `m ‚ąą ‚Ą§¬≤`, the time-dependent Fourier coefficient
`őĪ n t m` (extended by zero for `m ‚ąČ sqgBox n`) is uniformly bounded
(from the uniform `L¬≤` bound, ¬ß10.122‚Äď¬ß10.123) and uniformly
Lipschitz-in-time (from the uniform `H‚ĀĽ¬≤` bound on the time-derivative,
¬ß10.138, tested against individual Fourier modes).

Package these two inputs as `HasModeLipschitzFamily`.  Classical
Arzel√†‚ÄďAscoli applied mode-wise + Cantor diagonal across `‚Ą§¬≤ \ {0}`
(¬ß10.150) lifts this to a single subsequence converging pointwise-in-t
at every mode.  Parseval + dominated convergence on `‚Ąď¬≤(‚Ą§¬≤)` (¬ß10.151)
then lifts per-mode pointwise convergence to strong `L¬≤` convergence,
producing `HasAubinLionsExtraction`. -/

/-- **Per-mode uniform bound + per-mode Lipschitz witness.**
Packages the Fourier-side ingredients of classical compactness for
Aubin‚ÄďLions extraction on ūĚēč¬≤. -/
structure HasModeLipschitzFamily
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) where
  /-- Universal mode-value function extending `őĪ` to every mode.  Extended
  by zero outside `sqgBox n`.  Use `galerkinExtend (sqgBox n) (őĪ n t)` as
  the canonical choice. -/
  modeCoeff : ‚Ąē ‚Üí ‚ĄĚ ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā
  /-- Consistency with `őĪ` on `sqgBox n`. -/
  modeCoeff_eq : ‚ąÄ (n : ‚Ąē) (t : ‚ĄĚ) (m : Fin 2 ‚Üí ‚Ą§) (hm : m ‚ąą sqgBox n),
    modeCoeff n t m = őĪ n t ‚ü®m, hm‚ü©
  /-- Modes outside `sqgBox n` give `0`. -/
  modeCoeff_off : ‚ąÄ (n : ‚Ąē) (t : ‚ĄĚ) (m : Fin 2 ‚Üí ‚Ą§),
    m ‚ąČ sqgBox n ‚Üí modeCoeff n t m = 0
  /-- Per-mode uniform bound: `|modeCoeff n t m| ‚Č§ modeBound t` for every
  `(n, m)` at forward time `t ‚Č• 0`.  Weak (mode-independent) bound ‚ÄĒ
  in the SQG application, the uniform `L¬≤` bound from ¬ß10.123 combined
  with Parseval.  Restricted to `t ‚Č• 0` because the Galerkin ODE only
  runs forward. -/
  modeBound : ‚ĄĚ ‚Üí ‚ĄĚ
  modeBound_nonneg : ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ modeBound t
  modeBound_holds : ‚ąÄ (n : ‚Ąē) (t : ‚ĄĚ) (m : Fin 2 ‚Üí ‚Ą§),
    0 ‚Č§ t ‚Üí ‚ÄĖmodeCoeff n t m‚ÄĖ ‚Č§ modeBound t
  /-- Per-mode Lipschitz constant in time.  For SQG this comes from the
  `H‚ĀĽ¬≤` time-derivative bound (¬ß10.138) tested against `e^{-im¬∑x}`. -/
  modeLipschitz : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ
  modeLipschitz_nonneg : ‚ąÄ m : Fin 2 ‚Üí ‚Ą§, 0 ‚Č§ modeLipschitz m
  /-- Per-mode Lipschitz-in-time estimate.  The bound is uniform in `n`
  but the constant depends on `m` (typically `‚ąľ |m|¬≤` for an `H‚ĀĽ¬≤`
  time-derivative input). -/
  modeLipschitz_holds : ‚ąÄ (n : ‚Ąē) (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ),
    0 ‚Č§ s ‚Üí 0 ‚Č§ t ‚Üí
    ‚ÄĖmodeCoeff n t m - modeCoeff n s m‚ÄĖ ‚Č§ modeLipschitz m * |t - s|

/-- **Canonical `modeCoeff` for a Galerkin family: `galerkinExtend`.** -/
noncomputable def galerkinModeCoeff
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) :
    ‚Ąē ‚Üí ‚ĄĚ ‚Üí (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā :=
  fun n t m => galerkinExtend (sqgBox n) (őĪ n t) m

/-- **`galerkinModeCoeff` agrees with `őĪ` on `sqgBox n`.** -/
theorem galerkinModeCoeff_eq_of_mem
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā))
    (n : ‚Ąē) (t : ‚ĄĚ) (m : Fin 2 ‚Üí ‚Ą§) (hm : m ‚ąą sqgBox n) :
    galerkinModeCoeff őĪ n t m = őĪ n t ‚ü®m, hm‚ü© :=
  galerkinExtend_apply_of_mem _ _ hm

/-- **`galerkinModeCoeff` is zero off `sqgBox n`.** -/
theorem galerkinModeCoeff_eq_zero_of_not_mem
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā))
    (n : ‚Ąē) (t : ‚ĄĚ) (m : Fin 2 ‚Üí ‚Ą§) (hm : m ‚ąČ sqgBox n) :
    galerkinModeCoeff őĪ n t m = 0 :=
  galerkinExtend_apply_of_not_mem _ _ hm

/-! ### ¬ß10.150 `HasPerModeLimit`: output of Arzel√†‚ÄďAscoli + Cantor diagonal

Packages the OUTPUT of classical Arzel√†‚ÄďAscoli (mode-wise on `[0, T]`
for each `T > 0`) + Cantor diagonal across modes `m ‚ąą ‚Ą§¬≤ \ {0}`:
a single subsequence `nsub` and a per-mode limit function
`b : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ ‚Üí ‚Ąā` such that for every mode `m` and every
forward time `t ‚Č• 0`,

  `galerkinExtend (sqgBox (nsub k)) (őĪ (nsub k) t) m ‚Üí b m t`  as `k ‚Üí ‚ąě`.

The structural reduction: given `HasModeLipschitzFamily őĪ` (¬ß10.149),
classical Arzel√†‚ÄďAscoli produces `HasPerModeLimit őĪ`.  This predicate
isolates the compactness-extraction step as a named hypothesis. -/

/-- **Per-mode limit along an extracted subsequence.** -/
structure HasPerModeLimit
    (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) where
  /-- Extracted subsequence indices. -/
  nsub : ‚Ąē ‚Üí ‚Ąē
  /-- Subsequence is strictly increasing. -/
  strictMono : StrictMono nsub
  /-- Per-mode limit function. -/
  b : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ ‚Üí ‚Ąā
  /-- Per-mode pointwise-in-t convergence along the subsequence. -/
  tendsto_modeCoeff : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (t : ‚ĄĚ), 0 ‚Č§ t ‚Üí
    Filter.Tendsto
      (fun k : ‚Ąē => galerkinExtend (sqgBox (nsub k)) (őĪ (nsub k) t) m)
      Filter.atTop (nhds (b m t))

/-- **Zero-mode triviality for per-mode limits.**  Since `0 ‚ąČ sqgBox n`
for every `n`, the per-mode limit at the zero mode is automatically
`0`. -/
theorem HasPerModeLimit.b_zero_mode
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (per : HasPerModeLimit őĪ)
    {t : ‚ĄĚ} (ht : 0 ‚Č§ t) :
    per.b (0 : Fin 2 ‚Üí ‚Ą§) t = 0 := by
  have h := per.tendsto_modeCoeff (0 : Fin 2 ‚Üí ‚Ą§) t ht
  -- Sequence is constantly zero since 0 ‚ąČ sqgBox (nsub k).
  have h_const : ‚ąÄ k : ‚Ąē,
      galerkinExtend (sqgBox (per.nsub k)) (őĪ (per.nsub k) t)
        (0 : Fin 2 ‚Üí ‚Ą§) = 0 :=
    fun k => galerkinExtend_apply_of_not_mem _ _ (zero_not_mem_sqgBox _)
  have h_eq : (fun k : ‚Ąē =>
      galerkinExtend (sqgBox (per.nsub k)) (őĪ (per.nsub k) t)
        (0 : Fin 2 ‚Üí ‚Ą§)) = fun _ => (0 : ‚Ąā) :=
    funext h_const
  rw [h_eq] at h
  exact tendsto_nhds_unique h tendsto_const_nhds

/-! ### ¬ß10.151 Parseval synthesis: `HasPerModeLimit` ‚Üí `HasAubinLionsExtraction`

Given per-mode pointwise convergence (`HasPerModeLimit`) + uniform ‚Ąď¬≤
bound (Fatou gives ‚Ąď¬≤-summability of the limit modes) + strong-L¬≤
convergence of the Fourier-truncation to the initial data, Parseval
+ dominated convergence lifts the per-mode limit to strong L¬≤
convergence of the full Galerkin trajectory.

This step requires two extra analytical inputs beyond `HasPerModeLimit`:

1. A Fourier-synthesis witness: the per-mode limit function `b ¬∑ t`
   yields an honest `Lp ‚Ąā 2` element `őł_lim t` for every `t ‚Č• 0`.
2. Strong-L¬≤ convergence of the extracted sequence to that `őł_lim`,
   discharged from per-mode convergence + uniform ‚Ąď¬≤ control.

Package both as `HasFourierSynthesis`; the capstone then builds
`HasAubinLionsExtraction` from the combined hypotheses. -/

/-- **Fourier synthesis of the per-mode limit.**  Given
`HasPerModeLimit őĪ`, a synthesis witness provides the `Lp`-valued
limit trajectory + strong-L¬≤ convergence to it.  In the non-zero
case this requires classical dominated-convergence-on-‚Ąď¬≤ input;
we package it as a named hypothesis. -/
structure HasFourierSynthesis
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (per : HasPerModeLimit őĪ)
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) where
  /-- The `Lp`-valued limit trajectory. -/
  őł_lim : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))
  /-- Initial-data match: at `t = 0` the limit is the provided `őł`. -/
  init_eq : őł_lim 0 = őł
  /-- Fourier-coefficient match: the `Lp` element's coefficients coincide
  with the per-mode limit. -/
  mFourierCoeff_eq : ‚ąÄ (m : Fin 2 ‚Üí ‚Ą§) (t : ‚ĄĚ), 0 ‚Č§ t ‚Üí
    mFourierCoeff (őł_lim t) m = per.b m t
  /-- Strong-L¬≤ pointwise-in-t convergence of the extracted Galerkin
  sequence to `őł_lim`. -/
  tendsto_L2 : ‚ąÄ (t : ‚ĄĚ), 0 ‚Č§ t ‚Üí
    Filter.Tendsto
      (fun k : ‚Ąē =>
        ‚ąę x, ‚ÄĖgalerkinToLp (sqgBox (per.nsub k)) (őĪ (per.nsub k) t) x
              - őł_lim t x‚ÄĖ ^ 2)
      Filter.atTop (nhds 0)

/-- **Route B Aubin‚ÄďLions extraction from per-mode limit + Fourier
synthesis witness.**  Assembles `HasAubinLionsExtraction őł őĪ` from
a `HasPerModeLimit` witness + a `HasFourierSynthesis` witness. -/
noncomputable def HasAubinLionsExtraction.ofPerModeLimit
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    {őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))}
    (per : HasPerModeLimit őĪ)
    (syn : HasFourierSynthesis per őł) :
    HasAubinLionsExtraction őł őĪ where
  nsub := per.nsub
  strictMono := per.strictMono
  őł_lim := syn.őł_lim
  init_eq := syn.init_eq
  tendsto_L2 := syn.tendsto_L2

/-! ### ¬ß10.152 Discharge `HasModeLipschitzFamily` for the SQG Galerkin family

Constructs `HasModeLipschitzFamily őĪ` from the uniform-`L¬≤` per-mode
bound (¬ß10.123's `sq_galerkinExtend_le_L2Sq`) + a per-mode Lipschitz
witness (classically from the uniform `H‚ĀĽ¬≤` bound ¬ß10.138 integrated
against the ODE `dőĪ/dt = galerkinRHS` via `‚ąę_s^t`, producing
`modeLipschitz m ‚ąľ ‚ąöK ¬∑ (|m|¬≤)`).

The Lipschitz witness is taken as a named hypothesis here ‚ÄĒ its
discharge from ¬ß10.138 + ¬ß10.116's Galerkin ODE existence is the
final execution step.  The structural chain through ¬ß10.149‚Äď¬ß10.152
reduces Item 1's analytical closure to exactly this single explicit
per-mode integration. -/

/-- **SQG Galerkin `HasModeLipschitzFamily` discharge.**  Takes the
per-mode uniform `L¬≤` bound (via ¬ß10.123's energy-preservation
hypothesis) + a per-mode Lipschitz bound (from integrating the
`H‚ĀĽ¬≤`-controlled time-derivative against `e^{-im¬∑x}`), produces a
`HasModeLipschitzFamily` witness for `őĪ`. -/
noncomputable def HasModeLipschitzFamily.ofSqgGalerkinBounds
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (őł‚āÄ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hEnergy : ‚ąÄ n t, 0 ‚Č§ t ‚Üí
      (‚ąĎ m : ‚Ü•(sqgBox n), ‚ÄĖőĪ n t m‚ÄĖ ^ 2)
        = ‚ąĎ m : ‚Ü•(sqgBox n), ‚ÄĖfourierRestrict n őł‚āÄ m‚ÄĖ ^ 2)
    (L : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ)
    (hL_nonneg : ‚ąÄ m : Fin 2 ‚Üí ‚Ą§, 0 ‚Č§ L m)
    (hL_holds : ‚ąÄ (n : ‚Ąē) (m : Fin 2 ‚Üí ‚Ą§) (s t : ‚ĄĚ), 0 ‚Č§ s ‚Üí 0 ‚Č§ t ‚Üí
      ‚ÄĖgalerkinExtend (sqgBox n) (őĪ n t) m
          - galerkinExtend (sqgBox n) (őĪ n s) m‚ÄĖ ‚Č§ L m * |t - s|) :
    HasModeLipschitzFamily őĪ where
  modeCoeff := galerkinModeCoeff őĪ
  modeCoeff_eq := galerkinModeCoeff_eq_of_mem őĪ
  modeCoeff_off := galerkinModeCoeff_eq_zero_of_not_mem őĪ
  modeBound := fun _ => Real.sqrt (‚ąę x, ‚ÄĖőł‚āÄ x‚ÄĖ ^ 2)
  modeBound_nonneg := fun _ => Real.sqrt_nonneg _
  modeBound_holds := by
    intro n t m ht
    -- Produce the bound in a form that uses the same DecidableEq
    -- instance as `sq_galerkinExtend_le_L2Sq` (i.e. the theorem's
    -- `[DecidableEq]` parameter), then `convert` bridges to the
    -- auto-synthesized instance at the `galerkinModeCoeff` call site.
    have h_sq := sq_galerkinExtend_le_L2Sq őł‚āÄ n (őĪ n) (hEnergy n) ht m
    have h_norm_nn : (0 : ‚ĄĚ) ‚Č§ ‚ÄĖgalerkinExtend (sqgBox n) (őĪ n t) m‚ÄĖ :=
      norm_nonneg _
    have h_bound : ‚ÄĖgalerkinExtend (sqgBox n) (őĪ n t) m‚ÄĖ
        ‚Č§ Real.sqrt (‚ąę x, ‚ÄĖőł‚āÄ x‚ÄĖ ^ 2) := by
      calc ‚ÄĖgalerkinExtend (sqgBox n) (őĪ n t) m‚ÄĖ
          = Real.sqrt (‚ÄĖgalerkinExtend (sqgBox n) (őĪ n t) m‚ÄĖ ^ 2) :=
            (Real.sqrt_sq h_norm_nn).symm
        _ ‚Č§ Real.sqrt (‚ąę x, ‚ÄĖőł‚āÄ x‚ÄĖ ^ 2) := Real.sqrt_le_sqrt h_sq
    show ‚ÄĖgalerkinModeCoeff őĪ n t m‚ÄĖ ‚Č§ Real.sqrt (‚ąę x, ‚ÄĖőł‚āÄ x‚ÄĖ ^ 2)
    unfold galerkinModeCoeff
    convert h_bound
  modeLipschitz := L
  modeLipschitz_nonneg := hL_nonneg
  modeLipschitz_holds := by
    intro n m s t hs ht
    show ‚ÄĖgalerkinModeCoeff őĪ n t m - galerkinModeCoeff őĪ n s m‚ÄĖ
      ‚Č§ L m * |t - s|
    unfold galerkinModeCoeff
    -- `convert` bridges DecidableEq instance mismatch between
    -- `hL_holds`'s explicit instance and the auto-synthesized
    -- `Fintype.decidablePiFintype` at this call site.
    convert hL_holds n m s t hs ht

/-! ### ¬ß10.153 Per-mode Lipschitz from `H‚ĀĽ¬≤` bound + Galerkin ODE (FTC)

Derives the per-mode Lipschitz constant `L m = ‚ąöK ¬∑ őõ¬≤(m)` for
`HasModeLipschitzFamily.ofSqgGalerkinBounds` (¬ß10.152), via:

* **¬ß10.153.A** Per-mode upper bound on `galerkinRHS` at non-zero
  modes from the summable `H‚ĀĽ¬≤` tsum.
* **¬ß10.153.B** Mean-Value Theorem (via `norm_image_sub_le_of_norm_deriv_right_le_segment`)
  on the per-mode trajectory `ŌĄ ‚Ü¶ galerkinExtend S (őĪ ŌĄ) m`, turning
  the upper bound on the derivative into a Lipschitz bound on the
  trajectory.
-/

/-- **¬ß10.153.A** Per-mode upper bound on `galerkinRHS` at non-zero
modes.  If `‚ąĎ' m, (őõ‚ĀĽ¬≤ m)¬≤ ¬∑ ‚ÄĖgalerkinRHS m‚ÄĖ¬≤ ‚Č§ K` then
`‚ÄĖgalerkinRHS m‚ÄĖ ‚Č§ ‚ąöK ¬∑ őõ¬≤(m)` for every `m ‚Č† 0`.  (For `m = 0` the
bound holds trivially when `0 ‚ąČ S` but is not asserted here.) -/
theorem galerkinRHS_mode_bound_of_HsNeg2Bound_ne_zero
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) (K : ‚ĄĚ) (hK : 0 ‚Č§ K)
    (hBound : GalerkinRHSHsNegSqBound S c 2 K)
    {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚Č† 0) :
    ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ
      ‚Č§ Real.sqrt K * fracDerivSymbol 2 m := by
  obtain ‚ü®hSumm, hTsum‚ü© := hBound
  have hTerm : (fracDerivSymbol (-2) m) ^ 2
      * ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2 ‚Č§ K := by
    have hLe := hSumm.le_tsum m
      (fun _ _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))
    exact le_trans hLe hTsum
  have hFDS2_pos : 0 < fracDerivSymbol 2 m := fracDerivSymbol_pos 2 hm
  have hFDS2_nn : 0 ‚Č§ fracDerivSymbol 2 m := le_of_lt hFDS2_pos
  have hSqInv : (fracDerivSymbol (-2) m) ^ 2 * (fracDerivSymbol 2 m) ^ 2 = 1 :=
    fracDerivSymbol_sq_neg_inv hm
  have hNormSq : ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2
      ‚Č§ K * (fracDerivSymbol 2 m) ^ 2 := by
    calc ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2
        = ((fracDerivSymbol (-2) m) ^ 2 * (fracDerivSymbol 2 m) ^ 2)
            * ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2 := by rw [hSqInv]; ring
      _ = (fracDerivSymbol (-2) m) ^ 2
            * ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2
            * (fracDerivSymbol 2 m) ^ 2 := by ring
      _ ‚Č§ K * (fracDerivSymbol 2 m) ^ 2 :=
          mul_le_mul_of_nonneg_right hTerm (sq_nonneg _)
  -- Take square roots.
  have hNn : 0 ‚Č§ ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ := norm_nonneg _
  have hSqrtMul : Real.sqrt (K * (fracDerivSymbol 2 m) ^ 2)
      = Real.sqrt K * fracDerivSymbol 2 m := by
    rw [Real.sqrt_mul hK, Real.sqrt_sq hFDS2_nn]
  have hAbsSq : Real.sqrt (‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2)
      = ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ := Real.sqrt_sq hNn
  calc ‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ
      = Real.sqrt (‚ÄĖgalerkinRHS S (galerkinExtend S c) m‚ÄĖ ^ 2) := hAbsSq.symm
    _ ‚Č§ Real.sqrt (K * (fracDerivSymbol 2 m) ^ 2) := Real.sqrt_le_sqrt hNormSq
    _ = Real.sqrt K * fracDerivSymbol 2 m := hSqrtMul

/-- **¬ß10.153.B** Mean-Value Theorem on the per-mode Galerkin
trajectory: given a uniform upper bound on the mode's time-derivative
over `[s, t]`, the coefficient value changes by at most bound √ó time
interval. -/
theorem galerkinExtend_mode_lipschitz_of_ODE_bound
    (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (m : Fin 2 ‚Üí ‚Ą§) (M : ‚ĄĚ)
    {s t : ‚ĄĚ} (hst : s ‚Č§ t)
    (hDeriv : ‚ąÄ ŌĄ ‚ąą Set.Ico s t,
      HasDerivWithinAt (fun ŌÉ => galerkinExtend S (őĪ ŌÉ) m)
        (galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m) (Set.Ici ŌĄ) ŌĄ)
    (hCont : ContinuousOn (fun ŌÉ => galerkinExtend S (őĪ ŌÉ) m) (Set.Icc s t))
    (hBound : ‚ąÄ ŌĄ ‚ąą Set.Ico s t,
      ‚ÄĖgalerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m‚ÄĖ ‚Č§ M) :
    ‚ÄĖgalerkinExtend S (őĪ t) m - galerkinExtend S (őĪ s) m‚ÄĖ ‚Č§ M * (t - s) := by
  have h := norm_image_sub_le_of_norm_deriv_right_le_segment
    (f := fun ŌÉ => galerkinExtend S (őĪ ŌÉ) m)
    (f' := fun ŌĄ => galerkinRHS S (galerkinExtend S (őĪ ŌĄ)) m)
    (C := M) hCont hDeriv hBound t ‚ü®hst, le_refl t‚ü©
  exact h

