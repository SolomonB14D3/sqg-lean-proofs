                (galerkinRHS (sqgBox n)
                  (galerkinExtend (sqgBox n) (őĪ n ŌĄ)) m)
                (Set.Ici ŌĄ) ŌĄ := fun ŌĄ hŌĄ =>
            hDeriv n ŌĄ (le_trans hs hŌĄ.1) m hmS
