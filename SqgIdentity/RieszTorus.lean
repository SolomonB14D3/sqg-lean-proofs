  ¬∑ exact hsum.mul_left _

/-- **Heat-smoothed S‚āÄ‚āĀ tight integrated L¬≤ bound.** -/
theorem heat_smoothed_sqgStrain_01_L2_integrated_tight {t : ‚ĄĚ} (ht : 0 < t)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
