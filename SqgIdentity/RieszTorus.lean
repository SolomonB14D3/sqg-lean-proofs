theorem tendsto_integral_norm_sq_galerkin_sub_őłLim_of_tsum
    {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
