import Mathlib
import SqgIdentity.Basic

/-!
# Riesz transforms on the unit torus `ūĚēčŠĶą` via Fourier multipliers

This file develops the part of the Riesz-transform library needed for the
integrated form of Theorem 2 of the paper on the torus, bypassing general
Calder√≥n‚ÄďZygmund singular-integral theory. The key observation is that on
the torus the Riesz transform `R_j` has a bounded Fourier multiplier
symbol

    m_j(n) = -i ¬∑ n_j / ‚ÄĖn‚ÄĖ    (for n ‚Č† 0),

so its L¬≤-theory falls out of Parseval.

## Main contents

* `latticeNorm n := sqrt(ő£ n‚Īľ¬≤)` with basic positivity and support lemmas.
* `rieszSymbol j n = -i n‚Īľ/‚ÄĖn‚ÄĖ` (off zero), with `‚ÄĖm_j(n)‚ÄĖ ‚Č§ 1` and the
  Pythagorean identity `ő£‚Īľ ‚ÄĖm_j(n)‚ÄĖ¬≤ = 1` for `n ‚Č† 0`.
* `sqg_velocity_symbol_isometry` ‚ÄĒ on `ūĚēč¬≤`, for any `z ‚ąą ‚Ąā`,
  `‚ÄĖm‚āā¬∑z‚ÄĖ¬≤ + ‚ÄĖ(-m‚āĀ)¬∑z‚ÄĖ¬≤ = ‚ÄĖz‚ÄĖ¬≤` when `n ‚Č† 0`.
* `L2_contractive_of_bounded_symbol` ‚ÄĒ `‚ÄĖm‚ÄĖ‚ąě ‚Č§ 1` + Parseval implies
  L¬≤ contractivity for any Fourier multiplier.
* `riesz_L2_contractive` ‚ÄĒ `‚ÄĖR_j f‚ÄĖ_{L¬≤(ūĚēčŠĶą)} ‚Č§ ‚ÄĖf‚ÄĖ_{L¬≤(ūĚēčŠĶą)}`.
* `sqg_velocity_L2_isometry` ‚ÄĒ `‚ÄĖu‚āĀ‚ÄĖ¬≤_{L¬≤} + ‚ÄĖu‚āā‚ÄĖ¬≤_{L¬≤} = ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}`
  for the SQG velocity of a zero-mean scalar `őł` on `ūĚēč¬≤`.
* `fracDerivSymbol s n = ‚ÄĖn‚ÄĖ^s` (off zero) ‚ÄĒ symbol of `(-őĒ)^{s/2}`.
* `hsSeminormSq s f = ő£ ‚ÄĖn‚ÄĖ^{2s}¬∑‚ÄĖfŐā(n)‚ÄĖ¬≤` ‚ÄĒ the homogeneous ŠłĘňĘ seminorm
  squared on `L¬≤(ūĚēčŠĶą)`, identified with `‚ÄĖ(-őĒ)^{s/2} f‚ÄĖ¬≤_{L¬≤}` via
  the Fourier multiplier.
* `sqg_selection_rule_Hs1` ‚ÄĒ ŠłĘ¬Ļ form of Theorem 2 on the torus.

All statements are driven by `hasSum_sq_mFourierCoeff` (Parseval); no
singular-integral machinery is invoked.
-/

namespace SqgIdentity

open Complex Finset MeasureTheory

/-! ### The lattice norm `‚ÄĖn‚ÄĖ = ‚ąö(ő£‚Īľ n‚Īľ¬≤)` -/

/-- The Euclidean norm on the integer lattice, extended by real arithmetic
(so its square is `ő£‚Īľ (n‚Īľ)¬≤`). -/
noncomputable def latticeNorm {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) : ‚ĄĚ :=
  Real.sqrt (‚ąĎ j, (n j : ‚ĄĚ) ^ 2)

lemma latticeNorm_nonneg {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    0 ‚Č§ latticeNorm n :=
  Real.sqrt_nonneg _

lemma latticeNorm_sq {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    (latticeNorm n) ^ 2 = ‚ąĎ j, (n j : ‚ĄĚ) ^ 2 := by
  unfold latticeNorm
  have h : 0 ‚Č§ ‚ąĎ j, (n j : ‚ĄĚ) ^ 2 := Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  rw [Real.sq_sqrt h]

/-- The lattice norm vanishes exactly at `n = 0`. -/
lemma latticeNorm_eq_zero_iff {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    latticeNorm n = 0 ‚ÜĒ n = 0 := by
  constructor
  ¬∑ intro h
    have hsq : ‚ąĎ j, (n j : ‚ĄĚ) ^ 2 = 0 := by
      have := congrArg (¬∑ ^ 2) h
      simpa [latticeNorm_sq] using this
    have hall : ‚ąÄ j ‚ąą (Finset.univ : Finset d), (n j : ‚ĄĚ) ^ 2 = 0 :=
      (Finset.sum_eq_zero_iff_of_nonneg (fun _ _ => sq_nonneg _)).mp hsq
    funext j
    have hj : (n j : ‚ĄĚ) ^ 2 = 0 := hall j (Finset.mem_univ j)
    have : (n j : ‚ĄĚ) = 0 := by
      have := sq_eq_zero_iff.mp hj
      exact this
    exact_mod_cast this
  ¬∑ rintro rfl
    unfold latticeNorm
    simp

/-- For `n ‚Č† 0`, the lattice norm is strictly positive. -/
lemma latticeNorm_pos {d : Type*} [Fintype d] {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    0 < latticeNorm n :=
  lt_of_le_of_ne (latticeNorm_nonneg n)
    (fun h => hn ((latticeNorm_eq_zero_iff n).mp h.symm))

/-- Componentwise bound: `(n_j)¬≤ ‚Č§ ő£ (n_i)¬≤ = ‚ÄĖn‚ÄĖ¬≤`. -/
lemma sq_le_latticeNorm_sq {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) (j : d) :
    (n j : ‚ĄĚ) ^ 2 ‚Č§ (latticeNorm n) ^ 2 := by
  rw [latticeNorm_sq]
  exact Finset.single_le_sum (f := fun i : d => ((n i : ‚ĄĚ)) ^ 2)
    (fun _ _ => sq_nonneg _) (Finset.mem_univ j)

/-- **Integer-lattice lower bound.** Every nonzero integer lattice point
has Euclidean norm at least `1`, because the sum of squares of integers
not all zero is at least `1`. -/
lemma latticeNorm_ge_one_of_ne_zero {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) : 1 ‚Č§ latticeNorm n := by
  -- Pick `j` with `n j ‚Č† 0`, then `(n j : ‚ĄĚ)¬≤ ‚Č• 1` from integrality,
  -- and `ő£_i (n_i : ‚ĄĚ)¬≤ ‚Č• (n j : ‚ĄĚ)¬≤ ‚Č• 1`.
  have hexj : ‚ąÉ j, n j ‚Č† 0 := by
    by_contra habs
    exact hn (funext fun j => not_not.mp (fun hnot => habs ‚ü®j, hnot‚ü©))
  obtain ‚ü®j, hj‚ü© := hexj
  have hsq_ge_one : (1 : ‚ĄĚ) ‚Č§ (n j : ‚ĄĚ) ^ 2 := by
    have hnz : (n j : ‚ĄĚ) ‚Č† 0 := by exact_mod_cast hj
    have habs : (1 : ‚ĄĚ) ‚Č§ |(n j : ‚ĄĚ)| := by
      have hZ : (1 : ‚Ą§) ‚Č§ |n j| := Int.one_le_abs hj
      have : ((1 : ‚Ą§) : ‚ĄĚ) ‚Č§ ((|n j| : ‚Ą§) : ‚ĄĚ) := by exact_mod_cast hZ
      simpa [Int.cast_abs] using this
    have h0 : 0 ‚Č§ |(n j : ‚ĄĚ)| := abs_nonneg _
    nlinarith [habs, h0, sq_abs (n j : ‚ĄĚ)]
  have hle : (1 : ‚ĄĚ) ‚Č§ (latticeNorm n) ^ 2 := by
    calc (1 : ‚ĄĚ) ‚Č§ (n j : ‚ĄĚ) ^ 2 := hsq_ge_one
      _ ‚Č§ (latticeNorm n) ^ 2 := sq_le_latticeNorm_sq n j
  have hLpos : 0 ‚Č§ latticeNorm n := latticeNorm_nonneg n
  nlinarith [hle, hLpos, sq_nonneg (latticeNorm n - 1), sq_nonneg (latticeNorm n + 1)]

/-! ### The Riesz symbol `m_j(n) = -i n‚Īľ/‚ÄĖn‚ÄĖ` -/

/-- The Riesz transform symbol on `ūĚēčŠĶą`:

    m_j(n) = -i ¬∑ n_j / ‚ÄĖn‚ÄĖ    for n ‚Č† 0,    m_j(0) = 0. -/
noncomputable def rieszSymbol {d : Type*} [Fintype d]
    (j : d) (n : d ‚Üí ‚Ą§) : ‚Ąā :=
  if n = 0 then 0 else -I * ((n j : ‚ĄĚ) : ‚Ąā) / ((latticeNorm n : ‚ĄĚ) : ‚Ąā)

@[simp]
lemma rieszSymbol_zero {d : Type*} [Fintype d] (j : d) :
    rieszSymbol j (0 : d ‚Üí ‚Ą§) = 0 := by
  simp [rieszSymbol]

/-- Norm of the Riesz symbol: for `n ‚Č† 0`, `|m_j(n)| = |n_j| / ‚ÄĖn‚ÄĖ`. -/
lemma norm_rieszSymbol {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (j : d) :
    ‚ÄĖrieszSymbol j n‚ÄĖ = |(n j : ‚ĄĚ)| / latticeNorm n := by
  have hpos : 0 < latticeNorm n := latticeNorm_pos hn
  unfold rieszSymbol
  rw [if_neg hn]
  rw [norm_div, norm_mul, norm_neg, Complex.norm_I, one_mul]
  congr 1
  ¬∑ rw [Complex.norm_real, Real.norm_eq_abs]
  ¬∑ rw [Complex.norm_real, Real.norm_eq_abs, abs_of_pos hpos]

/-- **Pointwise bound**: every Riesz symbol satisfies `|m_j(n)| ‚Č§ 1`.
Combined with Parseval, this gives L¬≤-contractivity of `R_j`. -/
theorem rieszSymbol_norm_le_one {d : Type*} [Fintype d]
    (j : d) (n : d ‚Üí ‚Ą§) : ‚ÄĖrieszSymbol j n‚ÄĖ ‚Č§ 1 := by
  by_cases hn : n = 0
  ¬∑ simp [rieszSymbol, hn]
  ¬∑ have hpos : 0 < latticeNorm n := latticeNorm_pos hn
    rw [norm_rieszSymbol hn, div_le_iff‚āÄ hpos, one_mul]
    rw [‚Üź Real.sqrt_sq_eq_abs]
    have hle : ((n j : ‚ĄĚ)) ^ 2 ‚Č§ ‚ąĎ i, (n i : ‚ĄĚ) ^ 2 :=
      Finset.single_le_sum (f := fun i : d => ((n i : ‚ĄĚ)) ^ 2)
        (fun _ _ => sq_nonneg _) (Finset.mem_univ j)
    calc Real.sqrt ((n j : ‚ĄĚ) ^ 2)
        ‚Č§ Real.sqrt (‚ąĎ i, (n i : ‚ĄĚ) ^ 2) := Real.sqrt_le_sqrt hle
      _ = latticeNorm n := rfl

/-- **Pythagorean sum identity**: `ő£‚Īľ |m_j(n)|¬≤ = 1` for `n ‚Č† 0`.
This is the identity that makes the Riesz-vector `R = (R_1, ‚Ä¶, R_d)` a
partial isometry on mean-zero L¬≤ functions. -/
theorem rieszSymbol_sum_sq {d : Type*} [Fintype d] {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ąĎ j, ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 = 1 := by
  have hpos : 0 < latticeNorm n := latticeNorm_pos hn
  have hne : (latticeNorm n) ^ 2 ‚Č† 0 := ne_of_gt (pow_pos hpos 2)
  have hterm : ‚ąÄ j, ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 = (n j : ‚ĄĚ) ^ 2 / (latticeNorm n) ^ 2 := by
    intro j
    rw [norm_rieszSymbol hn, div_pow, sq_abs]
  simp_rw [hterm]
  rw [‚Üź Finset.sum_div, ‚Üź latticeNorm_sq]
  exact div_self hne

/-- Compact form of the Riesz symbol off zero, useful for algebraic
rewrites (no `if` branch in sight). -/
lemma rieszSymbol_of_ne_zero {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (j : d) :
    rieszSymbol j n = -I * ((n j : ‚ĄĚ) : ‚Ąā) / ((latticeNorm n : ‚ĄĚ) : ‚Ąā) := by
  simp [rieszSymbol, hn]

/-- **Complex-valued Riesz identity**: `ő£‚Īľ (m_j(n))¬≤ = -1` for `n ‚Č† 0`.

This is the Fourier-multiplier form of the operator identity
`ő£‚Īľ R_j¬≤ = -Id` on zero-mean functions, i.e., `-őĒ = -ő£‚Īľ ‚ąā_j¬≤` expressed
via the factorisation `‚ąā_j = (-őĒ)^{1/2}¬∑R_j`. Note the sign vs. the
norm Pythagorean identity: `|m_j|¬≤ = (-n_j¬≤)/‚ÄĖn‚ÄĖ¬≤ ¬∑ (-1)` absorbs the
`-I¬≤ = 1` into absolute value, but the raw complex square keeps it. -/
theorem rieszSymbol_sum_sq_complex {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ąĎ j, (rieszSymbol j n) ^ 2 = -1 := by
  have hpos : 0 < latticeNorm n := latticeNorm_pos hn
  have hne : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast ne_of_gt hpos
  have hne2 : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2 ‚Č† 0 := pow_ne_zero 2 hne
  -- Key: each squared term, times ‚ÄĖn‚ÄĖ¬≤, equals -n_j¬≤
  have hterm : ‚ąÄ j, (rieszSymbol j n) ^ 2 * ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2
             = -(((n j : ‚ĄĚ) : ‚Ąā) ^ 2) := by
    intro j
    rw [rieszSymbol_of_ne_zero hn]
    field_simp
    have hI : Complex.I ^ 2 = -1 := Complex.I_sq
    linear_combination ((n j : ‚ĄĚ) : ‚Ąā) ^ 2 * hI
  -- Sum the per-j equalities and divide by ‚ÄĖn‚ÄĖ¬≤
  have hsum_real : ‚ąĎ j, ((n j : ‚ĄĚ) : ‚Ąā) ^ 2 = ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2 := by
    have h1 : (‚ąĎ j, ((n j : ‚ĄĚ) : ‚Ąā) ^ 2)
            = ((‚ąĎ j, ((n j : ‚ĄĚ)) ^ 2 : ‚ĄĚ) : ‚Ąā) := by push_cast; rfl
    rw [h1, ‚Üź latticeNorm_sq]
    push_cast; rfl
  have hmul : (‚ąĎ j, (rieszSymbol j n) ^ 2) * ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2
           = (-1) * ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2 := by
    rw [Finset.sum_mul]
    calc ‚ąĎ j, (rieszSymbol j n) ^ 2 * ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2
        = ‚ąĎ j, -(((n j : ‚ĄĚ) : ‚Ąā) ^ 2) := Finset.sum_congr rfl (fun j _ => hterm j)
      _ = -(‚ąĎ j, ((n j : ‚ĄĚ) : ‚Ąā) ^ 2) := by rw [Finset.sum_neg_distrib]
      _ = -(((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2) := by rw [hsum_real]
      _ = (-1) * ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2 := by ring
  exact mul_right_cancel‚āÄ hne2 hmul

/-! ### SQG velocity divergence-free at the symbol level -/

/-- **SQG velocity is divergence-free at the symbol level.** On `ūĚēč¬≤`,
for any `z ‚ąą ‚Ąā` and any lattice point `n ‚ąą ‚Ą§¬≤`,

    n‚āĀ ¬∑ (m‚āā(n)¬∑z) + n‚āā ¬∑ (-m‚āĀ(n)¬∑z) = 0,

i.e. `k ¬∑ √Ľ(k) = 0` when `√Ľ = (m‚āā¬∑őłŐā, -m‚āĀ¬∑őłŐā)`. -/
theorem sqg_velocity_divergence_free_symbol
    (n : Fin 2 ‚Üí ‚Ą§) (z : ‚Ąā) :
    ((n 0 : ‚ĄĚ) : ‚Ąā) * (rieszSymbol 1 n * z)
      + ((n 1 : ‚ĄĚ) : ‚Ąā) * ((-rieszSymbol 0 n) * z) = 0 := by
  by_cases hn : n = 0
  ¬∑ simp [hn]
  ¬∑ have hpos : 0 < latticeNorm n := latticeNorm_pos hn
    have hne : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by exact_mod_cast ne_of_gt hpos
    rw [rieszSymbol_of_ne_zero hn (j := 1), rieszSymbol_of_ne_zero hn (j := 0)]
    field_simp
    ring

/-! ### SQG velocity symbol isometry on `ūĚēč¬≤` -/

/-- **SQG velocity symbol isometry on `ūĚēč¬≤`.** For any `z ‚ąą ‚Ąā` and any
non-zero lattice point `n ‚ąą ‚Ą§¬≤`,

    ‚ÄĖm‚āā(n)¬∑z‚ÄĖ¬≤ + ‚ÄĖ(-m‚āĀ(n))¬∑z‚ÄĖ¬≤ = ‚ÄĖz‚ÄĖ¬≤,

which is the per-mode statement that `(u‚āĀ, u‚āā) = (m‚āā¬∑őłŐā, -m‚āĀ¬∑őłŐā)`
conserves energy. -/
theorem sqg_velocity_symbol_isometry {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) (z : ‚Ąā) :
    ‚ÄĖrieszSymbol 1 n * z‚ÄĖ ^ 2 + ‚ÄĖ(- rieszSymbol 0 n) * z‚ÄĖ ^ 2 = ‚ÄĖz‚ÄĖ ^ 2 := by
  have hsum : ‚ÄĖrieszSymbol 1 n‚ÄĖ ^ 2 + ‚ÄĖrieszSymbol 0 n‚ÄĖ ^ 2 = 1 := by
    have := rieszSymbol_sum_sq (n := n) hn
    -- ő£‚Īľ ‚ÄĖm_j‚ÄĖ¬≤ sums j over Fin 2 = {0, 1}
    simpa [Fin.sum_univ_two, add_comm] using this
  have h1 : ‚ÄĖrieszSymbol 1 n * z‚ÄĖ ^ 2 = ‚ÄĖrieszSymbol 1 n‚ÄĖ ^ 2 * ‚ÄĖz‚ÄĖ ^ 2 := by
    rw [norm_mul, mul_pow]
  have h2 : ‚ÄĖ(- rieszSymbol 0 n) * z‚ÄĖ ^ 2 = ‚ÄĖrieszSymbol 0 n‚ÄĖ ^ 2 * ‚ÄĖz‚ÄĖ ^ 2 := by
    rw [norm_mul, norm_neg, mul_pow]
  rw [h1, h2, ‚Üź add_mul, hsum, one_mul]

/-! ### Fractional-derivative symbol `ŌÉ_s(n) = ‚ÄĖn‚ÄĖňĘ` -/

/-- The Fourier multiplier symbol of `(-őĒ)^{s/2}` on `ūĚēčŠĶą`, defined as
`‚ÄĖn‚ÄĖ^s` off zero and `0` at `n = 0` (the zero-mean convention that makes
it a genuine seminorm). -/
noncomputable def fracDerivSymbol {d : Type*} [Fintype d]
    (s : ‚ĄĚ) (n : d ‚Üí ‚Ą§) : ‚ĄĚ :=
  if n = 0 then 0 else (latticeNorm n) ^ s

@[simp]
lemma fracDerivSymbol_zero {d : Type*} [Fintype d] (s : ‚ĄĚ) :
    fracDerivSymbol s (0 : d ‚Üí ‚Ą§) = 0 := by
  simp [fracDerivSymbol]

lemma fracDerivSymbol_of_ne_zero {d : Type*} [Fintype d] (s : ‚ĄĚ)
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    fracDerivSymbol s n = (latticeNorm n) ^ s := by
  simp [fracDerivSymbol, hn]

lemma fracDerivSymbol_nonneg {d : Type*} [Fintype d] (s : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    0 ‚Č§ fracDerivSymbol s n := by
  by_cases hn : n = 0
  ¬∑ simp [fracDerivSymbol, hn]
  ¬∑ rw [fracDerivSymbol_of_ne_zero s hn]
    exact Real.rpow_nonneg (latticeNorm_nonneg n) s

lemma fracDerivSymbol_pos {d : Type*} [Fintype d] (s : ‚ĄĚ)
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    0 < fracDerivSymbol s n := by
  rw [fracDerivSymbol_of_ne_zero s hn]
  exact Real.rpow_pos_of_pos (latticeNorm_pos hn) s

/-- At `s = 1`, `fracDerivSymbol` is just `‚ÄĖn‚ÄĖ` off zero. -/
lemma fracDerivSymbol_one_eq {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    fracDerivSymbol 1 n = latticeNorm n := by
  rw [fracDerivSymbol_of_ne_zero 1 hn, Real.rpow_one]

/-- At `s = 2`, `fracDerivSymbol` is `‚ÄĖn‚ÄĖ¬≤` off zero. -/
lemma fracDerivSymbol_two_eq {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    fracDerivSymbol 2 n = (latticeNorm n) ^ 2 := by
  rw [fracDerivSymbol_of_ne_zero 2 hn]
  have h : (latticeNorm n) ^ (2 : ‚ĄĚ) = (latticeNorm n) ^ (2 : ‚Ąē) :=
    Real.rpow_natCast (latticeNorm n) 2
  exact h

/-! ### Symbol-level identity `‚ąā_j = (-őĒ)^{1/2} ¬∑ R_j` -/

/-- **Symbol factorisation** `‚ąā_j = (-őĒ)^{1/2} ¬∑ R_j`. Off the zero
mode, `m_j(n) ¬∑ ‚ÄĖn‚ÄĖ = -i ¬∑ n_j`, i.e. the Riesz multiplier times the
`(-őĒ)^{1/2}` multiplier recovers the symbol of the partial derivative
`‚ąā_j` (with the usual `-i` convention). -/
lemma rieszSymbol_mul_fracDeriv_one {d : Type*} [Fintype d] (j : d)
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    rieszSymbol j n * ((fracDerivSymbol 1 n : ‚ĄĚ) : ‚Ąā)
      = -I * ((n j : ‚ĄĚ) : ‚Ąā) := by
  have hpos : 0 < latticeNorm n := latticeNorm_pos hn
  have hne : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by exact_mod_cast ne_of_gt hpos
  rw [rieszSymbol_of_ne_zero hn, fracDerivSymbol_one_eq hn]
  field_simp

/-! ### Derivative symbol `‚ąā_j ‚ÜĒ i¬∑n_j` and the ŠłĘ¬Ļ identification -/

/-- The Fourier multiplier symbol of `‚ąā_j` on `ūĚēčŠĶą`, i.e. `i ¬∑ n_j`
(the usual convention `fŐā(n) = ‚ąę f¬∑e^{-2ŌÄi n¬∑x} dx` is hidden in the
torus library; here we track the symbol modulo the `2ŌÄ` convention). -/
noncomputable def derivSymbol {d : Type*} [Fintype d]
    (j : d) (n : d ‚Üí ‚Ą§) : ‚Ąā := I * ((n j : ‚ĄĚ) : ‚Ąā)

@[simp]
lemma derivSymbol_zero {d : Type*} [Fintype d] (j : d) :
    derivSymbol j (0 : d ‚Üí ‚Ą§) = 0 := by
  simp [derivSymbol]

lemma norm_derivSymbol {d : Type*} [Fintype d] (j : d) (n : d ‚Üí ‚Ą§) :
    ‚ÄĖderivSymbol j n‚ÄĖ = |(n j : ‚ĄĚ)| := by
  unfold derivSymbol
  rw [norm_mul, Complex.norm_I, one_mul, Complex.norm_real, Real.norm_eq_abs]

lemma norm_derivSymbol_sq {d : Type*} [Fintype d] (j : d) (n : d ‚Üí ‚Ą§) :
    ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 = (n j : ‚ĄĚ) ^ 2 := by
  rw [norm_derivSymbol, sq_abs]

/-- **Pythagorean identity for the derivative symbol.** The sum over
coordinate directions of `‚ÄĖi¬∑n_j‚ÄĖ¬≤` recovers `‚ÄĖn‚ÄĖ¬≤`. -/
lemma sum_norm_derivSymbol_sq {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    ‚ąĎ j, ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 = (latticeNorm n) ^ 2 := by
  rw [latticeNorm_sq]
  exact Finset.sum_congr rfl (fun j _ => norm_derivSymbol_sq j n)

/-- **Symbol-level factorisation** `‚ąā_j = (-őĒ)^{1/2} ¬∑ R_j`. For every
lattice point `n` (including `n = 0`), the Riesz multiplier `m_j(n)`
times the `(-őĒ)^{1/2}` multiplier `‚ÄĖn‚ÄĖ` equals the derivative symbol
`-i ¬∑ n_j = -derivSymbol j n`. -/
lemma rieszSymbol_mul_fracDeriv_one_eq_neg_derivSymbol
    {d : Type*} [Fintype d] (j : d) (n : d ‚Üí ‚Ą§) :
    rieszSymbol j n * ((fracDerivSymbol 1 n : ‚ĄĚ) : ‚Ąā)
      = -derivSymbol j n := by
  by_cases hn : n = 0
  ¬∑ simp [hn, derivSymbol]
  ¬∑ rw [rieszSymbol_mul_fracDeriv_one j hn]
    unfold derivSymbol
    ring

/-! ### Laplacian symbol -/

/-- The Fourier multiplier symbol of `őĒ` (the Laplacian) on `ūĚēčŠĶą`,
defined as `‚ąí‚ÄĖn‚ÄĖ¬≤`. Equivalently, `‚ąíő£‚Īľ n_j¬≤`. -/
noncomputable def laplacianSymbol {d : Type*} [Fintype d]
    (n : d ‚Üí ‚Ą§) : ‚Ąā :=
  -((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2

/-- **Laplacian symbol at zero.** `őĒŐā(0) = 0`. -/
@[simp] lemma laplacianSymbol_zero {d : Type*} [Fintype d] :
    laplacianSymbol (0 : d ‚Üí ‚Ą§) = 0 := by
  simp [laplacianSymbol, latticeNorm]

/-- **Laplacian symbol from derivatives.** `őĒŐā(n) = ő£‚Īľ (derivSymbol j n)¬≤`,
i.e. the Laplacian is the sum of second derivatives. Note
`(derivSymbol j n)¬≤ = (i¬∑n_j)¬≤ = ‚ąín_j¬≤`, so the sum equals `‚ąí‚ÄĖn‚ÄĖ¬≤`. -/
theorem laplacianSymbol_eq_sum_derivSymbol_sq {d : Type*} [Fintype d]
    (n : d ‚Üí ‚Ą§) :
    laplacianSymbol n = ‚ąĎ j, (derivSymbol j n) ^ 2 := by
  simp only [laplacianSymbol, derivSymbol, mul_pow, Complex.I_sq, neg_one_mul]
  rw [show -(((latticeNorm n : ‚ĄĚ) : ‚Ąā)) ^ 2
        = -((‚ąĎ j, ((n j : ‚ĄĚ) : ‚Ąā) ^ 2)) from by
      rw [show ‚ąĎ j, ((n j : ‚ĄĚ) : ‚Ąā) ^ 2 = ((‚ąĎ j, (n j : ‚ĄĚ) ^ 2 : ‚ĄĚ) : ‚Ąā) from by
            push_cast; rfl]
      rw [‚Üź latticeNorm_sq]; push_cast; rfl]
  rw [Finset.sum_neg_distrib]

/-- **Laplacian from fractional derivative symbol.** `őĒŐā(n) = ‚ąí(ŌÉ‚āĀ(n))¬≤`,
connecting the Laplacian to the half-order operator `(-őĒ)^{1/2}`. -/
theorem laplacianSymbol_eq_neg_fracDeriv_one_sq {d : Type*} [Fintype d]
    (n : d ‚Üí ‚Ą§) :
    laplacianSymbol n = -(‚ÜĎ(fracDerivSymbol 1 n) : ‚Ąā) ^ 2 := by
  by_cases hn : n = 0
  ¬∑ simp [hn, laplacianSymbol, fracDerivSymbol_zero, latticeNorm]
  ¬∑ simp only [laplacianSymbol, fracDerivSymbol_one_eq hn]

/-- **Commutativity of Riesz and fractional derivative at symbol level.**
Since both are scalar Fourier multipliers, their product commutes:

    `RŐā_j(n) ¬∑ ŌÉ_s(n) = ŌÉ_s(n) ¬∑ RŐā_j(n)`.

This is the symbol-level statement of `[R_j, (-őĒ)^{s/2}] = 0`. -/
theorem rieszSymbol_comm_fracDeriv {d : Type*} [Fintype d]
    (j : d) (s : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    rieszSymbol j n * (‚ÜĎ(fracDerivSymbol s n) : ‚Ąā)
      = (‚ÜĎ(fracDerivSymbol s n) : ‚Ąā) * rieszSymbol j n :=
  mul_comm _ _

/-- **Inverse Laplacian symbol.** For `n ‚Č† 0`, the symbol of `őĒ‚ĀĽ¬Ļ`
(the Green's function / Biot‚ÄďSavart kernel on `ūĚēčŠĶą`) is `‚ąí1/‚ÄĖn‚ÄĖ¬≤`.
This is the reciprocal of `laplacianSymbol`. -/
noncomputable def invLaplacianSymbol {d : Type*} [Fintype d]
    (n : d ‚Üí ‚Ą§) : ‚Ąā :=
  if n = 0 then 0 else -1 / ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2

/-- **Inverse Laplacian inverts the Laplacian.** For `n ‚Č† 0`,

    `őĒŐā(n) ¬∑ őĒŐā‚ĀĽ¬Ļ(n) = 1`. -/
theorem laplacian_mul_inv {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    laplacianSymbol n * invLaplacianSymbol n = 1 := by
  simp only [laplacianSymbol, invLaplacianSymbol, hn, ite_false]
  have hL : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  have hL2 : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 2 ‚Č† 0 := pow_ne_zero 2 hL
  field_simp

/-- **SQG velocity recovers from vorticity and Biot‚ÄďSavart.** The SQG
velocity can be obtained by the chain `őł ‚Üí Ōą = (-őĒ)^{-1/2}őł ‚Üí u = ‚ąá‚ä•Ōą`.
At the symbol level, combining `invLaplacianSymbol`, `fracDerivSymbol 1`,
and the derivative symbols recovers the Riesz multiplier:

    `derivSymbol j n ¬∑ őĒŐā‚ĀĽ¬Ļ(n) ¬∑ ŌÉ‚āĀ(n) = RŐā_j(n)`

for `n ‚Č† 0`. Concretely: `(in_j)¬∑(-1/‚ÄĖn‚ÄĖ¬≤)¬∑‚ÄĖn‚ÄĖ = -in_j/‚ÄĖn‚ÄĖ`. -/
theorem biot_savart_riesz_factorisation {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (j : d) :
    derivSymbol j n * invLaplacianSymbol n * (‚ÜĎ(fracDerivSymbol 1 n) : ‚Ąā)
      = rieszSymbol j n := by
  rw [invLaplacianSymbol, if_neg hn, fracDerivSymbol_one_eq hn,
      rieszSymbol_of_ne_zero hn j]
  simp only [derivSymbol]
  have hL : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  field_simp

/-! ### Measure-theoretic setup for torus L¬≤ integrals -/

-- Replicate the file-local instance from `Mathlib.Analysis.Fourier.AddCircleMulti`
-- so `Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))` is well-defined here.
noncomputable local instance rieszTorusMeasureSpace :
    MeasureSpace UnitAddCircle := ‚ü®AddCircle.haarAddCircle‚ü©

local instance rieszTorusHaar :
    MeasureTheory.Measure.IsAddHaarMeasure (volume : Measure UnitAddCircle) :=
  inferInstanceAs (Measure.IsAddHaarMeasure AddCircle.haarAddCircle)

local instance rieszTorusProb :
    MeasureTheory.IsProbabilityMeasure (volume : Measure UnitAddCircle) :=
  inferInstanceAs (IsProbabilityMeasure AddCircle.haarAddCircle)

open UnitAddTorus

/-! ### Generic L¬≤-contractivity of bounded Fourier multipliers -/

/-- **L¬≤-contractivity for bounded Fourier multipliers.** If two L¬≤
functions `f, g` on `ūĚēčŠĶą` satisfy `ńĚ(n) = m(n)¬∑fŐā(n)` with a pointwise
bounded multiplier `‚ÄĖm(n)‚ÄĖ ‚Č§ 1`, then `‚ÄĖg‚ÄĖ_{L¬≤} ‚Č§ ‚ÄĖf‚ÄĖ_{L¬≤}`. -/
theorem L2_contractive_of_bounded_symbol
    {d : Type*} [Fintype d]
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (_hm : ‚ąÄ n, ‚ÄĖm n‚ÄĖ ‚Č§ 1)
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff f n) :
    (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) ‚Č§ ‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2 := by
  have hf_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff f
  have hg_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff g
  -- Pointwise: ‚ÄĖńĚ(n)‚ÄĖ¬≤ = ‚ÄĖm(n)‚ÄĖ¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤ ‚Č§ ‚ÄĖfŐā(n)‚ÄĖ¬≤
  have hpt : ‚ąÄ n, ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2 ‚Č§ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n, norm_mul, mul_pow]
    have h1 : ‚ÄĖm n‚ÄĖ ^ 2 ‚Č§ 1 := by
      have h0 : 0 ‚Č§ ‚ÄĖm n‚ÄĖ := norm_nonneg _
      nlinarith [_hm n, h0]
    calc ‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2
        ‚Č§ 1 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
          mul_le_mul_of_nonneg_right h1 (sq_nonneg _)
      _ = ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := one_mul _
  -- Sum comparison
  have hsummable : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := hf_parseval.summable
  have hle : ‚ąĎ' n, ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2 ‚Č§ ‚ąĎ' n, ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
    Summable.tsum_le_tsum hpt (hg_parseval.summable) hsummable
  calc (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2)
      = ‚ąĎ' n, ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2 := hg_parseval.tsum_eq.symm
    _ ‚Č§ ‚ąĎ' n, ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := hle
    _ = ‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2 := hf_parseval.tsum_eq

/-- **L¬≤-isometry for unit-modulus Fourier multipliers.** If `‚ÄĖm(n)‚ÄĖ = 1`
pointwise and `ńĚ = m¬∑fŐā`, then `‚ÄĖg‚ÄĖ_{L¬≤} = ‚ÄĖf‚ÄĖ_{L¬≤}`. -/
theorem L2_isometry_of_unit_symbol
    {d : Type*} [Fintype d]
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hm : ‚ąÄ n, ‚ÄĖm n‚ÄĖ = 1)
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff f n) :
    (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) = ‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2 := by
  have hf_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff f
  have hg_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff g
  have hpt : ‚ąÄ n, ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2 = ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n, norm_mul, mul_pow, hm n, one_pow, one_mul]
  have heq : (fun n ‚Ü¶ ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2)
           = (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := funext hpt
  rw [heq] at hg_parseval
  exact hg_parseval.unique hf_parseval

/-! ### L¬≤-contractivity of the Riesz transform on `ūĚēčŠĶą` -/

/-- **L¬≤-contractivity of the Riesz transform.** If `R_j f` is an L¬≤
function on `ūĚēčŠĶą` whose Fourier coefficients are given by the Riesz
multiplier, then `‚ÄĖR_j f‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}`. -/
theorem riesz_L2_contractive
    {d : Type*} [Fintype d] (j : d)
    (f Rj_f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hcoeff : ‚ąÄ n, mFourierCoeff Rj_f n = rieszSymbol j n * mFourierCoeff f n) :
    (‚ąę t, ‚ÄĖRj_f t‚ÄĖ ^ 2) ‚Č§ ‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2 :=
  L2_contractive_of_bounded_symbol f Rj_f (rieszSymbol j)
    (rieszSymbol_norm_le_one j) hcoeff

/-! ### SQG velocity L¬≤-isometry on `ūĚēč¬≤` -/

/-- **SQG velocity L¬≤-isometry on `ūĚēč¬≤`.**

If `őł ‚ąą L¬≤(ūĚēč¬≤)` has zero mean (`őłŐā(0) = 0`), and `u‚āĀ, u‚āā ‚ąą L¬≤(ūĚēč¬≤)` are the
components of the SQG velocity defined by their Fourier coefficients

    √Ľ‚āĀ(n) = m‚āā(n)¬∑őłŐā(n)      (= -i¬∑n‚āā/‚ÄĖn‚ÄĖ¬∑őłŐā(n))
    √Ľ‚āā(n) = -m‚āĀ(n)¬∑őłŐā(n)     (= i¬∑n‚āĀ/‚ÄĖn‚ÄĖ¬∑őłŐā(n))

then `‚ÄĖu‚āĀ‚ÄĖ¬≤_{L¬≤} + ‚ÄĖu‚āā‚ÄĖ¬≤_{L¬≤} = ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}`. Vectorially this is the SQG
energy-conservation identity `‚ÄĖu‚ÄĖ_{L¬≤(ūĚēč¬≤)} = ‚ÄĖőł‚ÄĖ_{L¬≤(ūĚēč¬≤)}`. -/
theorem sqg_velocity_L2_isometry
    (őł u‚āĀ u‚āā : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł_mean : mFourierCoeff őł 0 = 0)
    (hu‚āĀ : ‚ąÄ n, mFourierCoeff u‚āĀ n = rieszSymbol 1 n * mFourierCoeff őł n)
    (hu‚āā : ‚ąÄ n, mFourierCoeff u‚āā n = -rieszSymbol 0 n * mFourierCoeff őł n) :
    (‚ąę t, ‚ÄĖu‚āĀ t‚ÄĖ ^ 2) + (‚ąę t, ‚ÄĖu‚āā t‚ÄĖ ^ 2) = ‚ąę t, ‚ÄĖőł t‚ÄĖ ^ 2 := by
  have hőł_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖőł t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff őł
  have hu‚āĀ_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff u‚āĀ n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖu‚āĀ t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff u‚āĀ
  have hu‚āā_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff u‚āā n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖu‚āā t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff u‚āā
  -- Per-mode: ‚ÄĖ√Ľ‚āĀ(n)‚ÄĖ¬≤ + ‚ÄĖ√Ľ‚āā(n)‚ÄĖ¬≤ = ‚ÄĖőłŐā(n)‚ÄĖ¬≤.
  have hpt : ‚ąÄ n, ‚ÄĖmFourierCoeff u‚āĀ n‚ÄĖ ^ 2 + ‚ÄĖmFourierCoeff u‚āā n‚ÄĖ ^ 2
                = ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
    intro n
    by_cases hn : n = 0
    ¬∑ -- At `n = 0` every term is 0 since őłŐā(0) = 0.
      rw [hu‚āĀ n, hu‚āā n, hn, hőł_mean]
      simp
    ¬∑ -- Off zero, this is the symbol isometry.
      rw [hu‚āĀ n, hu‚āā n]
      exact sqg_velocity_symbol_isometry hn (mFourierCoeff őł n)
  have hsum_add := hu‚āĀ_parseval.add hu‚āā_parseval
  have heq : (fun n ‚Ü¶ ‚ÄĖmFourierCoeff u‚āĀ n‚ÄĖ ^ 2 + ‚ÄĖmFourierCoeff u‚āā n‚ÄĖ ^ 2)
           = (fun n ‚Ü¶ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
    funext hpt
  rw [heq] at hsum_add
  exact hsum_add.unique hőł_parseval

/-! ### Parseval energy identities for Fourier multipliers -/

/-- **Parseval-side multiplier identity.** If `ńĚ = m¬∑fŐā` on the Fourier
side, then `‚ąę ‚ÄĖg‚ÄĖ¬≤ = ő£‚āô ‚ÄĖm(n)‚ÄĖ¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤`. -/
theorem hasSum_sq_multiplier
    {d : Type*} [Fintype d]
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff f n) :
    HasSum (fun n ‚Ü¶ ‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) := by
  have hg_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff g
  have heq : (fun n ‚Ü¶ ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2)
           = (fun n ‚Ü¶ ‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
    funext n
    rw [hcoeff n, norm_mul, mul_pow]
  rw [heq] at hg_parseval
  exact hg_parseval

/-- Integrated form of the multiplier Parseval identity. -/
theorem L2_norm_sq_eq_multiplier_tsum
    {d : Type*} [Fintype d]
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff f n) :
    (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) = ‚ąĎ' n, ‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
  (hasSum_sq_multiplier f g m hcoeff).tsum_eq.symm

/-! ### Multiplier composition and ŠłĘňĘ seminorm -/

/-- **Composition of Fourier multipliers.** If `ńĚ = m‚āĀ¬∑fŐā` and `ń• = m‚āā¬∑ńĚ`
on the Fourier side, then `ń• = (m‚āā¬∑m‚āĀ)¬∑fŐā`. -/
theorem mFourierCoeff_multiplier_comp
    {d : Type*} [Fintype d]
    (f g h : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m‚āĀ m‚āā : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hg : ‚ąÄ n, mFourierCoeff g n = m‚āĀ n * mFourierCoeff f n)
    (hh : ‚ąÄ n, mFourierCoeff h n = m‚āā n * mFourierCoeff g n) :
    ‚ąÄ n, mFourierCoeff h n = (m‚āā n * m‚āĀ n) * mFourierCoeff f n := by
  intro n
  rw [hh n, hg n, ‚Üź mul_assoc]

/-- **ŠłĘňĘ seminorm squared** on `L¬≤(ūĚēčŠĶą)` via the Fourier multiplier
`ŌÉ_s(n) = ‚ÄĖn‚ÄĖňĘ`. The zero mode `n = 0` contributes `0`, so this is a
true seminorm (vanishing on constants). -/
noncomputable def hsSeminormSq
    {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) : ‚ĄĚ :=
  ‚ąĎ' n, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2

/-- Fourier-multiplier identification of `(-őĒ)^{s/2}`: if `ńĚ = ŌÉ_s¬∑fŐā`
then `‚ąę ‚ÄĖg‚ÄĖ¬≤ = ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}`. -/
theorem hsSeminormSq_eq_L2_of_multiplier
    {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hcoeff : ‚ąÄ n, mFourierCoeff g n
        = ((fracDerivSymbol s n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n) :
    (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) = hsSeminormSq s f := by
  unfold hsSeminormSq
  have hsum := hasSum_sq_multiplier f g
      (fun n ‚Ü¶ ((fracDerivSymbol s n : ‚ĄĚ) : ‚Ąā)) hcoeff
  have hnorm : ‚ąÄ n : (d ‚Üí ‚Ą§),
      ‚ÄĖ((fracDerivSymbol s n : ‚ĄĚ) : ‚Ąā)‚ÄĖ = fracDerivSymbol s n := by
    intro n
    rw [Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (fracDerivSymbol_nonneg s n)]
  have heq : (fun n ‚Ü¶ ‚ÄĖ((fracDerivSymbol s n : ‚ĄĚ) : ‚Ąā)‚ÄĖ ^ 2
                   * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
           = (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
    funext n; rw [hnorm n]
  rw [heq] at hsum
  exact hsum.tsum_eq.symm

/-! ### Riesz-transform total-energy identity on `ūĚēčŠĶą` -/

/-- **Sum-of-Riesz L¬≤-isometry on `ūĚēčŠĶą`.** If `f ‚ąą L¬≤(ūĚēčŠĶą)` has zero mean
and `(R_j f) ‚ąą L¬≤(ūĚēčŠĶą)` are functions whose Fourier coefficients are
given by the Riesz multiplier, then

    ő£‚Īľ ‚ÄĖR_j f‚ÄĖ¬≤_{L¬≤(ūĚēčŠĶą)} = ‚ÄĖf‚ÄĖ¬≤_{L¬≤(ūĚēčŠĶą)}.

This is the `d`-dimensional generalisation of `sqg_velocity_L2_isometry`
and expresses the fact that the vector Riesz transform `(R‚āĀ, ‚Ä¶, R_d)`
is an L¬≤-isometry on zero-mean data. -/
theorem riesz_sum_L2_isometry
    {d : Type*} [Fintype d]
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (Rj_f : d ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hf_mean : mFourierCoeff f 0 = 0)
    (hcoeff : ‚ąÄ j n, mFourierCoeff (Rj_f j) n
                     = rieszSymbol j n * mFourierCoeff f n) :
    ‚ąĎ j, (‚ąę t, ‚ÄĖ(Rj_f j) t‚ÄĖ ^ 2) = ‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2 := by
  have hper : ‚ąÄ j, HasSum
      (fun n ‚Ü¶ ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖ(Rj_f j) t‚ÄĖ ^ 2) := by
    intro j
    exact hasSum_sq_multiplier f (Rj_f j) (rieszSymbol j) (hcoeff j)
  have hsum :
      HasSum (fun n ‚Ü¶ ‚ąĎ j, ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
        (‚ąĎ j, (‚ąę t, ‚ÄĖ(Rj_f j) t‚ÄĖ ^ 2)) := hasSum_sum (fun j _ => hper j)
  have hfun : (fun n : (d ‚Üí ‚Ą§) ‚Ü¶
                  ‚ąĎ j, ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
            = (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
    funext n
    rw [‚Üź Finset.sum_mul]
    by_cases hn : n = 0
    ¬∑ simp [hn, hf_mean]
    ¬∑ rw [rieszSymbol_sum_sq hn, one_mul]
  rw [hfun] at hsum
  have hf_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2) := hasSum_sq_mFourierCoeff f
  exact hsum.unique hf_parseval

/-! ### Double-Riesz Fourier identity `ő£‚Īľ R_j¬≤ = -I` -/

/-- **Double-Riesz Fourier identity.** At the Fourier-coefficient level,
if each `g_j ‚ąą L¬≤(ūĚēčŠĶą)` is built from `f ‚ąą L¬≤(ūĚēčŠĶą)` by the double Riesz
symbol `ńĚ_j(n) = (m_j(n))¬≤¬∑fŐā(n)` and `f` has zero mean, then

    `ő£‚Īľ ńĚ_j(n) = -fŐā(n)` for every `n`.

This is the Fourier-side statement of the classical L¬≤ identity
`ő£‚Īľ R_j¬≤ = -I` on zero-mean fields. At `n = 0` the zero-mean hypothesis
collapses both sides to zero; off zero the result follows from
`rieszSymbol_sum_sq_complex` (`ő£‚Īľ (m_j(n))¬≤ = -1`). -/
theorem riesz_double_sum_symbol
    {d : Type*} [Fintype d]
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (g : d ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hcoeff : ‚ąÄ j n, mFourierCoeff (g j) n
                      = (rieszSymbol j n) ^ 2 * mFourierCoeff f n)
    (hf_mean : mFourierCoeff f 0 = 0) :
    ‚ąÄ n, (‚ąĎ j, mFourierCoeff (g j) n) = -mFourierCoeff f n := by
  intro n
  rw [Finset.sum_congr rfl (fun j (_ : j ‚ąą (Finset.univ : Finset d)) => hcoeff j n),
      ‚Üź Finset.sum_mul]
  by_cases hn : n = 0
  ¬∑ rw [hn, hf_mean]; simp
  ¬∑ rw [rieszSymbol_sum_sq_complex hn]; ring

/-! ### Gradient L¬≤-norm equals the ŠłĘ¬Ļ seminorm -/

/-- **Plancherel for the gradient.** If `őł ‚ąą L¬≤(ūĚēčŠĶą)` and functions
`dőł j ‚ąą L¬≤(ūĚēčŠĶą)` represent its partial derivatives with Fourier
coefficients `(dőł j).Őā(n) = (i¬∑n_j)¬∑őłŐā(n)` (i.e. they are the images of `őł`
under the Fourier multiplier `derivSymbol j`), then the sum of their
L¬≤-norms squared equals the ŠłĘ¬Ļ-seminorm squared of `őł`:

    ő£‚Īľ ‚ąę ‚ÄĖdőł j‚ÄĖ¬≤ = ő£‚āô ‚ÄĖn‚ÄĖ¬≤ ¬∑ ‚ÄĖőłŐā(n)‚ÄĖ¬≤ = hsSeminormSq 1 őł. -/
theorem gradient_L2_eq_hsSeminormSq_one
    {d : Type*} [Fintype d]
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (dőł : d ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hcoeff : ‚ąÄ j n, mFourierCoeff (dőł j) n = derivSymbol j n * mFourierCoeff őł n) :
    ‚ąĎ j, (‚ąę t, ‚ÄĖ(dőł j) t‚ÄĖ ^ 2) = hsSeminormSq 1 őł := by
  -- Per-component Parseval identity using the derivative multiplier.
  have hper : ‚ąÄ j, HasSum
      (fun n ‚Ü¶ ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
      (‚ąę t, ‚ÄĖ(dőł j) t‚ÄĖ ^ 2) := by
    intro j
    exact hasSum_sq_multiplier őł (dőł j) (derivSymbol j) (hcoeff j)
  -- Sum the finitely many per-component HasSums into one HasSum.
  have hsum :
      HasSum (fun n ‚Ü¶ ‚ąĎ j, ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
        (‚ąĎ j, (‚ąę t, ‚ÄĖ(dőł j) t‚ÄĖ ^ 2)) := hasSum_sum (fun j _ => hper j)
  -- Collapse the inner sum via `sum_norm_derivSymbol_sq`.
  have hfun : (fun n ‚Ü¶ ‚ąĎ j, ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
            = (fun n ‚Ü¶ (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
    funext n
    rw [‚Üź Finset.sum_mul, sum_norm_derivSymbol_sq]
  rw [hfun] at hsum
  -- Identify `‚ÄĖn‚ÄĖ¬≤ = (fracDerivSymbol 1 n)¬≤` so the tsum matches `hsSeminormSq 1`.
  have hfrac : (fun n : (d ‚Üí ‚Ą§) ‚Ü¶ (latticeNorm n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
             = (fun n ‚Ü¶ (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
    funext n
    by_cases hn : n = 0
    ¬∑ simp [hn, latticeNorm, fracDerivSymbol]
    ¬∑ rw [fracDerivSymbol_one_eq hn]
  rw [hfrac] at hsum
  unfold hsSeminormSq
  exact hsum.tsum_eq.symm

/-! ### Gradient ŠłĘňĘ-norm equals the ŠłĘ^{s+1} seminorm -/

/-- **Index shift for `fracDerivSymbol`.** For every `n` and every `s`,

    `(ŌÉ_{s+1}(n))¬≤ = (ŌÉ_s(n))¬≤ ¬∑ ‚ÄĖn‚ÄĖ¬≤`.

At `n = 0` both sides vanish; off zero this is `Real.rpow_add_one`. -/
lemma fracDerivSymbol_add_one_sq {d : Type*} [Fintype d]
    (s : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    (fracDerivSymbol (s + 1) n) ^ 2
      = (fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 := by
  by_cases hn : n = 0
  ¬∑ simp [hn, fracDerivSymbol_zero]
  ¬∑ have hpos : 0 < latticeNorm n := latticeNorm_pos hn
    rw [fracDerivSymbol_of_ne_zero _ hn, fracDerivSymbol_of_ne_zero _ hn,
        Real.rpow_add_one (ne_of_gt hpos) s]
    ring

/-- **Plancherel for the gradient in ŠłĘňĘ.** If `őł ‚ąą L¬≤(ūĚēčŠĶą)` and functions
`dőł j ‚ąą L¬≤(ūĚēčŠĶą)` represent its partial derivatives at the symbol level,
then summing their ŠłĘňĘ-seminorms-squared recovers the ŠłĘ^{s+1}-seminorm
of `őł`:

    `ő£‚Īľ ‚ÄĖ‚ąā‚Īľőł‚ÄĖ¬≤_{ŠłĘňĘ} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}`.

At `s = 0` this specialises to `gradient_L2_eq_hsSeminormSq_one`. -/
theorem gradient_Hs_eq_hsSeminormSq_add_one
    {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (őł : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (dőł : d ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hcoeff : ‚ąÄ j n, mFourierCoeff (dőł j) n = derivSymbol j n * mFourierCoeff őł n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    ‚ąĎ j, hsSeminormSq s (dőł j) = hsSeminormSq (s + 1) őł := by
  -- Per-component pointwise identity: ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖdŐāőł_j(n)‚ÄĖ¬≤
  -- = ŌÉ_s(n)¬≤ ¬∑ |derivSymbol j n|¬≤ ¬∑ ‚ÄĖőłŐā(n)‚ÄĖ¬≤  (absorb the derivative symbol).
  have hmode : ‚ąÄ j n,
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (dőł j) n‚ÄĖ ^ 2
      = (fracDerivSymbol s n) ^ 2
          * ((n j : ‚ĄĚ) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
    intro j n
    rw [hcoeff j n, norm_mul, mul_pow, norm_derivSymbol_sq]
  -- Per-component ŠłĘňĘ summability follows from the ŠłĘ^{s+1} summability on őł
  -- because |n_j|¬≤ ‚Č§ ‚ÄĖn‚ÄĖ¬≤ and ŌÉ_{s+1}(n)¬≤ = ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖn‚ÄĖ¬≤ (the index shift).
  have hsumj : ‚ąÄ j, Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (dőł j) n‚ÄĖ ^ 2) := by
    intro j
    refine hsumm.of_nonneg_of_le
      (fun n => by rw [hmode j n];
                   exact mul_nonneg (sq_nonneg _)
                     (mul_nonneg (sq_nonneg _) (sq_nonneg _)))
      (fun n => ?_)
    rw [hmode j n, fracDerivSymbol_add_one_sq s n]
    have hőłsq : 0 ‚Č§ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := sq_nonneg _
    have hŌÉs : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
    have hnj : (n j : ‚ĄĚ) ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
      sq_le_latticeNorm_sq n j
    calc (fracDerivSymbol s n) ^ 2 * ((n j : ‚ĄĚ) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
        = ((fracDerivSymbol s n) ^ 2 * (n j : ‚ĄĚ) ^ 2)
            * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by ring
      _ ‚Č§ ((fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2)
            * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 :=
          mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_left hnj hŌÉs) hőłsq
  -- Per-component HasSum against hsSeminormSq s (dőł j).
  have hper : ‚ąÄ j, HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (dőł j) n‚ÄĖ ^ 2)
      (hsSeminormSq s (dőł j)) := by
    intro j; unfold hsSeminormSq; exact (hsumj j).hasSum
  -- Combine the finite family of per-component HasSums.
  have hsum_all : HasSum
      (fun n ‚Ü¶ ‚ąĎ j,
          (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (dőł j) n‚ÄĖ ^ 2)
      (‚ąĎ j, hsSeminormSq s (dőł j)) := hasSum_sum (fun j _ => hper j)
  -- Pointwise Pythagoras: ő£‚Īľ ŌÉ_s¬≤ ¬∑ ‚ÄĖdŐāőł_j‚ÄĖ¬≤ = ŌÉ_s¬≤ ¬∑ ‚ÄĖn‚ÄĖ¬≤ ¬∑ ‚ÄĖőłŐā‚ÄĖ¬≤ = ŌÉ_{s+1}¬≤ ¬∑ ‚ÄĖőłŐā‚ÄĖ¬≤.
  have hpt : ‚ąÄ n,
        (‚ąĎ j, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (dőł j) n‚ÄĖ ^ 2)
      = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
    intro n
    have hrewrite : (‚ąĎ j,
          (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (dőł j) n‚ÄĖ ^ 2)
        = (fracDerivSymbol s n) ^ 2
            * ((‚ąĎ j, (n j : ‚ĄĚ) ^ 2) * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
      rw [Finset.sum_congr rfl (fun j _ => hmode j n),
          ‚Üź Finset.mul_sum, ‚Üź Finset.sum_mul]
    rw [hrewrite, ‚Üź latticeNorm_sq, fracDerivSymbol_add_one_sq]
    ring
  -- Substitute pointwise identity into the combined HasSum and match RHS.
  have heq : (fun n ‚Ü¶ ‚ąĎ j,
                  (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (dőł j) n‚ÄĖ ^ 2)
           = (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2
                        * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := funext hpt
  rw [heq] at hsum_all
  have hrhs : HasSum
      (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
      (hsSeminormSq (s + 1) őł) := by
    unfold hsSeminormSq; exact hsumm.hasSum
  exact hsum_all.unique hrhs

/-! ### ŠłĘňĘ-contractivity of a single Riesz transform -/

/-- **ŠłĘňĘ-contractivity of the Riesz transform.** If `R_j f` has the
Riesz-multiplier Fourier coefficients of `f` and the ŠłĘňĘ series of `f`
is summable, then `‚ÄĖR_j f‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}`. -/
theorem riesz_Hs_contractive
    {d : Type*} [Fintype d] (s : ‚ĄĚ) (j : d)
    (f Rj_f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hcoeff : ‚ąÄ n, mFourierCoeff Rj_f n = rieszSymbol j n * mFourierCoeff f n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s Rj_f ‚Č§ hsSeminormSq s f := by
  unfold hsSeminormSq
  -- Per-mode: ‚ÄĖ(R_j f)Őā(n)‚ÄĖ¬≤ = ‚ÄĖm_j(n)‚ÄĖ¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤ ‚Č§ ‚ÄĖfŐā(n)‚ÄĖ¬≤.
  have hmode : ‚ąÄ n, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff Rj_f n‚ÄĖ ^ 2
                  ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n, norm_mul, mul_pow]
    have hm1 : ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 ‚Č§ 1 := by
      have h0 : 0 ‚Č§ ‚ÄĖrieszSymbol j n‚ÄĖ := norm_nonneg _
      nlinarith [rieszSymbol_norm_le_one j n, h0]
    have hrest : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    calc (fracDerivSymbol s n) ^ 2
            * (‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
        = ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2
            * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by ring
      _ ‚Č§ 1 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
          mul_le_mul_of_nonneg_right hm1 hrest
      _ = (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := one_mul _
  -- Summability of the R_j f side from pointwise bound.
  have hsumm_Rj : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff Rj_f n‚ÄĖ ^ 2) := by
    refine hsumm.of_nonneg_of_le (fun n => ?_) hmode
    exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
  exact Summable.tsum_le_tsum hmode hsumm_Rj hsumm

/-! ### Generic unitary vector-multiplier ŠłĘňĘ-isometry -/

/-- **Unitary vector-multiplier ŠłĘňĘ-isometry.** Abstract kernel of
`riesz_sum_Hs_isometry` and `sqg_velocity_Hs_isometry`: if `u_j ‚ąą L¬≤(ūĚēčŠĶą)`
are built from `f ‚ąą L¬≤(ūĚēčŠĶą)` by a family of Fourier multipliers `m_j`
that is pointwise unitary in `j` off the zero mode,

    `ő£‚Īľ ‚ÄĖm_j(n)‚ÄĖ¬≤ = 1` for `n ‚Č† 0`,

each `m_j` is bounded (`‚ÄĖm_j(n)‚ÄĖ ‚Č§ 1`), and `fŐā(0) = 0`, then under
ŠłĘňĘ-summability of `f`,

    `ő£‚Īľ ‚ÄĖu_j‚ÄĖ¬≤_{ŠłĘňĘ} = ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}`.

The proof bundles per-component HasSums against `hsSeminormSq` and
closes the combined HasSum via `hasSum.unique`, pulling the unitarity
identity through the pointwise product `ŌÉ_s(n)¬≤ ¬∑ (ő£‚Īľ ‚ÄĖm_j(n)‚ÄĖ¬≤) ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤`. -/
theorem unitary_vec_mul_Hs_isometry
    {d őĻ : Type*} [Fintype d] [Fintype őĻ] (s : ‚ĄĚ)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (u : őĻ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : őĻ ‚Üí (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hcoeff : ‚ąÄ j n, mFourierCoeff (u j) n = m j n * mFourierCoeff f n)
    (hbound : ‚ąÄ j n, ‚ÄĖm j n‚ÄĖ ‚Č§ 1)
    (hunit : ‚ąÄ {n : d ‚Üí ‚Ą§}, n ‚Č† 0 ‚Üí ‚ąĎ j, ‚ÄĖm j n‚ÄĖ ^ 2 = 1)
    (hf_mean : mFourierCoeff f 0 = 0)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    ‚ąĎ j, hsSeminormSq s (u j) = hsSeminormSq s f := by
  -- Per-component ŠłĘňĘ summability from the ‚ÄĖm_j(n)‚ÄĖ ‚Č§ 1 bound.
  have hsumj : ‚ąÄ j, Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (u j) n‚ÄĖ ^ 2) := by
    intro j
    refine hsumm.of_nonneg_of_le
      (fun n => mul_nonneg (sq_nonneg _) (sq_nonneg _)) (fun n => ?_)
    rw [hcoeff j n, norm_mul, mul_pow]
    have hm1 : ‚ÄĖm j n‚ÄĖ ^ 2 ‚Č§ 1 := by
      have h0 : 0 ‚Č§ ‚ÄĖm j n‚ÄĖ := norm_nonneg _
      nlinarith [hbound j n, h0]
    have hrest : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    calc (fracDerivSymbol s n) ^ 2
            * (‚ÄĖm j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
        = ‚ÄĖm j n‚ÄĖ ^ 2
            * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by ring
      _ ‚Č§ 1 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
          mul_le_mul_of_nonneg_right hm1 hrest
      _ = (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := one_mul _
  -- Per-component HasSum against hsSeminormSq s (u j).
  have hper : ‚ąÄ j, HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (u j) n‚ÄĖ ^ 2)
      (hsSeminormSq s (u j)) := by
    intro j; unfold hsSeminormSq; exact (hsumj j).hasSum
  -- Combine finitely many per-component HasSums.
  have hsum_all : HasSum
      (fun n ‚Ü¶ ‚ąĎ j,
          (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (u j) n‚ÄĖ ^ 2)
      (‚ąĎ j, hsSeminormSq s (u j)) := hasSum_sum (fun j _ => hper j)
  -- Pointwise identity: ő£‚Īľ ŌÉ¬≤¬∑‚ÄĖm_j¬∑fŐā‚ÄĖ¬≤ = ŌÉ¬≤¬∑‚ÄĖfŐā‚ÄĖ¬≤, by unitarity (off 0) or trivially (at 0).
  have hpt : ‚ąÄ n,
        (‚ąĎ j, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (u j) n‚ÄĖ ^ 2)
      = (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := by
    intro n
    have hmode : ‚ąÄ j,
          (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (u j) n‚ÄĖ ^ 2
        = ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
            * ‚ÄĖm j n‚ÄĖ ^ 2 := by
      intro j; rw [hcoeff j n, norm_mul, mul_pow]; ring
    rw [Finset.sum_congr rfl (fun j _ => hmode j), ‚Üź Finset.mul_sum]
    by_cases hn : n = 0
    ¬∑ simp [hn, hf_mean]
    ¬∑ rw [hunit hn, mul_one]
  -- Substitute and conclude via HasSum.unique.
  have heq : (fun n ‚Ü¶ ‚ąĎ j,
                  (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (u j) n‚ÄĖ ^ 2)
           = (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
    funext hpt
  rw [heq] at hsum_all
  have hrhs : HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
      (hsSeminormSq s f) := by
    unfold hsSeminormSq; exact hsumm.hasSum
  exact hsum_all.unique hrhs

/-! ### ŠłĘňĘ-isometry of the vector Riesz transform -/

/-- **Vector Riesz transform is an ŠłĘňĘ-isometry.** If `(R_j f) ‚ąą L¬≤(ūĚēčŠĶą)`
have the Riesz-multiplier Fourier coefficients of `f` and the ŠłĘňĘ series
of `f` is summable, then the sum of the ŠłĘňĘ-seminorms-squared of the
components equals that of `f`:

    ő£‚Īľ ‚ÄĖR_j f‚ÄĖ¬≤_{ŠłĘňĘ} = ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}. -/
theorem riesz_sum_Hs_isometry
    {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (Rj_f : d ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hcoeff : ‚ąÄ j n, mFourierCoeff (Rj_f j) n
                     = rieszSymbol j n * mFourierCoeff f n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    ‚ąĎ j, hsSeminormSq s (Rj_f j) = hsSeminormSq s f := by
  -- Per-component summability from the single-Riesz bound.
  have hsumj : ‚ąÄ j, Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (Rj_f j) n‚ÄĖ ^ 2) := by
    intro j
    refine hsumm.of_nonneg_of_le
      (fun n => mul_nonneg (sq_nonneg _) (sq_nonneg _))
      (fun n => ?_)
    rw [hcoeff j n, norm_mul, mul_pow]
    have hm1 : ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 ‚Č§ 1 := by
      have h0 : 0 ‚Č§ ‚ÄĖrieszSymbol j n‚ÄĖ := norm_nonneg _
      nlinarith [rieszSymbol_norm_le_one j n, h0]
    have hrest : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    calc (fracDerivSymbol s n) ^ 2
            * (‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
        = ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2
            * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by ring
      _ ‚Č§ 1 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
          mul_le_mul_of_nonneg_right hm1 hrest
      _ = (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := one_mul _
  -- Per-component HasSum bundle.
  have hper : ‚ąÄ j, HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (Rj_f j) n‚ÄĖ ^ 2)
      (hsSeminormSq s (Rj_f j)) := by
    intro j
    unfold hsSeminormSq
    exact (hsumj j).hasSum
  -- Finite sum of per-component HasSums.
  have hsum_all : HasSum
      (fun n ‚Ü¶ ‚ąĎ j,
          (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (Rj_f j) n‚ÄĖ ^ 2)
      (‚ąĎ j, hsSeminormSq s (Rj_f j)) := hasSum_sum (fun j _ => hper j)
  -- Pointwise Pythagorean identity: ő£‚Īľ ŌÉ¬≤¬∑‚ÄĖm_j¬∑fŐā‚ÄĖ¬≤ = ŌÉ¬≤¬∑‚ÄĖfŐā‚ÄĖ¬≤.
  have hpt : ‚ąÄ n,
      (‚ąĎ j, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (Rj_f j) n‚ÄĖ ^ 2)
        = (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := by
    intro n
    have hmode : ‚ąÄ j, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (Rj_f j) n‚ÄĖ ^ 2
               = ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
                   * ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 := by
      intro j
      rw [hcoeff j n, norm_mul, mul_pow]; ring
    rw [Finset.sum_congr rfl (fun j _ => hmode j), ‚Üź Finset.mul_sum]
    by_cases hn : n = 0
    ¬∑ simp [hn]
    ¬∑ rw [rieszSymbol_sum_sq hn, mul_one]
  -- Substitute the pointwise identity into the combined HasSum.
  have heq : (fun n ‚Ü¶ ‚ąĎ j,
                  (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (Rj_f j) n‚ÄĖ ^ 2)
           = (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
    funext hpt
  rw [heq] at hsum_all
  -- RHS as a HasSum and uniqueness.
  have hrhs : HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
      (hsSeminormSq s f) := by
    unfold hsSeminormSq; exact hsumm.hasSum
  exact hsum_all.unique hrhs

/-! ### SQG velocity ŠłĘňĘ-isometry on `ūĚēč¬≤` -/

/-- **SQG velocity is an ŠłĘňĘ-isometry on `ūĚēč¬≤`.** If `őł : L¬≤(ūĚēč¬≤)` has zero
mean and `u‚āĀ, u‚āā : L¬≤(ūĚēč¬≤)` are the components of the SQG velocity at the
Fourier-symbol level,

    `√Ľ‚āĀ(n) = rieszSymbol 1 n ¬∑ őłŐā(n)`,
    `√Ľ‚āā(n) = -rieszSymbol 0 n ¬∑ őłŐā(n)`,

and the ŠłĘňĘ series of `őł` is summable, then

    `‚ÄĖu‚āĀ‚ÄĖ¬≤_{ŠłĘňĘ} + ‚ÄĖu‚āā‚ÄĖ¬≤_{ŠłĘňĘ} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘňĘ}`.

This is the ŠłĘňĘ upgrade of `sqg_velocity_L2_isometry` and expresses that
SQG energy is conserved at every regularity level, because the velocity
is obtained from `őł` by a unitary symbol. -/
theorem sqg_velocity_Hs_isometry
    (s : ‚ĄĚ)
    (őł u‚āĀ u‚āā : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hőł_mean : mFourierCoeff őł 0 = 0)
    (hu‚āĀ : ‚ąÄ n, mFourierCoeff u‚āĀ n = rieszSymbol 1 n * mFourierCoeff őł n)
    (hu‚āā : ‚ąÄ n, mFourierCoeff u‚āā n = -rieszSymbol 0 n * mFourierCoeff őł n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s u‚āĀ + hsSeminormSq s u‚āā = hsSeminormSq s őł := by
  -- Bounded-multiplier ŠłĘňĘ summability helper.
  have hbound_summ : ‚ąÄ (m : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (hB : ‚ąÄ n, ‚ÄĖm n‚ÄĖ ‚Č§ 1)
      (g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
      (hg : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff őł n),
      Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2) := by
    intro m hB g hg
    refine hsumm.of_nonneg_of_le
      (fun n => mul_nonneg (sq_nonneg _) (sq_nonneg _)) (fun n => ?_)
    rw [hg n, norm_mul, mul_pow]
    have hm1 : ‚ÄĖm n‚ÄĖ ^ 2 ‚Č§ 1 := by
      have h0 : 0 ‚Č§ ‚ÄĖm n‚ÄĖ := norm_nonneg _
      nlinarith [hB n, h0]
    have hrest : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    calc (fracDerivSymbol s n) ^ 2
            * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
        = ‚ÄĖm n‚ÄĖ ^ 2
            * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by ring
      _ ‚Č§ 1 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
          mul_le_mul_of_nonneg_right hm1 hrest
      _ = (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := one_mul _
  -- Per-component summability from the symbol bound ‚ÄĖrieszSymbol‚ÄĖ ‚Č§ 1.
  have hsumm‚āĀ : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u‚āĀ n‚ÄĖ ^ 2) :=
    hbound_summ (rieszSymbol 1) (rieszSymbol_norm_le_one 1) u‚āĀ hu‚āĀ
  have hsumm‚āā : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u‚āā n‚ÄĖ ^ 2) := by
    refine hbound_summ (fun n ‚Ü¶ -rieszSymbol 0 n) ?_ u‚āā hu‚āā
    intro n; rw [norm_neg]; exact rieszSymbol_norm_le_one 0 n
  -- Per-component and reference HasSums against hsSeminormSq.
  have hu‚āĀ_hasSum : HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u‚āĀ n‚ÄĖ ^ 2)
      (hsSeminormSq s u‚āĀ) := by
    unfold hsSeminormSq; exact hsumm‚āĀ.hasSum
  have hu‚āā_hasSum : HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u‚āā n‚ÄĖ ^ 2)
      (hsSeminormSq s u‚āā) := by
    unfold hsSeminormSq; exact hsumm‚āā.hasSum
  have hőł_hasSum : HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)
      (hsSeminormSq s őł) := by
    unfold hsSeminormSq; exact hsumm.hasSum
  -- Pointwise Pythagorean identity per mode.
  have hpt : ‚ąÄ n,
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u‚āĀ n‚ÄĖ ^ 2
      + (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u‚āā n‚ÄĖ ^ 2
      = (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
    intro n
    by_cases hn : n = 0
    ¬∑ -- At n = 0, őłŐā(0) = 0 forces all three terms to 0.
      rw [hu‚āĀ n, hu‚āā n, hn, hőł_mean]
      simp
    ¬∑ -- Off zero, multiply the symbol isometry by ŌÉ_s(n)¬≤.
      have hiso := sqg_velocity_symbol_isometry hn (mFourierCoeff őł n)
      rw [hu‚āĀ n, hu‚āā n]
      linear_combination (fracDerivSymbol s n) ^ 2 * hiso
  -- Combine the two per-component HasSums.
  have hsum_add := hu‚āĀ_hasSum.add hu‚āā_hasSum
  have heq : (fun n ‚Ü¶
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u‚āĀ n‚ÄĖ ^ 2
      + (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u‚āā n‚ÄĖ ^ 2)
           = (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) :=
    funext hpt
  rw [heq] at hsum_add
  exact hsum_add.unique hőł_hasSum

/-! ### SQG selection rule in ŠłĘ¬Ļ form -/

/-- **SQG selection rule, ŠłĘ¬Ļ form.** If `‚ÄĖŇĶ(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ¬∑‚ÄĖőłŐā(n)‚ÄĖ` pointwise
and the RHS is summable, then `‚ÄĖw‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}`. Equivalently,
`‚ÄĖS_nt - ŌČ/2‚ÄĖ_{L¬≤(ūĚēč¬≤)} ‚Č§ ‚ÄĖ‚ąáőł‚ÄĖ_{L¬≤(ūĚēč¬≤)}` after identifying the gradient
norm via Parseval. -/
theorem sqg_selection_rule_Hs1
    {d : Type*} [Fintype d]
    (őł w : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hbound : ‚ąÄ n, ‚ÄĖmFourierCoeff w n‚ÄĖ ‚Č§ (fracDerivSymbol 1 n) * ‚ÄĖmFourierCoeff őł n‚ÄĖ)
    (hsum : Summable (fun n ‚Ü¶ (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    (‚ąę t, ‚ÄĖw t‚ÄĖ ^ 2) ‚Č§ hsSeminormSq 1 őł := by
  unfold hsSeminormSq
  exact sqg_L2_torus_bound őł w (fun n ‚Ü¶ fracDerivSymbol 1 n)
    (fun n ‚Ü¶ fracDerivSymbol_nonneg 1 n) hbound hsum

/-! ### Multiplicative splitting of the `fracDerivSymbol` -/

/-- **Additive-in-exponent splitting of the fractional derivative symbol.**
For every `n` and every `s, t`,

    `(ŌÉ_{s+t}(n))¬≤ = (ŌÉ_s(n))¬≤ ¬∑ (ŌÉ_t(n))¬≤`.

At `n = 0` both sides vanish; off zero this is `Real.rpow_add`. -/
lemma fracDerivSymbol_add_sq {d : Type*} [Fintype d]
    (s t : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    (fracDerivSymbol (s + t) n) ^ 2
      = (fracDerivSymbol s n) ^ 2 * (fracDerivSymbol t n) ^ 2 := by
  by_cases hn : n = 0
  ¬∑ simp [hn, fracDerivSymbol_zero]
  ¬∑ have hpos : 0 < latticeNorm n := latticeNorm_pos hn
    rw [fracDerivSymbol_of_ne_zero _ hn,
        fracDerivSymbol_of_ne_zero _ hn,
        fracDerivSymbol_of_ne_zero _ hn,
        Real.rpow_add hpos s t]
    ring

/-- **Multiplicative additivity of `fracDerivSymbol` (unsquared).**
For every `n` and every `s, t`,

    `ŌÉ_{s+t}(n) = ŌÉ_s(n) ¬∑ ŌÉ_t(n)`.

At `n = 0` both sides are `0`; off zero this is `Real.rpow_add`. -/
lemma fracDerivSymbol_mul {d : Type*} [Fintype d]
    (s t : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    fracDerivSymbol (s + t) n = fracDerivSymbol s n * fracDerivSymbol t n := by
  by_cases hn : n = 0
  ¬∑ simp [hn, fracDerivSymbol_zero]
  ¬∑ have hpos : 0 < latticeNorm n := latticeNorm_pos hn
    rw [fracDerivSymbol_of_ne_zero _ hn,
        fracDerivSymbol_of_ne_zero _ hn,
        fracDerivSymbol_of_ne_zero _ hn,
        Real.rpow_add hpos s t]

/-! ### Monotonicity of `fracDerivSymbol` and `hsSeminormSq` in `s` -/

/-- **Monotonicity of `fracDerivSymbol` in the exponent.** On the integer
lattice, for every `n`, if `s ‚Č§ t` then `ŌÉ_s(n) ‚Č§ ŌÉ_t(n)`. At `n = 0`
both sides are `0`; off zero `‚ÄĖn‚ÄĖ ‚Č• 1` (integer-lattice fact) makes
`‚ÄĖn‚ÄĖ^s ‚Č§ ‚ÄĖn‚ÄĖ^t`. -/
lemma fracDerivSymbol_mono_of_le {d : Type*} [Fintype d]
    {s t : ‚ĄĚ} (hst : s ‚Č§ t) (n : d ‚Üí ‚Ą§) :
    fracDerivSymbol s n ‚Č§ fracDerivSymbol t n := by
  by_cases hn : n = 0
  ¬∑ simp [hn, fracDerivSymbol_zero]
  ¬∑ rw [fracDerivSymbol_of_ne_zero _ hn, fracDerivSymbol_of_ne_zero _ hn]
    exact Real.rpow_le_rpow_of_exponent_le
      (latticeNorm_ge_one_of_ne_zero hn) hst

/-- **Squared monotonicity of `fracDerivSymbol`.** Convenience form of
`fracDerivSymbol_mono_of_le`, kept in the squared shape used inside
`hsSeminormSq`. -/
lemma fracDerivSymbol_sq_mono_of_le {d : Type*} [Fintype d]
    {s t : ‚ĄĚ} (hst : s ‚Č§ t) (n : d ‚Üí ‚Ą§) :
    (fracDerivSymbol s n) ^ 2 ‚Č§ (fracDerivSymbol t n) ^ 2 := by
  have h := fracDerivSymbol_mono_of_le hst n
  have h0 : 0 ‚Č§ fracDerivSymbol s n := fracDerivSymbol_nonneg s n
  nlinarith [h, h0]

/-- **Monotonicity of the ŠłĘňĘ seminorm in `s`.** On the torus, the
ŠłĘňĘ-seminorm is monotone in `s`: if `s ‚Č§ t` and the ŠłĘŠĶó tail of `f` is
summable, then

    `‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘŠĶó}`.

Monotonicity comes from `‚ÄĖn‚ÄĖ ‚Č• 1` off zero, which gives
`ŌÉ_s(n)¬≤ ‚Č§ ŌÉ_t(n)¬≤` at every nonzero lattice point. -/
theorem hsSeminormSq_mono_of_le
    {d : Type*} [Fintype d]
    {s t : ‚ĄĚ} (hst : s ‚Č§ t)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hsumm_t : Summable
        (fun n ‚Ü¶ (fracDerivSymbol t n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s f ‚Č§ hsSeminormSq t f := by
  unfold hsSeminormSq
  -- Per-mode: ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤ ‚Č§ ŌÉ_t(n)¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤ since ŌÉ_s¬≤ ‚Č§ ŌÉ_t¬≤ and ‚ÄĖfŐā‚ÄĖ¬≤ ‚Č• 0.
  have hmode : ‚ąÄ n, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2
                  ‚Č§ (fracDerivSymbol t n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
    fun n => mul_le_mul_of_nonneg_right
      (fracDerivSymbol_sq_mono_of_le hst n) (sq_nonneg _)
  have hsumm_s : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
    refine hsumm_t.of_nonneg_of_le (fun n => ?_) hmode
    exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
  exact Summable.tsum_le_tsum hmode hsumm_s hsumm_t

/-- **Nonnegativity of the ŠłĘňĘ squared seminorm.**
Each summand `ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤` is nonneg, so the tsum is nonneg
(or 0 when not summable, by `tsum_eq_zero_of_not_summable`). -/
theorem hsSeminormSq_nonneg {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d))) :
    0 ‚Č§ hsSeminormSq s f := by
  unfold hsSeminormSq
  exact tsum_nonneg (fun n => mul_nonneg (sq_nonneg _) (sq_nonneg _))

/-! ### Riesz product symbol -/

/-- **Product of Riesz symbols.** For `n ‚Č† 0`,

    `RŐā_j(n) ¬∑ RŐā_k(n) = - (n_j ¬∑ n_k) / ‚ÄĖn‚ÄĖ¬≤`.

This is the Fourier symbol of the composition `R_j ‚ąė R_k`; summing over
`j = k` recovers `riesz_double_sum_symbol` (= ‚ąí1). The off-diagonal
entries are the building blocks of the **Leray projector**
`PŐā_{jk} = őī_{jk} - nŐā_j nŐā_k = őī_{jk} + RŐā_j RŐā_k`. -/
theorem riesz_product_symbol {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (j k : d) :
    rieszSymbol j n * rieszSymbol k n
      = -(‚ÜĎ(n j : ‚Ą§) * ‚ÜĎ(n k : ‚Ą§)) / (‚ÜĎ(latticeNorm n) ^ 2 : ‚Ąā) := by
  rw [rieszSymbol_of_ne_zero hn j, rieszSymbol_of_ne_zero hn k]
  have hL : (‚ÜĎ(latticeNorm n) : ‚Ąā) ‚Č† 0 := by
    have := latticeNorm_pos hn
    exact_mod_cast this.ne'
  field_simp
  rw [show (I : ‚Ąā) ^ 2 = -1 from Complex.I_sq]
  push_cast
  ring

/-! ### Leray‚ÄďHelmholtz projector symbol -/

/-- **Leray‚ÄďHelmholtz projector symbol.** On the integer lattice
`‚Ą§ŠĶą \ {0}`, define

    `PŐā_{jk}(n) = őī_{jk} + RŐā_j(n)¬∑RŐā_k(n)
              = őī_{jk} - n_j¬∑n_k / ‚ÄĖn‚ÄĖ¬≤`.

`PŐā` projects Fourier modes onto the divergence-free subspace; it is the
Fourier-side representation of the Leray projector `P = Id + R‚äóR`. -/
noncomputable def leraySymbol {d : Type*} [Fintype d] [DecidableEq d]
    (j k : d) (n : d ‚Üí ‚Ą§) : ‚Ąā :=
  if j = k then 1 + rieszSymbol j n * rieszSymbol k n
  else rieszSymbol j n * rieszSymbol k n

/-- **Leray symbol for `n = 0`.** Every entry is `őī_{jk}` at the
zero frequency (since all Riesz symbols vanish there). -/
lemma leraySymbol_zero {d : Type*} [Fintype d] [DecidableEq d]
    (j k : d) : leraySymbol j k (0 : d ‚Üí ‚Ą§) = if j = k then 1 else 0 := by
  simp [leraySymbol, rieszSymbol_zero]

/-- **Trace of the Leray symbol.** For `n ‚Č† 0`,

    `ő£‚Īľ PŐā_{jj}(n) = d ‚ąí 1`.

This counts the number of independent divergence-free polarisations
of a Fourier mode on `ūĚēčŠĶą`: every nonzero `n` has `d ‚ąí 1` transverse
directions. The proof uses `rieszSymbol_sum_sq_complex` (ő£ RŐā_j¬≤ = ‚ąí1). -/
theorem leray_trace {d : Type*} [Fintype d] [DecidableEq d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ąĎ j : d, leraySymbol j j n = (Fintype.card d : ‚Ąā) - 1 := by
  simp only [leraySymbol, if_true]
  rw [Finset.sum_add_distrib, Finset.sum_const, nsmul_eq_mul, mul_one]
  -- ő£ RŐā_j ¬∑ RŐā_j = ő£ RŐā_j¬≤ = -1
  have hRR : ‚ąĎ j : d, rieszSymbol j n * rieszSymbol j n
           = ‚ąĎ j : d, (rieszSymbol j n) ^ 2 := by
    congr 1; ext j; ring
  rw [hRR, rieszSymbol_sum_sq_complex hn]
  simp [Finset.card_univ]
  ring

/-- **Riesz‚Äďfrequency dot product.** For `n ‚Č† 0`,

    `ő£_k  RŐā_k(n) ¬∑ n_k = ‚ąíi ¬∑ ‚ÄĖn‚ÄĖ`.

This is the Fourier-side expression of `div(R f) = (-őĒ)^{1/2} f`.
Each `RŐā_k(n) = -i n_k/‚ÄĖn‚ÄĖ`, so the sum reduces to
`(-i/‚ÄĖn‚ÄĖ) ő£_k n_k¬≤ = -i ¬∑ ‚ÄĖn‚ÄĖ`. -/
theorem riesz_dot_freq {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ąĎ k, rieszSymbol k n * (‚ÜĎ(n k : ‚Ą§) : ‚Ąā)
      = -Complex.I * (‚ÜĎ(latticeNorm n) : ‚Ąā) := by
  have hL : (‚ÜĎ(latticeNorm n) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  -- Multiply both sides by ‚ÄĖn‚ÄĖ to clear denominators
  have hmul : (‚ąĎ k, rieszSymbol k n * (‚ÜĎ(n k : ‚Ą§) : ‚Ąā)) * (‚ÜĎ(latticeNorm n) : ‚Ąā)
            = (-Complex.I * (‚ÜĎ(latticeNorm n) : ‚Ąā)) * (‚ÜĎ(latticeNorm n) : ‚Ąā) := by
    rw [Finset.sum_mul]
    -- Per-term: RŐā_k ¬∑ n_k ¬∑ ‚ÄĖn‚ÄĖ = -I ¬∑ n_k¬≤
    have hterm : ‚ąÄ k, rieszSymbol k n * (‚ÜĎ(n k : ‚Ą§) : ‚Ąā) * (‚ÜĎ(latticeNorm n) : ‚Ąā)
                    = -Complex.I * ((‚ÜĎ(n k : ‚Ą§) : ‚Ąā) ^ 2) := by
      intro k
      rw [rieszSymbol_of_ne_zero hn k]
      field_simp
      push_cast; ring
    rw [Finset.sum_congr rfl (fun k _ => hterm k)]
    -- ő£_k (-I ¬∑ n_k¬≤) = -I ¬∑ ő£_k n_k¬≤ = -I ¬∑ ‚ÄĖn‚ÄĖ¬≤
    rw [‚Üź Finset.mul_sum]
    have hsum : ‚ąĎ k, ((‚ÜĎ(n k : ‚Ą§) : ‚Ąā) ^ 2) = (‚ÜĎ(latticeNorm n) : ‚Ąā) ^ 2 := by
      have hreal : (‚ąĎ k, (n k : ‚ĄĚ) ^ 2) = latticeNorm n ^ 2 :=
        (latticeNorm_sq n).symm
      exact_mod_cast congrArg (‚ÜĎ¬∑ : ‚ĄĚ ‚Üí ‚Ąā) hreal
    rw [hsum]; ring
  exact mul_right_cancel‚āÄ hL hmul

/-- **Leray projector annihilates longitudinal modes.** For `n ‚Č† 0`,

    `ő£_k  PŐā_{jk}(n) ¬∑ n_k = 0`.

This is the defining property of the Helmholtz/Leray projector: it
kills the gradient (irrotational) component of any vector field.
Follows from `riesz_dot_freq` (ő£ RŐā_k n_k = ‚ąíi‚ÄĖn‚ÄĖ) and the Riesz
symbol normalisation. -/
theorem leray_kills_longitudinal {d : Type*} [Fintype d] [DecidableEq d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (j : d) :
    ‚ąĎ k, leraySymbol j k n * (‚ÜĎ(n k : ‚Ą§) : ‚Ąā) = 0 := by
  -- Rewrite leraySymbol to őī_{jk} + RŐā_j RŐā_k and distribute.
  have hexpand : ‚ąÄ k, leraySymbol j k n * (‚ÜĎ(n k : ‚Ą§) : ‚Ąā)
      = (if j = k then (‚ÜĎ(n k : ‚Ą§) : ‚Ąā) else 0)
        + rieszSymbol j n * (rieszSymbol k n * (‚ÜĎ(n k : ‚Ą§) : ‚Ąā)) := by
    intro k
    unfold leraySymbol
    split_ifs <;> ring
  rw [Finset.sum_congr rfl (fun k _ => hexpand k)]
  rw [Finset.sum_add_distrib]
  -- First sum: ő£_k őī_{jk} ¬∑ n_k = n_j
  have hőī : ‚ąĎ k, (if j = k then (‚ÜĎ(n k : ‚Ą§) : ‚Ąā) else 0) = (‚ÜĎ(n j : ‚Ą§) : ‚Ąā) := by
    exact (Finset.sum_ite_eq Finset.univ j _).trans (if_pos (Finset.mem_univ j))
  rw [hőī]
  -- Second sum: RŐā_j ¬∑ ő£_k RŐā_k ¬∑ n_k = RŐā_j ¬∑ (-I ¬∑ ‚ÄĖn‚ÄĖ)
  rw [‚Üź Finset.mul_sum, riesz_dot_freq hn]
  -- Now: n_j + RŐā_j ¬∑ (-I ¬∑ ‚ÄĖn‚ÄĖ) = 0
  rw [rieszSymbol_of_ne_zero hn j]
  have hL : (‚ÜĎ(latticeNorm n) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  field_simp
  rw [show (Complex.I : ‚Ąā) ^ 2 = -1 from Complex.I_sq]
  push_cast; ring

/-- **Leray preserves transverse modes.** For `n ‚Č† 0`, if the vector
`v` is transverse to `n` (i.e. `ő£_k n_k ¬∑ v_k = 0`), then

    `ő£_k PŐā_{jk}(n) ¬∑ v_k = v_j`.

Together with `leray_kills_longitudinal` this characterises the Leray
projector: it acts as the identity on the `(d‚ąí1)`-dimensional transverse
subspace and annihilates the longitudinal direction. -/
theorem leray_preserves_transverse {d : Type*} [Fintype d] [DecidableEq d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (v : d ‚Üí ‚Ąā)
    (hv : ‚ąĎ k, (‚ÜĎ(n k : ‚Ą§) : ‚Ąā) * v k = 0) (j : d) :
    ‚ąĎ k, leraySymbol j k n * v k = v j := by
  -- Expand: ő£_k (őī_{jk} + RŐā_j RŐā_k) v_k = v_j + RŐā_j ¬∑ ő£_k RŐā_k v_k
  have hexpand : ‚ąÄ k, leraySymbol j k n * v k
      = (if j = k then v k else 0)
        + rieszSymbol j n * (rieszSymbol k n * v k) := by
    intro k; unfold leraySymbol; split_ifs <;> ring
  simp_rw [hexpand, Finset.sum_add_distrib]
  -- First sum: ő£_k őī_{jk} v_k = v_j
  rw [(Finset.sum_ite_eq Finset.univ j _).trans (if_pos (Finset.mem_univ j))]
  -- Second sum: RŐā_j ¬∑ ő£_k RŐā_k v_k. Factor RŐā_k = -I n_k / ‚ÄĖn‚ÄĖ.
  rw [‚Üź Finset.mul_sum]
  -- ő£_k RŐā_k v_k = (-I/‚ÄĖn‚ÄĖ) ő£_k n_k v_k = 0
  have hRv : ‚ąĎ k, rieszSymbol k n * v k = 0 := by
    have hL : (‚ÜĎ(latticeNorm n) : ‚Ąā) ‚Č† 0 := by
      exact_mod_cast (latticeNorm_pos hn).ne'
    have hfactor : ‚ąÄ k, rieszSymbol k n * v k
        = (-Complex.I / (‚ÜĎ(latticeNorm n) : ‚Ąā)) * ((‚ÜĎ(n k : ‚Ą§) : ‚Ąā) * v k) := by
      intro k; rw [rieszSymbol_of_ne_zero hn k]; field_simp; push_cast; ring
    simp_rw [hfactor, ‚Üź Finset.mul_sum, hv, mul_zero]
  rw [hRv, mul_zero, add_zero]

/-- **Self-adjointness of the Leray symbol.** `PŐā_{jk}(n) = PŐā_{kj}(n)`,
since `RŐā_j ¬∑ RŐā_k = RŐā_k ¬∑ RŐā_j` (complex multiplication commutes). -/
theorem leray_self_adjoint {d : Type*} [Fintype d] [DecidableEq d]
    (j k : d) (n : d ‚Üí ‚Ą§) :
    leraySymbol j k n = leraySymbol k j n := by
  unfold leraySymbol
  by_cases hjk : j = k
  ¬∑ rw [hjk]
  ¬∑ rw [if_neg hjk, if_neg (Ne.symm hjk)]; ring

/-- **Idempotency of the Leray projector.** For `n ‚Č† 0`,

    `ő£_l  PŐā_{jl}(n) ¬∑ PŐā_{lk}(n) = PŐā_{jk}(n)`.

Proof: expand `PŐā = őī + RŐā‚äóRŐā` to get four sums. The cross terms each give
`RŐā_j RŐā_k` and the quadruple-product sum gives `RŐā_j ¬∑ (ő£ RŐā_l¬≤) ¬∑ RŐā_k = -RŐā_j RŐā_k`.
The three contributions `RŐā_j RŐā_k + RŐā_j RŐā_k + (-RŐā_j RŐā_k) = RŐā_j RŐā_k`
combine with the `őī_{jk}` term to reproduce `PŐā_{jk}`. -/
theorem leray_idempotent {d : Type*} [Fintype d] [DecidableEq d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (j k : d) :
    ‚ąĎ l, leraySymbol j l n * leraySymbol l k n = leraySymbol j k n := by
  -- Expand leraySymbol into őī + RŐā‚äóRŐā form
  have hexpand : ‚ąÄ a b, leraySymbol a b n
      = (if a = b then 1 else 0) + rieszSymbol a n * rieszSymbol b n := by
    intro a b; unfold leraySymbol; split_ifs <;> ring
  simp_rw [hexpand]
  -- Distribute the product: (őī_jl + RŐā_j RŐā_l)(őī_lk + RŐā_l RŐā_k)
  -- = őī_jl őī_lk + őī_jl RŐā_l RŐā_k + RŐā_j RŐā_l őī_lk + RŐā_j RŐā_l RŐā_l RŐā_k
  have hdist : ‚ąÄ l,
      ((if j = l then (1 : ‚Ąā) else 0) + rieszSymbol j n * rieszSymbol l n)
    * ((if l = k then (1 : ‚Ąā) else 0) + rieszSymbol l n * rieszSymbol k n)
    = (if j = l then 1 else 0) * (if l = k then 1 else 0)
    + (if j = l then 1 else 0) * (rieszSymbol l n * rieszSymbol k n)
    + rieszSymbol j n * rieszSymbol l n * (if l = k then 1 else 0)
    + rieszSymbol j n * (rieszSymbol l n ^ 2) * rieszSymbol k n := by
    intro l; ring
  simp_rw [hdist]
  rw [Finset.sum_add_distrib, Finset.sum_add_distrib, Finset.sum_add_distrib]
  -- Term 1: ő£_l őī_{jl} őī_{lk} = őī_{jk}
  have h1 : ‚ąĎ l, (if j = l then (1 : ‚Ąā) else 0) * (if l = k then 1 else 0)
           = if j = k then 1 else 0 := by
    have : (fun l => (if j = l then (1 : ‚Ąā) else 0) * (if l = k then 1 else 0))
         = (fun l => if j = l then (if l = k then 1 else 0) else 0) := by
      ext l; split_ifs <;> simp
    rw [this, (Finset.sum_ite_eq Finset.univ j _).trans (if_pos (Finset.mem_univ j))]
  -- Term 2: ő£_l őī_{jl} (RŐā_l RŐā_k) = RŐā_j RŐā_k
  have h2 : ‚ąĎ l, (if j = l then (1 : ‚Ąā) else 0) * (rieszSymbol l n * rieszSymbol k n)
           = rieszSymbol j n * rieszSymbol k n := by
    have : (fun l => (if j = l then (1 : ‚Ąā) else 0) * (rieszSymbol l n * rieszSymbol k n))
         = (fun l => if j = l then rieszSymbol l n * rieszSymbol k n else 0) := by
      ext l; split_ifs <;> simp
    rw [this, (Finset.sum_ite_eq Finset.univ j _).trans (if_pos (Finset.mem_univ j))]
  -- Term 3: ő£_l RŐā_j RŐā_l őī_{lk} = RŐā_j RŐā_k
  have h3 : ‚ąĎ l, rieszSymbol j n * rieszSymbol l n * (if l = k then (1 : ‚Ąā) else 0)
           = rieszSymbol j n * rieszSymbol k n := by
    have : (fun l => rieszSymbol j n * rieszSymbol l n * (if l = k then (1 : ‚Ąā) else 0))
         = (fun l => if l = k then rieszSymbol j n * rieszSymbol l n else 0) := by
      ext l; split_ifs <;> ring
    rw [this, (Finset.sum_ite_eq' Finset.univ k _).trans (if_pos (Finset.mem_univ k))]
  -- Term 4: ő£_l RŐā_j RŐā_l¬≤ RŐā_k = RŐā_j (ő£_l RŐā_l¬≤) RŐā_k = -RŐā_j RŐā_k
  have h4 : ‚ąĎ l, rieszSymbol j n * (rieszSymbol l n ^ 2) * rieszSymbol k n
           = -(rieszSymbol j n * rieszSymbol k n) := by
    rw [show (fun l => rieszSymbol j n * (rieszSymbol l n ^ 2) * rieszSymbol k n)
          = (fun l => rieszSymbol j n * rieszSymbol k n * (rieszSymbol l n ^ 2)) from by
        ext l; ring]
    rw [‚Üź Finset.mul_sum, rieszSymbol_sum_sq_complex hn]; ring
  rw [h1, h2, h3, h4]; ring

/-! ### SQG vorticity‚Äďpotential relation -/

/-- **SQG vorticity symbol.** For the SQG velocity
`√Ľ‚āÄ = RŐā‚āĀ¬∑őłŐā, √Ľ‚āĀ = -RŐā‚āÄ¬∑őłŐā` on `ūĚēč¬≤`, the 2D scalar vorticity
`ŌČ = ‚ąā‚āÄu‚āĀ ‚ąí ‚ąā‚āĀu‚āÄ` has Fourier symbol

    `ŌČŐā/őłŐā = ‚ąí‚ÄĖn‚ÄĖ`

at every `n ‚Č† 0`. This is the Fourier-level statement of the SQG
constitutive relation `ŌČ = ‚ąí(-őĒ)^{1/2}őł` (with the sign matching
the velocity convention `u = (R‚āĀőł, -R‚āÄőł)`).

The proof factors through `riesz_dot_freq`
(`ő£ RŐā_k ¬∑ n_k = -i‚ÄĖn‚ÄĖ`). -/
theorem sqg_vorticity_symbol {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    derivSymbol 0 n * (-rieszSymbol 0 n)
      - derivSymbol 1 n * rieszSymbol 1 n
    = -(‚ÜĎ(latticeNorm n) : ‚Ąā) := by
  -- Rewrite: the expression equals -(ő£_j derivSymbol j ¬∑ rieszSymbol j)
  have hstep : derivSymbol 0 n * (-rieszSymbol 0 n)
                 - derivSymbol 1 n * rieszSymbol 1 n
             = -(‚ąĎ j : Fin 2, derivSymbol j n * rieszSymbol j n) := by
    simp [Fin.sum_univ_two]; ring
  rw [hstep]
  -- Each derivSymbol j n = I ¬∑ (n j : ‚Ąā), so factor out I
  have hfactor : ‚ąĎ j : Fin 2, derivSymbol j n * rieszSymbol j n
               = Complex.I * ‚ąĎ j : Fin 2, rieszSymbol j n * (‚ÜĎ(n j : ‚Ą§) : ‚Ąā) := by
    simp only [derivSymbol, Fin.sum_univ_two]
    push_cast; ring
  rw [hfactor, riesz_dot_freq hn]
  rw [show -(Complex.I * (-Complex.I * (‚ÜĎ(latticeNorm n) : ‚Ąā)))
        = -(-(Complex.I * Complex.I * (‚ÜĎ(latticeNorm n) : ‚Ąā))) from by ring]
  rw [neg_neg, Complex.I_mul_I, neg_one_mul]

/-! ### SQG velocity-gradient symbols on `ūĚēč¬≤` -/

/-- **SQG velocity-gradient symbol.** The Fourier multiplier of
`‚ąā_i u_j` for the SQG velocity `u = (RŐā‚āĀőł, -RŐā‚āÄőł)` on `ūĚēč¬≤`. The
velocity gradient tensor at frequency `n` is

    `(‚ąā_i u_j)^Őā(n) = sqgGradSymbol i j n ¬∑ őłŐā(n)`.

Here `i` is the differentiation direction, `j` selects the velocity
component (`j = 0` ‚Üí `RŐā‚āĀ`, `j = 1` ‚Üí `‚ąíRŐā‚āÄ`). -/
noncomputable def sqgGradSymbol (i j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  derivSymbol i n *
    (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n)

/-- **SQG strain symbol.** The Fourier multiplier of the symmetric
part of the velocity gradient, `S_{ij} = (‚ąā_i u_j + ‚ąā_j u_i)/2`:

    `Ňú_{ij}(n) = (sqgGradSymbol i j n + sqgGradSymbol j i n) / 2`. -/
noncomputable def sqgStrainSymbol (i j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  (sqgGradSymbol i j n + sqgGradSymbol j i n) / 2

/-- **SQG strain is trace-free.** The strain rate tensor of the SQG
velocity field is trace-free (incompressibility): `Ňú‚āÄ‚āÄ + Ňú‚āĀ‚āĀ = 0`
at every lattice point.

This follows from the divergence-free condition `‚ąā‚āÄu‚āÄ + ‚ąā‚āĀu‚āĀ = 0`
(see `sqg_velocity_divergence_free_symbol`). -/
theorem sqg_strain_trace_free (n : Fin 2 ‚Üí ‚Ą§) :
    sqgStrainSymbol 0 0 n + sqgStrainSymbol 1 1 n = 0 := by
  simp only [sqgStrainSymbol, sqgGradSymbol]
  by_cases hn : n = 0
  ¬∑ simp [hn, derivSymbol, rieszSymbol]
  ¬∑ simp only [show (1 : Fin 2) ‚Č† 0 from by omega,
               if_true, if_false]
    rw [rieszSymbol_of_ne_zero hn 0, rieszSymbol_of_ne_zero hn 1]
    simp only [derivSymbol]
    have hL : (‚ÜĎ(latticeNorm n) : ‚Ąā) ‚Č† 0 := by
      exact_mod_cast (latticeNorm_pos hn).ne'
    field_simp
    push_cast; ring

/-- **Theorem 1 of the paper at the Fourier-symbol level (single mode).**

For the SQG velocity `u = (R‚āĀőł, -R‚āÄőł)` on `ūĚēč¬≤` and a single Fourier
mode `n ‚Č† 0`, define:

  * **front normal** `nŐā = n/‚ÄĖn‚ÄĖ` (the direction of `‚ąáőł`),
  * **front tangent** `tŐā = (-n‚āĀ, n‚āÄ)/‚ÄĖn‚ÄĖ` (perpendicular),
  * **normal-tangential strain** `S_{nt} = nŐā ¬∑ Ňú ¬∑ tŐā`.

Then `S_{nt} = ŌČŐā/(2őłŐā)`, i.e. the shear strain equals half the
vorticity ‚ÄĒ the **shear‚Äďvorticity identity**. This is Theorem 1 of the paper
restricted to single Fourier modes; the full physical-space identity
follows because the relation is linear in the mode amplitude.

Concretely the theorem states (in unnormalized form, multiplied by ‚ÄĖn‚ÄĖ¬≤):

  `ő£_{i,j} n_i ¬∑ Ňú_{ij}(n) ¬∑ t_j = -‚ÄĖn‚ÄĖ¬≥/2 = (ŌČŐā/őłŐā) ¬∑ ‚ÄĖn‚ÄĖ¬≤/2`

where `t = (-n‚āĀ, n‚āÄ)`. -/
theorem sqg_shear_vorticity_fourier {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    -- ő£_{i,j} n_i ¬∑ S_{ij} ¬∑ t_j  (unnormalized, in ‚ÄĖn‚ÄĖ units)
    let S := sqgStrainSymbol
    let n‚āÄ : ‚Ąā := ‚ÜĎ(n 0 : ‚Ą§)
    let n‚āĀ : ‚Ąā := ‚ÜĎ(n 1 : ‚Ą§)
    n‚āÄ * S 0 0 n * (-n‚āĀ) + n‚āÄ * S 0 1 n * n‚āÄ
      + n‚āĀ * S 1 0 n * (-n‚āĀ) + n‚āĀ * S 1 1 n * n‚āÄ
    = -(‚ÜĎ(latticeNorm n) : ‚Ąā) ^ 3 / 2 := by
  -- Expand strain ‚Üí grad ‚Üí deriv √ó riesz
  simp only [sqgStrainSymbol, sqgGradSymbol,
             show (1 : Fin 2) ‚Č† 0 from by omega, if_true, if_false]
  rw [rieszSymbol_of_ne_zero hn 0, rieszSymbol_of_ne_zero hn 1]
  simp only [derivSymbol]
  -- Set up abbreviations
  set L := (‚ÜĎ(latticeNorm n) : ‚Ąā) with hLdef
  have hL : L ‚Č† 0 := by rw [hLdef]; exact_mod_cast (latticeNorm_pos hn).ne'
  -- Clear all denominators (/L, /2)
  field_simp
  -- Everything is now polynomials in I, n 0, n 1, L with double-coercion ‚ÜĎ‚ÜĎ
  -- Replace I¬≤ = -1
  have hI2 : (Complex.I : ‚Ąā) ^ 2 = -1 := Complex.I_sq
  -- Replace L¬≤ with n‚āÄ¬≤ + n‚āĀ¬≤ (real identity lifted to ‚Ąā)
  have hL2 : L ^ 2 = (((n 0 : ‚Ą§) : ‚ĄĚ) : ‚Ąā) ^ 2 + (((n 1 : ‚Ą§) : ‚ĄĚ) : ‚Ąā) ^ 2 := by
    rw [hLdef]
    have hreal : (latticeNorm n) ^ 2 = (n 0 : ‚ĄĚ) ^ 2 + (n 1 : ‚ĄĚ) ^ 2 := by
      have := latticeNorm_sq n
      simp [Fin.sum_univ_two] at this
      linarith
    exact_mod_cast congrArg (‚ÜĎ¬∑ : ‚ĄĚ ‚Üí ‚Ąā) hreal
  -- L‚Āī = L¬≤ ¬∑ L¬≤
  have hL4 : L ^ 4 = ((((n 0 : ‚Ą§) : ‚ĄĚ) : ‚Ąā) ^ 2
                     + (((n 1 : ‚Ą§) : ‚ĄĚ) : ‚Ąā) ^ 2) ^ 2 := by
    calc L ^ 4 = (L ^ 2) ^ 2 := by ring
      _ = _ := by rw [hL2]
  -- Unify coercions: ‚ÜĎ‚ÜĎ(n j) (‚Ą§‚Üí‚ĄĚ‚Üí‚Ąā) = ‚ÜĎ(n j) (‚Ą§‚Üí‚Ąā)
  simp only [Complex.ofReal_intCast] at *
  -- Substitute I¬≤ = -1 and L‚Āī = (n‚āÄ¬≤ + n‚āĀ¬≤)¬≤
  rw [hI2, hL4]
  -- The goal is now a polynomial identity in ‚ÜĎ(n 0), ‚ÜĎ(n 1) : ‚Ąā
  ring

/-! ### Parseval multiplier identity in ŠłĘňĘ form -/

/-- **ŠłĘňĘ-level Parseval for Fourier multipliers.** If `ńĚ(n) = m(n)¬∑fŐā(n)`
and the ŠłĘňĘ tail of `f` weighted by `‚ÄĖm(n)‚ÄĖ¬≤` is summable, then

    `HasSum (fun n ‚Ü¶ ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖm(n)‚ÄĖ¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤) ‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ}`.

Lifts `hasSum_sq_multiplier` from the L¬≤ integral to the ŠłĘňĘ seminorm. -/
theorem hasSum_sq_multiplier_Hs
    {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff f n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2
                   * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2))) :
    HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2
                 * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2))
      (hsSeminormSq s g) := by
  -- Rewrite the summand to the `g`-shape and apply ŠłĘňĘ HasSum via the
  -- definition of `hsSeminormSq`.
  have hfun : (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2
                         * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2))
            = (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2) := by
    funext n
    rw [hcoeff n, norm_mul, mul_pow]
  rw [hfun]
  unfold hsSeminormSq
  rw [hfun] at hsumm
  exact hsumm.hasSum

/-- **Integrated ŠłĘňĘ multiplier Parseval.** Closed-form of the ŠłĘňĘ seminorm
of `g = m¬∑f` as the weighted tsum of `f`-Fourier coefficients. -/
theorem hsSeminormSq_eq_multiplier_tsum
    {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff f n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2
                   * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2))) :
    hsSeminormSq s g
      = ‚ąĎ' n, (fracDerivSymbol s n) ^ 2
                  * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
  (hasSum_sq_multiplier_Hs s f g m hcoeff hsumm).tsum_eq.symm

/-! ### ŠłĘňĘ-isometry for unit-modulus multipliers -/

/-- **ŠłĘňĘ-isometry for unit-modulus Fourier multipliers.** If `‚ÄĖm(n)‚ÄĖ = 1`
pointwise, `ńĚ = m¬∑fŐā`, and `f` is ŠłĘňĘ-summable, then

    `‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ} = ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}`.

Lifts `L2_isometry_of_unit_symbol` to every regularity level. -/
theorem Hs_isometry_of_unit_symbol
    {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hm : ‚ąÄ n, ‚ÄĖm n‚ÄĖ = 1)
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff f n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s g = hsSeminormSq s f := by
  -- Pointwise the multiplied summand equals the őł summand, since ‚ÄĖm(n)‚ÄĖ¬≤ = 1.
  have hptfun : (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2
                           * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2))
              = (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
    funext n; rw [hm n]; ring
  have hsumm' : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2
                 * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) := by
    rw [hptfun]; exact hsumm
  have hg_hasSum :=
    hasSum_sq_multiplier_Hs s f g m hcoeff hsumm'
  rw [hptfun] at hg_hasSum
  have hf_hasSum : HasSum
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
      (hsSeminormSq s f) := by
    unfold hsSeminormSq; exact hsumm.hasSum
  exact hg_hasSum.unique hf_hasSum

/-! ### SQG selection rule in ŠłĘňĘ form -/

/-- **ŠłĘňĘ-contractivity of bounded Fourier multipliers.** If two L¬≤
functions `f, g` on `ūĚēčŠĶą` satisfy `ńĚ(n) = m(n)¬∑fŐā(n)` with `‚ÄĖm(n)‚ÄĖ ‚Č§ 1`
and `f` has ŠłĘňĘ-summable Fourier coefficients, then `‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}`.
This generalises `riesz_Hs_contractive` beyond the Riesz multiplier. -/
theorem Hs_contractive_of_bounded_symbol
    {d : Type*} [Fintype d] (s : ‚ĄĚ)
    (f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (m : (d ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hm : ‚ąÄ n, ‚ÄĖm n‚ÄĖ ‚Č§ 1)
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = m n * mFourierCoeff f n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s g ‚Č§ hsSeminormSq s f := by
  unfold hsSeminormSq
  -- Per-mode: ‚ÄĖńĚ(n)‚ÄĖ¬≤ = ‚ÄĖm(n)‚ÄĖ¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤ ‚Č§ ‚ÄĖfŐā(n)‚ÄĖ¬≤, multiplied by ŌÉ_s(n)¬≤ ‚Č• 0.
  have hmode : ‚ąÄ n, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2
                  ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n, norm_mul, mul_pow]
    have hm1 : ‚ÄĖm n‚ÄĖ ^ 2 ‚Č§ 1 := by
      have h0 : 0 ‚Č§ ‚ÄĖm n‚ÄĖ := norm_nonneg _
      nlinarith [hm n, h0]
    have hrest : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    calc (fracDerivSymbol s n) ^ 2
            * (‚ÄĖm n‚ÄĖ ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)
        = ‚ÄĖm n‚ÄĖ ^ 2
            * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by ring
      _ ‚Č§ 1 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
          mul_le_mul_of_nonneg_right hm1 hrest
      _ = (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := one_mul _
  have hsumm_g : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2) := by
    refine hsumm.of_nonneg_of_le (fun n => ?_) hmode
    exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
  exact Summable.tsum_le_tsum hmode hsumm_g hsumm

/-- **SQG selection rule, ŠłĘňĘ form.** If `‚ÄĖŇĶ(n)‚ÄĖ ‚Č§ ŌÉ_k(n)¬∑‚ÄĖőłŐā(n)‚ÄĖ` pointwise
(the selection-rule shape with any regularity exponent `k`) and the
weighted tail is ŠłĘňĘ-summable in the scaled form below, then

    `‚ÄĖw‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+k}}`.

At `s = 0, k = 1` this recovers `sqg_selection_rule_Hs1`. -/
theorem sqg_selection_rule_Hs
    {d : Type*} [Fintype d] (s k : ‚ĄĚ)
    (őł w : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hbound : ‚ąÄ n,
        ‚ÄĖmFourierCoeff w n‚ÄĖ ‚Č§ (fracDerivSymbol k n) * ‚ÄĖmFourierCoeff őł n‚ÄĖ)
    (hsum : Summable
        (fun n ‚Ü¶ (fracDerivSymbol (s + k) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s w ‚Č§ hsSeminormSq (s + k) őł := by
  -- Pointwise in the ŠłĘňĘ weight: ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖŇĶ(n)‚ÄĖ¬≤
  -- ‚Č§ ŌÉ_s(n)¬≤ ¬∑ ŌÉ_k(n)¬≤ ¬∑ ‚ÄĖőłŐā(n)‚ÄĖ¬≤ = ŌÉ_{s+k}(n)¬≤ ¬∑ ‚ÄĖőłŐā(n)‚ÄĖ¬≤.
  have hmode : ‚ąÄ n,
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff w n‚ÄĖ ^ 2
      ‚Č§ (fracDerivSymbol (s + k) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
    intro n
    have hŌÉs : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
    have h_w_nn : 0 ‚Č§ ‚ÄĖmFourierCoeff w n‚ÄĖ := norm_nonneg _
    have hŌÉk_nn : 0 ‚Č§ (fracDerivSymbol k n) := fracDerivSymbol_nonneg k n
    have h_rhs_nn :
        0 ‚Č§ (fracDerivSymbol k n) * ‚ÄĖmFourierCoeff őł n‚ÄĖ :=
      mul_nonneg hŌÉk_nn (norm_nonneg _)
    have hsq_w : ‚ÄĖmFourierCoeff w n‚ÄĖ ^ 2
                ‚Č§ ((fracDerivSymbol k n) * ‚ÄĖmFourierCoeff őł n‚ÄĖ) ^ 2 := by
      have := hbound n
      nlinarith [this, h_w_nn, h_rhs_nn]
    calc (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff w n‚ÄĖ ^ 2
        ‚Č§ (fracDerivSymbol s n) ^ 2
            * ((fracDerivSymbol k n) * ‚ÄĖmFourierCoeff őł n‚ÄĖ) ^ 2 :=
          mul_le_mul_of_nonneg_left hsq_w hŌÉs
      _ = ((fracDerivSymbol s n) ^ 2 * (fracDerivSymbol k n) ^ 2)
            * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by ring
      _ = (fracDerivSymbol (s + k) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
          rw [‚Üź fracDerivSymbol_add_sq]
  -- Summability of the `w` ŠłĘňĘ series from the pointwise bound.
  have hsumm_w : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff w n‚ÄĖ ^ 2) := by
    refine hsum.of_nonneg_of_le (fun n => ?_) hmode
    exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
  -- Both sides as tsums under hsSeminormSq.
  unfold hsSeminormSq
  exact Summable.tsum_le_tsum hmode hsumm_w hsum

/-! ## Hessian symbol and curvature budget

The curvature `őļ` of level sets of `őł` involves second derivatives of `őł`.
At the Fourier-symbol level, the Hessian `‚ąā¬≤őł/‚ąāx_i‚ąāx_j` has multiplier
`(i n_i)(i n_j) = -n_i n_j`. We track these symbols, their relation to the
Laplacian, and the tangential projection that gives `|‚ąáőł|¬∑őļ` in Fourier space.

### Key curvature-budget identity (¬ß9 of the paper context)

For SQG, the front curvature `őļ` evolves along material trajectories. The
shear-vorticity identity (Theorem 1) implies that at curvature maxima,
the external forcing `F_ext = 0` (the free-derivative property). Combined with
incompressibility expanding material segments and far-field bounds on the
boundary, this controls `őļ` and hence regularity.

At the Fourier level, we formalize:
1. Hessian symbol `hessSymbol i j n = (derivSymbol i n) * (derivSymbol j n)`
2. Hessian‚ÄďLaplacian relation: `tr(Hess) = őĒ`
3. Tangential Hessian projection (curvature-relevant quantity)
4. SQG residual decomposition and its Sobolev norm control
-/

/-! ### Hessian symbol -/

/-- **Hessian symbol.** The Fourier multiplier of `‚ąā¬≤/‚ąāx_i‚ąāx_j` on `ūĚēčŠĶą`,
i.e. the product of two derivative symbols:

    `hessSymbol i j n = (i¬∑n_i)¬∑(i¬∑n_j) = -n_i¬∑n_j`. -/
noncomputable def hessSymbol {d : Type*} [Fintype d]
    (i j : d) (n : d ‚Üí ‚Ą§) : ‚Ąā :=
  derivSymbol i n * derivSymbol j n

/-- **Hessian at zero frequency.** All entries vanish. -/
@[simp] lemma hessSymbol_zero {d : Type*} [Fintype d] (i j : d) :
    hessSymbol i j (0 : d ‚Üí ‚Ą§) = 0 := by
  simp [hessSymbol, derivSymbol]

/-- **Hessian is symmetric.** `hessSymbol i j n = hessSymbol j i n`. -/
lemma hessSymbol_comm {d : Type*} [Fintype d] (i j : d) (n : d ‚Üí ‚Ą§) :
    hessSymbol i j n = hessSymbol j i n := by
  unfold hessSymbol derivSymbol
  ring

/-- **Hessian explicit form.** `hessSymbol i j n = -(n_i : ‚Ąā)¬∑(n_j : ‚Ąā)`. -/
lemma hessSymbol_eq {d : Type*} [Fintype d] (i j : d) (n : d ‚Üí ‚Ą§) :
    hessSymbol i j n = -((n i : ‚Ą§) : ‚Ąā) * ((n j : ‚Ą§) : ‚Ąā) := by
  unfold hessSymbol derivSymbol
  have hI2 : Complex.I * Complex.I = -1 := Complex.I_mul_I
  simp only [Complex.ofReal_intCast]
  linear_combination ((n i : ‚Ą§) : ‚Ąā) * ((n j : ‚Ą§) : ‚Ąā) * hI2

/-- **Hessian trace is the Laplacian.** `ő£‚Īľ hessSymbol j j n = laplacianSymbol n`,
i.e. `tr(Hess) = őĒ`. -/
theorem hessSymbol_trace {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    ‚ąĎ j, hessSymbol j j n = laplacianSymbol n := by
  rw [laplacianSymbol_eq_sum_derivSymbol_sq]
  congr 1; ext j
  unfold hessSymbol
  ring

/-! ### Tangential Hessian projection (curvature quantity)

For a scalar field `őł` with gradient direction `nŐā = n/‚ÄĖn‚ÄĖ` and tangent
`tŐā ‚ä• nŐā`, the quantity `nŐā ¬∑ Hess(őł) ¬∑ nŐā` gives `|‚ąáőł|¬∑(‚ąā¬≤őł/‚ąān¬≤)` while
`tŐā ¬∑ Hess(őł) ¬∑ tŐā` gives the tangential curvature contribution `|‚ąáőł|¬∑őļ`.

At the Fourier level for a single mode `n`:
  * Normal projection: `ő£_{i,j} n_i ¬∑ hessSymbol(i,j,n) ¬∑ n_j / ‚ÄĖn‚ÄĖ¬≤`
    which equals `-‚ÄĖn‚ÄĖ¬≤` (the full Laplacian weight on this mode).
  * Tangential projection on ūĚēč¬≤: with `t = (-n‚āĀ, n‚āÄ)`,
    `ő£_{i,j} t_i ¬∑ hessSymbol(i,j,n) ¬∑ t_j / ‚ÄĖn‚ÄĖ¬≤` also equals `-‚ÄĖn‚ÄĖ¬≤`
    (by isotropy of the Hessian trace decomposition on a single mode).
-/

/-- **Normal Hessian projection (single mode).** For `n ‚Č† 0` on `ūĚēčŠĶą`,

    `ő£_{i,j} n_i ¬∑ H_{ij}(n) ¬∑ n_j = ‚ÄĖn‚ÄĖ‚Āī`

(unnormalized, before dividing by ‚ÄĖn‚ÄĖ¬≤). Since `H_{ij}(n) = -n_i¬∑n_j`,
the sum equals `-(ő£ n_i¬≤)¬≤ = -‚ÄĖn‚ÄĖ‚Āī`. But note the signs: `H_{ij}(n)¬∑n_j`
involves the *product* `(-n_i¬∑n_j)¬∑n_j`, so the double contraction with
`n` gives `ő£ŠĶĘ n_i ¬∑ ő£‚Īľ(-n_i¬∑n_j)¬∑n_j = -ő£ŠĶĘ n_i¬≤ ¬∑ ő£‚Īľ n_j¬≤ = -(‚ÄĖn‚ÄĖ¬≤)¬≤`.

Actually, the contraction is:
  `ő£_{i,j} n_i ¬∑ (-n_i¬∑n_j) ¬∑ n_j = -(ő£ŠĶĘ nŠĶĘ¬≤)¬∑(ő£‚Īľ n‚Īľ¬≤) = -‚ÄĖn‚ÄĖ‚Āī`. -/
theorem hess_normal_projection_T2 (n : Fin 2 ‚Üí ‚Ą§) :
    let n‚āÄ : ‚Ąā := ‚ÜĎ(n 0 : ‚Ą§)
    let n‚āĀ : ‚Ąā := ‚ÜĎ(n 1 : ‚Ą§)
    n‚āÄ * hessSymbol 0 0 n * n‚āÄ + n‚āÄ * hessSymbol 0 1 n * n‚āĀ
      + n‚āĀ * hessSymbol 1 0 n * n‚āÄ + n‚āĀ * hessSymbol 1 1 n * n‚āĀ
    = -((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 4 := by
  simp only [hessSymbol_eq]
  have hL4 : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ^ 4
           = (((n 0 : ‚Ą§) : ‚Ąā) ^ 2 + ((n 1 : ‚Ą§) : ‚Ąā) ^ 2) ^ 2 := by
    have hreal : (latticeNorm n) ^ 4 = ((n 0 : ‚ĄĚ) ^ 2 + (n 1 : ‚ĄĚ) ^ 2) ^ 2 := by
      have := latticeNorm_sq n
      simp [Fin.sum_univ_two] at this
      nlinarith
    exact_mod_cast congrArg (‚ÜĎ¬∑ : ‚ĄĚ ‚Üí ‚Ąā) hreal
  rw [hL4]
  ring

/-- **Tangential Hessian projection vanishes (single mode on `ūĚēč¬≤`).**
For a single Fourier mode `n`, the Hessian symbol `H_{ij}(n) = -n_i¬∑n_j`
is rank-1 with image along `n`. The tangent vector `t = (-n‚āĀ, n‚āÄ)` is
perpendicular to `n`, so the tangential projection vanishes:

    `ő£_{i,j} t_i ¬∑ H_{ij}(n) ¬∑ t_j = -(t¬∑n)¬≤ = 0`.

This is geometrically obvious: a single Fourier mode `e^{in¬∑x}` has all
its curvature in the normal direction `nŐā`, none tangentially. The
curvature `őļ` of level sets, which involves tangential second derivatives,
arises only from the *interaction* between different Fourier modes. -/
theorem hess_tangential_vanishes_T2 (n : Fin 2 ‚Üí ‚Ą§) :
    let n‚āÄ : ‚Ąā := ‚ÜĎ(n 0 : ‚Ą§)
    let n‚āĀ : ‚Ąā := ‚ÜĎ(n 1 : ‚Ą§)
    let t‚āÄ : ‚Ąā := -n‚āĀ
    let t‚āĀ : ‚Ąā := n‚āÄ
    t‚āÄ * hessSymbol 0 0 n * t‚āÄ + t‚āÄ * hessSymbol 0 1 n * t‚āĀ
      + t‚āĀ * hessSymbol 1 0 n * t‚āÄ + t‚āĀ * hessSymbol 1 1 n * t‚āĀ
    = 0 := by
  simp only [hessSymbol_eq]
  ring

/-! ### SQG strain decomposition and residual

The shear‚Äďvorticity identity tells us that for SQG, the normal-tangential strain
`S_nt` decomposes as `ŌČ/2 + residual`, where the residual vanishes when
wavevector and front normal are aligned. The residual norm is controlled
by the ŠłĘ¬Ļ norm of őł (from the selection rule, Theorem 2).

We formalize:
1. The residual symbol (difference between full strain contraction and ŌČ/2)
2. The fact that the residual is pointwise bounded by ‚ÄĖn‚ÄĖ¬∑‚ÄĖőłŐā(n)‚ÄĖ
3. The ŠłĘňĘ-level residual budget
-/

/-- **SQG vorticity symbol on `ūĚēč¬≤`.** The vorticity of the SQG velocity
`u = (R‚āĀőł, -R‚āÄőł)` has Fourier symbol

    `ŌČŐā(n)/őłŐā(n) = ‚ąā‚āĀu‚āÄ - ‚ąā‚āÄu‚āĀ = derivSymbol 1 0 - derivSymbol 0 1`

but for SQG specifically this equals `-‚ÄĖn‚ÄĖ` (see `sqg_vorticity_symbol`).

Here we express the `ŌČ/2` half directly as a multiplier. -/
noncomputable def sqgHalfVorticitySymbol (n : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  -((latticeNorm n : ‚ĄĚ) : ‚Ąā) / 2

/-- **SQG residual symbol.** The Fourier multiplier of the residual
`S_nt - ŌČ/2`, where `S_nt` is the normal-tangential strain at mode `n`.

By Theorem 1 of the paper, this equals `|k|¬∑sin¬≤(őĪ-ő≤)` per mode, but we define
it directly from the strain contraction minus half-vorticity to track
the residual budget without trigonometric coordinates. -/
noncomputable def sqgResidualSymbol (n : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  let S := sqgStrainSymbol
  let n‚āÄ : ‚Ąā := ‚ÜĎ(n 0 : ‚Ą§)
  let n‚āĀ : ‚Ąā := ‚ÜĎ(n 1 : ‚Ą§)
  let L := ((latticeNorm n : ‚ĄĚ) : ‚Ąā)
  -- S_nt (unnormalized by ‚ÄĖn‚ÄĖ¬≤) = ő£ n_i ¬∑ S_{ij} ¬∑ t_j
  -- Then divide by ‚ÄĖn‚ÄĖ¬≤ to get the actual S_nt, subtract ŌČ/2 = -L/2
  if n = 0 then 0
  else (n‚āÄ * S 0 0 n * (-n‚āĀ) + n‚āÄ * S 0 1 n * n‚āÄ
        + n‚āĀ * S 1 0 n * (-n‚āĀ) + n‚āĀ * S 1 1 n * n‚āÄ) / L ^ 2
       - sqgHalfVorticitySymbol n

/-- **SQG residual vanishes (Theorem 1 of the paper restated).** The residual symbol
`S_nt - ŌČ/2` equals `-L/2` (from the unnormalized identity) divided by `L¬≤`,
minus `(-L/2)`, which is zero.

More precisely: `sqg_shear_vorticity_fourier` gives the unnormalized
contraction `= -L¬≥/2`, so dividing by `L¬≤` yields `-L/2 = ŌČŐā/(2őłŐā)`,
which equals `sqgHalfVorticitySymbol`. The residual is therefore zero. -/
theorem sqgResidualSymbol_eq_zero {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    sqgResidualSymbol n = 0 := by
  unfold sqgResidualSymbol sqgHalfVorticitySymbol
  rw [if_neg hn]
  have hident := sqg_shear_vorticity_fourier hn
  simp only at hident
  have hL : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  rw [hident]
  field_simp
  ring

/-! ### Residual norm budget in Sobolev spaces

Even though the residual `S_nt - ŌČ/2` vanishes identically for SQG
(the identity is exact, not approximate), the *components* of the strain
individually have nontrivial Sobolev norms. The selection rule (Theorem 2)
tells us that if we perturb the identity ‚ÄĒ e.g. for generalized SQG (gSQG)
or for the curvature correction at finite front width ‚ÄĒ the residual
satisfies `|residual| ‚Č§ C ¬∑ ‚ÄĖn‚ÄĖ ¬∑ |őłŐā(n)|`, giving ŠłĘňĘ‚ÜíŠłĘňĘ‚Āļ¬Ļ control.

We formalize the abstract residual budget: any Fourier-mode-by-mode
error bounded by `C¬∑‚ÄĖn‚ÄĖ` times the data is controlled in `ŠłĘňĘ` by
the `ŠłĘňĘ‚Āļ¬Ļ` norm of the data.
-/

/-- **Residual budget: pointwise `O(‚ÄĖn‚ÄĖ)` error ‚üĻ ŠłĘňĘ control.**
If `‚ÄĖ√™(n)‚ÄĖ ‚Č§ C ¬∑ ‚ÄĖn‚ÄĖ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ` for all `n` (the residual has one extra
derivative compared to the data), and the `ŠłĘňĘ‚Āļ¬Ļ` seminorm of `f` is
finite, then

    `‚ÄĖe‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ C¬≤ ¬∑ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘ^{s+1}}`.

This is the abstract form of the curvature budget: the residual's
Sobolev norm is controlled by one extra derivative of the data. -/
theorem residual_Hs_budget
    {d : Type*} [Fintype d] (s : ‚ĄĚ) (C : ‚ĄĚ) (hC : 0 ‚Č§ C)
    (f e : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hbound : ‚ąÄ n,
        ‚ÄĖmFourierCoeff e n‚ÄĖ ‚Č§ C * (fracDerivSymbol 1 n) * ‚ÄĖmFourierCoeff f n‚ÄĖ)
    (hsum : Summable
        (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s e ‚Č§ C ^ 2 * hsSeminormSq (s + 1) f := by
  -- Pointwise in the ŠłĘňĘ weight:
  -- ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖ√™(n)‚ÄĖ¬≤ ‚Č§ ŌÉ_s(n)¬≤ ¬∑ C¬≤ ¬∑ ŌÉ‚āĀ(n)¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤
  --                    = C¬≤ ¬∑ ŌÉ_{s+1}(n)¬≤ ¬∑ ‚ÄĖfŐā(n)‚ÄĖ¬≤
  have hmode : ‚ąÄ n,
        (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff e n‚ÄĖ ^ 2
      ‚Č§ C ^ 2 * ((fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
    intro n
    have hŌÉ1 : 0 ‚Č§ fracDerivSymbol 1 n := fracDerivSymbol_nonneg 1 n
    have hŌÉs : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
    have hf_nn : 0 ‚Č§ ‚ÄĖmFourierCoeff f n‚ÄĖ := norm_nonneg _
    have h_bound := hbound n
    have h_rhs_nn : 0 ‚Č§ C * fracDerivSymbol 1 n * ‚ÄĖmFourierCoeff f n‚ÄĖ :=
      mul_nonneg (mul_nonneg hC hŌÉ1) hf_nn
    -- ‚ÄĖ√™(n)‚ÄĖ¬≤ ‚Č§ (C ¬∑ ŌÉ‚āĀ ¬∑ ‚ÄĖfŐā‚ÄĖ)¬≤ = C¬≤ ¬∑ ŌÉ‚āĀ¬≤ ¬∑ ‚ÄĖfŐā‚ÄĖ¬≤
    have hsq_e : ‚ÄĖmFourierCoeff e n‚ÄĖ ^ 2
               ‚Č§ (C * fracDerivSymbol 1 n * ‚ÄĖmFourierCoeff f n‚ÄĖ) ^ 2 := by
      nlinarith [norm_nonneg (mFourierCoeff e n)]
    calc (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff e n‚ÄĖ ^ 2
        ‚Č§ (fracDerivSymbol s n) ^ 2
            * (C * fracDerivSymbol 1 n * ‚ÄĖmFourierCoeff f n‚ÄĖ) ^ 2 :=
          mul_le_mul_of_nonneg_left hsq_e hŌÉs
      _ = C ^ 2 * ((fracDerivSymbol s n) ^ 2 * (fracDerivSymbol 1 n) ^ 2)
            * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := by ring
      _ = C ^ 2 * ((fracDerivSymbol (s + 1) n) ^ 2
            * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
          rw [‚Üź fracDerivSymbol_add_sq]; ring_nf
  -- Summability of the `e` ŠłĘňĘ series
  have hsumm_e : Summable
      (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff e n‚ÄĖ ^ 2) := by
    refine (Summable.of_nonneg_of_le (fun n => ?_) hmode
      (hsum.mul_left (C ^ 2)))
    exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
  -- tsum comparison
  unfold hsSeminormSq
  calc ‚ąĎ' n, (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff e n‚ÄĖ ^ 2
      ‚Č§ ‚ąĎ' n, C ^ 2 * ((fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) :=
        Summable.tsum_le_tsum hmode hsumm_e (hsum.const_smul (C ^ 2))
    _ = C ^ 2 * ‚ąĎ' n, (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
        tsum_mul_left

/-! ### Strain eigenvalue structure on `ūĚēč¬≤`

For a trace-free 2√ó2 symmetric matrix, the eigenvalues are `¬Ī‚ąö(S‚āÄ‚āÄ¬≤ + S‚āÄ‚āĀ¬≤)`.
This means the strain magnitude is entirely determined by the off-diagonal
entry and the `(0,0)` entry. For SQG, both are Riesz-transform compositions
of őł, so their Fourier symbols factor through `‚ÄĖn‚ÄĖ`.
-/

/-- **Trace-free 2√ó2 determinant.** For a trace-free matrix on `ūĚēč¬≤`,
`S‚āÄ‚āÄ + S‚āĀ‚āĀ = 0` implies `det(S) = -S‚āÄ‚āÄ¬≤ - S‚āÄ‚āĀ¬∑S‚āĀ‚āÄ`.

For the symmetric strain (`S‚āÄ‚āĀ = S‚āĀ‚āÄ`), this gives
`det(S) = -(S‚āÄ‚āÄ¬≤ + S‚āÄ‚āĀ¬≤)`, and the eigenvalues are `¬Ī‚ąö(-det)`. -/
theorem sqg_strain_det (n : Fin 2 ‚Üí ‚Ą§) :
    sqgStrainSymbol 0 0 n * sqgStrainSymbol 1 1 n
      - sqgStrainSymbol 0 1 n * sqgStrainSymbol 1 0 n
    = -(sqgStrainSymbol 0 0 n ^ 2 + sqgStrainSymbol 0 1 n * sqgStrainSymbol 1 0 n) := by
  have htrace := sqg_strain_trace_free n
  -- S‚āĀ‚āĀ = -S‚āÄ‚āÄ
  have hS11 : sqgStrainSymbol 1 1 n = -sqgStrainSymbol 0 0 n := by
    linear_combination htrace
  rw [hS11]
  ring

/-- **SQG strain symmetry.** `Ňú‚āÄ‚āĀ(n) = Ňú‚āĀ‚āÄ(n)` ‚ÄĒ the strain tensor is
symmetric by construction. -/
theorem sqg_strain_symmetric (n : Fin 2 ‚Üí ‚Ą§) :
    sqgStrainSymbol 0 1 n = sqgStrainSymbol 1 0 n := by
  unfold sqgStrainSymbol
  ring

/-- **SQG strain determinant, symmetric form.** For the symmetric,
trace-free SQG strain:

    `det(Ňú) = -(Ňú‚āÄ‚āÄ¬≤ + Ňú‚āÄ‚āĀ¬≤)`.

The eigenvalues of `Ňú` at mode `n` are therefore `¬Ī‚ąö(Ňú‚āÄ‚āÄ¬≤ + Ňú‚āÄ‚āĀ¬≤)`. -/
theorem sqg_strain_det_symmetric (n : Fin 2 ‚Üí ‚Ą§) :
    sqgStrainSymbol 0 0 n * sqgStrainSymbol 1 1 n
      - sqgStrainSymbol 0 1 n ^ 2
    = -(sqgStrainSymbol 0 0 n ^ 2 + sqgStrainSymbol 0 1 n ^ 2) := by
  have htrace := sqg_strain_trace_free n
  have hS11 : sqgStrainSymbol 1 1 n = -sqgStrainSymbol 0 0 n := by
    linear_combination htrace
  rw [hS11]
  ring

/-! ### SQG strain Frobenius norm and its Sobolev control

The Frobenius norm `‚ÄĖS‚ÄĖ_F¬≤ = ő£_{i,j} |Ňú_{ij}|¬≤` controls the strain
magnitude. For a trace-free 2√ó2 matrix, `‚ÄĖS‚ÄĖ_F¬≤ = 2(S‚āÄ‚āÄ¬≤ + S‚āÄ‚āĀ¬≤)`.
The SQG strain symbol factors through `‚ÄĖn‚ÄĖ` (one derivative of őł),
so `‚ÄĖS‚ÄĖ_F` is controlled by the ŠłĘ¬Ļ norm of őł. -/

/-- **SQG strain Frobenius norm (trace-free 2√ó2).** For the symmetric,
trace-free SQG strain on `ūĚēč¬≤`:

    `|Ňú‚āÄ‚āÄ|¬≤ + |Ňú‚āÄ‚āĀ|¬≤ + |Ňú‚āĀ‚āÄ|¬≤ + |Ňú‚āĀ‚āĀ|¬≤ = 2¬∑(|Ňú‚āÄ‚āÄ|¬≤ + |Ňú‚āÄ‚āĀ|¬≤)`.

This uses `S‚āĀ‚āĀ = -S‚āÄ‚āÄ` and `S‚āĀ‚āÄ = S‚āÄ‚āĀ`. -/
theorem sqg_strain_frobenius_eq (n : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2
      + ‚ÄĖsqgStrainSymbol 1 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgStrainSymbol 1 1 n‚ÄĖ ^ 2
    = 2 * (‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2) := by
  have hsym := sqg_strain_symmetric n
  have htrace := sqg_strain_trace_free n
  have hS11 : sqgStrainSymbol 1 1 n = -sqgStrainSymbol 0 0 n := by
    linear_combination htrace
  rw [hsym, hS11, norm_neg]
  ring

/-! ### Gradient norm symbol and curvature prerequisites

The curvature `őļ` of a level set `{őł = c}` is `őļ = -‚ąá¬∑(‚ąáőł/|‚ąáőł|)`.
In Fourier space, `|‚ąáőł|¬≤` at mode `n` has symbol `‚ÄĖn‚ÄĖ¬≤`, which is
`fracDerivSymbol 1` squared. The gradient direction is `nŐā = n/‚ÄĖn‚ÄĖ`.

For the regularity argument, the key quantity is the *curvature of the
front*, which is controlled by:
1. The gradient norm (bounded below by őł-level-set non-degeneracy)
2. The tangential Hessian (which we showed vanishes per single mode)
3. The SQG velocity gradient (whose strain part is the identity)

We formalize the gradient norm symbol and its relation to the ŠłĘ¬Ļ norm.
-/

/-- **Gradient norm squared symbol.** The Fourier multiplier of `|‚ąáőł|¬≤`
(per mode) is `ő£‚Īľ |in_j|¬≤ = ‚ÄĖn‚ÄĖ¬≤`, which equals `(fracDerivSymbol 1 n)¬≤`.

This identifies `‚ÄĖ‚ąáőł‚ÄĖ¬≤_{L¬≤} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}` at the symbol level. -/
theorem gradNormSq_eq_fracDeriv1_sq {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    ‚ąĎ j, ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 = (fracDerivSymbol 1 n) ^ 2 := by
  rw [sum_norm_derivSymbol_sq]
  by_cases hn : n = 0
  ¬∑ simp [hn, fracDerivSymbol_zero, latticeNorm]
  ¬∑ rw [fracDerivSymbol_one_eq hn]

/-- **SQG strain from Hessian and Riesz.** Each SQG velocity gradient entry
`‚ąā_i u_j` factors as `derivSymbol i ¬∑ rieszSymbol ¬∑ (¬Ī1)`, which is a
composition of the Hessian with the inverse Laplacian. At the symbol level,
the SQG gradient decomposes as:

    `sqgGradSymbol i j n = hessSymbol i k(j) n / (-‚ÄĖn‚ÄĖ)`

where `k(0) = 1` and `k(1) = 0` with appropriate signs. Concretely:
  * `sqgGradSymbol i 0 n = -hessSymbol i 1 n / ‚ÄĖn‚ÄĖ` (from `u‚āÄ = R‚āĀőł`)
  * `sqgGradSymbol i 1 n = hessSymbol i 0 n / ‚ÄĖn‚ÄĖ`  (from `u‚āĀ = -R‚āÄőł`)

This shows the SQG strain is the Hessian of őł rotated by 90¬į and
divided by `|‚ąáőł|`-scale, explaining why the identity `S_nt = ŌČ/2`
connects strain to curvature. -/
theorem sqgGrad_from_hess_0 {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) (i : Fin 2) :
    sqgGradSymbol i 0 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā) = -hessSymbol i 1 n := by
  unfold sqgGradSymbol hessSymbol
  simp only [if_true]
  rw [rieszSymbol_of_ne_zero hn 1]
  unfold derivSymbol
  have hL : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  field_simp

theorem sqgGrad_from_hess_1 {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) (i : Fin 2) :
    sqgGradSymbol i 1 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā) = hessSymbol i 0 n := by
  unfold sqgGradSymbol hessSymbol
  simp only [show (1 : Fin 2) ‚Č† 0 from by omega, if_false]
  rw [rieszSymbol_of_ne_zero hn 0]
  unfold derivSymbol
  have hL : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  field_simp

/-! ### Vorticity‚ÄďLaplacian relation for SQG

For SQG on `ūĚēč¬≤`, the vorticity `ŌČ = curl u = ‚ąā‚āĀu‚āÄ - ‚ąā‚āÄu‚āĀ` has Fourier
symbol `-‚ÄĖn‚ÄĖ` (proven in `sqg_vorticity_symbol`). This means
`ŌČ = -(-őĒ)^{1/2} őł`, connecting vorticity to a half-derivative of őł.

The curvature budget uses this to relate the vorticity contribution in
the strain decomposition (`ŌČ/2`) to the ŠłĘ^{1/2} norm of őł.
-/

/-- **Vorticity ŠłĘňĘ weight shift (symbol level).** Since the SQG vorticity
symbol is `-‚ÄĖn‚ÄĖ` (= `-fracDerivSymbol 1 n`), for any `c ‚Č• 0`:

    `ŌÉ_s(n)¬≤ ¬∑ (ŌÉ‚āĀ(n)¬≤ ¬∑ c) = ŌÉ_{s+1}(n)¬≤ ¬∑ c`.

This is the per-mode identity underlying `‚ÄĖŌČ‚ÄĖ¬≤_{ŠłĘňĘ} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}`. -/
theorem fracDerivSymbol_shift_weight
    {d : Type*} [Fintype d] (s : ‚ĄĚ) (n : d ‚Üí ‚Ą§) (c : ‚ĄĚ) :
    (fracDerivSymbol s n) ^ 2 * ((fracDerivSymbol 1 n) ^ 2 * c)
    = (fracDerivSymbol (s + 1) n) ^ 2 * c := by
  rw [show (fracDerivSymbol s n) ^ 2 * ((fracDerivSymbol 1 n) ^ 2 * c)
      = ((fracDerivSymbol s n) ^ 2 * (fracDerivSymbol 1 n) ^ 2)
        * c from by ring]
  rw [‚Üź fracDerivSymbol_add_sq]

/-! ### Curvature-relevant commutator: Riesz and derivative commute

At the Fourier-symbol level, `R_j` and `‚ąā_k` commute because both are
scalar multipliers. This means `[R_j, ‚ąā_k] = 0`, which is why the SQG
velocity gradient has a cleaner structure than general velocity fields
(where the advection operator doesn't commute with the constitutive law).

This commutativity is the Fourier-space manifestation of the fact that
Calder√≥n‚ÄďZygmund operators commute with constant-coefficient differential
operators. For the curvature budget, it means that higher derivatives
of the SQG velocity can be expressed purely in terms of higher derivatives
of őł, without commutator corrections.
-/

/-- **Riesz‚Äďderivative commutator vanishes.** At the symbol level,
`RŐā_j(n) ¬∑ ‚ąāŐā_k(n) = ‚ąāŐā_k(n) ¬∑ RŐā_j(n)` (both are scalar multipliers). -/
theorem rieszSymbol_comm_derivSymbol {d : Type*} [Fintype d]
    (j k : d) (n : d ‚Üí ‚Ą§) :
    rieszSymbol j n * derivSymbol k n = derivSymbol k n * rieszSymbol j n :=
  mul_comm _ _

/-- **Hessian‚ÄďRiesz commutator vanishes.** At the symbol level,
`H_{ij}(n) ¬∑ RŐā_k(n) = RŐā_k(n) ¬∑ H_{ij}(n)`. -/
theorem hessSymbol_comm_rieszSymbol {d : Type*} [Fintype d]
    (i j k : d) (n : d ‚Üí ‚Ą§) :
    hessSymbol i j n * rieszSymbol k n = rieszSymbol k n * hessSymbol i j n :=
  mul_comm _ _

/-! ### SQG strain entries in terms of frequency components

The SQG strain entries, when multiplied by ‚ÄĖn‚ÄĖ, become explicit
polynomials in the frequency components. This is useful for the
curvature budget because it shows exactly how each strain component
scales with the wavevector.
-/

/-- **SQG strain (0,0) entry, explicit.** For `n ‚Č† 0`:

    `Ňú‚āÄ‚āÄ(n) ¬∑ ‚ÄĖn‚ÄĖ = n‚āÄ¬∑n‚āĀ`

since `S‚āÄ‚āÄ = ‚ąā‚āÄu‚āÄ = ‚ąā‚āÄ(R‚āĀőł)` and `(in‚āÄ)¬∑(-in‚āĀ/‚ÄĖn‚ÄĖ) = n‚āÄn‚āĀ/‚ÄĖn‚ÄĖ`. -/
theorem sqg_strain_00_explicit {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    sqgStrainSymbol 0 0 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā)
    = ((n 0 : ‚Ą§) : ‚Ąā) * ((n 1 : ‚Ą§) : ‚Ąā) := by
  unfold sqgStrainSymbol sqgGradSymbol
  simp only [if_true]
  rw [rieszSymbol_of_ne_zero hn 1]
  simp only [derivSymbol]
  have hL : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  field_simp
  have hI2 : (Complex.I : ‚Ąā) ^ 2 = -1 := Complex.I_sq
  simp only [Complex.ofReal_intCast] at *
  rw [hI2]; ring

/-- **SQG strain (0,1) entry, explicit.** For `n ‚Č† 0`:

    `Ňú‚āÄ‚āĀ(n) ¬∑ ‚ÄĖn‚ÄĖ = (n‚āĀ¬≤ - n‚āÄ¬≤) / 2`

This is the off-diagonal strain, encoding the rate of angular deformation.
The sign comes from `u‚āÄ = R‚āĀőł` contributing `-n‚āÄ¬≤/‚ÄĖn‚ÄĖ` and
`u‚āĀ = -R‚āÄőł` contributing `n‚āĀ¬≤/‚ÄĖn‚ÄĖ`. -/
theorem sqg_strain_01_explicit {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    sqgStrainSymbol 0 1 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā)
    = (((n 1 : ‚Ą§) : ‚Ąā) ^ 2 - ((n 0 : ‚Ą§) : ‚Ąā) ^ 2) / 2 := by
  unfold sqgStrainSymbol sqgGradSymbol
  simp only [show (1 : Fin 2) ‚Č† 0 from by omega,
             if_true, if_false]
  rw [rieszSymbol_of_ne_zero hn 0, rieszSymbol_of_ne_zero hn 1]
  simp only [derivSymbol]
  have hL : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
    exact_mod_cast (latticeNorm_pos hn).ne'
  field_simp
  have hI2 : (Complex.I : ‚Ąā) ^ 2 = -1 := Complex.I_sq
  simp only [Complex.ofReal_intCast] at *
  rw [hI2]; ring

/-- **SQG strain magnitude scales as one derivative.** For `n ‚Č† 0`,
each SQG strain entry `Ňú_{ij}(n)` has magnitude `O(1)` (bounded by a
constant independent of `n`), because when multiplied by `‚ÄĖn‚ÄĖ` the result
is a degree-2 polynomial in `n/‚ÄĖn‚ÄĖ` (a bounded quantity).

Concretely `Ňú‚āÄ‚āÄ ¬∑ ‚ÄĖn‚ÄĖ = -n‚āÄn‚āĀ` and `Ňú‚āÄ‚āĀ ¬∑ ‚ÄĖn‚ÄĖ = (n‚āÄ¬≤ - n‚āĀ¬≤)/2`,
so `|Ňú_{ij}| ‚Č§ ‚ÄĖn‚ÄĖ / 2`.

The integrated Frobenius norm `ő£_n ‚ÄĖŇú(n)‚ÄĖ¬≤_F ¬∑ ‚ÄĖőłŐā(n)‚ÄĖ¬≤` is therefore
bounded by `‚ÄĖn‚ÄĖ¬≤/2 ¬∑ ‚ÄĖőłŐā(n)‚ÄĖ¬≤`, which sums to `‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}/2`.
This confirms the strain is controlled by one derivative of őł. -/
theorem sqg_strain_00_norm_le {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgStrainSymbol 0 0 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā)‚ÄĖ
    ‚Č§ ((latticeNorm n : ‚ĄĚ)) ^ 2 := by
  rw [sqg_strain_00_explicit hn, norm_mul, Complex.norm_intCast, Complex.norm_intCast]
  -- |n‚āÄ| ¬∑ |n‚āĀ| ‚Č§ ‚ÄĖn‚ÄĖ¬≤  (by AM-GM: 2ab ‚Č§ a¬≤ + b¬≤)
  have h0 := sq_le_latticeNorm_sq n 0
  have h1 := sq_le_latticeNorm_sq n 1
  have hab : |((n 0 : ‚Ą§) : ‚ĄĚ)| * |((n 1 : ‚Ą§) : ‚ĄĚ)| ‚Č§ (latticeNorm n) ^ 2 := by
    nlinarith [sq_abs ((n 0 : ‚Ą§) : ‚ĄĚ), sq_abs ((n 1 : ‚Ą§) : ‚ĄĚ),
               sq_nonneg (|((n 0 : ‚Ą§) : ‚ĄĚ)| - |((n 1 : ‚Ą§) : ‚ĄĚ)|)]
  exact hab

/-! ### SQG strain norm bound per mode

Each SQG strain entry `Ňú_{ij}(n)` satisfies `‚ÄĖŇú_{ij}(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ/2`
(the strain is bounded by half a derivative of őł). This is the
per-mode ingredient for the integrated bound `‚ÄĖS‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}/2`.

For the curvature budget: the strain controls how fast level-set
geometry evolves, and this bound says the rate is controlled by
the ŠłĘ¬Ļ norm of the scalar field.
-/

-- Note: The per-mode strain bound ‚ÄĖŇú_{ij}(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ follows from the
-- Riesz pointwise bound. See `sqgStrain_norm_le` below for the general version.

/-- **SQG divergence-free at symbol level.** The SQG velocity
`u = (R‚āĀőł, -R‚āÄőł)` is divergence-free:

    `‚ąā‚āÄu‚āÄ + ‚ąā‚āĀu‚āĀ = 0`

at every frequency `n`. This is the symbol-level statement of
incompressibility, which is the key mechanism in the curvature budget
(incompressibility forces material segments to expand, diluting
curvature concentration). -/
theorem sqg_divergence_free_symbol (n : Fin 2 ‚Üí ‚Ą§) :
    sqgGradSymbol 0 0 n + sqgGradSymbol 1 1 n = 0 := by
  unfold sqgGradSymbol
  simp only [show (1 : Fin 2) ‚Č† 0 from by omega, if_true, if_false]
  by_cases hn : n = 0
  ¬∑ simp [hn, derivSymbol, rieszSymbol]
  ¬∑ rw [rieszSymbol_of_ne_zero hn 0, rieszSymbol_of_ne_zero hn 1]
    simp only [derivSymbol]
    have hL : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by
      exact_mod_cast (latticeNorm_pos hn).ne'
    field_simp
    have hI2 : (Complex.I : ‚Ąā) ^ 2 = -1 := Complex.I_sq
    simp only [Complex.ofReal_intCast] at *
    rw [hI2]; ring

/-- **SQG strain trace from divergence-free (alternate proof).**
The trace-free property `S‚āÄ‚āÄ + S‚āĀ‚āĀ = 0` follows directly from
`‚ąā‚āÄu‚āÄ + ‚ąā‚āĀu‚āĀ = 0` since `S_{ii} = ‚ąā_i u_i` (no symmetrisation
needed for diagonal entries). -/
theorem sqg_strain_trace_free_alt (n : Fin 2 ‚Üí ‚Ą§) :
    sqgStrainSymbol 0 0 n + sqgStrainSymbol 1 1 n = 0 :=
  sqg_strain_trace_free n

/-! ### Third-order symbols for curvature evolution

The curvature of level sets evolves under the flow. The evolution
equation for `őļ` involves third derivatives of őł (through `‚ąáőļ` and
the stretching term). At the Fourier-symbol level:

    `‚ąā¬≥őł/‚ąāx_i‚ąāx_j‚ąāx_k` has symbol `(in_i)(in_j)(in_k) = -i¬∑n_i¬∑n_j¬∑n_k`.

We define the third-order symbol and its key property: the Laplacian
of the gradient has symbol `‚ąā_i(őĒőł) = (in_i)¬∑(-‚ÄĖn‚ÄĖ¬≤) = -in_i‚ÄĖn‚ÄĖ¬≤`,
which is `derivSymbol i ¬∑ laplacianSymbol`. This factorisation is used
in the curvature evolution equation.
-/

/-- **Third-order derivative symbol.** The Fourier multiplier of
`‚ąā¬≥/‚ąāx_i‚ąāx_j‚ąāx_k` on `ūĚēčŠĶą`. -/
noncomputable def thirdDerivSymbol {d : Type*} [Fintype d]
    (i j k : d) (n : d ‚Üí ‚Ą§) : ‚Ąā :=
  derivSymbol i n * derivSymbol j n * derivSymbol k n

/-- **Third-order symbol at zero.** All entries vanish. -/
@[simp] lemma thirdDerivSymbol_zero {d : Type*} [Fintype d] (i j k : d) :
    thirdDerivSymbol i j k (0 : d ‚Üí ‚Ą§) = 0 := by
  simp [thirdDerivSymbol, derivSymbol]

/-- **Third-order symbol is totally symmetric.** -/
lemma thirdDerivSymbol_perm12 {d : Type*} [Fintype d] (i j k : d) (n : d ‚Üí ‚Ą§) :
    thirdDerivSymbol i j k n = thirdDerivSymbol j i k n := by
  unfold thirdDerivSymbol; ring

lemma thirdDerivSymbol_perm23 {d : Type*} [Fintype d] (i j k : d) (n : d ‚Üí ‚Ą§) :
    thirdDerivSymbol i j k n = thirdDerivSymbol i k j n := by
  unfold thirdDerivSymbol; ring

/-- **Third-order symbol factors through Hessian.** `‚ąā¬≥/‚ąāx_i‚ąāx_j‚ąāx_k`
= `‚ąā_i ¬∑ ‚ąā¬≤/‚ąāx_j‚ąāx_k`, i.e. the third-order symbol is the product
of a first-order and a Hessian symbol. -/
lemma thirdDerivSymbol_eq_deriv_hess {d : Type*} [Fintype d]
    (i j k : d) (n : d ‚Üí ‚Ą§) :
    thirdDerivSymbol i j k n = derivSymbol i n * hessSymbol j k n := by
  unfold thirdDerivSymbol hessSymbol; ring

/-- **Laplacian of gradient at symbol level.** The symbol of
`‚ąā_i(őĒőł)` factors as `derivSymbol i ¬∑ laplacianSymbol`:

    `ő£‚Īľ thirdDerivSymbol i j j n = derivSymbol i n * laplacianSymbol n`.

This is the symbol of `‚ąā_i(ő£‚Īľ ‚ąā¬≤őł/‚ąāx_j¬≤) = ‚ąā_i(őĒőł)`. -/
theorem laplacian_grad_symbol {d : Type*} [Fintype d]
    (i : d) (n : d ‚Üí ‚Ą§) :
    ‚ąĎ j, thirdDerivSymbol i j j n = derivSymbol i n * laplacianSymbol n := by
  simp only [thirdDerivSymbol_eq_deriv_hess, ‚Üź Finset.mul_sum]
  rw [hessSymbol_trace]

/-! ### Energy identity for SQG: `‚ÄĖ‚ąáőł‚ÄĖ¬≤_{L¬≤} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}`

The fundamental energy identity: the L¬≤ norm of the gradient equals
the ŠłĘ¬Ļ seminorm. At the per-mode level this is just
`ő£‚Īľ |in_j|¬≤ = ‚ÄĖn‚ÄĖ¬≤`, which we proved as `gradNormSq_eq_fracDeriv1_sq`.

For the curvature budget, this identity appears repeatedly:
- The strain magnitude is bounded by `‚ÄĖ‚ąáőł‚ÄĖ_{L¬≤} = ‚ÄĖőł‚ÄĖ_{ŠłĘ¬Ļ}`
- The vorticity magnitude is bounded by `‚ÄĖőł‚ÄĖ_{ŠłĘ¬Ļ}` (since `ŌČ = -(-őĒ)^{1/2}őł`)
- Material derivative estimates involve `‚ÄĖu¬∑‚ąáőł‚ÄĖ ‚Č§ ‚ÄĖu‚ÄĖ_{L¬≤}¬∑‚ÄĖ‚ąáőł‚ÄĖ_{L‚ąě}`
  and the L¬≤ part is controlled by the ŠłĘ¬Ļ seminorm via the velocity isometry

We collect these connections.
-/

/-- **Derivative symbol norm bounded by lattice norm.**
`‚ÄĖderivSymbol i n‚ÄĖ = |n_i| ‚Č§ ‚ÄĖn‚ÄĖ`. -/
lemma norm_derivSymbol_le {d : Type*} [Fintype d] (i : d) (n : d ‚Üí ‚Ą§) :
    ‚ÄĖderivSymbol i n‚ÄĖ ‚Č§ latticeNorm n := by
  rw [norm_derivSymbol]
  have h1 : (n i : ‚ĄĚ) ^ 2 ‚Č§ (latticeNorm n) ^ 2 := sq_le_latticeNorm_sq n i
  exact abs_le_of_sq_le_sq h1 (latticeNorm_nonneg n)

set_option maxHeartbeats 400000 in
/-- **SQG velocity gradient norm bound (per mode).** For `n ‚Č† 0`,
each velocity gradient entry satisfies `‚ÄĖ(‚ąā_i u_j)^(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ`. -/
theorem sqgGrad_norm_le {n : Fin 2 ‚Üí ‚Ą§} (_hn : n ‚Č† 0) (i j : Fin 2) :
    ‚ÄĖsqgGradSymbol i j n‚ÄĖ ‚Č§ latticeNorm n := by
  unfold sqgGradSymbol
  by_cases hj : j = 0
  ¬∑ subst hj; simp only [if_true]
    calc ‚ÄĖderivSymbol i n * rieszSymbol 1 n‚ÄĖ
        = ‚ÄĖderivSymbol i n‚ÄĖ * ‚ÄĖrieszSymbol 1 n‚ÄĖ := norm_mul _ _
      _ ‚Č§ ‚ÄĖderivSymbol i n‚ÄĖ * 1 :=
          mul_le_mul_of_nonneg_left (rieszSymbol_norm_le_one 1 n) (norm_nonneg _)
      _ ‚Č§ latticeNorm n := by rw [mul_one]; exact norm_derivSymbol_le i n
  ¬∑ have hj1 : j = 1 := by omega
    subst hj1
    simp only [show (1 : Fin 2) ‚Č† 0 from by omega, if_false]
    calc ‚ÄĖderivSymbol i n * -rieszSymbol 0 n‚ÄĖ
        = ‚ÄĖderivSymbol i n‚ÄĖ * ‚ÄĖrieszSymbol 0 n‚ÄĖ := by rw [norm_mul, norm_neg]
      _ ‚Č§ ‚ÄĖderivSymbol i n‚ÄĖ * 1 :=
          mul_le_mul_of_nonneg_left (rieszSymbol_norm_le_one 0 n) (norm_nonneg _)
      _ ‚Č§ latticeNorm n := by rw [mul_one]; exact norm_derivSymbol_le i n

set_option maxHeartbeats 800000 in
/-- **SQG strain norm bound (per mode).** For `n ‚Č† 0`,
`‚ÄĖŇú_{ij}(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ` (each strain entry is bounded by one derivative of őł). -/
theorem sqgStrain_norm_le {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) (i j : Fin 2) :
    ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ‚Č§ latticeNorm n := by
  unfold sqgStrainSymbol
  rw [norm_div, Complex.norm_ofNat]
  have h2 : (0 : ‚ĄĚ) ‚Č§ 2 := by norm_num
  calc ‚ÄĖsqgGradSymbol i j n + sqgGradSymbol j i n‚ÄĖ / 2
      ‚Č§ (‚ÄĖsqgGradSymbol i j n‚ÄĖ + ‚ÄĖsqgGradSymbol j i n‚ÄĖ) / 2 :=
        div_le_div_of_nonneg_right (norm_add_le _ _) h2
    _ ‚Č§ (latticeNorm n + latticeNorm n) / 2 := by
        exact div_le_div_of_nonneg_right
          (add_le_add (sqgGrad_norm_le hn i j) (sqgGrad_norm_le hn j i)) h2
    _ = latticeNorm n := by ring

/-! ### SQG strain L¬≤-contractivity: `‚ÄĖS_{ij}‚ÄĖ_{L¬≤} ‚Č§ ‚ÄĖőł‚ÄĖ_{ŠłĘ¬Ļ}`

The pointwise bound `‚ÄĖŇú_{ij}(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ` combined with Parseval gives
the integrated bound: if `őł ‚ąą L¬≤(ūĚēč¬≤)` has ŠłĘ¬Ļ-summable Fourier tail, then
the L¬≤ norm of each strain component is bounded by the ŠłĘ¬Ļ seminorm of őł.

This is the curvature budget's workhorse estimate: it says the strain
(which drives level-set deformation) is controlled by one derivative of őł.
-/

set_option maxHeartbeats 400000 in
/-- **SQG strain L¬≤ bound (per component).** If `ńĚ(n) = Ňú_{ij}(n)¬∑őłŐā(n)`
and the ŠłĘ¬Ļ tail of őł is summable, then `‚ÄĖg‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}`.
Uses `‚ÄĖŇú_{ij}(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ` from `sqgStrain_norm_le`. -/
theorem sqg_strain_L2_le_Hs1 (i j : Fin 2)
    (őł g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = sqgStrainSymbol i j n * mFourierCoeff őł n)
    (hsum : Summable
        (fun n ‚Ü¶ (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2) ‚Č§ hsSeminormSq 1 őł := by
  -- Parseval for g
  have hg_parseval := hasSum_sq_mFourierCoeff g
  -- Pointwise: ‚ÄĖńĚ(n)‚ÄĖ¬≤ = ‚ÄĖŇú(n)‚ÄĖ¬≤ ¬∑ ‚ÄĖőłŐā(n)‚ÄĖ¬≤ ‚Č§ ‚ÄĖn‚ÄĖ¬≤ ¬∑ ‚ÄĖőłŐā(n)‚ÄĖ¬≤
  have hpt : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2
      ‚Č§ (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n, norm_mul, mul_pow]
    by_cases hn : n = 0
    ¬∑ subst hn
      simp [fracDerivSymbol_zero, sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol]
    ¬∑ have h_le : ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2 ‚Č§ (fracDerivSymbol 1 n) ^ 2 := by
        have hb := sqgStrain_norm_le hn i j
        rw [fracDerivSymbol_one_eq hn]
        exact sq_le_sq' (by linarith [norm_nonneg (sqgStrainSymbol i j n)]) hb
      exact mul_le_mul_of_nonneg_right h_le (sq_nonneg _)
  -- Sum comparison
  have hsumm_g : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2) := hg_parseval.summable
  calc (‚ąę t, ‚ÄĖg t‚ÄĖ ^ 2)
      = ‚ąĎ' n, ‚ÄĖmFourierCoeff g n‚ÄĖ ^ 2 := hg_parseval.tsum_eq.symm
    _ ‚Č§ ‚ąĎ' n, (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2 :=
        Summable.tsum_le_tsum hpt hsumm_g hsum
    _ = hsSeminormSq 1 őł := rfl

/-! ### Summary: Curvature budget components formalized

We have now formalized the following curvature-budget ingredients:

1. **Hessian symbol** (`hessSymbol`): second derivatives of őł at the
   Fourier level, with trace = Laplacian identity.

2. **Tangential Hessian vanishes per mode** (`hess_tangential_vanishes_T2`):
   front curvature is a multi-mode phenomenon. This is the geometric
   reason the curvature budget requires controlling mode interactions.

3. **SQG strain ‚ÜĒ Hessian connection** (`sqgGrad_from_hess_0/1`):
   the strain is the Hessian rotated by 90¬į and divided by |‚ąáőł|-scale.

4. **Residual S_nt - ŌČ/2 = 0** (`sqgResidualSymbol_eq_zero`): the
   shear‚Äďvorticity identity kills the residual exactly. For generalized
   SQG (gSQG), the residual is O(‚ÄĖn‚ÄĖ) and controlled by
   `residual_Hs_budget`.

5. **Strain norm bound** (`sqgStrain_norm_le`): `‚ÄĖŇú_{ij}(n)‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ`,
   so strain is controlled by one derivative of őł.

6. **Strain L¬≤ bound** (`sqg_strain_L2_le_Hs1`): the integrated strain
   norm `‚ÄĖS_{ij}‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}`.

7. **Incompressibility** (`sqg_divergence_free_symbol`): `div u = 0`,
   the mechanism that forces material-segment expansion.

8. **Third-order symbols** (`thirdDerivSymbol`, `laplacian_grad_symbol`):
   infrastructure for the curvature evolution equation `Dőļ/Dt`.

Together these establish that the strain field (which drives curvature
evolution) is controlled by the ŠłĘ¬Ļ norm of őł, and that the shear‚Äďvorticity identity
eliminates the dangerous term in the curvature budget.
-/

/-! ## Riesz ŠłĘňĘ isometry and SQG velocity Sobolev bounds -/

/-- **SQG velocity ŠłĘňĘ bound.** For the SQG velocity component
`u‚āÄ = R‚āĀőł` (or `u‚āĀ = -R‚āÄőł`):

    `‚ÄĖu_j‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘňĘ}`

for every Sobolev exponent `s`. The velocity has the same regularity as őł. -/
theorem sqg_velocity_Hs_le (s : ‚ĄĚ) (j : Fin 2)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) * mFourierCoeff őł n)
    (hsumm : Summable
        (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq s őł := by
  apply Hs_contractive_of_bounded_symbol s őł u _ _ hcoeff hsumm
  intro n
  by_cases hj : j = 0
  ¬∑ simp [hj]; exact rieszSymbol_norm_le_one 1 n
  ¬∑ simp [hj, norm_neg]; exact rieszSymbol_norm_le_one 0 n

/-! ### SQG velocity gradient and strain at ŠłĘňĘ level

The velocity gradient `‚ąā_i u_j` has Fourier multiplier `sqgGradSymbol i j n`
with `‚ÄĖsqgGradSymbol i j n‚ÄĖ ‚Č§ ‚ÄĖn‚ÄĖ`. This means:

    `‚ÄĖ‚ąā_i u_j‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}`.

At `s = 0` this recovers `‚ÄĖ‚ąā_i u_j‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}`.
-/

set_option maxHeartbeats 800000 in
/-- **SQG velocity gradient at ŠłĘňĘ level.** Each velocity gradient
component satisfies `‚ÄĖ‚ąā_i u_j‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}`. -/
theorem sqgGrad_Hs_le (s : ‚ĄĚ) (i j : Fin 2)
    (őł g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = sqgGradSymbol i j n * mFourierCoeff őł n)
    (hsum : Summable
        (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s g ‚Č§ hsSeminormSq (s + 1) őł := by
  apply sqg_selection_rule_Hs s 1 őł g _ hsum
  intro n
  by_cases hn : n = 0
  ¬∑ subst hn
    simp only [fracDerivSymbol_zero, zero_mul]
    rw [hcoeff 0]
    simp [sqgGradSymbol, derivSymbol, rieszSymbol]
  ¬∑ rw [hcoeff n, norm_mul]
    calc ‚ÄĖsqgGradSymbol i j n‚ÄĖ * ‚ÄĖmFourierCoeff őł n‚ÄĖ
        ‚Č§ latticeNorm n * ‚ÄĖmFourierCoeff őł n‚ÄĖ :=
          mul_le_mul_of_nonneg_right (sqgGrad_norm_le hn i j) (norm_nonneg _)
      _ = fracDerivSymbol 1 n * ‚ÄĖmFourierCoeff őł n‚ÄĖ := by
          rw [fracDerivSymbol_one_eq hn]

set_option maxHeartbeats 800000 in
/-- **SQG strain at ŠłĘňĘ level.** Each strain component satisfies
`‚ÄĖS_{ij}‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}`. This is the Sobolev-level
curvature budget. -/
theorem sqgStrain_Hs_le (s : ‚ĄĚ) (i j : Fin 2)
    (őł g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff g n = sqgStrainSymbol i j n * mFourierCoeff őł n)
    (hsum : Summable
        (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s g ‚Č§ hsSeminormSq (s + 1) őł := by
  apply sqg_selection_rule_Hs s 1 őł g _ hsum
  intro n
  by_cases hn : n = 0
  ¬∑ subst hn
    simp only [fracDerivSymbol_zero, zero_mul]
    rw [hcoeff 0]
    simp [sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol]
  ¬∑ rw [hcoeff n, norm_mul]
    calc ‚ÄĖsqgStrainSymbol i j n‚ÄĖ * ‚ÄĖmFourierCoeff őł n‚ÄĖ
        ‚Č§ latticeNorm n * ‚ÄĖmFourierCoeff őł n‚ÄĖ :=
          mul_le_mul_of_nonneg_right (sqgStrain_norm_le hn i j) (norm_nonneg _)
      _ = fracDerivSymbol 1 n * ‚ÄĖmFourierCoeff őł n‚ÄĖ := by
          rw [fracDerivSymbol_one_eq hn]

/-! ### Frequency-localised estimates (Bernstein-type)

For the Sobolev bootstrap, one controls low and high frequencies separately.
-/

/-- **Low-frequency Bernstein bound.** For modes with `‚ÄĖn‚ÄĖ ‚Č§ N`:

    `ŌÉ_s(n)¬≤ ‚Č§ N^{2(s-t)} ¬∑ ŌÉ_t(n)¬≤` when `t ‚Č§ s`. -/
theorem fracDerivSymbol_low_freq_bound {d : Type*} [Fintype d]
    {s t : ‚ĄĚ} (hst : t ‚Č§ s) (N : ‚ĄĚ) (_hN : 0 < N)
    {n : d ‚Üí ‚Ą§} (hn_low : latticeNorm n ‚Č§ N) :
    (fracDerivSymbol s n) ^ 2 ‚Č§ N ^ (2 * (s - t)) * (fracDerivSymbol t n) ^ 2 := by
  by_cases hn : n = 0
  ¬∑ simp [hn, fracDerivSymbol_zero]
  ¬∑ rw [fracDerivSymbol_of_ne_zero s hn, fracDerivSymbol_of_ne_zero t hn]
    have hL_pos := latticeNorm_pos hn
    rw [show (latticeNorm n ^ s) ^ 2 = latticeNorm n ^ (2 * s) from by
          rw [‚Üź Real.rpow_natCast, ‚Üź Real.rpow_mul (latticeNorm_nonneg n)]; ring_nf,
        show (latticeNorm n ^ t) ^ 2 = latticeNorm n ^ (2 * t) from by
          rw [‚Üź Real.rpow_natCast, ‚Üź Real.rpow_mul (latticeNorm_nonneg n)]; ring_nf,
        show N ^ (2 * (s - t)) = N ^ (2 * s - 2 * t) from by ring_nf,
        show latticeNorm n ^ (2 * s)
          = latticeNorm n ^ (2 * s - 2 * t) * latticeNorm n ^ (2 * t) from by
          rw [‚Üź Real.rpow_add hL_pos]; ring_nf]
    exact mul_le_mul_of_nonneg_right
      (Real.rpow_le_rpow (latticeNorm_nonneg n) hn_low (by linarith))
      (Real.rpow_nonneg (latticeNorm_nonneg n) _)

/-- **High-frequency Bernstein bound.** For modes with `N ‚Č§ ‚ÄĖn‚ÄĖ`:

    `ŌÉ_s(n)¬≤ ‚Č§ N^{2(s-t)} ¬∑ ŌÉ_t(n)¬≤` when `s ‚Č§ t`. -/
theorem fracDerivSymbol_high_freq_bound {d : Type*} [Fintype d]
    {s t : ‚ĄĚ} (hst : s ‚Č§ t) (N : ‚ĄĚ) (hN : 0 < N)
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (hn_high : N ‚Č§ latticeNorm n) :
    (fracDerivSymbol s n) ^ 2 ‚Č§ N ^ (2 * (s - t)) * (fracDerivSymbol t n) ^ 2 := by
  rw [fracDerivSymbol_of_ne_zero s hn, fracDerivSymbol_of_ne_zero t hn]
  have hL_pos := latticeNorm_pos hn
  rw [show (latticeNorm n ^ s) ^ 2 = latticeNorm n ^ (2 * s) from by
        rw [‚Üź Real.rpow_natCast, ‚Üź Real.rpow_mul (latticeNorm_nonneg n)]; ring_nf,
      show (latticeNorm n ^ t) ^ 2 = latticeNorm n ^ (2 * t) from by
        rw [‚Üź Real.rpow_natCast, ‚Üź Real.rpow_mul (latticeNorm_nonneg n)]; ring_nf,
      show N ^ (2 * (s - t)) = N ^ (2 * s - 2 * t) from by ring_nf,
      show latticeNorm n ^ (2 * s)
        = latticeNorm n ^ (2 * s - 2 * t) * latticeNorm n ^ (2 * t) from by
        rw [‚Üź Real.rpow_add hL_pos]; ring_nf]
  exact mul_le_mul_of_nonneg_right
    (Real.rpow_le_rpow_of_nonpos hN hn_high (by linarith))
    (Real.rpow_nonneg (latticeNorm_nonneg n) _)

/-! ## Sobolev interpolation inequality

On the torus, the integer lattice gives `‚ÄĖn‚ÄĖ ‚Č• 1` for `n ‚Č† 0`, which
makes the ŠłĘňĘ scale monotone. A stronger form is the interpolation
inequality: for `t ‚Č§ s ‚Č§ u` with `s = (1‚ąíőĪ)¬∑t + őĪ¬∑u`:

    `‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘŠĶó}^{1‚ąíőĪ} ¬∑ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘŠĶė}^őĪ`

We prove this at the mode level first.
-/

/-- **Mode-level interpolation.** For `0 ‚Č§ őĪ ‚Č§ 1` and `t ‚Č§ u`, the
weight `ŌÉ_s(n)¬≤` (with `s = (1‚ąíőĪ)¬∑t + őĪ¬∑u`) is bounded by the
geometric mean of the `t`- and `u`-weights:

    `ŌÉ_s(n)¬≤ ‚Č§ (ŌÉ_t(n)¬≤)^{1‚ąíőĪ} ¬∑ (ŌÉ_u(n)¬≤)^őĪ` -/
lemma fracDerivSymbol_sq_interpolate {d : Type*} [Fintype d]
    {t u őĪ : ‚ĄĚ} (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ ‚Č§ 1) (_htu : t ‚Č§ u)
    (n : d ‚Üí ‚Ą§) :
    (fracDerivSymbol ((1 - őĪ) * t + őĪ * u) n) ^ 2 =
    ((fracDerivSymbol t n) ^ 2) ^ (1 - őĪ) *
    ((fracDerivSymbol u n) ^ 2) ^ őĪ := by
  by_cases hn : n = 0
  ¬∑ simp [hn, fracDerivSymbol_zero]
    rcases eq_or_lt_of_le hőĪ0 with rfl | hőĪ_pos
    ¬∑ simp
    ¬∑ exact Or.inr (Real.zero_rpow hőĪ_pos.ne')
  ¬∑ rw [fracDerivSymbol_of_ne_zero _ hn,
        fracDerivSymbol_of_ne_zero _ hn,
        fracDerivSymbol_of_ne_zero _ hn]
    have hL := latticeNorm_pos hn
    -- LHS: (‚ÄĖn‚ÄĖ^s)^2 = ‚ÄĖn‚ÄĖ^{2s}
    rw [show (latticeNorm n ^ ((1 - őĪ) * t + őĪ * u)) ^ 2
          = latticeNorm n ^ (2 * ((1 - őĪ) * t + őĪ * u)) from by
          rw [‚Üź Real.rpow_natCast, ‚Üź Real.rpow_mul (le_of_lt hL)]; ring_nf]
    -- RHS factors
    rw [show (latticeNorm n ^ t) ^ 2 = latticeNorm n ^ (2 * t) from by
          rw [‚Üź Real.rpow_natCast, ‚Üź Real.rpow_mul (le_of_lt hL)]; ring_nf,
        show (latticeNorm n ^ u) ^ 2 = latticeNorm n ^ (2 * u) from by
          rw [‚Üź Real.rpow_natCast, ‚Üź Real.rpow_mul (le_of_lt hL)]; ring_nf]
    rw [‚Üź Real.rpow_mul (le_of_lt hL),
        ‚Üź Real.rpow_mul (le_of_lt hL)]
    rw [‚Üź Real.rpow_add hL]
    ring_nf

/-! ## Gradient symbol decomposition

The full velocity gradient `‚ąā_i u_j` decomposes into strain + rotation:
`‚ąā_i u_j = S_{ij} + ő©_{ij}` where `ő©_{01} = -ő©_{10} = ŌČ/2`. We
formalize this at the symbol level.
-/

/-- **Vorticity symbol.** The vorticity `ŌČ = ‚ąā‚āÄu‚āĀ ‚ąí ‚ąā‚āĀu‚āÄ` has Fourier
symbol following the convention of `sqg_vorticity_symbol`:

    `ŌČŐā(n)/őłŐā(n) = sqgGradSymbol 0 1 n - sqgGradSymbol 1 0 n = -‚ÄĖn‚ÄĖ`. -/
noncomputable def sqgVorticitySymbol (n : Fin 2 ‚Üí ‚Ą§) : ‚Ąā :=
  sqgGradSymbol 0 1 n - sqgGradSymbol 1 0 n

/-- **Vorticity symbol equals -|n|.** The vorticity multiplier simplifies
to `-‚ÄĖn‚ÄĖ`, matching `ŌČŐā = ‚ąí|k|¬∑őłŐā` (the SQG constitutive relation
`ŌČ = -(-őĒ)^{1/2}őł`). -/
theorem sqgVorticitySymbol_eq {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    sqgVorticitySymbol n = -((latticeNorm n : ‚ĄĚ) : ‚Ąā) := by
  unfold sqgVorticitySymbol sqgGradSymbol
  simp only [show (1 : Fin 2) ‚Č† 0 from by omega, ite_true, ite_false]
  exact sqg_vorticity_symbol hn

/-- **Strain-rotation decomposition at symbol level.** For each `(i,j)`,
the velocity gradient equals strain plus rotation:

    `‚ąā_i u_j = S_{ij} + ő©_{ij}`

where `S` is the symmetric part and `ő©` is antisymmetric. This identity
holds per Fourier mode: `sqgGradSymbol i j n = sqgStrainSymbol i j n + ő©_{ij}(n)`.

Here we prove it for the diagonal (where ő© vanishes). -/
theorem sqgGrad_eq_strain_diag (i : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) :
    sqgGradSymbol i i n = sqgStrainSymbol i i n := by
  unfold sqgStrainSymbol
  ring

/-- **Strain symmetry at the symbol level.** `S_{ij}(n) = S_{ji}(n)`. -/
theorem sqgStrainSymbol_comm (i j : Fin 2) (n : Fin 2 ‚Üí ‚Ą§) :
    sqgStrainSymbol i j n = sqgStrainSymbol j i n := by
  unfold sqgStrainSymbol
  ring

/-- **Antisymmetric part of gradient is vorticity/2.**

    `(sqgGradSymbol 1 0 n - sqgGradSymbol 0 1 n) / 2 =
     sqgVorticitySymbol n / 2`

which is trivially true by definition. The nontrivial content is that
`sqgGradSymbol i j n - sqgStrainSymbol i j n` equals `¬ĪŌČ/2` for off-diagonal. -/
theorem sqgGrad_antisym_eq_half_vort (n : Fin 2 ‚Üí ‚Ą§) :
    (sqgGradSymbol 0 1 n - sqgGradSymbol 1 0 n) / 2
    = sqgVorticitySymbol n / 2 := by
  rfl

/-- **Off-diagonal gradient decomposition.** For `(i,j) = (1,0)`:

    `sqgGradSymbol 1 0 n = sqgStrainSymbol 1 0 n - sqgVorticitySymbol n / 2`

(note: since `sqgVorticitySymbol = sqgGrad 0 1 - sqgGrad 1 0`,
the rotation matrix `ő©_{10} = -ŌČ/2`.) -/
theorem sqgGrad_10_decomposition (n : Fin 2 ‚Üí ‚Ą§) :
    sqgGradSymbol 1 0 n =
      sqgStrainSymbol 1 0 n - sqgVorticitySymbol n / 2 := by
  unfold sqgStrainSymbol sqgVorticitySymbol
  ring

/-- **Off-diagonal gradient decomposition.** For `(i,j) = (0,1)`:

    `sqgGradSymbol 0 1 n = sqgStrainSymbol 0 1 n + sqgVorticitySymbol n / 2` -/
theorem sqgGrad_01_decomposition (n : Fin 2 ‚Üí ‚Ą§) :
    sqgGradSymbol 0 1 n =
      sqgStrainSymbol 0 1 n + sqgVorticitySymbol n / 2 := by
  unfold sqgStrainSymbol sqgVorticitySymbol
  ring

/-! ### Vorticity norm bound -/

/-- **Vorticity symbol norm.** `‚ÄĖŌČŐā(n)‚ÄĖ = ‚ÄĖn‚ÄĖ` for `n ‚Č† 0`. -/
theorem sqgVorticitySymbol_norm {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgVorticitySymbol n‚ÄĖ = latticeNorm n := by
  rw [sqgVorticitySymbol_eq hn, norm_neg, Complex.norm_real,
    Real.norm_of_nonneg (latticeNorm_nonneg n)]

/-- **Half-vorticity norm bound.** `‚ÄĖŌČŐā(n)/2‚ÄĖ = ‚ÄĖn‚ÄĖ/2` for `n ‚Č† 0`. -/
theorem sqgHalfVorticitySymbol_norm {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgVorticitySymbol n / 2‚ÄĖ = latticeNorm n / 2 := by
  rw [norm_div, sqgVorticitySymbol_norm hn]
  norm_num

/-! ## Mode-level Riesz Pythagorean identity

The velocity isometry `|R‚āÄ(n)|¬≤ + |R‚āĀ(n)|¬≤ = 1` (for n ‚Č† 0) implies
that the ŠłĘňĘ-weighted velocity modes sum to the őł mode. This is the
mode-level version; the integrated form follows by tsum. -/

/-- **Mode-level velocity Pythagorean.** For each mode `n ‚Č† 0` and
coefficient `c`:

    `ŌÉ_s¬≤ ¬∑ ‚ÄĖR‚āĀ¬∑c‚ÄĖ¬≤ + ŌÉ_s¬≤ ¬∑ ‚ÄĖR‚āÄ¬∑c‚ÄĖ¬≤ = ŌÉ_s¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤`

This is the fundamental reason the velocity has the same Sobolev regularity as őł. -/
theorem riesz_pythagorean_Hs_mode (s : ‚ĄĚ) {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖrieszSymbol 1 n * c‚ÄĖ ^ 2
    + (fracDerivSymbol s n) ^ 2 * ‚ÄĖrieszSymbol 0 n * c‚ÄĖ ^ 2
    = (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, norm_mul, mul_pow, mul_pow, ‚Üź mul_add, ‚Üź add_mul]
  congr 1
  have hpyth := rieszSymbol_sum_sq hn
  rw [Fin.sum_univ_two] at hpyth
  nlinarith [sq_nonneg ‚ÄĖc‚ÄĖ]

/-! ## Riesz‚Äďderivative‚ÄďfracDeriv factorisation

The Riesz symbol factors as the derivative symbol divided by the
fractional-derivative scale: `R_j(n) ¬∑ ‚ÄĖn‚ÄĖ = -‚ąāŐā_j(n)` (i.e.
`-i¬∑n_j/‚ÄĖn‚ÄĖ ¬∑ ‚ÄĖn‚ÄĖ = -i¬∑n_j`). This is the Fourier-level content
of `R_j = ‚ąā_j / (-őĒ)^{1/2}`.
-/

/-- **Riesz‚Äďderivative factorisation.** For `n ‚Č† 0`:

    `RŐā_j(n) ¬∑ ‚ÄĖn‚ÄĖ = -derivSymbol j n`

This factors the Riesz transform as `R = ‚ąā/(-őĒ)^{1/2}`. -/
theorem riesz_times_norm_eq_neg_deriv {d : Type*} [Fintype d]
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) (j : d) :
    rieszSymbol j n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā) = -(derivSymbol j n) := by
  rw [rieszSymbol_of_ne_zero hn]
  unfold derivSymbol
  have hL := latticeNorm_pos hn
  have hLc : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by exact_mod_cast ne_of_gt hL
  field_simp

/-! ## Strain eigenvalue analysis

For 2D SQG, the strain matrix `S` is a symmetric 2√ó2 traceless matrix
(traceless because `div u = 0`). Its eigenvalues are therefore `¬Ī|S|`
where `|S|` is the Frobenius norm divided by ‚ąö2. At the symbol level
this means the strain controls stretching by exactly its Frobenius norm.
-/

/-- **Strain Frobenius norm squared.** For the SQG strain matrix at
mode `n ‚Č† 0`, the sum of squared entries equals twice the squared
off-diagonal entry plus twice the squared diagonal entry, and by
tracelessness `S‚āÄ‚āÄ = -S‚āĀ‚āĀ`, the Frobenius norm squared is
`2¬∑(S‚āÄ‚āÄ¬≤ + S‚āÄ‚āĀ¬≤)`. -/
theorem sqgStrain_frobenius_explicit (n : Fin 2 ‚Üí ‚Ą§) :
    ‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2
    = 2 * (‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2) := by
  simp only [Fin.sum_univ_two]
  have hsymm : sqgStrainSymbol 1 0 n = sqgStrainSymbol 0 1 n :=
    sqgStrainSymbol_comm 1 0 n
  have h11 : sqgStrainSymbol 1 1 n = -sqgStrainSymbol 0 0 n := by
    linear_combination sqg_strain_trace_free n
  rw [hsymm, h11, norm_neg]; ring

/-- **Strain tracelessness implies eigenvalue structure.** The
trace-free condition `S‚āÄ‚āÄ + S‚āĀ‚āĀ = 0` means `S‚āĀ‚āĀ = ‚ąíS‚āÄ‚āÄ`, so the
2√ó2 strain matrix has the form `[[a, b], [b, -a]]` with characteristic
polynomial `őĽ¬≤ - (a¬≤ + b¬≤) = 0`, giving eigenvalues `¬Ī‚ąö(a¬≤ + b¬≤)`.

We prove the intermediate step: `S‚āÄ‚āÄ¬≤ + S‚āÄ‚āĀ¬≤ = S‚āÄ‚āÄ ¬∑ S‚āĀ‚āĀ + S‚āÄ‚āĀ¬≤`
with a sign (since `S‚āĀ‚āĀ = -S‚āÄ‚āÄ`). -/
theorem sqgStrain_eigenvalue_sq (n : Fin 2 ‚Üí ‚Ą§) :
    sqgStrainSymbol 0 0 n * sqgStrainSymbol 1 1 n
    - sqgStrainSymbol 0 1 n * sqgStrainSymbol 1 0 n
    = -(sqgStrainSymbol 0 0 n ^ 2 + sqgStrainSymbol 0 1 n ^ 2) := by
  have h11 : sqgStrainSymbol 1 1 n = -sqgStrainSymbol 0 0 n := by
    linear_combination sqg_strain_trace_free n
  have h10 : sqgStrainSymbol 1 0 n = sqgStrainSymbol 0 1 n :=
    sqgStrainSymbol_comm 1 0 n
  rw [h11, h10]; ring

/-! ## Sobolev embedding and torus-specific bounds

On `ūĚēčŠĶą`, the lattice norm satisfies `‚ÄĖn‚ÄĖ ‚Č• 1` for `n ‚Č† 0` (integer
lattice property). This gives the torus-specific embedding: higher
Sobolev norms dominate lower ones. We already have `fracDerivSymbol_mono_of_le`;
here we add the integrated form.
-/

/-- **ŠłĘňĘ seminorm dominance on the torus.** For `s ‚Č§ t` on `ūĚēčŠĶą`:

    `‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘŠĶó}`

This is stronger than on ‚ĄĚŠĶą because integer lattice modes have `‚ÄĖn‚ÄĖ ‚Č• 1`. -/
theorem hsSeminormSq_mono {d : Type*} [Fintype d]
    {s t : ‚ĄĚ} (hst : s ‚Č§ t)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus d)))
    (hsum : Summable (fun n ‚Ü¶ (fracDerivSymbol t n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s f ‚Č§ hsSeminormSq t f := by
  unfold hsSeminormSq
  exact Summable.tsum_le_tsum
    (fun n ‚Ü¶ mul_le_mul_of_nonneg_right
      (fracDerivSymbol_sq_mono_of_le hst n)
      (sq_nonneg _))
    (hsum.of_nonneg_of_le
      (fun n ‚Ü¶ mul_nonneg (sq_nonneg _) (sq_nonneg _))
      (fun n ‚Ü¶ mul_le_mul_of_nonneg_right
        (fracDerivSymbol_sq_mono_of_le hst n)
        (sq_nonneg _)))
    hsum

/-! ## Strain spectral bound

The strain eigenvalue bound: each eigenvalue `őĽ` of `S(n)` (symmetric
traceless 2√ó2) satisfies `|őĽ|¬≤ ‚Č§ |n|¬≤`. At the mode level this is
equivalent to `|S‚āÄ‚āÄ|¬≤ + |S‚āÄ‚āĀ|¬≤ ‚Č§ |n|¬≤`.
-/

/-- **Strain eigenvalue norm bound (weak form).** At mode `n ‚Č† 0`, the
sum of the squared diagonal and off-diagonal strain components is
bounded by twice the mode norm squared:

    `|S‚āÄ‚āÄ|¬≤ + |S‚āÄ‚āĀ|¬≤ ‚Č§ 2¬∑‚ÄĖn‚ÄĖ¬≤`

Each component satisfies `|S_{ij}| ‚Č§ ‚ÄĖn‚ÄĖ` (from `sqgStrain_norm_le`),
so summing two squares gives `‚Č§ 2‚ÄĖn‚ÄĖ¬≤`. The tight bound is
`‚ÄĖn‚ÄĖ¬≤/4` (AM-GM), but the weak form suffices for energy estimates. -/
theorem sqgStrain_eigenvalue_norm_le {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2
    ‚Č§ 2 * (latticeNorm n) ^ 2 := by
  have hS00_bound : ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ‚Č§ latticeNorm n :=
    sqgStrain_norm_le hn 0 0
  have hS01_bound : ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ‚Č§ latticeNorm n :=
    sqgStrain_norm_le hn 0 1
  have hL_nn : 0 ‚Č§ latticeNorm n := latticeNorm_nonneg n
  have h00sq : ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
    sq_le_sq' (by linarith [norm_nonneg (sqgStrainSymbol 0 0 n)]) hS00_bound
  have h01sq : ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
    sq_le_sq' (by linarith [norm_nonneg (sqgStrainSymbol 0 1 n)]) hS01_bound
  linarith

/-- **Strain tight identity: |S‚āÄ‚āÄ|¬≤ + |S‚āÄ‚āĀ|¬≤ = ‚ÄĖn‚ÄĖ¬≤/4.**
This is the sharp identity: combining the explicit formulas
`S‚āÄ‚āÄ¬∑‚ÄĖn‚ÄĖ = n‚āÄ¬∑n‚āĀ` and `S‚āÄ‚āĀ¬∑‚ÄĖn‚ÄĖ = (n‚āĀ¬≤ - n‚āÄ¬≤)/2` gives

    `(S‚āÄ‚āÄ¬∑‚ÄĖn‚ÄĖ)¬≤ + (S‚āÄ‚āĀ¬∑‚ÄĖn‚ÄĖ)¬≤ = n‚āÄ¬≤n‚āĀ¬≤ + (n‚āĀ¬≤-n‚āÄ¬≤)¬≤/4 = (n‚āÄ¬≤+n‚āĀ¬≤)¬≤/4 = ‚ÄĖn‚ÄĖ‚Āī/4`

So `|S‚āÄ‚āÄ|¬≤ + |S‚āÄ‚āĀ|¬≤ = ‚ÄĖn‚ÄĖ¬≤/4`. This is the tight form of
`sqgStrain_eigenvalue_norm_le`. -/
theorem sqgStrain_eigenvalue_tight {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2
    = (latticeNorm n) ^ 2 / 4 := by
  have hL_pos := latticeNorm_pos hn
  have hL_ne : (latticeNorm n : ‚ĄĚ) ‚Č† 0 := ne_of_gt hL_pos
  have hLc : ((latticeNorm n : ‚ĄĚ) : ‚Ąā) ‚Č† 0 := by exact_mod_cast hL_ne
  have h00 := sqg_strain_00_explicit hn
  have h01 := sqg_strain_01_explicit hn
  have hL_sq : (latticeNorm n) ^ 2 = ((n 0 : ‚Ą§) : ‚ĄĚ) ^ 2 + ((n 1 : ‚Ą§) : ‚ĄĚ) ^ 2 := by
    rw [latticeNorm_sq]; simp [Fin.sum_univ_two]
  -- Multiply both sides by L¬≤
  have key : ((latticeNorm n) ^ 2) *
      (‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 + ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2)
    = (latticeNorm n) ^ 4 / 4 := by
    have h00_sq : ‚ÄĖsqgStrainSymbol 0 0 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā)‚ÄĖ ^ 2
        = (latticeNorm n) ^ 2 * ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 := by
      rw [norm_mul, mul_pow, Complex.norm_real, Real.norm_of_nonneg (latticeNorm_nonneg n)]
      ring
    have h01_sq : ‚ÄĖsqgStrainSymbol 0 1 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā)‚ÄĖ ^ 2
        = (latticeNorm n) ^ 2 * ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 := by
      rw [norm_mul, mul_pow, Complex.norm_real, Real.norm_of_nonneg (latticeNorm_nonneg n)]
      ring
    have h00_val : ‚ÄĖsqgStrainSymbol 0 0 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā)‚ÄĖ ^ 2
        = (((n 0 : ‚Ą§) : ‚ĄĚ) * ((n 1 : ‚Ą§) : ‚ĄĚ)) ^ 2 := by
      rw [h00, norm_mul, Complex.norm_intCast, Complex.norm_intCast]
      rw [‚Üź abs_mul, sq_abs]
    have h01_val : ‚ÄĖsqgStrainSymbol 0 1 n * ((latticeNorm n : ‚ĄĚ) : ‚Ąā)‚ÄĖ ^ 2
        = ((((n 1 : ‚Ą§) : ‚ĄĚ) ^ 2 - ((n 0 : ‚Ą§) : ‚ĄĚ) ^ 2) / 2) ^ 2 := by
      rw [h01]
      have hcast : (((n 1 : ‚Ą§) : ‚Ąā) ^ 2 - ((n 0 : ‚Ą§) : ‚Ąā) ^ 2) / 2
          = ((((n 1 : ‚Ą§) : ‚ĄĚ) ^ 2 - ((n 0 : ‚Ą§) : ‚ĄĚ) ^ 2) / 2 : ‚ĄĚ) := by
        push_cast; ring
      rw [hcast, Complex.norm_real, Real.norm_eq_abs, sq_abs]
    -- Now we have:
    -- L¬≤ ¬∑ (‚ÄĖS‚āÄ‚āÄ‚ÄĖ¬≤ + ‚ÄĖS‚āÄ‚āĀ‚ÄĖ¬≤) = ‚ÄĖS‚āÄ‚āÄ¬∑L‚ÄĖ¬≤ + ‚ÄĖS‚āÄ‚āĀ¬∑L‚ÄĖ¬≤  (from h00_sq, h01_sq)
    --                        = (n‚āÄn‚āĀ)¬≤ + ((n‚āĀ¬≤-n‚āÄ¬≤)/2)¬≤
    -- = n‚āÄ¬≤n‚āĀ¬≤ + (n‚āĀ‚Āī - 2n‚āÄ¬≤n‚āĀ¬≤ + n‚āÄ‚Āī)/4
    -- = (4n‚āÄ¬≤n‚āĀ¬≤ + n‚āĀ‚Āī - 2n‚āÄ¬≤n‚āĀ¬≤ + n‚āÄ‚Āī)/4
    -- = (n‚āÄ‚Āī + 2n‚āÄ¬≤n‚āĀ¬≤ + n‚āĀ‚Āī)/4
    -- = (n‚āÄ¬≤ + n‚āĀ¬≤)¬≤/4
    -- = L‚Āī/4
    rw [mul_add, ‚Üź h00_sq, ‚Üź h01_sq, h00_val, h01_val]
    have hL4 : (latticeNorm n) ^ 4 = ((latticeNorm n) ^ 2) ^ 2 := by ring
    rw [hL4, hL_sq]
    ring
  -- Divide both sides by L¬≤
  have hL_sq_pos : 0 < (latticeNorm n) ^ 2 := by positivity
  have hL_sq_ne : (latticeNorm n) ^ 2 ‚Č† 0 := ne_of_gt hL_sq_pos
  field_simp at key
  linarith [key, pow_nonneg (latticeNorm_nonneg n) 4]

/-- **Strain Frobenius norm tight equality.** For `n ‚Č† 0`:

    `ő£_{ij} ‚ÄĖS_{ij}(n)‚ÄĖ¬≤ = ‚ÄĖn‚ÄĖ¬≤/2`

This follows from tracelessness (ő£ over {(0,0),(1,1)} gives `2¬∑|S‚āÄ‚āÄ|¬≤`)
and symmetry (`S‚āĀ‚āÄ = S‚āÄ‚āĀ`, giving `ő£ = 2¬∑(|S‚āÄ‚āÄ|¬≤ + |S‚āÄ‚āĀ|¬≤) = L¬≤/2`). -/
theorem sqgStrain_frobenius_tight {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2) = (latticeNorm n) ^ 2 / 2 := by
  rw [sqgStrain_frobenius_explicit n, sqgStrain_eigenvalue_tight hn]
  ring

/-- **Velocity gradient norm tight equality.** For `n ‚Č† 0`, the sum
of all squared velocity gradient components equals `‚ÄĖn‚ÄĖ¬≤`:

    `ő£_{ij} ‚ÄĖ‚ąāŐā_i u_j(n)‚ÄĖ¬≤ = ‚ÄĖn‚ÄĖ¬≤`

Proof: `‚ąāŐā_i u_j(n) = (in_i) ¬∑ R_{swap(j)}(n)` with `|iR_k| = |R_k|`,
and `ő£_i n_i¬≤ ¬∑ ő£_k ‚ÄĖR_k‚ÄĖ¬≤ = ‚ÄĖn‚ÄĖ¬≤ ¬∑ 1`. -/
theorem sqgGrad_frobenius_tight {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2) = (latticeNorm n) ^ 2 := by
  have hR : ‚ÄĖrieszSymbol (0 : Fin 2) n‚ÄĖ ^ 2 + ‚ÄĖrieszSymbol (1 : Fin 2) n‚ÄĖ ^ 2 = 1 := by
    have := rieszSymbol_sum_sq hn
    simp only [Fin.sum_univ_two] at this
    linarith
  have hL_sq : (latticeNorm n) ^ 2 = ((n 0 : ‚Ą§) : ‚ĄĚ) ^ 2 + ((n 1 : ‚Ą§) : ‚ĄĚ) ^ 2 := by
    rw [latticeNorm_sq]; simp [Fin.sum_univ_two]
  -- Helper: ‚ÄĖsqgGradSymbol i 0 n‚ÄĖ¬≤ = |n_i|¬≤ ¬∑ ‚ÄĖR‚āĀ(n)‚ÄĖ¬≤
  have h0 : ‚ąÄ i : Fin 2, ‚ÄĖsqgGradSymbol i 0 n‚ÄĖ ^ 2
      = ((n i : ‚Ą§) : ‚ĄĚ) ^ 2 * ‚ÄĖrieszSymbol 1 n‚ÄĖ ^ 2 := by
    intro i
    unfold sqgGradSymbol derivSymbol
    simp only [if_true]
    rw [norm_mul, mul_pow]
    rw [show ‚ÄĖComplex.I * ((((n i : ‚Ą§) : ‚ĄĚ) : ‚Ąā))‚ÄĖ = |((n i : ‚Ą§) : ‚ĄĚ)| from by
      rw [norm_mul, Complex.norm_I, one_mul, Complex.norm_real, Real.norm_eq_abs]]
    rw [sq_abs]
  -- Helper: ‚ÄĖsqgGradSymbol i 1 n‚ÄĖ¬≤ = |n_i|¬≤ ¬∑ ‚ÄĖR‚āÄ(n)‚ÄĖ¬≤
  have h1 : ‚ąÄ i : Fin 2, ‚ÄĖsqgGradSymbol i 1 n‚ÄĖ ^ 2
      = ((n i : ‚Ą§) : ‚ĄĚ) ^ 2 * ‚ÄĖrieszSymbol 0 n‚ÄĖ ^ 2 := by
    intro i
    unfold sqgGradSymbol derivSymbol
    simp only [show (1 : Fin 2) ‚Č† 0 from by omega, if_false]
    rw [norm_mul, mul_pow, norm_neg]
    rw [show ‚ÄĖComplex.I * ((((n i : ‚Ą§) : ‚ĄĚ) : ‚Ąā))‚ÄĖ = |((n i : ‚Ą§) : ‚ĄĚ)| from by
      rw [norm_mul, Complex.norm_I, one_mul, Complex.norm_real, Real.norm_eq_abs]]
    rw [sq_abs]
  simp only [Fin.sum_univ_two]
  rw [h0 0, h0 1, h1 0, h1 1, hL_sq]
  nlinarith [hR, sq_nonneg ((n 0 : ‚Ą§) : ‚ĄĚ), sq_nonneg ((n 1 : ‚Ą§) : ‚ĄĚ)]

/-- **Velocity gradient = strain + rotation partition at mode level.**
For `n ‚Č† 0`:

    `ő£_{ij} ‚ÄĖ‚ąāŐā_i u_j(n)‚ÄĖ¬≤ = ő£_{ij} ‚ÄĖS_{ij}(n)‚ÄĖ¬≤ + ‚ÄĖŌČŐā(n)‚ÄĖ¬≤ / 2`

which at tight values becomes `L¬≤ = L¬≤/2 + L¬≤/2`. This is the
microlocal form of the enstrophy = vorticity¬≤ + 2¬∑strain¬≤ identity. -/
theorem sqg_grad_strain_vort_partition {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2)
    = (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2)
      + ‚ÄĖsqgVorticitySymbol n‚ÄĖ ^ 2 / 2 := by
  rw [sqgGrad_frobenius_tight hn, sqgStrain_frobenius_tight hn,
      sqgVorticitySymbol_norm hn]
  ring

/-- **Strain eigenvalue tight upper bound.** Each strain eigenvalue `őĽ`
satisfies `|őĽ| ‚Č§ ‚ÄĖn‚ÄĖ/2`, so `|őĽ|¬≤ ‚Č§ ‚ÄĖn‚ÄĖ¬≤/4`. This is the tight form
of the strain spectral bound. -/
theorem sqgStrain_00_sq_le_quarter {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 / 4 := by
  have htight := sqgStrain_eigenvalue_tight hn
  have h01_nn : 0 ‚Č§ ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 := sq_nonneg _
  linarith

/-- **Off-diagonal strain eigenvalue tight upper bound.** -/
theorem sqgStrain_01_sq_le_quarter {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 / 4 := by
  have htight := sqgStrain_eigenvalue_tight hn
  have h00_nn : 0 ‚Č§ ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 := sq_nonneg _
  linarith

/-- **Tight ŠłĘňĘ strain bound.** For each strain component and each `s`:

    `‚ÄĖS_{ij}(n)‚ÄĖ¬≤ ¬∑ ŌÉ_s(n)¬≤ ‚Č§ ŌÉ_{s+1}(n)¬≤¬∑‚ÄĖőłŐā(n)‚ÄĖ¬≤/4`

This is a sharper form of `sqgStrain_Hs_le`, reflecting that each
individual strain component is bounded by `L/2`, not just `L`. -/
theorem sqgStrain_tight_Hs_mode_bound {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (s : ‚ĄĚ) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖsqgStrainSymbol 0 0 n * c‚ÄĖ ^ 2
    ‚Č§ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 / 4 := by
  rw [norm_mul, mul_pow]
  have h00 := sqgStrain_00_sq_le_quarter hn
  have hfrac := fracDerivSymbol_add_sq s 1 n
  have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
    rw [fracDerivSymbol_one_eq hn]
  have hŌÉs_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hprod_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 :=
    mul_nonneg hŌÉs_nn hc_nn
  calc (fracDerivSymbol s n) ^ 2 * (‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ‚ÄĖsqgStrainSymbol 0 0 n‚ÄĖ ^ 2 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ ((latticeNorm n) ^ 2 / 4) * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right h00 hprod_nn
    _ = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 / 4 := by
        rw [hfrac, hfrac1]; ring

/-! ## ŠłĘ^{1/2} connection: vorticity L¬≤ equals őł ŠłĘ^{1/2}

The SQG constitutive relation `ŌČ = ‚ąí(-őĒ)^{1/2}őł` means the vorticity
has a half-derivative extra smoothness gap compared to őł. At the
Fourier level this is `ŌČŐā(n) = ‚ąí‚ÄĖn‚ÄĖ¬∑őłŐā(n)`, so `‚ÄĖŌČ‚ÄĖ¬≤_{L¬≤} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}`.
-/

/-- **Mode-level vorticity = fracDeriv_1 őł.** For `n ‚Č† 0`:

    `‚ÄĖŌČŐā(n)‚ÄĖ¬≤ = (fracDerivSymbol 1 n)¬≤`

so the L¬≤ norm of `ŌČ` equals the ŠłĘ¬Ļ seminorm of őł, not ŠłĘ^{1/2}.
(The factor 1/2 in `ŌČ/2` is absorbed into the constant when connecting
to the identity `ŌČ = -őõőł` on the full torus convention.) -/
theorem sqgVorticitySymbol_norm_sq_eq {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    ‚ÄĖsqgVorticitySymbol n‚ÄĖ ^ 2 = (fracDerivSymbol 1 n) ^ 2 := by
  rw [sqgVorticitySymbol_norm hn, fracDerivSymbol_one_eq hn]

/-- **Vorticity L¬≤ norm equals őł ŠłĘ¬Ļ seminorm (integrated form).**
For SQG velocity with `ŌČŐā(n) = -‚ÄĖn‚ÄĖ¬∑őłŐā(n)` and `ŌČ : Lp ‚Ąā 2`:

    `‚ÄĖŌČ‚ÄĖ¬≤_{L¬≤} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ}`

Proof: Parseval + mode-level identity. -/
theorem sqgVorticity_L2_eq_Hs1
    (őł ŌČ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff ŌČ n = sqgVorticitySymbol n * mFourierCoeff őł n)
    (_hsum : Summable
      (fun n ‚Ü¶ (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2))
    (hŌČ_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff ŌČ n‚ÄĖ ^ 2) (‚ąę t, ‚ÄĖŌČ t‚ÄĖ ^ 2)) :
    (‚ąę t, ‚ÄĖŌČ t‚ÄĖ ^ 2) = hsSeminormSq 1 őł := by
  unfold hsSeminormSq
  rw [‚Üź hŌČ_parseval.tsum_eq]
  congr 1
  ext n
  rw [hcoeff n, norm_mul, mul_pow]
  by_cases hn : n = 0
  ¬∑ subst hn
    rw [show sqgVorticitySymbol 0 = 0 from by
          unfold sqgVorticitySymbol sqgGradSymbol derivSymbol rieszSymbol
          simp, norm_zero]
    simp [fracDerivSymbol_zero]
  ¬∑ rw [sqgVorticitySymbol_norm hn, fracDerivSymbol_one_eq hn]

/-- **Strain L¬≤ norm = őł ŠłĘ¬Ļ seminorm / 2.** For each strain component,
the L¬≤ norm of `S_{ij}` equals `‚ÄĖn‚ÄĖ/2 ¬∑ |őłŐā|` in the mode picture,
giving:

    `ő£_{ij} ‚ÄĖS_{ij}‚ÄĖ¬≤_{L¬≤} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ¬Ļ} / 2`

(from the tight Frobenius identity). This matches the velocity gradient
decomposition energy identity. -/
theorem sqgStrain_Frobenius_L2_eq_Hs1_half {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (c : ‚Ąā) :
    (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgStrainSymbol i j n * c‚ÄĖ ^ 2)
    = (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 / 2 := by
  have hfactor : (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgStrainSymbol i j n * c‚ÄĖ ^ 2)
      = (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2) * ‚ÄĖc‚ÄĖ ^ 2 := by
    simp only [norm_mul, mul_pow]
    simp only [Fin.sum_univ_two]
    ring
  rw [hfactor, sqgStrain_frobenius_tight hn, fracDerivSymbol_one_eq hn]
  ring

/-! ## Riesz transform ŠłĘňĘ properties

Each Riesz transform `R_j : Lp ‚Ąā 2 ‚Üí Lp ‚Ąā 2` is an isometry modulo zero modes,
and the transfer of fractional derivatives commutes with Riesz transforms.
We establish mode-level properties.
-/

/-- **Riesz symbol preserves ŠłĘňĘ weight norm.** At each nonzero mode:

    `ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖR_j(n) ¬∑ c‚ÄĖ¬≤ = ‚ÄĖR_j(n)‚ÄĖ¬≤ ¬∑ ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤`

which is trivial algebra but useful for sum manipulations. -/
theorem rieszSymbol_Hs_mode_factor (s : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§)
    (j : Fin 2) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖrieszSymbol j n * c‚ÄĖ ^ 2
    = ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) := by
  rw [norm_mul, mul_pow]; ring

/-- **Riesz ŠłĘňĘ bound per component.** For each `j` and `n ‚Č† 0`:

    `ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖR_j(n) ¬∑ c‚ÄĖ¬≤ ‚Č§ ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤`

This is the mode-level ŠłĘňĘ contractivity of each Riesz transform. -/
theorem rieszSymbol_Hs_mode_bound (s : ‚ĄĚ) {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (j : Fin 2) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖrieszSymbol j n * c‚ÄĖ ^ 2
    ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [rieszSymbol_Hs_mode_factor s n j c]
  have hR : ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 ‚Č§ 1 := by
    have := rieszSymbol_sum_sq hn
    have hR_j_nn : 0 ‚Č§ ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 := sq_nonneg _
    have hR_other_nn : ‚ąÄ k : Fin 2, 0 ‚Č§ ‚ÄĖrieszSymbol k n‚ÄĖ ^ 2 :=
      fun _ ‚Ü¶ sq_nonneg _
    -- ‚ÄĖR_j‚ÄĖ¬≤ ‚Č§ ő£ ‚ÄĖR_k‚ÄĖ¬≤ = 1
    calc ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2
        ‚Č§ ‚ąĎ k : Fin 2, ‚ÄĖrieszSymbol k n‚ÄĖ ^ 2 := by
          rw [show (‚ÄĖrieszSymbol j n‚ÄĖ ^ 2)
              = ‚ąĎ k ‚ąą ({j} : Finset (Fin 2)), ‚ÄĖrieszSymbol k n‚ÄĖ ^ 2 from by simp]
          exact Finset.sum_le_sum_of_subset_of_nonneg
            (by simp : ({j} : Finset (Fin 2)) ‚äÜ Finset.univ)
            (fun k _ _ ‚Ü¶ hR_other_nn k)
      _ = 1 := this
  have hprod_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 :=
    mul_nonneg (sq_nonneg _) (sq_nonneg _)
  calc ‚ÄĖrieszSymbol j n‚ÄĖ ^ 2 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      ‚Č§ 1 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right hR hprod_nn
    _ = (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := one_mul _

/-- **Derivative symbol preserves ŠłĘňĘ**: `ŌÉ_s¬≤ ¬∑ |‚ąāŐā_j ¬∑ c|¬≤ ‚Č§ ŌÉ_{s+1}¬≤ ¬∑ |c|¬≤` -/
theorem derivSymbol_Hs_mode_bound (s : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§)
    (j : Fin 2) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖderivSymbol j n * c‚ÄĖ ^ 2
    ‚Č§ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    simp [derivSymbol, fracDerivSymbol_zero]
  rw [norm_mul, mul_pow]
  rw [show (fracDerivSymbol (s + 1) n) ^ 2
      = (fracDerivSymbol s n) ^ 2 * (fracDerivSymbol 1 n) ^ 2 from
    fracDerivSymbol_add_sq s 1 n]
  rw [fracDerivSymbol_one_eq hn]
  have h_deriv : ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 := by
    unfold derivSymbol
    rw [show ‚ÄĖComplex.I * (((n j : ‚Ą§) : ‚ĄĚ) : ‚Ąā)‚ÄĖ = |((n j : ‚Ą§) : ‚ĄĚ)| from by
      rw [norm_mul, Complex.norm_I, one_mul, Complex.norm_real, Real.norm_eq_abs]]
    rw [sq_abs]
    exact sq_le_latticeNorm_sq n j
  have hŌÉs_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hprod_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 :=
    mul_nonneg hŌÉs_nn hc_nn
  calc (fracDerivSymbol s n) ^ 2 * (‚ÄĖderivSymbol j n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ‚ÄĖderivSymbol j n‚ÄĖ ^ 2 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ (latticeNorm n) ^ 2 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right h_deriv hprod_nn
    _ = (fracDerivSymbol s n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-! ## Strain-ŠłĘňĘ tight identity

Using the tight strain Frobenius identity ő£‚ÄĖS_ij‚ÄĖ¬≤ = ‚ÄĖn‚ÄĖ¬≤/2 at each
mode, we can derive the sharp ŠłĘňĘ strain identity for the sum of all
strain components at once.
-/

/-- **Mode-level strain Frobenius ŠłĘňĘ tight bound.** For `n ‚Č† 0` and any
coefficient `c`:

    `ŌÉ_s(n)¬≤ ¬∑ ő£_{ij} ‚ÄĖS_{ij}(n)¬∑c‚ÄĖ¬≤ = ŌÉ_{s+1}(n)¬≤¬∑‚ÄĖc‚ÄĖ¬≤/2`

This is the tight form: the strain Frobenius norm at frequency `n`
equals exactly `ŌÉ_1(n)/‚ąö2 ¬∑ |c|`. -/
theorem sqgStrain_Frobenius_Hs_tight {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (s : ‚ĄĚ) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2
      * (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgStrainSymbol i j n * c‚ÄĖ ^ 2)
    = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 / 2 := by
  rw [sqgStrain_Frobenius_L2_eq_Hs1_half hn c]
  rw [show (fracDerivSymbol (s + 1) n) ^ 2
      = (fracDerivSymbol s n) ^ 2 * (fracDerivSymbol 1 n) ^ 2 from
    fracDerivSymbol_add_sq s 1 n]
  ring

/-- **Mode-level gradient Frobenius ŠłĘňĘ tight bound.** For `n ‚Č† 0`:

    `ŌÉ_s(n)¬≤ ¬∑ ő£_{ij} ‚ÄĖ‚ąāŐā_i u_j(n)¬∑c‚ÄĖ¬≤ = ŌÉ_{s+1}(n)¬≤¬∑‚ÄĖc‚ÄĖ¬≤`

So the velocity gradient tensor has the exact ŠłĘňĘ scale `ŠłĘ^{s+1}(őł)`. -/
theorem sqgGrad_Frobenius_Hs_tight {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (s : ‚ĄĚ) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2
      * (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgGradSymbol i j n * c‚ÄĖ ^ 2)
    = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  have hfactor : (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgGradSymbol i j n * c‚ÄĖ ^ 2)
      = (‚ąĎ i : Fin 2, ‚ąĎ j : Fin 2, ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2) * ‚ÄĖc‚ÄĖ ^ 2 := by
    simp only [norm_mul, mul_pow]
    simp only [Fin.sum_univ_two]
    ring
  rw [hfactor, sqgGrad_frobenius_tight hn]
  rw [show (fracDerivSymbol (s + 1) n) ^ 2
      = (fracDerivSymbol s n) ^ 2 * (fracDerivSymbol 1 n) ^ 2 from
    fracDerivSymbol_add_sq s 1 n]
  rw [fracDerivSymbol_one_eq hn]
  ring

/-- **Vorticity ŠłĘňĘ tight identity.** For `n ‚Č† 0`:

    `ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖŌČŐā(n)¬∑c‚ÄĖ¬≤ = ŌÉ_{s+1}(n)¬≤¬∑‚ÄĖc‚ÄĖ¬≤`

The vorticity has the exact ŠłĘňĘ scale `ŠłĘ^{s+1}(őł)`. -/
theorem sqgVorticity_Hs_tight {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (s : ‚ĄĚ) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖsqgVorticitySymbol n * c‚ÄĖ ^ 2
    = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, sqgVorticitySymbol_norm hn]
  rw [show (fracDerivSymbol (s + 1) n) ^ 2
      = (fracDerivSymbol s n) ^ 2 * (fracDerivSymbol 1 n) ^ 2 from
    fracDerivSymbol_add_sq s 1 n]
  rw [fracDerivSymbol_one_eq hn]
  ring

/-! ## Integrated ŠłĘňĘ tight identities (Parseval/tsum form)

Lifting the mode-level tight identities to integrated ŠłĘňĘ seminorms.
-/

/-- **Vorticity ŠłĘňĘ tight identity.** For `ŌČŐā(n) = sqgVorticitySymbol n ¬∑ őłŐā(n)`:

    `‚ÄĖŌČ‚ÄĖ¬≤_{ŠłĘňĘ} = ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}`

The proof is by Parseval plus the mode-level `sqgVorticity_Hs_tight`. -/
theorem sqgVorticity_Hs_eq_Hs1
    (s : ‚ĄĚ)
    (őł ŌČ : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff ŌČ n = sqgVorticitySymbol n * mFourierCoeff őł n)
    (_hsum : Summable (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s ŌČ = hsSeminormSq (s + 1) őł := by
  unfold hsSeminormSq
  congr 1
  ext n
  by_cases hn : n = 0
  ¬∑ subst hn
    have h0 : sqgVorticitySymbol 0 = 0 := by
      unfold sqgVorticitySymbol sqgGradSymbol derivSymbol rieszSymbol
      simp
    rw [hcoeff 0, h0, zero_mul, norm_zero]
    simp [fracDerivSymbol_zero]
  ¬∑ rw [hcoeff n]
    exact sqgVorticity_Hs_tight hn s (mFourierCoeff őł n)

/-- **Strain 0,0 component ŠłĘňĘ tight bound (integrated).** The (0,0)
component of the strain matrix satisfies:

    `‚ÄĖS‚āÄ‚āÄ‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}} / 4`

This is 4√ó sharper than `sqgStrain_Hs_le` (which gives ‚Č§ ‚ÄĖőł‚ÄĖ¬≤_{ŠłĘ^{s+1}}).
The factor 1/4 comes from the tight eigenvalue bound `|S‚āÄ‚āÄ|¬≤ ‚Č§ ‚ÄĖn‚ÄĖ¬≤/4`. -/
theorem sqgStrain_00_Hs_le_quarter
    (s : ‚ĄĚ)
    (őł S : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff S n = sqgStrainSymbol 0 0 n * mFourierCoeff őł n)
    (hsum : Summable (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s S ‚Č§ hsSeminormSq (s + 1) őł / 4 := by
  unfold hsSeminormSq
  rw [show (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2) / 4
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 / 4 from by
    rw [‚Üź tsum_div_const]]
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶
    fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS) n‚ÄĖ ^ 2)
  ¬∑ intro n
    by_cases hn : n = 0
    ¬∑ subst hn
      rw [hcoeff 0]
      simp [sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol,
        fracDerivSymbol_zero]
    ¬∑ rw [hcoeff n]
      have := sqgStrain_tight_Hs_mode_bound hn s (mFourierCoeff őł n)
      convert this using 1
  ¬∑ apply (hsum.div_const 4).of_nonneg_of_le
    ¬∑ intro n
      exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      by_cases hn : n = 0
      ¬∑ subst hn
        rw [hcoeff 0]
        simp [sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol,
          fracDerivSymbol_zero]
      ¬∑ rw [hcoeff n]
        have := sqgStrain_tight_Hs_mode_bound hn s (mFourierCoeff őł n)
        convert this using 1
  ¬∑ exact hsum.div_const 4

/-- **Strain 0,1 component tight ŠłĘňĘ mode bound.** -/
theorem sqgStrain_01_tight_Hs_mode_bound {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0)
    (s : ‚ĄĚ) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖsqgStrainSymbol 0 1 n * c‚ÄĖ ^ 2
    ‚Č§ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 / 4 := by
  rw [norm_mul, mul_pow]
  have h01 := sqgStrain_01_sq_le_quarter hn
  have hfrac := fracDerivSymbol_add_sq s 1 n
  have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
    rw [fracDerivSymbol_one_eq hn]
  have hŌÉs_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hprod_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 :=
    mul_nonneg hŌÉs_nn hc_nn
  calc (fracDerivSymbol s n) ^ 2 * (‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ‚ÄĖsqgStrainSymbol 0 1 n‚ÄĖ ^ 2 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ ((latticeNorm n) ^ 2 / 4) * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right h01 hprod_nn
    _ = (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 / 4 := by
        rw [hfrac, hfrac1]; ring

/-- **Strain 0,1 component ŠłĘňĘ tight bound (integrated).** -/
theorem sqgStrain_01_Hs_le_quarter
    (s : ‚ĄĚ)
    (őł S : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff S n = sqgStrainSymbol 0 1 n * mFourierCoeff őł n)
    (hsum : Summable (fun n ‚Ü¶ (fracDerivSymbol (s + 1) n) ^ 2 * ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    hsSeminormSq s S ‚Č§ hsSeminormSq (s + 1) őł / 4 := by
  unfold hsSeminormSq
  rw [show (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2) / 4
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        fracDerivSymbol (s + 1) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 / 4 from by
    rw [‚Üź tsum_div_const]]
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶
    fracDerivSymbol s n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎS) n‚ÄĖ ^ 2)
  ¬∑ intro n
    by_cases hn : n = 0
    ¬∑ subst hn
      rw [hcoeff 0]
      simp [sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol,
        fracDerivSymbol_zero]
    ¬∑ rw [hcoeff n]
      exact sqgStrain_01_tight_Hs_mode_bound hn s (mFourierCoeff őł n)
  ¬∑ apply (hsum.div_const 4).of_nonneg_of_le
    ¬∑ intro n
      exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      by_cases hn : n = 0
      ¬∑ subst hn
        rw [hcoeff 0]
        simp [sqgStrainSymbol, sqgGradSymbol, derivSymbol, rieszSymbol,
          fracDerivSymbol_zero]
      ¬∑ rw [hcoeff n]
        exact sqgStrain_01_tight_Hs_mode_bound hn s (mFourierCoeff őł n)
  ¬∑ exact hsum.div_const 4

/-! ## Heat semigroup symbol

The heat equation `‚ąā_t u = őĒ u` has semigroup `e^{tőĒ}` with Fourier
multiplier `e^{-t¬∑‚ÄĖn‚ÄĖ¬≤}`. This is always in (0, 1], and represents
parabolic smoothing.

The fractional heat `e^{-t(-őĒ)^őĪ}` (for SQG's diffusion-free setting,
with őĪ = 0 here) has symbol `e^{-t¬∑‚ÄĖn‚ÄĖ^{2őĪ}}`.
-/

/-- **Heat semigroup symbol.** For `t ‚Č• 0`:

    `√™_tőĒ(n) = exp(-t¬∑‚ÄĖn‚ÄĖ¬≤)`. -/
noncomputable def heatSymbol {d : Type*} [Fintype d]
    (t : ‚ĄĚ) (n : d ‚Üí ‚Ą§) : ‚ĄĚ :=
  Real.exp (-t * (latticeNorm n) ^ 2)

/-- **Heat semigroup symbol at n = 0 is 1.** -/
@[simp] lemma heatSymbol_zero_mode {d : Type*} [Fintype d] (t : ‚ĄĚ) :
    heatSymbol t (0 : d ‚Üí ‚Ą§) = 1 := by
  unfold heatSymbol
  simp [latticeNorm]

/-- **Heat semigroup symbol is positive.** -/
lemma heatSymbol_pos {d : Type*} [Fintype d] (t : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    0 < heatSymbol t n := Real.exp_pos _

/-- **Heat semigroup symbol is nonneg.** -/
lemma heatSymbol_nonneg {d : Type*} [Fintype d] (t : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    0 ‚Č§ heatSymbol t n := le_of_lt (heatSymbol_pos t n)

/-- **Heat semigroup at t=0 is identity.** -/
@[simp] lemma heatSymbol_zero_time {d : Type*} [Fintype d] (n : d ‚Üí ‚Ą§) :
    heatSymbol 0 n = 1 := by
  unfold heatSymbol
  simp

/-- **Heat semigroup is bounded by 1 for t ‚Č• 0.** -/
lemma heatSymbol_le_one {d : Type*} [Fintype d] {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (n : d ‚Üí ‚Ą§) :
    heatSymbol t n ‚Č§ 1 := by
  unfold heatSymbol
  rw [show (1 : ‚ĄĚ) = Real.exp 0 from Real.exp_zero.symm]
  apply Real.exp_le_exp.mpr
  have hL_sq_nn : 0 ‚Č§ (latticeNorm n) ^ 2 := sq_nonneg _
  nlinarith

/-- **Heat semigroup is strictly below 1 at nonzero modes for t > 0.** -/
lemma heatSymbol_lt_one {d : Type*} [Fintype d] {t : ‚ĄĚ} (ht : 0 < t)
    {n : d ‚Üí ‚Ą§} (hn : n ‚Č† 0) :
    heatSymbol t n < 1 := by
  unfold heatSymbol
  rw [show (1 : ‚ĄĚ) = Real.exp 0 from Real.exp_zero.symm]
  apply Real.exp_lt_exp.mpr
  have hL_pos : 0 < latticeNorm n := latticeNorm_pos hn
  have hL_sq_pos : 0 < (latticeNorm n) ^ 2 := by positivity
  nlinarith

/-- **Heat semigroup: additive in time (homomorphism).** -/
lemma heatSymbol_add {d : Type*} [Fintype d] (t‚āĀ t‚āā : ‚ĄĚ) (n : d ‚Üí ‚Ą§) :
    heatSymbol (t‚āĀ + t‚āā) n = heatSymbol t‚āĀ n * heatSymbol t‚āā n := by
  unfold heatSymbol
  rw [‚Üź Real.exp_add]
  congr 1
  ring

/-- **Heat semigroup ŠłĘňĘ mode contractivity.** For `t ‚Č• 0`:

    `ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖ(e^{tőĒ})Őā(n) ¬∑ c‚ÄĖ¬≤ ‚Č§ ŌÉ_s(n)¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤`

Parabolic smoothing is a contraction at every Sobolev level. -/
theorem heatSymbol_Hs_mode_bound {t : ‚ĄĚ} (ht : 0 ‚Č§ t) (s : ‚ĄĚ)
    {n : (Fin 2) ‚Üí ‚Ą§} (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real, Real.norm_of_nonneg (heatSymbol_nonneg _ _)]
  have hh_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
  have hh_le : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht n
  have hh_sq_le : (heatSymbol t n) ^ 2 ‚Č§ 1 := pow_le_one‚āÄ hh_nn hh_le
  have hŌÉs_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hprod_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 :=
    mul_nonneg hŌÉs_nn hc_nn
  calc (fracDerivSymbol s n) ^ 2 * ((heatSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = (heatSymbol t n) ^ 2 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ 1 * ((fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right hh_sq_le hprod_nn
    _ = (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := one_mul _

/-! ## Parabolic smoothing at the k=1 level

Classical parabolic smoothing: `‚ÄĖn‚ÄĖ¬≤ ¬∑ exp(-t¬∑‚ÄĖn‚ÄĖ¬≤) ‚Č§ 1/(et)`.
This is the gradient-level smoothing provided by the heat semigroup.

The key is the tangent-line inequality: `x ¬∑ exp(-x) ‚Č§ exp(-1)`
(classical; max at `x = 1`).
-/

/-- **Tangent-line inequality at `x = 1`.** `x ¬∑ exp(-x) ‚Č§ exp(-1)`
for all real `x`.

At `x = 1` this is equality. Both `x ¬∑ exp(-x)` and `exp(-1)` tangent
each other at `x = 1` and the convex-below-concave argument gives
`‚Č§`. Equivalently: `ex ‚Č§ exp(x)`, which is the tangent line inequality
for `exp` at `x = 1`. -/
theorem mul_exp_neg_le_exp_neg_one (x : ‚ĄĚ) :
    x * Real.exp (-x) ‚Č§ Real.exp (-1) := by
  by_cases hx : 0 ‚Č§ x
  ¬∑ -- x ‚Č• 0: use x ‚Č§ exp(x-1) (tangent line at x=1)
    have h1 : x ‚Č§ Real.exp (x - 1) := by
      have := Real.add_one_le_exp (x - 1)
      linarith
    have hexp_neg_pos : 0 < Real.exp (-x) := Real.exp_pos _
    calc x * Real.exp (-x)
        ‚Č§ Real.exp (x - 1) * Real.exp (-x) :=
          mul_le_mul_of_nonneg_right h1 hexp_neg_pos.le
      _ = Real.exp ((x - 1) + (-x)) := (Real.exp_add _ _).symm
      _ = Real.exp (-1) := by
          congr 1; ring
  ¬∑ -- x < 0: x ¬∑ exp(-x) < 0 ‚Č§ exp(-1)
    push Not at hx
    have hexp_neg_pos : 0 < Real.exp (-x) := Real.exp_pos _
    have hneg : x * Real.exp (-x) < 0 := mul_neg_of_neg_of_pos hx hexp_neg_pos
    have hpos : 0 < Real.exp (-1) := Real.exp_pos _
    linarith

/-- **Parabolic smoothing bound at gradient level.** For `t > 0`:

    `‚ÄĖn‚ÄĖ¬≤ ¬∑ exp(-t¬∑‚ÄĖn‚ÄĖ¬≤) ‚Č§ exp(-1) / t`

This is the mode-level statement of the heat-semigroup smoothing estimate
`‚ÄĖ‚ąá(e^{tőĒ}f)‚ÄĖ_L¬≤ ‚Č§ C/‚ąöt ¬∑ ‚ÄĖf‚ÄĖ_L¬≤` at frequency `n`. -/
theorem latticeNorm_sq_mul_heat_le {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm n) ^ 2 * heatSymbol t n ‚Č§ Real.exp (-1) / t := by
  unfold heatSymbol
  -- Goal: L¬≤ ¬∑ exp(-t¬∑L¬≤) ‚Č§ exp(-1)/t
  -- Let y = t¬∑L¬≤. Then L¬≤ = y/t and exp(-t¬∑L¬≤) = exp(-y).
  -- So LHS = (y/t) ¬∑ exp(-y) = y¬∑exp(-y) / t ‚Č§ exp(-1)/t.
  set y : ‚ĄĚ := t * (latticeNorm n) ^ 2 with hy_def
  have hy_nn : 0 ‚Č§ y := mul_nonneg ht.le (sq_nonneg _)
  have hexp_rw : Real.exp (-t * (latticeNorm n) ^ 2) = Real.exp (-y) := by
    congr 1; rw [hy_def]; ring
  rw [hexp_rw]
  -- Now: L¬≤ ¬∑ exp(-y) ‚Č§ exp(-1)/t, with y = t¬∑L¬≤
  have hL_sq_eq : (latticeNorm n) ^ 2 = y / t := by
    rw [hy_def]; field_simp
  rw [hL_sq_eq, div_mul_eq_mul_div]
  -- Goal: y * exp(-y) / t ‚Č§ exp(-1) / t
  have h_num : y * Real.exp (-y) ‚Č§ Real.exp (-1) := mul_exp_neg_le_exp_neg_one y
  gcongr

/-- **Parabolic smoothing: fracDerivSymbol 1 form.** For `t > 0`:

    `ŌÉ_1(n)¬≤ ¬∑ heatSymbol(t, n) ‚Č§ exp(-1) / t`. -/
theorem fracDerivSymbol_1_sq_mul_heat_le {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (fracDerivSymbol 1 n) ^ 2 * heatSymbol t n ‚Č§ Real.exp (-1) / t := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have : (fracDerivSymbol 1 (0 : Fin 2 ‚Üí ‚Ą§)) = 0 := fracDerivSymbol_zero 1
    rw [this]
    simp
    exact div_nonneg (Real.exp_pos _).le ht.le
  ¬∑ rw [fracDerivSymbol_one_eq hn]
    exact latticeNorm_sq_mul_heat_le ht n

/-- **Parabolic smoothing in `ŠłĘ¬Ļ` form.** For `t > 0`, the heat-smoothed
function has gradient bounded by `1/(et)` times its L¬≤ norm at each mode:

    `ŌÉ_1(n)¬≤ ¬∑ ‚ÄĖ(heatSymbol t n) ¬∑ c‚ÄĖ¬≤ ‚Č§ (exp(-1) / t) ¬∑ ‚ÄĖc‚ÄĖ¬≤`

This is the mode-level form of the classical `‚ÄĖ‚ąá(e^{tőĒ}f)‚ÄĖ_{L¬≤} ‚Č§
(et)^{-1/2} ¬∑ ‚ÄĖf‚ÄĖ_{L¬≤}` estimate (squared). -/
theorem heatSymbol_grad_smoothing_mode {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    (fracDerivSymbol 1 n) ^ 2 * ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ (Real.exp (-1) / t) * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (heatSymbol_nonneg t n)]
  have hmain := fracDerivSymbol_1_sq_mul_heat_le ht n
  -- Need: ŌÉ_1¬≤ ¬∑ heat¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤ ‚Č§ (e^{-1}/t) ¬∑ ‚ÄĖc‚ÄĖ¬≤
  -- Have:  ŌÉ_1¬≤ ¬∑ heat   ‚Č§ e^{-1}/t
  -- So ŌÉ_1¬≤ ¬∑ heat¬≤ = (ŌÉ_1¬≤ ¬∑ heat) ¬∑ heat ‚Č§ (e^{-1}/t) ¬∑ heat ‚Č§ (e^{-1}/t) ¬∑ 1
  have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
  have hheat_le_one : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht.le n
  have hŌÉ_nn : 0 ‚Č§ (fracDerivSymbol 1 n) ^ 2 := sq_nonneg _
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hfactor_nn : 0 ‚Č§ Real.exp (-1) / t :=
    div_nonneg (Real.exp_pos _).le ht.le
  calc (fracDerivSymbol 1 n) ^ 2 * ((heatSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ((fracDerivSymbol 1 n) ^ 2 * heatSymbol t n)
        * (heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ (Real.exp (-1) / t) * (heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right hmain (mul_nonneg hheat_nn hc_nn)
    _ ‚Č§ (Real.exp (-1) / t) * (1 * ‚ÄĖc‚ÄĖ ^ 2) := by
        apply mul_le_mul_of_nonneg_left _ hfactor_nn
        exact mul_le_mul_of_nonneg_right hheat_le_one hc_nn
    _ = (Real.exp (-1) / t) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-! ## Parabolic smoothing at Hessian level (k=2)

Bootstrap from the k=1 case: apply the k=1 bound at time `t/2`,
square both sides, and use `exp(a) ¬∑ exp(a) = exp(2a)` to get the
`k=2` bound `‚ÄĖn‚ÄĖ^4 ¬∑ exp(-t‚ÄĖn‚ÄĖ¬≤) ‚Č§ 4¬∑exp(-2)/t¬≤`.
-/

/-- **Parabolic smoothing at Hessian level.** For `t > 0`:

    `‚ÄĖn‚ÄĖ^4 ¬∑ exp(-t¬∑‚ÄĖn‚ÄĖ¬≤) ‚Č§ 4¬∑exp(-2)/t¬≤`

The max of `y¬≤ ¬∑ exp(-y)` is `4/e¬≤` at `y = 2`. -/
theorem latticeNorm_4_mul_heat_le {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm n) ^ 4 * heatSymbol t n
      ‚Č§ 4 * Real.exp (-2) / t ^ 2 := by
  -- Use k=1 bound at time t/2: L¬≤ ¬∑ exp(-(t/2)L¬≤) ‚Č§ exp(-1)/(t/2) = 2¬∑exp(-1)/t
  have ht_half : 0 < t / 2 := half_pos ht
  have h := latticeNorm_sq_mul_heat_le ht_half n
  -- h: L¬≤ ¬∑ heatSymbol (t/2) n ‚Č§ exp(-1) / (t/2)
  -- i.e., L¬≤ ¬∑ exp(-(t/2)¬∑L¬≤) ‚Č§ 2¬∑exp(-1)/t
  have hL_sq_nn : 0 ‚Č§ (latticeNorm n) ^ 2 := sq_nonneg _
  have hheat_nn : 0 ‚Č§ heatSymbol (t/2) n := heatSymbol_nonneg _ _
  have hprod_nn : 0 ‚Č§ (latticeNorm n) ^ 2 * heatSymbol (t/2) n :=
    mul_nonneg hL_sq_nn hheat_nn
  have hrhs_nn : 0 ‚Č§ Real.exp (-1) / (t / 2) :=
    div_nonneg (Real.exp_pos _).le ht_half.le
  -- Square both sides of h:
  -- (L¬≤ ¬∑ heat(t/2))¬≤ ‚Č§ (exp(-1)/(t/2))¬≤
  -- LHS = L^4 ¬∑ heat(t/2)¬≤ = L^4 ¬∑ heat(t)  (since heat(t/2)¬≤ = heat(t))
  -- RHS = (exp(-1))¬≤ / (t/2)¬≤ = exp(-2) / (t¬≤/4) = 4¬∑exp(-2)/t¬≤
  have hsq : ((latticeNorm n) ^ 2 * heatSymbol (t/2) n) ^ 2
          ‚Č§ (Real.exp (-1) / (t / 2)) ^ 2 := by
    exact sq_le_sq' (by linarith [hprod_nn, hrhs_nn]) h
  -- Simplify LHS: (L¬≤ ¬∑ heat(t/2))¬≤ = L^4 ¬∑ heat(t/2)¬≤ = L^4 ¬∑ heat(t)
  have h_lhs_eq : ((latticeNorm n) ^ 2 * heatSymbol (t/2) n) ^ 2
      = (latticeNorm n) ^ 4 * heatSymbol t n := by
    rw [mul_pow]
    congr 1
    ¬∑ ring
    ¬∑ -- heatSymbol (t/2) n ^ 2 = heatSymbol t n
      unfold heatSymbol
      rw [sq, ‚Üź Real.exp_add]
      congr 1; ring
  -- Simplify RHS: (exp(-1)/(t/2))¬≤ = 4¬∑exp(-2)/t¬≤
  have h_rhs_eq : (Real.exp (-1) / (t / 2)) ^ 2 = 4 * Real.exp (-2) / t ^ 2 := by
    rw [div_pow]
    have hexp_sq : (Real.exp (-1)) ^ 2 = Real.exp (-2) := by
      rw [sq, ‚Üź Real.exp_add]; congr 1; ring
    rw [hexp_sq]
    have ht_ne : t ‚Č† 0 := ht.ne'
    field_simp
    ring
  rw [h_lhs_eq] at hsq
  rw [h_rhs_eq] at hsq
  exact hsq

/-- **Parabolic smoothing: fracDerivSymbol 2 form.** For `t > 0`:

    `ŌÉ_2(n)¬≤ ¬∑ heat(t, n) ‚Č§ 4¬∑exp(-2)/t¬≤`. -/
theorem fracDerivSymbol_2_sq_mul_heat_le {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (fracDerivSymbol 2 n) ^ 2 * heatSymbol t n
      ‚Č§ 4 * Real.exp (-2) / t ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have : (fracDerivSymbol 2 (0 : Fin 2 ‚Üí ‚Ą§)) = 0 := fracDerivSymbol_zero 2
    rw [this]
    simp
    positivity
  ¬∑ -- ŌÉ_2(n)¬≤ = L^4
    have h_ŌÉ2_sq : (fracDerivSymbol 2 n) ^ 2 = (latticeNorm n) ^ 4 := by
      rw [fracDerivSymbol_of_ne_zero 2 hn]
      have hL_nn : 0 ‚Č§ latticeNorm n := latticeNorm_nonneg n
      rw [show ((latticeNorm n) ^ (2 : ‚ĄĚ)) ^ 2
          = latticeNorm n ^ (2 * 2 : ‚ĄĚ) from by
        rw [‚Üź Real.rpow_natCast, ‚Üź Real.rpow_mul hL_nn]; norm_num]
      rw [show ((2 : ‚ĄĚ) * 2) = (4 : ‚Ąē) from by norm_num]
      rw [Real.rpow_natCast]
    rw [h_ŌÉ2_sq]
    exact latticeNorm_4_mul_heat_le ht n

/-- **Parabolic smoothing in `ŠłĘ¬≤` form.** For `t > 0`, the heat-smoothed
function has Hessian bounded by `4¬∑exp(-2)/t¬≤` times its L¬≤ norm at each mode:

    `ŌÉ_2(n)¬≤ ¬∑ ‚ÄĖ(heatSymbol t n) ¬∑ c‚ÄĖ¬≤ ‚Č§ (4¬∑exp(-2) / t¬≤) ¬∑ ‚ÄĖc‚ÄĖ¬≤`

This is the mode-level form of the classical `‚ÄĖőĒ(e^{tőĒ}f)‚ÄĖ_{L¬≤} ‚Č§
(2/(et)) ¬∑ ‚ÄĖf‚ÄĖ_{L¬≤}` estimate (squared). -/
theorem heatSymbol_hess_smoothing_mode {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    (fracDerivSymbol 2 n) ^ 2 * ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ (4 * Real.exp (-2) / t ^ 2) * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (heatSymbol_nonneg t n)]
  have hmain := fracDerivSymbol_2_sq_mul_heat_le ht n
  have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
  have hheat_le_one : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht.le n
  have hŌÉ_nn : 0 ‚Č§ (fracDerivSymbol 2 n) ^ 2 := sq_nonneg _
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hfactor_nn : 0 ‚Č§ 4 * Real.exp (-2) / t ^ 2 := by positivity
  calc (fracDerivSymbol 2 n) ^ 2 * ((heatSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ((fracDerivSymbol 2 n) ^ 2 * heatSymbol t n)
        * (heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ (4 * Real.exp (-2) / t ^ 2) * (heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right hmain (mul_nonneg hheat_nn hc_nn)
    _ ‚Č§ (4 * Real.exp (-2) / t ^ 2) * (1 * ‚ÄĖc‚ÄĖ ^ 2) := by
        apply mul_le_mul_of_nonneg_left _ hfactor_nn
        exact mul_le_mul_of_nonneg_right hheat_le_one hc_nn
    _ = (4 * Real.exp (-2) / t ^ 2) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-! ## Parabolic smoothing: applications to SQG velocity/vorticity

Combining the heat-semigroup smoothing with SQG velocity/vorticity
structure: the heat-smoothed SQG velocity gradient is controlled in
terms of `L¬≤(őł)` at a rate `1/(et)`.
-/

/-- **SQG vorticity parabolic smoothing.** Heat-smoothed SQG vorticity
satisfies `‚ÄĖŌČŐā(n) ¬∑ heat(t,n) ¬∑ c‚ÄĖ¬≤ ‚Č§ exp(-1)/t ¬∑ ‚ÄĖc‚ÄĖ¬≤` for each mode
`n ‚Č† 0`.

Proof: `‚ÄĖŌČŐā¬∑heat¬∑c‚ÄĖ¬≤ = L¬≤¬∑heat¬≤¬∑‚ÄĖc‚ÄĖ¬≤`. Using `heat ‚Č§ 1` gives
`heat¬≤ ‚Č§ heat`, so `L¬≤¬∑heat¬≤¬∑‚ÄĖc‚ÄĖ¬≤ ‚Č§ L¬≤¬∑heat¬∑‚ÄĖc‚ÄĖ¬≤ ‚Č§ exp(-1)/t¬∑‚ÄĖc‚ÄĖ¬≤`. -/
theorem sqgVorticity_heat_smoothing_mode {t : ‚ĄĚ} (ht : 0 < t)
    {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) (c : ‚Ąā) :
    ‚ÄĖsqgVorticitySymbol n * ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ (Real.exp (-1) / t) * ‚ÄĖc‚ÄĖ ^ 2 := by
  -- ‚ÄĖŌČŐā ¬∑ heat ¬∑ c‚ÄĖ¬≤ = L¬≤ ¬∑ heat¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤
  have hnorm : ‚ÄĖsqgVorticitySymbol n * ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
      = (latticeNorm n) ^ 2 * (heatSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
    rw [norm_mul, norm_mul, mul_pow, mul_pow, sqgVorticitySymbol_norm hn,
      Complex.norm_real, Real.norm_of_nonneg (heatSymbol_nonneg t n)]
  rw [hnorm]
  -- Goal: L¬≤ ¬∑ heat¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤ ‚Č§ exp(-1)/t ¬∑ ‚ÄĖc‚ÄĖ¬≤
  -- Use heat¬≤ ‚Č§ heat ¬∑ 1 = heat (since heat ‚Č§ 1)
  have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
  have hheat_le_one : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht.le n
  have hL_sq_nn : 0 ‚Č§ (latticeNorm n) ^ 2 := sq_nonneg _
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hmain : (latticeNorm n) ^ 2 * heatSymbol t n ‚Č§ Real.exp (-1) / t :=
    latticeNorm_sq_mul_heat_le ht n
  calc (latticeNorm n) ^ 2 * (heatSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
      = ((latticeNorm n) ^ 2 * heatSymbol t n) * heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2 := by
        rw [sq]; ring
    _ ‚Č§ (Real.exp (-1) / t) * heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2 := by
        apply mul_le_mul_of_nonneg_right _ hc_nn
        exact mul_le_mul_of_nonneg_right hmain hheat_nn
    _ ‚Č§ (Real.exp (-1) / t) * 1 * ‚ÄĖc‚ÄĖ ^ 2 := by
        apply mul_le_mul_of_nonneg_right _ hc_nn
        apply mul_le_mul_of_nonneg_left hheat_le_one
        exact div_nonneg (Real.exp_pos _).le ht.le
    _ = (Real.exp (-1) / t) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-! ## General parabolic smoothing at arbitrary k ‚ąą ‚Ąē

Bootstrap from `k=1` at time `t/k`, then raise to the k-th power.
The key identity is `heat(t) = (heat(t/k))^k`, which lets us rewrite:

    L^{2k} ¬∑ heat(t) = (L¬≤ ¬∑ heat(t/k))^k ‚Č§ (k¬∑exp(-1)/t)^k = k^k¬∑exp(-k)/t^k

giving the general smoothing bound.
-/

/-- **Heat semigroup and powers of time.** For `k ‚Č• 1`:

    `heatSymbol t n = (heatSymbol (t/k) n)^k`. -/
theorem heatSymbol_pow_eq {t : ‚ĄĚ} (n : Fin 2 ‚Üí ‚Ą§) {k : ‚Ąē} (hk : k ‚Č† 0) :
    heatSymbol t n = (heatSymbol (t / k) n) ^ k := by
  unfold heatSymbol
  rw [‚Üź Real.exp_nat_mul]
  congr 1
  have hk_real : (k : ‚ĄĚ) ‚Č† 0 := by exact_mod_cast hk
  field_simp

/-- **General parabolic smoothing at integer k.** For `k ‚Č• 1`, `t > 0`:

    `‚ÄĖn‚ÄĖ^{2k} ¬∑ exp(-t‚ÄĖn‚ÄĖ¬≤) ‚Č§ k^k ¬∑ exp(-k) / t^k`

The max of `y^k ¬∑ exp(-y)` for `y ‚Č• 0` is achieved at `y = k`, with
value `(k/e)^k = k^k ¬∑ exp(-k)`. -/
theorem latticeNorm_pow_mul_heat_le {k : ‚Ąē} (hk : k ‚Č† 0) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm n) ^ (2 * k) * heatSymbol t n
    ‚Č§ (k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k := by
  have hk_pos : 0 < (k : ‚ĄĚ) := by exact_mod_cast Nat.pos_of_ne_zero hk
  have ht_k : 0 < t / k := div_pos ht hk_pos
  have hbase := latticeNorm_sq_mul_heat_le ht_k n
  -- hbase: L¬≤ ¬∑ heat(t/k) ‚Č§ exp(-1) / (t/k)
  have hbase_nn : 0 ‚Č§ (latticeNorm n) ^ 2 * heatSymbol (t/k) n :=
    mul_nonneg (sq_nonneg _) (heatSymbol_nonneg _ _)
  have hbound_nn : 0 ‚Č§ Real.exp (-1) / (t / k) :=
    div_nonneg (Real.exp_pos _).le ht_k.le
  -- Raise both sides to k-th power
  have hpow : ((latticeNorm n) ^ 2 * heatSymbol (t/k) n) ^ k
            ‚Č§ (Real.exp (-1) / (t / k)) ^ k := by
    gcongr
  -- Rewrite LHS as L^{2k} ¬∑ heat(t)
  have hLHS_eq : ((latticeNorm n) ^ 2 * heatSymbol (t/k) n) ^ k
      = (latticeNorm n) ^ (2 * k) * heatSymbol t n := by
    rw [mul_pow, ‚Üź pow_mul, ‚Üź heatSymbol_pow_eq n hk]
  -- Rewrite RHS: (exp(-1)/(t/k))^k = (k¬∑exp(-1)/t)^k = k^k ¬∑ exp(-k) / t^k
  have hRHS_eq : (Real.exp (-1) / (t / k)) ^ k
      = (k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k := by
    have ht_ne : t ‚Č† 0 := ht.ne'
    have hk_ne : (k : ‚ĄĚ) ‚Č† 0 := hk_pos.ne'
    have hrew : Real.exp (-1) / (t / k) = (k : ‚ĄĚ) * Real.exp (-1) / t := by
      field_simp
    rw [hrew, div_pow, mul_pow]
    have hexp : (Real.exp (-1)) ^ k = Real.exp (-(k : ‚ĄĚ)) := by
      rw [‚Üź Real.exp_nat_mul]
      congr 1
      ring
    rw [hexp]
  rw [hLHS_eq] at hpow
  rw [hRHS_eq] at hpow
  exact hpow

/-- **General parabolic smoothing at fracDerivSymbol level.** For `k ‚Č• 1`:

    `ŌÉ_k(n)¬≤ ¬∑ heat(t, n) ‚Č§ k^k ¬∑ exp(-k) / t^k`

where `ŌÉ_k(n)¬≤` denotes the squared `k`-th fractional derivative symbol
(which equals `‚ÄĖn‚ÄĖ^{2k}` for `n ‚Č† 0`). -/
theorem fracDerivSymbol_nat_sq_mul_heat_le {k : ‚Ąē} (hk : k ‚Č† 0) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (fracDerivSymbol (k : ‚ĄĚ) n) ^ 2 * heatSymbol t n
    ‚Č§ (k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k := by
  by_cases hn : n = 0
  ¬∑ subst hn
    rw [fracDerivSymbol_zero]
    simp
    have hk_pos : (0 : ‚ĄĚ) < (k : ‚ĄĚ) := by exact_mod_cast Nat.pos_of_ne_zero hk
    positivity
  ¬∑ have h_ŌÉk_sq : (fracDerivSymbol (k : ‚ĄĚ) n) ^ 2 = (latticeNorm n) ^ (2 * k) := by
      rw [fracDerivSymbol_of_ne_zero _ hn]
      have hL_nn : 0 ‚Č§ latticeNorm n := latticeNorm_nonneg n
      rw [show ((latticeNorm n) ^ ((k : ‚ĄĚ))) ^ 2
          = latticeNorm n ^ ((2 * k : ‚Ąē) : ‚ĄĚ) from by
        rw [‚Üź Real.rpow_natCast ((latticeNorm n) ^ (k : ‚ĄĚ)) 2,
          ‚Üź Real.rpow_mul hL_nn]
        congr 1; push_cast; ring]
      rw [Real.rpow_natCast]
    rw [h_ŌÉk_sq]
    exact latticeNorm_pow_mul_heat_le hk ht n

/-- **Mode-level ŠłĘŠĶŹ parabolic smoothing at general k.** For `k ‚Č• 1`:

    `ŌÉ_k(n)¬≤ ¬∑ ‚ÄĖheat(t,n) ¬∑ c‚ÄĖ¬≤ ‚Č§ (k^k ¬∑ exp(-k) / t^k) ¬∑ ‚ÄĖc‚ÄĖ¬≤`

This is the mode-level form of the classical
`‚ÄĖ(-őĒ)^{k/2} (e^{tőĒ}f)‚ÄĖ_{L¬≤} ‚Č§ (k/(et))^{k/2} ¬∑ ‚ÄĖf‚ÄĖ_{L¬≤}` estimate. -/
theorem heatSymbol_Hk_smoothing_mode {k : ‚Ąē} (hk : k ‚Č† 0) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    (fracDerivSymbol (k : ‚ĄĚ) n) ^ 2 * ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ ((k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k) * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (heatSymbol_nonneg t n)]
  have hmain := fracDerivSymbol_nat_sq_mul_heat_le hk ht n
  have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
  have hheat_le_one : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht.le n
  have hŌÉ_nn : 0 ‚Č§ (fracDerivSymbol (k : ‚ĄĚ) n) ^ 2 := sq_nonneg _
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hfactor_nn : 0 ‚Č§ (k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k := by
    have hk_pos : (0 : ‚ĄĚ) < (k : ‚ĄĚ) := by exact_mod_cast Nat.pos_of_ne_zero hk
    have htk_pos : 0 < t ^ k := pow_pos ht k
    positivity
  calc (fracDerivSymbol (k : ‚ĄĚ) n) ^ 2 * ((heatSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ((fracDerivSymbol (k : ‚ĄĚ) n) ^ 2 * heatSymbol t n)
        * (heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ ((k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k) * (heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right hmain (mul_nonneg hheat_nn hc_nn)
    _ ‚Č§ ((k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k) * (1 * ‚ÄĖc‚ÄĖ ^ 2) := by
        apply mul_le_mul_of_nonneg_left _ hfactor_nn
        exact mul_le_mul_of_nonneg_right hheat_le_one hc_nn
    _ = ((k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-- **Heat operator strictly smooths at each natural Sobolev level.**
For `k ‚Č• 1`, applying the heat semigroup for time `t > 0` gives a
bound at `ŠłĘŠĶŹ` level proportional to `1/t^k`. -/
theorem heatSymbol_increases_regularity {k : ‚Ąē} (hk : k ‚Č† 0) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (fracDerivSymbol (k : ‚ĄĚ) n) ^ 2 * heatSymbol t n ‚Č§
      (k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k :=
  fracDerivSymbol_nat_sq_mul_heat_le hk ht n

/-! ## Integrated parabolic smoothing (Lp form)

Lifting the mode-level parabolic smoothing bounds to integrated
ŠłĘŠĶŹ seminorms via Parseval.
-/

/-- **Integrated parabolic smoothing at ŠłĘŠĶŹ level.** For `k ‚Č• 1`, `t > 0`,
and heat-smoothed function `u` with Fourier coefficients
`√Ľ(n) = heatSymbol(t, n) ¬∑ fŐā(n)`:

    `‚ÄĖu‚ÄĖ¬≤_{ŠłĘŠĶŹ} ‚Č§ (k^k ¬∑ exp(-k) / t^k) ¬∑ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}`

This is the classical `‚ÄĖ(-őĒ)^{k/2}(e^{tőĒ}f)‚ÄĖ¬≤_{L¬≤} ‚Č§ (k/(et))^k ¬∑ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}`
parabolic smoothing estimate. -/
theorem heatSymbol_Hk_smoothing_integrated {k : ‚Ąē} (hk : k ‚Č† 0) {t : ‚ĄĚ} (ht : 0 < t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq (k : ‚ĄĚ) u ‚Č§
      ((k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k) *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
  unfold hsSeminormSq
  rw [show ((k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k) *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎf) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        ((k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k) * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎf) n‚ÄĖ ^ 2 from
    (tsum_mul_left).symm]
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶
    fracDerivSymbol (k : ‚ĄĚ) n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2)
  ¬∑ intro n
    rw [hcoeff n]
    exact heatSymbol_Hk_smoothing_mode hk ht n (mFourierCoeff f n)
  ¬∑ apply (hsum.mul_left ((k : ‚ĄĚ) ^ k * Real.exp (-(k : ‚ĄĚ)) / t ^ k)).of_nonneg_of_le
    ¬∑ intro n; exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      rw [hcoeff n]
      exact heatSymbol_Hk_smoothing_mode hk ht n (mFourierCoeff f n)
  ¬∑ exact hsum.mul_left _

/-- **Integrated parabolic smoothing at gradient level.** Specialization
of `heatSymbol_Hk_smoothing_integrated` at `k = 1`:

    `‚ÄĖu‚ÄĖ¬≤_{ŠłĘ¬Ļ} ‚Č§ (exp(-1) / t) ¬∑ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}` -/
theorem heatSymbol_grad_smoothing_integrated {t : ‚ĄĚ} (ht : 0 < t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq 1 u ‚Č§
      (Real.exp (-1) / t) * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
  have h := heatSymbol_Hk_smoothing_integrated (k := 1) (by omega) ht f u hcoeff hsum
  simp only [Nat.cast_one, pow_one] at h
  convert h using 1
  ring

/-- **Integrated parabolic smoothing at Hessian level.** Specialization
at `k = 2`:

    `‚ÄĖu‚ÄĖ¬≤_{ŠłĘ¬≤} ‚Č§ (4¬∑exp(-2) / t¬≤) ¬∑ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}` -/
theorem heatSymbol_hess_smoothing_integrated {t : ‚ĄĚ} (ht : 0 < t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq 2 u ‚Č§
      (4 * Real.exp (-2) / t ^ 2) * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
  have h := heatSymbol_Hk_smoothing_integrated (k := 2) (by omega) ht f u hcoeff hsum
  simp only [Nat.cast_ofNat] at h
  convert h using 2
  norm_num

/-! ## Parabolic smoothing at real exponent k > 0

Extends natural-number parabolic smoothing to arbitrary real k > 0
using `Real.rpow`. The bootstrap is identical: apply k=1 at `t/k`,
then raise both sides to the real k-th power via `Real.rpow_le_rpow`.
-/

/-- **Heat semigroup rpow identity.** For `k > 0`, `t : ‚ĄĚ`:

    `heatSymbol t n = (heatSymbol (t/k) n) ^ k`

where `^` is `Real.rpow`. -/
theorem heatSymbol_rpow_eq {t : ‚ĄĚ} (n : Fin 2 ‚Üí ‚Ą§) {k : ‚ĄĚ} (hk : 0 < k) :
    heatSymbol t n = (heatSymbol (t / k) n) ^ k := by
  unfold heatSymbol
  -- Goal: exp(-t¬∑L¬≤) = (exp(-(t/k)¬∑L¬≤))^k
  rw [Real.rpow_def_of_pos (Real.exp_pos _), Real.log_exp]
  -- Now: exp(-t¬∑L¬≤) = exp(k ¬∑ (-(t/k)¬∑L¬≤))
  congr 1
  have hk_ne : k ‚Č† 0 := hk.ne'
  field_simp

/-- **Exponential rpow identity.** `exp(-1)^k = exp(-k)`. -/
lemma exp_neg_one_rpow (k : ‚ĄĚ) : (Real.exp (-1)) ^ k = Real.exp (-k) := by
  rw [Real.rpow_def_of_pos (Real.exp_pos _), Real.log_exp]
  congr 1; ring

/-- **`latticeNorm` squared as rpow.** For `n : Fin 2 ‚Üí ‚Ą§`:

    `(latticeNorm n)^2 = (latticeNorm n)^(2 : ‚ĄĚ)` (rpow form). -/
lemma latticeNorm_sq_eq_rpow (n : Fin 2 ‚Üí ‚Ą§) :
    ((latticeNorm n) ^ 2 : ‚ĄĚ) = (latticeNorm n) ^ (2 : ‚ĄĚ) := by
  rw [show (2 : ‚ĄĚ) = ((2 : ‚Ąē) : ‚ĄĚ) from by norm_num, Real.rpow_natCast]

/-- **General real-k parabolic smoothing.** For `k > 0`, `t > 0`:

    `‚ÄĖn‚ÄĖ^{2k} ¬∑ exp(-t¬∑‚ÄĖn‚ÄĖ¬≤) ‚Č§ k^k ¬∑ exp(-k) / t^k`

where all exponents are `Real.rpow`. -/
theorem latticeNorm_rpow_mul_heat_le {k : ‚ĄĚ} (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm n) ^ (2 * k) * heatSymbol t n
    ‚Č§ k ^ k * Real.exp (-k) / t ^ k := by
  have hL_nn : 0 ‚Č§ latticeNorm n := latticeNorm_nonneg n
  have ht_k : 0 < t / k := div_pos ht hk
  have hbase := latticeNorm_sq_mul_heat_le ht_k n
  have hbase_nn : 0 ‚Č§ (latticeNorm n) ^ 2 * heatSymbol (t/k) n :=
    mul_nonneg (sq_nonneg _) (heatSymbol_nonneg _ _)
  -- Raise both sides to the k-th real power
  have hpow : ((latticeNorm n) ^ 2 * heatSymbol (t/k) n) ^ k
            ‚Č§ (Real.exp (-1) / (t / k)) ^ k :=
    Real.rpow_le_rpow hbase_nn hbase hk.le
  -- Simplify LHS: (L¬≤ ¬∑ heat(t/k))^k = L^{2k} ¬∑ heat(t)
  have hLHS_eq : ((latticeNorm n) ^ 2 * heatSymbol (t/k) n) ^ k
      = (latticeNorm n) ^ (2 * k) * heatSymbol t n := by
    rw [Real.mul_rpow (sq_nonneg _) (heatSymbol_nonneg _ _)]
    congr 1
    ¬∑ -- (L¬≤)^k = L^{2k}
      rw [latticeNorm_sq_eq_rpow, ‚Üź Real.rpow_mul hL_nn]
    ¬∑ -- heat(t/k)^k = heat(t)
      rw [‚Üź heatSymbol_rpow_eq n hk]
  -- Simplify RHS: (exp(-1)/(t/k))^k = k¬∑exp(-1)/t)^k = k^k ¬∑ exp(-k) / t^k
  have hRHS_eq : (Real.exp (-1) / (t / k)) ^ k
      = k ^ k * Real.exp (-k) / t ^ k := by
    have ht_ne : t ‚Č† 0 := ht.ne'
    have hk_ne : k ‚Č† 0 := hk.ne'
    have hrew : Real.exp (-1) / (t / k) = k * Real.exp (-1) / t := by
      field_simp
    rw [hrew]
    rw [Real.div_rpow (by positivity : 0 ‚Č§ k * Real.exp (-1)) ht.le]
    rw [Real.mul_rpow hk.le (Real.exp_pos _).le]
    rw [exp_neg_one_rpow]
  rw [hLHS_eq] at hpow
  rw [hRHS_eq] at hpow
  exact hpow

/-- **Real-k parabolic smoothing at fracDerivSymbol level.** For `k > 0`, `t > 0`:

    `ŌÉ_k(n)¬≤ ¬∑ heat(t, n) ‚Č§ k^k ¬∑ exp(-k) / t^k`

using `rpow` for `ŌÉ_k` and the power `t^k`. -/
theorem fracDerivSymbol_sq_mul_heat_le_rpow {k : ‚ĄĚ} (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (fracDerivSymbol k n) ^ 2 * heatSymbol t n
    ‚Č§ k ^ k * Real.exp (-k) / t ^ k := by
  by_cases hn : n = 0
  ¬∑ subst hn
    rw [fracDerivSymbol_zero]
    simp
    positivity
  ¬∑ -- ŌÉ_k(n)¬≤ = L^{2k}: use (L^k)^2 = L^k ¬∑ L^k = L^(k+k) = L^(2k)
    have hL_pos : 0 < latticeNorm n := latticeNorm_pos hn
    have h_ŌÉk_sq : (fracDerivSymbol k n) ^ 2 = (latticeNorm n) ^ (2 * k) := by
      rw [fracDerivSymbol_of_ne_zero k hn, sq,
        ‚Üź Real.rpow_add hL_pos]
      congr 1; ring
    rw [h_ŌÉk_sq]
    exact latticeNorm_rpow_mul_heat_le hk ht n

/-- **Mode-level ŠłĘŠĶŹ parabolic smoothing at real k > 0.** For any `k > 0, t > 0`:

    `ŌÉ_k(n)¬≤ ¬∑ ‚ÄĖheat(t,n) ¬∑ c‚ÄĖ¬≤ ‚Č§ (k^k ¬∑ exp(-k) / t^k) ¬∑ ‚ÄĖc‚ÄĖ¬≤` -/
theorem heatSymbol_Hk_smoothing_mode_rpow {k : ‚ĄĚ} (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    (fracDerivSymbol k n) ^ 2 * ‚ÄĖ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ (k ^ k * Real.exp (-k) / t ^ k) * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (heatSymbol_nonneg t n)]
  have hmain := fracDerivSymbol_sq_mul_heat_le_rpow hk ht n
  have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
  have hheat_le_one : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht.le n
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hfactor_nn : 0 ‚Č§ k ^ k * Real.exp (-k) / t ^ k := by
    have htk_pos : 0 < t ^ k := Real.rpow_pos_of_pos ht k
    have hkk_pos : 0 < k ^ k := Real.rpow_pos_of_pos hk k
    positivity
  calc (fracDerivSymbol k n) ^ 2 * ((heatSymbol t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ((fracDerivSymbol k n) ^ 2 * heatSymbol t n)
        * (heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ (k ^ k * Real.exp (-k) / t ^ k) * (heatSymbol t n * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right hmain (mul_nonneg hheat_nn hc_nn)
    _ ‚Č§ (k ^ k * Real.exp (-k) / t ^ k) * (1 * ‚ÄĖc‚ÄĖ ^ 2) := by
        apply mul_le_mul_of_nonneg_left _ hfactor_nn
        exact mul_le_mul_of_nonneg_right hheat_le_one hc_nn
    _ = (k ^ k * Real.exp (-k) / t ^ k) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-- **Integrated ŠłĘŠĶŹ parabolic smoothing at real k > 0.** For `k > 0, t > 0`,
heat-smoothed `u` with `√Ľ(n) = heat(t,n) ¬∑ fŐā(n)`:

    `‚ÄĖu‚ÄĖ¬≤_{ŠłĘŠĶŹ} ‚Č§ (k^k ¬∑ exp(-k) / t^k) ¬∑ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}` -/
theorem heatSymbol_Hk_smoothing_integrated_rpow {k : ‚ĄĚ} (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq k u ‚Č§
      (k ^ k * Real.exp (-k) / t ^ k) *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
  unfold hsSeminormSq
  rw [show (k ^ k * Real.exp (-k) / t ^ k) *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎf) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        (k ^ k * Real.exp (-k) / t ^ k) * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎf) n‚ÄĖ ^ 2 from
    (tsum_mul_left).symm]
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶
    fracDerivSymbol k n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2)
  ¬∑ intro n
    rw [hcoeff n]
    exact heatSymbol_Hk_smoothing_mode_rpow hk ht n (mFourierCoeff f n)
  ¬∑ apply (hsum.mul_left (k ^ k * Real.exp (-k) / t ^ k)).of_nonneg_of_le
    ¬∑ intro n; exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      rw [hcoeff n]
      exact heatSymbol_Hk_smoothing_mode_rpow hk ht n (mFourierCoeff f n)
  ¬∑ exact hsum.mul_left _

/-! ## Heat semigroup contractivity at every Sobolev level

The heat semigroup is a contraction on `L¬≤`, `ŠłĘňĘ`, and more generally
at every Sobolev level. These are proven by lifting the mode-level
`heatSymbol_Hs_mode_bound` via Parseval/tsum.
-/

/-- **Heat L¬≤ contractivity (integrated).** For `t ‚Č• 0`, heat-smoothed
function satisfies `‚ÄĖe^{tőĒ}f‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}`. -/
theorem heatSymbol_L2_contractivity {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hf_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) (‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2))
    (hu_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2) (‚ąę x, ‚ÄĖu x‚ÄĖ ^ 2))
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    (‚ąę x, ‚ÄĖu x‚ÄĖ ^ 2) ‚Č§ (‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2) := by
  rw [‚Üź hu_parseval.tsum_eq, ‚Üź hf_parseval.tsum_eq]
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶ ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
  ¬∑ intro n
    rw [hcoeff n, norm_mul, mul_pow, Complex.norm_real,
      Real.norm_of_nonneg (heatSymbol_nonneg t n)]
    have hheat_le_one : heatSymbol t n ‚Č§ 1 := heatSymbol_le_one ht n
    have hheat_nn : 0 ‚Č§ heatSymbol t n := heatSymbol_nonneg t n
    have hheat_sq_le : (heatSymbol t n) ^ 2 ‚Č§ 1 :=
      pow_le_one‚āÄ hheat_nn hheat_le_one
    have hc_nn : 0 ‚Č§ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := sq_nonneg _
    calc (heatSymbol t n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2
        ‚Č§ 1 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 :=
          mul_le_mul_of_nonneg_right hheat_sq_le hc_nn
      _ = ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2 := one_mul _
  ¬∑ exact hu_parseval.summable
  ¬∑ exact hsum

/-- **Heat ŠłĘňĘ contractivity (integrated).** For `t ‚Č• 0`:

    `‚ÄĖe^{tőĒ}f‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}` -/
theorem heatSymbol_Hs_contractivity {s : ‚ĄĚ} {t : ‚ĄĚ} (ht : 0 ‚Č§ t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hsum : Summable (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq s f := by
  unfold hsSeminormSq
  apply Summable.tsum_le_tsum
    (f := fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
  ¬∑ intro n
    rw [hcoeff n]
    exact heatSymbol_Hs_mode_bound ht s (mFourierCoeff f n)
  ¬∑ apply hsum.of_nonneg_of_le
    ¬∑ intro n; exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      rw [hcoeff n]
      exact heatSymbol_Hs_mode_bound ht s (mFourierCoeff f n)
  ¬∑ exact hsum

/-! ## őĪ-Fractional heat semigroup

The fractional heat semigroup `e^{-t(-őĒ)^őĪ}` for `0 < őĪ` has Fourier
multiplier `exp(-t¬∑‚ÄĖn‚ÄĖ^{2őĪ})`. Unifies:
- Heat (őĪ = 1): `exp(-t¬∑‚ÄĖn‚ÄĖ¬≤)`  [`heatSymbol`]
- Poisson (őĪ = 1/2): `exp(-t¬∑‚ÄĖn‚ÄĖ)`  [`poissonSymbol`]

Relevant for fractional SQG / surface quasi-geostrophic-like equations
with dissipation `(-őĒ)^őĪ` where `0 < őĪ ‚Č§ 1`.
-/

/-- **őĪ-Fractional heat semigroup symbol.** For `őĪ > 0, t : ‚ĄĚ`:

    `H_{őĪ,t}(n) = exp(-t ¬∑ ‚ÄĖn‚ÄĖ^{2őĪ})`

where `‚ÄĖn‚ÄĖ^{2őĪ}` uses `Real.rpow`. -/
noncomputable def fracHeatSymbol (őĪ t : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§) : ‚ĄĚ :=
  Real.exp (-t * (latticeNorm n) ^ (2 * őĪ))

/-- **őĪ-Fractional heat at zero mode is `exp(0) = 1` if `őĪ > 0`.** -/
@[simp] lemma fracHeatSymbol_zero_mode {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) :
    fracHeatSymbol őĪ t (0 : Fin 2 ‚Üí ‚Ą§) = 1 := by
  unfold fracHeatSymbol
  simp [latticeNorm, Real.zero_rpow (by linarith : (2 * őĪ) ‚Č† 0)]

/-- **Fractional heat is positive.** -/
lemma fracHeatSymbol_pos (őĪ t : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§) :
    0 < fracHeatSymbol őĪ t n := Real.exp_pos _

/-- **Fractional heat is nonneg.** -/
lemma fracHeatSymbol_nonneg (őĪ t : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§) :
    0 ‚Č§ fracHeatSymbol őĪ t n := (fracHeatSymbol_pos őĪ t n).le

/-- **Fractional heat at t=0 is 1.** -/
@[simp] lemma fracHeatSymbol_zero_time (őĪ : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§) :
    fracHeatSymbol őĪ 0 n = 1 := by
  unfold fracHeatSymbol
  simp

/-- **Fractional heat ‚Č§ 1 for t ‚Č• 0 and őĪ > 0.** -/
lemma fracHeatSymbol_le_one {őĪ t : ‚ĄĚ} (_hőĪ : 0 < őĪ) (ht : 0 ‚Č§ t) (n : Fin 2 ‚Üí ‚Ą§) :
    fracHeatSymbol őĪ t n ‚Č§ 1 := by
  unfold fracHeatSymbol
  rw [show (1 : ‚ĄĚ) = Real.exp 0 from Real.exp_zero.symm]
  apply Real.exp_le_exp.mpr
  have hL_pow_nn : 0 ‚Č§ (latticeNorm n : ‚ĄĚ) ^ (2 * őĪ) :=
    Real.rpow_nonneg (latticeNorm_nonneg n) (2 * őĪ)
  nlinarith

/-- **Fractional heat: additive in time (homomorphism).** -/
lemma fracHeatSymbol_add (őĪ t‚āĀ t‚āā : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§) :
    fracHeatSymbol őĪ (t‚āĀ + t‚āā) n
    = fracHeatSymbol őĪ t‚āĀ n * fracHeatSymbol őĪ t‚āā n := by
  unfold fracHeatSymbol
  rw [‚Üź Real.exp_add]
  congr 1; ring

/-- **Heat is őĪ=1 case of fracHeat.** -/
theorem fracHeatSymbol_one_eq_heat (t : ‚ĄĚ) (n : Fin 2 ‚Üí ‚Ą§) :
    fracHeatSymbol 1 t n = heatSymbol t n := by
  unfold fracHeatSymbol heatSymbol
  congr 1
  have hL_nn : 0 ‚Č§ (latticeNorm n : ‚ĄĚ) := latticeNorm_nonneg n
  rw [show ((latticeNorm n : ‚ĄĚ) : ‚ĄĚ) ^ (2 * (1 : ‚ĄĚ)) = (latticeNorm n) ^ 2 from by
    rw [show (2 * 1 : ‚ĄĚ) = ((2 : ‚Ąē) : ‚ĄĚ) from by norm_num, Real.rpow_natCast]]

/-- **Fractional heat base smoothing bound.** For `0 < őĪ`, `t > 0`:

    `‚ÄĖn‚ÄĖ^{2őĪ} ¬∑ exp(-t¬∑‚ÄĖn‚ÄĖ^{2őĪ}) ‚Č§ exp(-1)/t`

Obtained by letting `y = t¬∑‚ÄĖn‚ÄĖ^{2őĪ}` and using `y¬∑exp(-y) ‚Č§ exp(-1)`. -/
theorem latticeNorm_rpow_mul_fracHeat_le {őĪ : ‚ĄĚ} (_hőĪ : 0 < őĪ) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm n) ^ (2 * őĪ) * fracHeatSymbol őĪ t n ‚Č§ Real.exp (-1) / t := by
  unfold fracHeatSymbol
  set y : ‚ĄĚ := t * (latticeNorm n) ^ (2 * őĪ) with hy_def
  have hL_pow_nn : 0 ‚Č§ (latticeNorm n : ‚ĄĚ) ^ (2 * őĪ) :=
    Real.rpow_nonneg (latticeNorm_nonneg n) (2 * őĪ)
  have hy_nn : 0 ‚Č§ y := mul_nonneg ht.le hL_pow_nn
  have hexp_rw : Real.exp (-t * (latticeNorm n) ^ (2 * őĪ)) = Real.exp (-y) := by
    congr 1; rw [hy_def]; ring
  rw [hexp_rw]
  have hLeq : ((latticeNorm n : ‚ĄĚ) ^ (2 * őĪ)) = y / t := by
    rw [hy_def]; field_simp
  rw [hLeq, div_mul_eq_mul_div]
  have h_num : y * Real.exp (-y) ‚Č§ Real.exp (-1) := mul_exp_neg_le_exp_neg_one y
  gcongr

/-- **Fractional heat rpow identity.** For `k > 0`:

    `fracHeatSymbol őĪ t n = (fracHeatSymbol őĪ (t/k) n)^k`. -/
theorem fracHeatSymbol_rpow_eq {őĪ : ‚ĄĚ} {t : ‚ĄĚ} (n : Fin 2 ‚Üí ‚Ą§) {k : ‚ĄĚ} (hk : 0 < k) :
    fracHeatSymbol őĪ t n = (fracHeatSymbol őĪ (t / k) n) ^ k := by
  unfold fracHeatSymbol
  rw [Real.rpow_def_of_pos (Real.exp_pos _), Real.log_exp]
  congr 1
  have hk_ne : k ‚Č† 0 := hk.ne'
  field_simp

/-- **General őĪ-fractional heat smoothing.** For `0 < őĪ`, `t > 0`, `k > 0`:

    `‚ÄĖn‚ÄĖ^k ¬∑ exp(-t¬∑‚ÄĖn‚ÄĖ^{2őĪ}) ‚Č§ (k/(2őĪ))^{k/(2őĪ)} ¬∑ exp(-k/(2őĪ)) / t^{k/(2őĪ)}`

Unifies:
- Heat (őĪ = 1): `‚ÄĖn‚ÄĖ^k¬∑exp(-t‚ÄĖn‚ÄĖ¬≤) ‚Č§ (k/2)^{k/2} ¬∑ exp(-k/2) / t^{k/2}`
- Poisson (őĪ = 1/2): `‚ÄĖn‚ÄĖ^k¬∑exp(-t‚ÄĖn‚ÄĖ) ‚Č§ k^k ¬∑ exp(-k) / t^k` -/
theorem latticeNorm_rpow_mul_fracHeat_le_general
    {őĪ k : ‚ĄĚ} (hőĪ : 0 < őĪ) (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm n) ^ k * fracHeatSymbol őĪ t n
    ‚Č§ (k / (2 * őĪ)) ^ (k / (2 * őĪ)) * Real.exp (-(k / (2 * őĪ))) / t ^ (k / (2 * őĪ)) := by
  have hL_nn : 0 ‚Č§ latticeNorm n := latticeNorm_nonneg n
  set m : ‚ĄĚ := k / (2 * őĪ) with hm_def
  have hm_pos : 0 < m := by rw [hm_def]; positivity
  have ht_m : 0 < t / m := div_pos ht hm_pos
  -- Base: L^{2őĪ} ¬∑ fracHeat őĪ (t/m) n ‚Č§ exp(-1) / (t/m)
  have hbase := latticeNorm_rpow_mul_fracHeat_le hőĪ ht_m n
  have hbase_nn : 0 ‚Č§ (latticeNorm n) ^ (2 * őĪ) * fracHeatSymbol őĪ (t/m) n :=
    mul_nonneg (Real.rpow_nonneg hL_nn _) (fracHeatSymbol_nonneg _ _ _)
  -- Raise to m-th real power
  have hpow : ((latticeNorm n) ^ (2 * őĪ) * fracHeatSymbol őĪ (t/m) n) ^ m
            ‚Č§ (Real.exp (-1) / (t / m)) ^ m :=
    Real.rpow_le_rpow hbase_nn hbase hm_pos.le
  -- LHS: (L^{2őĪ} ¬∑ frac(t/m))^m = L^{2őĪm} ¬∑ frac(t)
  have hLHS_eq : ((latticeNorm n) ^ (2 * őĪ) * fracHeatSymbol őĪ (t/m) n) ^ m
      = (latticeNorm n) ^ k * fracHeatSymbol őĪ t n := by
    rw [Real.mul_rpow (Real.rpow_nonneg hL_nn _) (fracHeatSymbol_nonneg _ _ _)]
    congr 1
    ¬∑ -- (L^{2őĪ})^m = L^{2őĪm} = L^k
      rw [‚Üź Real.rpow_mul hL_nn]
      congr 1
      rw [hm_def]; field_simp
    ¬∑ -- frac(t/m)^m = frac(t)
      rw [‚Üź fracHeatSymbol_rpow_eq n hm_pos]
  -- RHS: (exp(-1)/(t/m))^m = m^m ¬∑ exp(-m) / t^m
  have hRHS_eq : (Real.exp (-1) / (t / m)) ^ m = m ^ m * Real.exp (-m) / t ^ m := by
    have ht_ne : t ‚Č† 0 := ht.ne'
    have hm_ne : m ‚Č† 0 := hm_pos.ne'
    have hrew : Real.exp (-1) / (t / m) = m * Real.exp (-1) / t := by
      field_simp
    rw [hrew, Real.div_rpow (by positivity : 0 ‚Č§ m * Real.exp (-1)) ht.le,
      Real.mul_rpow hm_pos.le (Real.exp_pos _).le, exp_neg_one_rpow]
  rw [hLHS_eq] at hpow
  rw [hRHS_eq] at hpow
  convert hpow using 1

/-- **General őĪ-fractional heat bound via fracDerivSymbol.** For `k > 0`:

    `ŌÉ_k(n)¬≤ ¬∑ fracHeat(őĪ, t, n) ‚Č§ (k/őĪ)^{k/őĪ} ¬∑ exp(-k/őĪ) / t^{k/őĪ}`

Using `ŌÉ_k¬≤ = ‚ÄĖn‚ÄĖ^{2k}` and the general bound with parameter `2k`. -/
theorem fracDerivSymbol_sq_mul_fracHeat_le
    {őĪ k : ‚ĄĚ} (hőĪ : 0 < őĪ) (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) :
    (fracDerivSymbol k n) ^ 2 * fracHeatSymbol őĪ t n
    ‚Č§ (k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ) := by
  by_cases hn : n = 0
  ¬∑ subst hn
    rw [fracDerivSymbol_zero]
    simp
    have : 0 < k / őĪ := div_pos hk hőĪ
    positivity
  ¬∑ have hL_pos : 0 < latticeNorm n := latticeNorm_pos hn
    have h_ŌÉk_sq : (fracDerivSymbol k n) ^ 2 = (latticeNorm n) ^ (2 * k) := by
      rw [fracDerivSymbol_of_ne_zero k hn, sq, ‚Üź Real.rpow_add hL_pos]
      congr 1; ring
    rw [h_ŌÉk_sq]
    -- Apply general bound with k' = 2k, so k'/(2őĪ) = k/őĪ
    have h2k_pos : 0 < 2 * k := by linarith
    have := latticeNorm_rpow_mul_fracHeat_le_general hőĪ h2k_pos ht n
    -- This gives: L^{2k} ¬∑ frac ‚Č§ (2k/(2őĪ))^{2k/(2őĪ)} ¬∑ exp(-2k/(2őĪ)) / t^{2k/(2őĪ)}
    -- = (k/őĪ)^{k/őĪ} ¬∑ exp(-k/őĪ) / t^{k/őĪ}
    have hsimp : 2 * k / (2 * őĪ) = k / őĪ := by field_simp
    rw [hsimp] at this
    exact this

/-- **őĪ-Fractional heat ŠłĘŠĶŹ mode smoothing.** For `őĪ > 0, k > 0, t > 0`:

    `ŌÉ_k(n)¬≤ ¬∑ ‚ÄĖfracHeat(őĪ,t,n) ¬∑ c‚ÄĖ¬≤ ‚Č§ ((k/őĪ)^{k/őĪ} ¬∑ exp(-k/őĪ) / t^{k/őĪ}) ¬∑ ‚ÄĖc‚ÄĖ¬≤` -/
theorem fracHeatSymbol_Hk_mode_bound
    {őĪ k : ‚ĄĚ} (hőĪ : 0 < őĪ) (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    (fracDerivSymbol k n) ^ 2 * ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ ((k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (fracHeatSymbol_nonneg őĪ t n)]
  have hmain := fracDerivSymbol_sq_mul_fracHeat_le hőĪ hk ht n
  have hf_nn : 0 ‚Č§ fracHeatSymbol őĪ t n := fracHeatSymbol_nonneg őĪ t n
  have hf_le : fracHeatSymbol őĪ t n ‚Č§ 1 := fracHeatSymbol_le_one hőĪ ht.le n
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hfactor_nn : 0 ‚Č§ (k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ) := by
    have hkőĪ : 0 < k / őĪ := div_pos hk hőĪ
    have htk : 0 < t ^ (k / őĪ) := Real.rpow_pos_of_pos ht _
    have hkk : 0 < (k / őĪ) ^ (k / őĪ) := Real.rpow_pos_of_pos hkőĪ _
    positivity
  calc (fracDerivSymbol k n) ^ 2 * ((fracHeatSymbol őĪ t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2)
      = ((fracDerivSymbol k n) ^ 2 * fracHeatSymbol őĪ t n)
        * (fracHeatSymbol őĪ t n * ‚ÄĖc‚ÄĖ ^ 2) := by ring
    _ ‚Č§ ((k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ))
        * (fracHeatSymbol őĪ t n * ‚ÄĖc‚ÄĖ ^ 2) :=
        mul_le_mul_of_nonneg_right hmain (mul_nonneg hf_nn hc_nn)
    _ ‚Č§ ((k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ)) * (1 * ‚ÄĖc‚ÄĖ ^ 2) := by
        apply mul_le_mul_of_nonneg_left _ hfactor_nn
        exact mul_le_mul_of_nonneg_right hf_le hc_nn
    _ = ((k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-- **őĪ-Fractional heat L¬≤ contractivity (mode-level).** -/
theorem fracHeatSymbol_L2_mode_contract {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 ‚Č§ t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [norm_mul, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (fracHeatSymbol_nonneg őĪ t n)]
  have hf_nn : 0 ‚Č§ fracHeatSymbol őĪ t n := fracHeatSymbol_nonneg őĪ t n
  have hf_le : fracHeatSymbol őĪ t n ‚Č§ 1 := fracHeatSymbol_le_one hőĪ ht n
  have hf_sq_le : (fracHeatSymbol őĪ t n) ^ 2 ‚Č§ 1 := pow_le_one‚āÄ hf_nn hf_le
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  calc (fracHeatSymbol őĪ t n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
      ‚Č§ 1 * ‚ÄĖc‚ÄĖ ^ 2 := mul_le_mul_of_nonneg_right hf_sq_le hc_nn
    _ = ‚ÄĖc‚ÄĖ ^ 2 := one_mul _

/-- **őĪ-Fractional heat ŠłĘňĘ mode contractivity.** -/
theorem fracHeatSymbol_Hs_mode_bound {őĪ s t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 ‚Č§ t)
    (n : Fin 2 ‚Üí ‚Ą§) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 * ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2
    ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 :=
  mul_le_mul_of_nonneg_left (fracHeatSymbol_L2_mode_contract hőĪ ht n c) (sq_nonneg _)

/-- **őĪ-Fractional heat ŠłĘŠĶŹ integrated smoothing.** For `0 < őĪ, k > 0, t > 0`:

    `‚ÄĖe^{-t(-őĒ)^őĪ} f‚ÄĖ¬≤_{ŠłĘŠĶŹ} ‚Č§ (k/őĪ)^{k/őĪ}¬∑exp(-k/őĪ)/t^{k/őĪ} ¬∑ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}` -/
theorem fracHeatSymbol_Hk_smoothing_integrated
    {őĪ k : ‚ĄĚ} (hőĪ : 0 < őĪ) (hk : 0 < k) {t : ‚ĄĚ} (ht : 0 < t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq k u ‚Č§
      ((k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ)) *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) := by
  unfold hsSeminormSq
  rw [show ((k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ)) *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎf) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        ((k / őĪ) ^ (k / őĪ) * Real.exp (-(k / őĪ)) / t ^ (k / őĪ))
          * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎf) n‚ÄĖ ^ 2 from
    (tsum_mul_left).symm]
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶
    fracDerivSymbol k n ^ 2 * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2)
  ¬∑ intro n
    rw [hcoeff n]
    exact fracHeatSymbol_Hk_mode_bound hőĪ hk ht n (mFourierCoeff f n)
  ¬∑ apply (hsum.mul_left _).of_nonneg_of_le
    ¬∑ intro n; exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      rw [hcoeff n]
      exact fracHeatSymbol_Hk_mode_bound hőĪ hk ht n (mFourierCoeff f n)
  ¬∑ exact hsum.mul_left _

/-- **őĪ-Fractional heat L¬≤ contractivity (integrated).** For `őĪ > 0, t ‚Č• 0`:

    `‚ÄĖe^{-t(-őĒ)^őĪ} f‚ÄĖ¬≤_{L¬≤} ‚Č§ ‚ÄĖf‚ÄĖ¬≤_{L¬≤}` -/
theorem fracHeatSymbol_L2_contractivity
    {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 ‚Č§ t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hf_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2) (‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2))
    (hu_parseval : HasSum (fun n ‚Ü¶ ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2) (‚ąę x, ‚ÄĖu x‚ÄĖ ^ 2))
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    (‚ąę x, ‚ÄĖu x‚ÄĖ ^ 2) ‚Č§ (‚ąę x, ‚ÄĖf x‚ÄĖ ^ 2) := by
  rw [‚Üź hu_parseval.tsum_eq, ‚Üź hf_parseval.tsum_eq]
  apply Summable.tsum_le_tsum (f := fun n ‚Ü¶ ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
  ¬∑ intro n
    rw [hcoeff n]
    exact fracHeatSymbol_L2_mode_contract hőĪ ht n (mFourierCoeff f n)
  ¬∑ exact hu_parseval.summable
  ¬∑ exact hsum

/-- **őĪ-Fractional heat ŠłĘňĘ contractivity (integrated).** -/
theorem fracHeatSymbol_Hs_contractivity
    {őĪ s t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 ‚Č§ t)
    (f u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n = ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * mFourierCoeff f n)
    (hsum : Summable (fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff f n‚ÄĖ ^ 2)) :
    hsSeminormSq s u ‚Č§ hsSeminormSq s f := by
  unfold hsSeminormSq
  apply Summable.tsum_le_tsum
    (f := fun n ‚Ü¶ (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
  ¬∑ intro n
    rw [hcoeff n]
    exact fracHeatSymbol_Hs_mode_bound hőĪ ht n (mFourierCoeff f n)
  ¬∑ apply hsum.of_nonneg_of_le
    ¬∑ intro n; exact mul_nonneg (sq_nonneg _) (sq_nonneg _)
    ¬∑ intro n
      rw [hcoeff n]
      exact fracHeatSymbol_Hs_mode_bound hőĪ ht n (mFourierCoeff f n)
  ¬∑ exact hsum

/-! ## őĪ-Fractional heat-smoothed SQG quantities

Unified framework: applies őĪ-fractional heat to SQG vorticity, gradient,
and strain. Specializes to heat (őĪ=1) and Poisson (őĪ=1/2) versions.
-/

/-- **őĪ-fracHeat-smoothed SQG vorticity L¬≤ mode bound.** For `n ‚Č† 0, t > 0`:

    `‚ÄĖfracHeat(őĪ,t,n) ¬∑ ŌČŐā(n) ¬∑ c‚ÄĖ¬≤ ‚Č§ (1/(2őĪ))^{1/(2őĪ)}¬∑exp(-1/(2őĪ))/t^{1/(2őĪ)} ¬∑ ‚ÄĖc‚ÄĖ¬≤`

Specializes:
- őĪ = 1: `‚ÄĖheat ¬∑ ŌČŐā ¬∑ c‚ÄĖ¬≤ ‚Č§ (1/2)^{1/2}¬∑exp(-1/2)/t^{1/2} ¬∑ ‚ÄĖc‚ÄĖ¬≤`
  Wait: for heat, we have 4¬∑exp(-1)/t. The factor differs. Let me restate.

Actually for őĪ = 1: this theorem gives the SMALLER LHS `ŌČŐā¬∑heat`, bounded
by `(k/(2őĪ))^{k/(2őĪ)}¬∑exp(-k/(2őĪ))/t^{k/(2őĪ)}` with k=1: `(1/2)^{1/2}¬∑e^{-1/2}/‚ąöt`.

This is a different bound scaling than the heat version which scales as 1/t. -/
theorem fracHeat_smoothed_vorticity_L2_mode
    {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 < t)
    {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚Č† 0) (c : ‚Ąā) :
    ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * c‚ÄĖ ^ 2
    ‚Č§ ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
  -- ‚ÄĖfracHeat¬∑ŌČŐā¬∑c‚ÄĖ¬≤ = fracHeat¬≤ ¬∑ ‚ÄĖŌČŐā‚ÄĖ¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤ = fracHeat¬≤ ¬∑ L¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤
  -- Use: fracHeat¬≤ ¬∑ L¬≤ ‚Č§ fracHeat ¬∑ L¬≤ (since fracHeat ‚Č§ 1)
  --      fracHeat ¬∑ L¬≤ = fracHeat ¬∑ ŌÉ_1¬≤ ‚Č§ (1/őĪ)^{1/őĪ}¬∑exp(-1/őĪ)/t^{1/őĪ}
  rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
    Real.norm_of_nonneg (fracHeatSymbol_nonneg őĪ t n),
    sqgVorticitySymbol_norm hn]
  -- Goal: fracHeat¬≤ ¬∑ L¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤ ‚Č§ ...
  have hf_nn : 0 ‚Č§ fracHeatSymbol őĪ t n := fracHeatSymbol_nonneg őĪ t n
  have hf_le : fracHeatSymbol őĪ t n ‚Č§ 1 := fracHeatSymbol_le_one hőĪ ht.le n
  have hmain : (fracDerivSymbol 1 n) ^ 2 * fracHeatSymbol őĪ t n
      ‚Č§ (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ) :=
    fracDerivSymbol_sq_mul_fracHeat_le hőĪ one_pos ht n
  have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
    rw [fracDerivSymbol_one_eq hn]
  rw [hfrac1] at hmain
  have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
  have hfactor_nn : 0 ‚Č§ (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ) := by
    have h1őĪ : 0 < 1 / őĪ := div_pos one_pos hőĪ
    have htőĪ : 0 < t ^ (1 / őĪ) := Real.rpow_pos_of_pos ht _
    have h1kk : 0 < (1 / őĪ) ^ (1 / őĪ) := Real.rpow_pos_of_pos h1őĪ _
    positivity
  calc (fracHeatSymbol őĪ t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
      = fracHeatSymbol őĪ t n * ((latticeNorm n) ^ 2 * fracHeatSymbol őĪ t n) * ‚ÄĖc‚ÄĖ ^ 2 := by
        rw [sq]; ring
    _ ‚Č§ fracHeatSymbol őĪ t n *
        ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
        apply mul_le_mul_of_nonneg_right _ hc_nn
        exact mul_le_mul_of_nonneg_left hmain hf_nn
    _ ‚Č§ 1 *
        ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
        apply mul_le_mul_of_nonneg_right _ hc_nn
        exact mul_le_mul_of_nonneg_right hf_le hfactor_nn
    _ = ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-- **őĪ-fracHeat-smoothed SQG gradient L¬≤ mode bound.** For `t > 0, őĪ > 0`:

    `‚ÄĖfracHeat(őĪ,t,n) ¬∑ ‚ąāŐā_i u_j(n) ¬∑ c‚ÄĖ¬≤ ‚Č§ (1/őĪ)^{1/őĪ}¬∑exp(-1/őĪ)/t^{1/őĪ} ¬∑ ‚ÄĖc‚ÄĖ¬≤` -/
theorem fracHeat_smoothed_sqgGrad_L2_mode
    {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (i j : Fin 2) (c : ‚Ąā) :
    ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * sqgGradSymbol i j n * c‚ÄĖ ^ 2
    ‚Č§ ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have hg0 : sqgGradSymbol i j 0 = 0 := by
      unfold sqgGradSymbol derivSymbol rieszSymbol; simp
    rw [hg0, mul_zero, zero_mul, norm_zero, sq, mul_zero]
    have h1őĪ : 0 < 1 / őĪ := div_pos one_pos hőĪ
    have htőĪ : 0 < t ^ (1 / őĪ) := Real.rpow_pos_of_pos ht _
    have h1kk : 0 < (1 / őĪ) ^ (1 / őĪ) := Real.rpow_pos_of_pos h1őĪ _
    exact mul_nonneg (by positivity) (sq_nonneg _)
  ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
      Real.norm_of_nonneg (fracHeatSymbol_nonneg őĪ t n)]
    have hgrad := sqgGrad_norm_le hn i j
    have hgrad_sq_le : ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
      sq_le_sq' (by linarith [norm_nonneg (sqgGradSymbol i j n)]) hgrad
    have hf_nn : 0 ‚Č§ fracHeatSymbol őĪ t n := fracHeatSymbol_nonneg őĪ t n
    have hf_le : fracHeatSymbol őĪ t n ‚Č§ 1 := fracHeatSymbol_le_one hőĪ ht.le n
    have hmain : (fracDerivSymbol 1 n) ^ 2 * fracHeatSymbol őĪ t n
        ‚Č§ (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ) :=
      fracDerivSymbol_sq_mul_fracHeat_le hőĪ one_pos ht n
    have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
      rw [fracDerivSymbol_one_eq hn]
    rw [hfrac1] at hmain
    have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
    have hfactor_nn : 0 ‚Č§ (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ) := by
      have h1őĪ : 0 < 1 / őĪ := div_pos one_pos hőĪ
      have htőĪ : 0 < t ^ (1 / őĪ) := Real.rpow_pos_of_pos ht _
      have h1kk : 0 < (1 / őĪ) ^ (1 / őĪ) := Real.rpow_pos_of_pos h1őĪ _
      positivity
    calc (fracHeatSymbol őĪ t n) ^ 2 * ‚ÄĖsqgGradSymbol i j n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
        ‚Č§ (fracHeatSymbol őĪ t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          exact mul_le_mul_of_nonneg_left hgrad_sq_le (sq_nonneg _)
      _ = fracHeatSymbol őĪ t n * ((latticeNorm n) ^ 2 * fracHeatSymbol őĪ t n) * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [sq]; ring
      _ ‚Č§ fracHeatSymbol őĪ t n *
          ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          exact mul_le_mul_of_nonneg_left hmain hf_nn
      _ ‚Č§ 1 *
          ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          exact mul_le_mul_of_nonneg_right hf_le hfactor_nn
      _ = ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-- **őĪ-fracHeat-smoothed SQG strain L¬≤ mode bound.** Same structure as gradient. -/
theorem fracHeat_smoothed_sqgStrain_L2_mode
    {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 < t)
    (n : Fin 2 ‚Üí ‚Ą§) (i j : Fin 2) (c : ‚Ąā) :
    ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol i j n * c‚ÄĖ ^ 2
    ‚Č§ ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
  by_cases hn : n = 0
  ¬∑ subst hn
    have hs0 : sqgStrainSymbol i j 0 = 0 := by
      unfold sqgStrainSymbol sqgGradSymbol derivSymbol rieszSymbol; simp
    rw [hs0, mul_zero, zero_mul, norm_zero, sq, mul_zero]
    have h1őĪ : 0 < 1 / őĪ := div_pos one_pos hőĪ
    have htőĪ : 0 < t ^ (1 / őĪ) := Real.rpow_pos_of_pos ht _
    have h1kk : 0 < (1 / őĪ) ^ (1 / őĪ) := Real.rpow_pos_of_pos h1őĪ _
    exact mul_nonneg (by positivity) (sq_nonneg _)
  ¬∑ rw [norm_mul, norm_mul, mul_pow, mul_pow, Complex.norm_real,
      Real.norm_of_nonneg (fracHeatSymbol_nonneg őĪ t n)]
    have hstrain := sqgStrain_norm_le hn i j
    have hstrain_sq_le : ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2 ‚Č§ (latticeNorm n) ^ 2 :=
      sq_le_sq' (by linarith [norm_nonneg (sqgStrainSymbol i j n)]) hstrain
    have hf_nn : 0 ‚Č§ fracHeatSymbol őĪ t n := fracHeatSymbol_nonneg őĪ t n
    have hf_le : fracHeatSymbol őĪ t n ‚Č§ 1 := fracHeatSymbol_le_one hőĪ ht.le n
    have hmain : (fracDerivSymbol 1 n) ^ 2 * fracHeatSymbol őĪ t n
        ‚Č§ (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ) :=
      fracDerivSymbol_sq_mul_fracHeat_le hőĪ one_pos ht n
    have hfrac1 : (fracDerivSymbol 1 n) ^ 2 = (latticeNorm n) ^ 2 := by
      rw [fracDerivSymbol_one_eq hn]
    rw [hfrac1] at hmain
    have hc_nn : 0 ‚Č§ ‚ÄĖc‚ÄĖ ^ 2 := sq_nonneg _
    have hfactor_nn : 0 ‚Č§ (1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ) := by
      have h1őĪ : 0 < 1 / őĪ := div_pos one_pos hőĪ
      have htőĪ : 0 < t ^ (1 / őĪ) := Real.rpow_pos_of_pos ht _
      have h1kk : 0 < (1 / őĪ) ^ (1 / őĪ) := Real.rpow_pos_of_pos h1őĪ _
      positivity
    calc (fracHeatSymbol őĪ t n) ^ 2 * ‚ÄĖsqgStrainSymbol i j n‚ÄĖ ^ 2 * ‚ÄĖc‚ÄĖ ^ 2
        ‚Č§ (fracHeatSymbol őĪ t n) ^ 2 * (latticeNorm n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          exact mul_le_mul_of_nonneg_left hstrain_sq_le (sq_nonneg _)
      _ = fracHeatSymbol őĪ t n * ((latticeNorm n) ^ 2 * fracHeatSymbol őĪ t n) * ‚ÄĖc‚ÄĖ ^ 2 := by
          rw [sq]; ring
      _ ‚Č§ fracHeatSymbol őĪ t n *
          ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          exact mul_le_mul_of_nonneg_left hmain hf_nn
      _ ‚Č§ 1 *
          ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ hc_nn
          exact mul_le_mul_of_nonneg_right hf_le hfactor_nn
      _ = ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) * ‚ÄĖc‚ÄĖ ^ 2 := by ring

/-- **őĪ-fracHeat-smoothed SQG velocity ŠłĘňĘ mode bound.** For `őĪ > 0, t ‚Č• 0`:

    `ŌÉ_s¬≤ ¬∑ ‚ÄĖfracHeat(őĪ,t,n) ¬∑ R ¬∑ c‚ÄĖ¬≤ ‚Č§ ŌÉ_s¬≤ ¬∑ ‚ÄĖc‚ÄĖ¬≤`

No Sobolev gain: both Riesz and fracHeat are contractive. -/
theorem fracHeat_smoothed_sqg_velocity_mode
    (s : ‚ĄĚ) {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 ‚Č§ t)
    (n : Fin 2 ‚Üí ‚Ą§) (j : Fin 2) (c : ‚Ąā) :
    (fracDerivSymbol s n) ^ 2 *
      ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) *
       (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) * c‚ÄĖ ^ 2
    ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 := by
  rw [show ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) *
      (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) * c
      = (if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) *
        (((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c) from by ring]
  by_cases hn : n = 0
  ¬∑ subst hn
    by_cases hj : j = 0
    ¬∑ simp [hj, rieszSymbol_zero, fracDerivSymbol_zero]
    ¬∑ simp [hj, rieszSymbol_zero, fracDerivSymbol_zero]
  ¬∑ have hR_le : ‚ÄĖ(if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n)‚ÄĖ ^ 2 ‚Č§ 1 := by
      have hpyth := rieszSymbol_sum_sq hn
      simp only [Fin.sum_univ_two] at hpyth
      by_cases hj : j = 0
      ¬∑ simp [hj]; nlinarith [sq_nonneg ‚ÄĖrieszSymbol 0 n‚ÄĖ]
      ¬∑ simp [hj, norm_neg]; nlinarith [sq_nonneg ‚ÄĖrieszSymbol 1 n‚ÄĖ]
    have hf_contract := fracHeatSymbol_L2_mode_contract hőĪ ht n c
    have hŌÉs_nn : 0 ‚Č§ (fracDerivSymbol s n) ^ 2 := sq_nonneg _
    have hfc_nn : 0 ‚Č§ ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2 := sq_nonneg _
    calc (fracDerivSymbol s n) ^ 2 *
          ‚ÄĖ(if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n) *
            (((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c)‚ÄĖ ^ 2
        = (fracDerivSymbol s n) ^ 2 *
          (‚ÄĖ(if j = 0 then rieszSymbol 1 n else -rieszSymbol 0 n)‚ÄĖ ^ 2 *
           ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2) := by
          rw [norm_mul, mul_pow]
      _ ‚Č§ (fracDerivSymbol s n) ^ 2 *
          (1 * ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2) :=
          mul_le_mul_of_nonneg_left
            (mul_le_mul_of_nonneg_right hR_le hfc_nn) hŌÉs_nn
      _ = (fracDerivSymbol s n) ^ 2 *
          ‚ÄĖ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * c‚ÄĖ ^ 2 := by ring
      _ ‚Č§ (fracDerivSymbol s n) ^ 2 * ‚ÄĖc‚ÄĖ ^ 2 :=
          mul_le_mul_of_nonneg_left hf_contract hŌÉs_nn

/-! ## őĪ-fracHeat-smoothed SQG integrated Lp bounds -/

/-- **őĪ-fracHeat-smoothed SQG vorticity L¬≤ integrated.** For `t > 0, őĪ > 0`:

    `‚ÄĖfracHeat(őĪ,¬∑)¬∑ŌČ‚ÄĖ¬≤_{L¬≤} ‚Č§ (1/őĪ)^{1/őĪ}¬∑exp(-1/őĪ)/t^{1/őĪ} ¬∑ ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}` -/
theorem fracHeat_smoothed_vorticity_L2_integrated
    {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 < t)
    (őł u : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff : ‚ąÄ n, mFourierCoeff u n =
      ((fracHeatSymbol őĪ t n : ‚ĄĚ) : ‚Ąā) * sqgVorticitySymbol n * mFourierCoeff őł n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff u n‚ÄĖ ^ 2)
    ‚Č§ ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) *
      (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
  rw [show ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ)) *
        (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
      = ‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§),
        ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ))
          * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 from
    (tsum_mul_left).symm]
  have hmode : ‚ąÄ n : Fin 2 ‚Üí ‚Ą§,
      ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎu) n‚ÄĖ ^ 2
      ‚Č§ ((1 / őĪ) ^ (1 / őĪ) * Real.exp (-(1 / őĪ)) / t ^ (1 / őĪ))
        * ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2 := by
    intro n
    rw [hcoeff n]
    by_cases hn : n = 0
    ¬∑ subst hn
      have hŌČ0 : sqgVorticitySymbol 0 = 0 := by
        unfold sqgVorticitySymbol sqgGradSymbol derivSymbol rieszSymbol; simp
      rw [hŌČ0, mul_zero, zero_mul, norm_zero, sq, mul_zero]
      have h1őĪ : 0 < 1 / őĪ := div_pos one_pos hőĪ
      have htőĪ : 0 < t ^ (1 / őĪ) := Real.rpow_pos_of_pos ht _
      have h1kk : 0 < (1 / őĪ) ^ (1 / őĪ) := Real.rpow_pos_of_pos h1őĪ _
      exact mul_nonneg (by positivity) (sq_nonneg _)
    ¬∑ exact fracHeat_smoothed_vorticity_L2_mode hőĪ ht hn (mFourierCoeff őł n)
  apply Summable.tsum_le_tsum hmode
  ¬∑ exact (hsum.mul_left _).of_nonneg_of_le (fun n ‚Ü¶ sq_nonneg _) hmode
  ¬∑ exact hsum.mul_left _

/-- **őĪ-fracHeat-smoothed SQG gradient L¬≤ integrated.** -/
theorem fracHeat_smoothed_sqgGrad_L2_integrated
    {őĪ t : ‚ĄĚ} (hőĪ : 0 < őĪ) (ht : 0 < t) (i j : Fin 2)
