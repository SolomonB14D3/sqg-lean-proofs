      have hŌČ0 : sqgVorticitySymbol 0 = 0 := by
        unfold sqgVorticitySymbol sqgGradSymbol derivSymbol rieszSymbol; simp
      rw [hŌČ0, mul_zero, zero_mul, norm_zero, sq, mul_zero]
      exact mul_nonneg (div_nonneg (Real.exp_pos _).le (sq_nonneg _)) (sq_nonneg _)
    ¬∑ exact poisson_smoothed_vorticity_L2_mode ht hn (mFourierCoeff őł n)
  apply Summable.tsum_le_tsum hmode
  ¬∑ exact (hsum.mul_left (Real.exp (-2) / t ^ 2)).of_nonneg_of_le
      (fun n ‚Ü¶ sq_nonneg _) hmode
  ¬∑ exact hsum.mul_left _

/-- **Tight heat-smoothed strain L¬≤ sum bound.**

    `‚ÄĖe^{tőĒ}S‚āÄ‚āÄ‚ÄĖ¬≤_{L¬≤} + ‚ÄĖe^{tőĒ}S‚āÄ‚āĀ‚ÄĖ¬≤_{L¬≤} ‚Č§ exp(-1)/(2t) ¬∑ ‚ÄĖőł‚ÄĖ¬≤_{L¬≤}` -/
theorem heat_smoothed_sqgStrain_L2_sum_le {t : ‚ĄĚ} (ht : 0 < t)
    (őł S00 S01 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hcoeff0 : ‚ąÄ n, mFourierCoeff S00 n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol 0 0 n * mFourierCoeff őł n)
    (hcoeff1 : ‚ąÄ n, mFourierCoeff S01 n =
      ((heatSymbol t n : ‚ĄĚ) : ‚Ąā) * sqgStrainSymbol 0 1 n * mFourierCoeff őł n)
    (hsum : Summable (fun n ‚Ü¶ ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2)) :
    (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff S00 n‚ÄĖ ^ 2)
    + (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff S01 n‚ÄĖ ^ 2)
    ‚Č§ Real.exp (-1) / (2 * t) *
      (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff őł n‚ÄĖ ^ 2) := by
  have h00 := heat_smoothed_sqgStrain_00_L2_integrated_tight ht őł S00 hcoeff0 hsum
  have h01 := heat_smoothed_sqgStrain_01_L2_integrated_tight ht őł S01 hcoeff1 hsum
  have ht' : (0 : ‚ĄĚ) < 4 * t := by linarith
  have h_sum_quarter :
      Real.exp (-1) / (4 * t) * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
      + Real.exp (-1) / (4 * t) * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2)
      = Real.exp (-1) / (2 * t) * (‚ąĎ' (n : Fin 2 ‚Üí ‚Ą§), ‚ÄĖmFourierCoeff (‚ÜĎ‚ÜĎőł) n‚ÄĖ ^ 2) := by
    field_simp
    ring
  linarith [h00, h01, h_sum_quarter]

