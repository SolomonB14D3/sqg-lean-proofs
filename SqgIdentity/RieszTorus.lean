theorem sqgGalerkin_modeLipschitz_from_UniformH2
    [DecidableEq (Fin 2 вҶ’ в„Ө)]
    (Оұ : вҲҖ n : в„•, в„қ вҶ’ (вҶҘ(sqgBox n) вҶ’ в„Ӯ))
    (K : в„қ) (hK : 0 вүӨ K)
    (hH2 : вҲҖ (n : в„•) (П„ : в„қ), 0 вүӨ П„ вҶ’
      GalerkinRHSHsNegSqBound (sqgBox n) (Оұ n П„) 2 K)
    (hDeriv : вҲҖ (n : в„•) (П„ : в„қ), 0 вүӨ П„ вҶ’ вҲҖ (m : Fin 2 вҶ’ в„Ө), m вҲҲ sqgBox n вҶ’
      HasDerivWithinAt (fun Пғ => galerkinExtend (sqgBox n) (Оұ n Пғ) m)
        (galerkinRHS (sqgBox n) (galerkinExtend (sqgBox n) (Оұ n П„)) m)
        (Set.Ici П„) П„)
    (hCont : вҲҖ (n : в„•) (m : Fin 2 вҶ’ в„Ө), m вҲҲ sqgBox n вҶ’ вҲҖ (s t : в„қ), 0 вүӨ s вҶ’ s вүӨ t вҶ’
      ContinuousOn (fun Пғ => galerkinExtend (sqgBox n) (Оұ n Пғ) m)
        (Set.Icc s t)) :
    вҲғ L : (Fin 2 вҶ’ в„Ө) вҶ’ в„қ,
      (вҲҖ m, 0 вүӨ L m) вҲ§
      вҲҖ (n : в„•) (m : Fin 2 вҶ’ в„Ө) (s t : в„қ), 0 вүӨ s вҶ’ 0 вүӨ t вҶ’
        вҖ–galerkinExtend (sqgBox n) (Оұ n t) m
          - galerkinExtend (sqgBox n) (Оұ n s) mвҖ–
          вүӨ L m * |t - s| := by
  classical
  refine вҹЁfun m => if m = 0 then 0 else Real.sqrt K * fracDerivSymbol 2 m,
    ?hNN, ?hHoldsвҹ©
  case hNN =>
    intro m
    by_cases hm : m = 0
    В· simp [hm]
    В· simp only [hm, if_false]
      exact mul_nonneg (Real.sqrt_nonneg _)
        (le_of_lt (fracDerivSymbol_pos 2 hm))
  case hHolds =>
    intro n m s t hs ht
    by_cases hm : m = 0
    В· subst hm
      have h0_nm : (0 : Fin 2 вҶ’ в„Ө) вҲү sqgBox n := zero_not_mem_sqgBox n
      have h_t : galerkinExtend (sqgBox n) (Оұ n t) (0 : Fin 2 вҶ’ в„Ө) = 0 :=
        galerkinExtend_apply_of_not_mem _ _ h0_nm
      have h_s : galerkinExtend (sqgBox n) (Оұ n s) (0 : Fin 2 вҶ’ в„Ө) = 0 :=
        galerkinExtend_apply_of_not_mem _ _ h0_nm
      simp [h_t, h_s]
    В· by_cases hmS : m вҲҲ sqgBox n
      В· -- `m вү  0` and `m вҲҲ sqgBox n`: use `hDeriv`, `hCont` with the `m вҲҲ sqgBox n` datum.
        simp only [hm, if_false]
        rcases le_total s t with hst | hts
        В· have h_abs : |t - s| = t - s := abs_of_nonneg (sub_nonneg.mpr hst)
          rw [h_abs]
          have h_bound : вҲҖ П„ вҲҲ Set.Ico s t,
              вҖ–galerkinRHS (sqgBox n)
                (galerkinExtend (sqgBox n) (Оұ n П„)) mвҖ–
                вүӨ Real.sqrt K * fracDerivSymbol 2 m := by
            intro П„ hП„
            exact galerkinRHS_mode_bound_of_HsNeg2Bound_ne_zero
              (sqgBox n) (Оұ n П„) K hK
              (hH2 n П„ (le_trans hs hП„.1)) hm
          have h_deriv_local : вҲҖ П„ вҲҲ Set.Ico s t,
              HasDerivWithinAt (fun Пғ => galerkinExtend (sqgBox n) (Оұ n Пғ) m)
                (galerkinRHS (sqgBox n)
                  (galerkinExtend (sqgBox n) (Оұ n П„)) m)
                (Set.Ici П„) П„ := fun П„ hП„ =>
            hDeriv n П„ (le_trans hs hП„.1) m hmS
          exact galerkinExtend_mode_lipschitz_of_ODE_bound
            (sqgBox n) (Оұ n) m (Real.sqrt K * fracDerivSymbol 2 m) hst
            h_deriv_local (hCont n m hmS s t hs hst) h_bound
        В· have h_abs : |t - s| = s - t := by
            rw [abs_of_nonpos (sub_nonpos.mpr hts), neg_sub]
          rw [h_abs]
          have h_bound : вҲҖ П„ вҲҲ Set.Ico t s,
              вҖ–galerkinRHS (sqgBox n)
                (galerkinExtend (sqgBox n) (Оұ n П„)) mвҖ–
                вүӨ Real.sqrt K * fracDerivSymbol 2 m := by
            intro П„ hП„
            exact galerkinRHS_mode_bound_of_HsNeg2Bound_ne_zero
              (sqgBox n) (Оұ n П„) K hK
              (hH2 n П„ (le_trans ht hП„.1)) hm
          have h_deriv_local : вҲҖ П„ вҲҲ Set.Ico t s,
              HasDerivWithinAt (fun Пғ => galerkinExtend (sqgBox n) (Оұ n Пғ) m)
                (galerkinRHS (sqgBox n)
                  (galerkinExtend (sqgBox n) (Оұ n П„)) m)
                (Set.Ici П„) П„ := fun П„ hП„ =>
            hDeriv n П„ (le_trans ht hП„.1) m hmS
          have h_mvt : вҖ–galerkinExtend (sqgBox n) (Оұ n s) m
              - galerkinExtend (sqgBox n) (Оұ n t) mвҖ–
              вүӨ Real.sqrt K * fracDerivSymbol 2 m * (s - t) :=
            galerkinExtend_mode_lipschitz_of_ODE_bound
              (sqgBox n) (Оұ n) m (Real.sqrt K * fracDerivSymbol 2 m) hts
              h_deriv_local (hCont n m hmS t s ht hts) h_bound
          rw [norm_sub_rev]
          exact h_mvt
      В· -- `m вү  0` but `m вҲү sqgBox n`: leakage mode вҖ” `galerkinExtend = 0` on both sides.
        have h_t : galerkinExtend (sqgBox n) (Оұ n t) m = 0 :=
          galerkinExtend_apply_of_not_mem _ _ hmS
        have h_s : galerkinExtend (sqgBox n) (Оұ n s) m = 0 :=
          galerkinExtend_apply_of_not_mem _ _ hmS
