  rw [show ((1 / α) ^ (1 / α) * Real.exp (-(1 / α)) / t ^ (1 / α)) *
        (∑' (n : Fin 2 → ℤ), ‖mFourierCoeff (↑↑θ) n‖ ^ 2)
      = ∑' (n : Fin 2 → ℤ),
        ((1 / α) ^ (1 / α) * Real.exp (-(1 / α)) / t ^ (1 / α))
          * ‖mFourierCoeff (↑↑θ) n‖ ^ 2 from
    (tsum_mul_left).symm]
  have hmode : ∀ n : Fin 2 → ℤ,
      ‖mFourierCoeff (↑↑u) n‖ ^ 2
      ≤ ((1 / α) ^ (1 / α) * Real.exp (-(1 / α)) / t ^ (1 / α))
