    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (h0 : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ S) (c : ‚Ü•S ‚Üí ‚Ąā) :
    trigPolyEnergyHs 0 S c = ‚ąĎ m : ‚Ü•S, ‚ÄĖc m‚ÄĖ ^ 2 := by
  unfold trigPolyEnergyHs
  apply Finset.sum_congr rfl
  intros m _
  have hm_ne : m.val ‚Č† 0 := fun hv => h0 (hv ‚Ėł m.property)
  rw [fracDerivSymbol_of_ne_zero 0 hm_ne, Real.rpow_zero]; ring

/-- **Bridge: finite-sum `ŠłĘňĘ` energy = `hsSeminormSq s (galerkinToLp S c)`.**
Generalization of ¬ß10.68's `trigPolyEnergyHs2_eq_hsSeminormSq` to
arbitrary `s : ‚ĄĚ`. -/
theorem trigPolyEnergyHs_eq_hsSeminormSq
    (s : ‚ĄĚ) (S : Finset (Fin 2 ‚Üí ‚Ą§)) [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) :
    trigPolyEnergyHs s S c = hsSeminormSq s (galerkinToLp S c) := by
  unfold trigPolyEnergyHs hsSeminormSq
  -- Show the tsum collapses to a Finset sum over `S`.
  have hZeroOff : ‚ąÄ n ‚ąČ S,
      (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (galerkinToLp S c) n‚ÄĖ ^ 2 = 0 := by
    intros n hn
    rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_not_mem _ _ hn,
        norm_zero]; ring
  rw [tsum_eq_sum (s := S) (fun n hn => hZeroOff n hn)]
  -- Rewrite the Finset sum over S as a sum over the subtype ‚Ü•S.
  rw [‚Üź Finset.sum_attach S (fun n =>
      (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (galerkinToLp S c) n‚ÄĖ ^ 2)]
  apply Finset.sum_congr rfl
  intros m _
  rw [mFourierCoeff_galerkinToLp, galerkinExtend_apply_of_mem _ _ m.property]

/-- **Energy bound transferred from parametric trig-poly to `hsSeminormSq`.**
Generalization of `hsSeminormSq_le_of_trigPolyEnergyHs2_le`. -/
lemma hsSeminormSq_le_of_trigPolyEnergyHs_le
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) (E : ‚ĄĚ) (hE : trigPolyEnergyHs s S c ‚Č§ E) :
    hsSeminormSq s (galerkinToLp S c) ‚Č§ E := by
  rw [‚Üź trigPolyEnergyHs_eq_hsSeminormSq]; exact hE

/-! ### ¬ß10.178 Pointwise derivative of parametric-`s` Galerkin energy

Generalizes ¬ß10.69's `trigPolyEnergyHs2_hasDerivAt` to arbitrary `s : ‚ĄĚ`.
The structure is identical: each coordinate `ŌĄ ‚Ü¶ őĪ ŌĄ m` has derivative
`galerkinVectorField S (őĪ ŌĄ) m` (via `hasDerivAt_pi`), and `HasDerivAt.norm_sq`
differentiates the squared norm via the real inner product on `‚Ąā`.  The
`(fracDerivSymbol s m)¬≤` weight is pulled out by `const_mul`.

Output:
```
d/dŌĄ trigPolyEnergyHs s S (őĪ ŌĄ)
  = ‚ąĎ m : ‚Ü•S, (fracDerivSymbol s m.val)¬≤ ¬∑ 2 ¬∑ ‚ü™őĪ ŌĄ m, galerkinVectorField S (őĪ ŌĄ) m‚üę_‚ĄĚ
```

This is the Galerkin `ŠłĘňĘ` energy identity (Phase 1 at `s = 1`; Phase 3 at
`s ‚ąą (1, 2]`). -/

theorem trigPolyEnergyHs_hasDerivAt
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (ŌĄ : ‚ĄĚ) :
    HasDerivAt (fun t => trigPolyEnergyHs s S (őĪ t))
      (‚ąĎ m : ‚Ü•S, (fracDerivSymbol s m.val) ^ 2 *
        (2 * (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m)))) ŌĄ := by
  unfold trigPolyEnergyHs
  apply HasDerivAt.fun_sum
  intros m _
  have hőĪm : HasDerivAt (fun t => őĪ t m) (galerkinVectorField S (őĪ ŌĄ) m) ŌĄ :=
    (hasDerivAt_pi.mp (hőĪ ŌĄ)) m
  have hNormSq := hőĪm.norm_sq
  exact hNormSq.const_mul _

/-- **¬ß10.178.A  Specialization to `s = 1`: the `ŠłĘ¬Ļ` energy identity
(Phase 1 deliverable).** -/
theorem trigPolyEnergyH1_hasDerivAt
    {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (ŌĄ : ‚ĄĚ) :
    HasDerivAt (fun t => trigPolyEnergyHs 1 S (őĪ t))
      (‚ąĎ m : ‚Ü•S, (fracDerivSymbol 1 m.val) ^ 2 *
        (2 * (@inner ‚ĄĚ ‚Ąā _ (őĪ ŌĄ m) (galerkinVectorField S (őĪ ŌĄ) m)))) ŌĄ :=
  trigPolyEnergyHs_hasDerivAt 1 őĪ hőĪ ŌĄ

/-! ### ¬ß10.179 `ŠłĘňĘ` energy flux decomposition

The `ŠłĘňĘ` energy flux
`F_s(őĪ ŌĄ) := ‚ąĎ_{m ‚ąą ‚Ü•S} (|m|^s)¬≤ ¬∑ 2 ¬∑ ‚ü™őĪ ŌĄ m, galerkinVectorField S (őĪ ŌĄ) m‚üę_‚ĄĚ`
is the classical advection-convolution flux against the Sobolev weight.
We package it as a named quantity for downstream use. -/

/-- **Galerkin `ŠłĘňĘ` flux.** The formal time-derivative of `trigPolyEnergyHs s`. -/
noncomputable def galerkinHsFlux
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (c : ‚Ü•S ‚Üí ‚Ąā) : ‚ĄĚ :=
  ‚ąĎ m : ‚Ü•S, (fracDerivSymbol s m.val) ^ 2 *
    (2 * (@inner ‚ĄĚ ‚Ąā _ (c m) (galerkinVectorField S c m)))

/-- **Energy identity in compact form**: `d/dŌĄ trigPolyEnergyHs s S (őĪ ŌĄ)
= galerkinHsFlux s (őĪ ŌĄ)`. -/
theorem galerkinHsFlux_eq_deriv
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (ŌĄ : ‚ĄĚ) :
    deriv (fun t => trigPolyEnergyHs s S (őĪ t)) ŌĄ = galerkinHsFlux s (őĪ ŌĄ) :=
  (trigPolyEnergyHs_hasDerivAt s őĪ hőĪ ŌĄ).deriv

/-- **Zero flux on radial shells.** When `S` is a radial shell,
`galerkinVectorField S c = 0`, so the flux vanishes regardless of `s`. -/
lemma galerkinHsFlux_eq_zero_of_isRadialShell
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (hS : IsRadialShell S) (c : ‚Ü•S ‚Üí ‚Ąā) :
    galerkinHsFlux s c = 0 := by
  unfold galerkinHsFlux
  rw [galerkinVectorField_eq_zero_of_isRadialShell hS]
  simp

/-! ### ¬ß10.180 Galerkin `ŠłĘňĘ` energy is continuous in time

`t ‚Ü¶ trigPolyEnergyHs s S (őĪ t)` is differentiable at every `ŌĄ`
(with derivative `galerkinHsFlux s (őĪ ŌĄ)`), so in particular continuous.
We package this as a reusable lemma for Gr√∂nwall application. -/

lemma trigPolyEnergyHs_differentiable
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t) :
    Differentiable ‚ĄĚ (fun t => trigPolyEnergyHs s S (őĪ t)) :=
  fun ŌĄ => (trigPolyEnergyHs_hasDerivAt s őĪ hőĪ ŌĄ).differentiableAt

lemma trigPolyEnergyHs_continuous
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t) :
    Continuous (fun t => trigPolyEnergyHs s S (őĪ t)) :=
  (trigPolyEnergyHs_differentiable s őĪ hőĪ).continuous

/-! ### ¬ß10.181 Sobolev energy monotonicity identity on an interval

For use in Gr√∂nwall-style bounds: if
`|deriv (trigPolyEnergyHs s ‚ąė őĪ) ŌĄ| ‚Č§ K ¬∑ trigPolyEnergyHs s S (őĪ ŌĄ)` on
`[0, T]`, then `trigPolyEnergyHs s S (őĪ t) ‚Č§ trigPolyEnergyHs s S (őĪ 0) ¬∑
exp(K ¬∑ t)` on `[0, T]`.

Directly calls the existing `scalar_gronwall_exp` used by ¬ß10.79's
`galerkinTrigEnergyHs2_gronwall_bound`. -/

theorem trigPolyEnergyHs_gronwall_bound
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (K T : ‚ĄĚ) (hT : 0 ‚Č§ T)
    (hDerivBound : ‚ąÄ x ‚ąą Set.Ico 0 T,
      |deriv (fun t => trigPolyEnergyHs s S (őĪ t)) x|
        ‚Č§ K * |trigPolyEnergyHs s S (őĪ x)|) :
    ‚ąÄ t ‚ąą Set.Icc 0 T,
      trigPolyEnergyHs s S (őĪ t)
        ‚Č§ trigPolyEnergyHs s S (őĪ 0) * Real.exp (K * t) := by
  have hE_hasDerivWithin : ‚ąÄ x ‚ąą Set.Ico 0 T,
      HasDerivWithinAt (fun t => trigPolyEnergyHs s S (őĪ t))
        (deriv (fun t => trigPolyEnergyHs s S (őĪ t)) x) (Set.Ici x) x := by
    intros x _
    have h := (trigPolyEnergyHs_hasDerivAt s őĪ hőĪ x).hasDerivWithinAt
              (s := Set.Ici x)
    have hd := (trigPolyEnergyHs_hasDerivAt s őĪ hőĪ x).deriv
    rw [hd]; exact h
  have hE_cont : ContinuousOn (fun t => trigPolyEnergyHs s S (őĪ t))
                    (Set.Icc 0 T) :=
    (trigPolyEnergyHs_continuous s őĪ hőĪ).continuousOn
  exact scalar_gronwall_exp (fun t => trigPolyEnergyHs s S (őĪ t)) K T hT
    hE_cont hE_hasDerivWithin hDerivBound
    (fun _ _ => trigPolyEnergyHs_nonneg s (őĪ _))

/-- **Corollary**: Bound on `hsSeminormSq` via parametric-`s` Gr√∂nwall. -/
theorem hsSeminormSq_galerkin_gronwall_bound
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā))
    (hőĪ : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t)
    (K T : ‚ĄĚ) (hT : 0 ‚Č§ T)
    (hDerivBound : ‚ąÄ x ‚ąą Set.Ico 0 T,
      |deriv (fun t => trigPolyEnergyHs s S (őĪ t)) x|
        ‚Č§ K * |trigPolyEnergyHs s S (őĪ x)|) :
    ‚ąÄ t ‚ąą Set.Icc 0 T,
      hsSeminormSq s (galerkinToLp S (őĪ t))
        ‚Č§ hsSeminormSq s (galerkinToLp S (őĪ 0)) * Real.exp (K * t) := by
  intro t ht
  rw [‚Üź trigPolyEnergyHs_eq_hsSeminormSq, ‚Üź trigPolyEnergyHs_eq_hsSeminormSq]
  exact trigPolyEnergyHs_gronwall_bound s őĪ hőĪ K T hT hDerivBound t ht

/-! ### ¬ß10.182 Named hypothesis: Gr√∂nwall-integrable velocity control

Phase 2 and Phase 5 deliverable of Route A.  A named Lean structure
that packages the three inputs needed to produce a uniform `ŠłĘňĘ`
bound on the Galerkin approximation at a fixed `s`:

1. ODE validity of the Galerkin trajectory (as a `HasDerivAt` hypothesis).
2. A pointwise log-derivative bound
   `|d/dŌĄ trigPolyEnergyHs s S (őĪ ŌĄ)| ‚Č§ K ¬∑ trigPolyEnergyHs s S (őĪ ŌĄ)`
   ‚ÄĒ the BKM-integral expression of velocity control.
3. A uniform initial-data `ŠłĘňĘ` bound.

The closure `HasGalerkinHsGronwall.uniform_bound` runs ¬ß10.181's
`trigPolyEnergyHs_gronwall_bound` across the family and produces the
final time-uniform `ŠłĘňĘ` bound on `[0, T]`.  For `T ‚Üí ‚ąě`, the caller
must supply a `K` such that the exponent `K ¬∑ T` stays finite (the
classical case where the BKM integral is finite). -/

/-- **Phase 2/5 input package** for a single Galerkin level. -/
structure HasGalerkinHsGronwallLevel
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)) where
  hDeriv : ‚ąÄ t, HasDerivAt őĪ (galerkinVectorField S (őĪ t)) t
  /-- `K` is the (nominally time-integrable) velocity control constant. -/
  K : ‚ĄĚ
  hDerivBound : ‚ąÄ T : ‚ĄĚ, 0 ‚Č§ T ‚Üí ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
    |deriv (fun t => trigPolyEnergyHs s S (őĪ t)) x|
      ‚Č§ K * |trigPolyEnergyHs s S (őĪ x)|
  E‚āÄ : ‚ĄĚ
  hE‚āÄ : trigPolyEnergyHs s S (őĪ 0) ‚Č§ E‚āÄ

/-- **Bound on a compact interval** extracted from the level package.
Requires `0 ‚Č§ h.K` so that `exp(K¬∑t)` is monotone in `t`. -/
theorem HasGalerkinHsGronwallLevel.bound_on_Icc
    (s : ‚ĄĚ) {S : Finset (Fin 2 ‚Üí ‚Ą§)} [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {őĪ : ‚ĄĚ ‚Üí (‚Ü•S ‚Üí ‚Ąā)} (h : HasGalerkinHsGronwallLevel s őĪ)
    (hK_nn : 0 ‚Č§ h.K) (T : ‚ĄĚ) (hT : 0 ‚Č§ T) :
    ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) T,
      hsSeminormSq s (galerkinToLp S (őĪ t)) ‚Č§ h.E‚āÄ * Real.exp (h.K * T) := by
  intro t ht
  have h1 : hsSeminormSq s (galerkinToLp S (őĪ t))
      ‚Č§ hsSeminormSq s (galerkinToLp S (őĪ 0)) * Real.exp (h.K * t) :=
    hsSeminormSq_galerkin_gronwall_bound s őĪ h.hDeriv h.K T hT
      (h.hDerivBound T hT) t ht
  have h2 : hsSeminormSq s (galerkinToLp S (őĪ 0))
      = trigPolyEnergyHs s S (őĪ 0) :=
    (trigPolyEnergyHs_eq_hsSeminormSq s S (őĪ 0)).symm
  have h3 : trigPolyEnergyHs s S (őĪ 0) ‚Č§ h.E‚āÄ := h.hE‚āÄ
  have h4 : 0 ‚Č§ Real.exp (h.K * t) := (Real.exp_pos _).le
  have h5 : Real.exp (h.K * t) ‚Č§ Real.exp (h.K * T) := by
    apply Real.exp_le_exp.mpr
    exact mul_le_mul_of_nonneg_left ht.2 hK_nn
  have hE‚āÄ_nn : 0 ‚Č§ h.E‚āÄ :=
    le_trans (trigPolyEnergyHs_nonneg s _) h3
  calc hsSeminormSq s (galerkinToLp S (őĪ t))
      ‚Č§ hsSeminormSq s (galerkinToLp S (őĪ 0)) * Real.exp (h.K * t) := h1
    _ = trigPolyEnergyHs s S (őĪ 0) * Real.exp (h.K * t) := by rw [h2]
    _ ‚Č§ h.E‚āÄ * Real.exp (h.K * t) := by
        apply mul_le_mul_of_nonneg_right h3 h4
    _ ‚Č§ h.E‚āÄ * Real.exp (h.K * T) := by
        apply mul_le_mul_of_nonneg_left h5 hE‚āÄ_nn

/-- **Uniform-across-levels Phase 2 input package** for the Galerkin
family indexed by `n : ‚Ąē`. -/
structure HasGalerkinHsGronwallFamily
    (s : ‚ĄĚ) (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) where
  level : ‚ąÄ n : ‚Ąē, HasGalerkinHsGronwallLevel s (őĪ n)
  /-- Uniform-in-`n` velocity control and initial-data bounds. -/
  K_uniform : ‚ĄĚ
  hK_uniform : ‚ąÄ n : ‚Ąē, (level n).K = K_uniform
  E‚āÄ_uniform : ‚ĄĚ
  hE‚āÄ_uniform : ‚ąÄ n : ‚Ąē, (level n).E‚āÄ = E‚āÄ_uniform

/-- **Phase 2 closure (s = 1) / Phase 5 closure (s ‚ąą (1, 2] or s > 1)**:
From a uniform-in-`n` Gr√∂nwall family with `0 ‚Č§ K_uniform`, extract a
time-uniform `ŠłĘňĘ` bound across the Galerkin family on any compact
`[0, T]` interval. -/
theorem HasGalerkinHsGronwallFamily.uniform_bound_on_Icc
    (s : ‚ĄĚ) {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (h : HasGalerkinHsGronwallFamily s őĪ)
    (hK_nn : 0 ‚Č§ h.K_uniform)
    (T : ‚ĄĚ) (hT : 0 ‚Č§ T) :
    ‚ąÄ n : ‚Ąē, ‚ąÄ t ‚ąą Set.Icc (0 : ‚ĄĚ) T,
      hsSeminormSq s (galerkinToLp (sqgBox n) (őĪ n t))
        ‚Č§ h.E‚āÄ_uniform * Real.exp (h.K_uniform * T) := by
  intro n t ht
  have hKn_nn : 0 ‚Č§ (h.level n).K := by rw [h.hK_uniform n]; exact hK_nn
  have hBound := (h.level n).bound_on_Icc s hKn_nn T hT t ht
  rw [h.hE‚āÄ_uniform n, h.hK_uniform n] at hBound
  exact hBound

/-- **Uniform Phase 2 / Phase 5 bound ‚ÄĒ compact interval.** Packages
`HasGalerkinHsGronwallFamily.uniform_bound_on_Icc` in the signature
directly consumable by `sqg_regularity_of_aubinLions_via_interpolation`'s
`hBoundOne` argument at `s = 1` (after restricting to `[0, T]`). -/
theorem HasGalerkinHsGronwallFamily.global_uniform_bound
    (s : ‚ĄĚ) {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (h : HasGalerkinHsGronwallFamily s őĪ)
    (hK_nn : 0 ‚Č§ h.K_uniform)
    (T : ‚ĄĚ) (hT : 0 ‚Č§ T) :
    ‚ąÉ M : ‚ĄĚ, ‚ąÄ n : ‚Ąē, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí t ‚Č§ T ‚Üí
      hsSeminormSq s (galerkinToLp (sqgBox n) (őĪ n t)) ‚Č§ M := by
  refine ‚ü®h.E‚āÄ_uniform * Real.exp (h.K_uniform * T), ?_‚ü©
  intro n t ht0 htT
  exact h.uniform_bound_on_Icc s hK_nn T hT n t ‚ü®ht0, htT‚ü©

/-! ## Littlewood‚ÄďPaley dyadic decomposition (Phase 6‚Äď11 of Route A)

Formalizes the part of Littlewood‚ÄďPaley theory needed for in-project
paraproduct + Kato‚ÄďPonce estimates.  Lives inline inside `RieszTorus`
because the local `rieszTorusMeasureSpace` instance binds `volume` on
`UnitAddTorus` here. -/

/-! ### ¬ß11.1 Dyadic annuli on `‚Ą§¬≤` -/

/-- **Dyadic `‚Ąď‚ąě`-annulus on `‚Ą§¬≤`.**  For `N ‚Č• 1`:
`sqgBox (2^N - 1) \ sqgBox (2^(N-1) - 1)`.  For `N = 0`: `{0}`. -/
noncomputable def dyadicAnnulus (N : ‚Ąē) : Finset (Fin 2 ‚Üí ‚Ą§) :=
  if N = 0 then ({0} : Finset (Fin 2 ‚Üí ‚Ą§))
  else (sqgBox (2 ^ N - 1)) \ (sqgBox (2 ^ (N - 1) - 1))

@[simp] lemma dyadicAnnulus_zero :
    dyadicAnnulus 0 = ({0} : Finset (Fin 2 ‚Üí ‚Ą§)) := by
  unfold dyadicAnnulus; rfl

lemma zero_mem_dyadicAnnulus_zero : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąą dyadicAnnulus 0 := by
  rw [dyadicAnnulus_zero]; exact Finset.mem_singleton.mpr rfl

lemma zero_not_mem_dyadicAnnulus_pos {N : ‚Ąē} (hN : 0 < N) :
    (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ dyadicAnnulus N := by
  unfold dyadicAnnulus
  rw [if_neg (Nat.pos_iff_ne_zero.mp hN)]
  rw [Finset.mem_sdiff]
  push_neg
  intro h
  exact absurd h (zero_not_mem_sqgBox _)

lemma dyadicAnnulus_subset_sqgBox_pos {N : ‚Ąē} (hN : 0 < N) :
    dyadicAnnulus N ‚äÜ sqgBox (2 ^ N - 1) := by
  unfold dyadicAnnulus
  rw [if_neg (Nat.pos_iff_ne_zero.mp hN)]
  exact Finset.sdiff_subset

/-! ### ¬ß11.2 Fourier truncation onto a finite set -/

/-- **Fourier projection onto a finite set.** Uses existing `trigPoly`
infrastructure. -/
noncomputable def fourierTruncate
    (A : Finset (Fin 2 ‚Üí ‚Ą§))
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  trigPoly A (fun (m : Fin 2 ‚Üí ‚Ą§) => mFourierCoeff f m)

/-! ### ¬ß11.3 Littlewood‚ÄďPaley dyadic projector `őĒ_N` -/

/-- **Littlewood‚ÄďPaley dyadic projector.** -/
noncomputable def lpProjector
    (N : ‚Ąē) (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  fourierTruncate (dyadicAnnulus N) f

/-- **Partial-sum operator** `S_N = ‚ąĎ_{k ‚Č§ N} őĒ_k`. -/
noncomputable def lpPartialSum
    (N : ‚Ąē) (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  ‚ąĎ k ‚ąą Finset.range (N + 1), lpProjector k f

/-! ### ¬ß11.4 Fourier coefficients + seminorm computations -/

/-- **Fourier coefficients of a truncation.** Kronecker-indicator of `A`. -/
theorem fourierTruncate_mFourierCoeff
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A : Finset (Fin 2 ‚Üí ‚Ą§))
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (fourierTruncate A f) m
      = if m ‚ąą A then mFourierCoeff f m else 0 := by
  unfold fourierTruncate
  exact mFourierCoeff_trigPoly A _ m

lemma fourierTruncate_mFourierCoeff_of_mem
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A : Finset (Fin 2 ‚Üí ‚Ą§))
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚ąą A) :
    mFourierCoeff (fourierTruncate A f) m = mFourierCoeff f m := by
  rw [fourierTruncate_mFourierCoeff, if_pos hm]

lemma fourierTruncate_mFourierCoeff_of_not_mem
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A : Finset (Fin 2 ‚Üí ‚Ą§))
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚ąČ A) :
    mFourierCoeff (fourierTruncate A f) m = 0 := by
  rw [fourierTruncate_mFourierCoeff, if_neg hm]

/-- **`ŠłĘňĘ` seminorm of a truncation = weighted ‚Ąď¬≤ norm on `A`.** -/
theorem hsSeminormSq_fourierTruncate
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (s : ‚ĄĚ) (A : Finset (Fin 2 ‚Üí ‚Ą§))
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    hsSeminormSq s (fourierTruncate A f)
      = ‚ąĎ m ‚ąą A, (fracDerivSymbol s m) ^ 2 * ‚ÄĖmFourierCoeff f m‚ÄĖ ^ 2 := by
  unfold hsSeminormSq
  have hZeroOff : ‚ąÄ n ‚ąČ A,
      (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (fourierTruncate A f) n‚ÄĖ ^ 2 = 0 := by
    intros n hn
    rw [fourierTruncate_mFourierCoeff_of_not_mem A f hn, norm_zero]; ring
  rw [tsum_eq_sum (s := A) (fun n hn => hZeroOff n hn)]
  apply Finset.sum_congr rfl
  intros m hm
  rw [fourierTruncate_mFourierCoeff_of_mem A f hm]

lemma hsSeminormSq_fourierTruncate_nonneg
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (s : ‚ĄĚ) (A : Finset (Fin 2 ‚Üí ‚Ą§))
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    0 ‚Č§ hsSeminormSq s (fourierTruncate A f) := by
  rw [hsSeminormSq_fourierTruncate]
  exact Finset.sum_nonneg (fun m _ => mul_nonneg (sq_nonneg _) (sq_nonneg _))

theorem lpProjector_mFourierCoeff
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (N : ‚Ąē) (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (m : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (lpProjector N f) m
      = if m ‚ąą dyadicAnnulus N then mFourierCoeff f m else 0 := by
  unfold lpProjector
  exact fourierTruncate_mFourierCoeff _ f m

theorem hsSeminormSq_lpProjector
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (s : ‚ĄĚ) (N : ‚Ąē)
    (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    hsSeminormSq s (lpProjector N f)
      = ‚ąĎ m ‚ąą dyadicAnnulus N,
          (fracDerivSymbol s m) ^ 2 * ‚ÄĖmFourierCoeff f m‚ÄĖ ^ 2 := by
  unfold lpProjector
  exact hsSeminormSq_fourierTruncate s _ f

/-! ### ¬ß11.5 Paraproduct hypothesis types (Phase 7 structural) -/

/-- **Paraproduct `T_f g` placeholder.** -/
noncomputable def paraproduct
    (_f _g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) := 0

/-- **Paraproduct remainder `R(f, g)` placeholder.** -/
noncomputable def paraRemainder
    (_f _g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) := 0

/-- **Paraproduct `ŠłĘňĘ` bound hypothesis.** -/
structure HasParaproductHsBound (s C : ‚ĄĚ) where
  bound : ‚ąÄ f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))),
    hsSeminormSq s (paraproduct f g) ‚Č§
      C * (hsSeminormSq 0 f) * (hsSeminormSq s g)

/-- **Paraproduct remainder `ŠłĘňĘ` bound hypothesis.** -/
structure HasParaRemainderHsBound (s C : ‚ĄĚ) where
  bound : ‚ąÄ f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))),
    hsSeminormSq s (paraRemainder f g) ‚Č§
      C * (hsSeminormSq s f) * (hsSeminormSq s g)

/-! ### ¬ß11.6 Commutator `[JňĘ, f] ¬∑ ‚ąág` (Phase 8 structural) -/

/-- **Kato‚ÄďPonce commutator bound** as structure. -/
structure HasKatoPonceCommutatorBound (s C : ‚ĄĚ) where
  bound : ‚ąÄ f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))),
    ‚ąÄ gradNormF gradNormG : ‚ĄĚ, 0 ‚Č§ gradNormF ‚Üí 0 ‚Č§ gradNormG ‚Üí
    hsSeminormSq 0 (paraRemainder f g) ‚Č§
      C ^ 2 * (gradNormF ^ 2 * hsSeminormSq s g
                + gradNormG ^ 2 * hsSeminormSq s f)

/-! ### ¬ß11.7 Full Kato‚ÄďPonce (Phase 9 structural) -/

/-- **Kato‚ÄďPonce product bound (tame).** -/
structure HasKatoPonceProductBound (s C : ‚ĄĚ) where
  bound : ‚ąÄ f g : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))),
    ‚ąÄ normF normG : ‚ĄĚ, 0 ‚Č§ normF ‚Üí 0 ‚Č§ normG ‚Üí
    hsSeminormSq s (paraproduct f g) + hsSeminormSq s (paraRemainder f g) ‚Č§
      C ^ 2 * (normG ^ 2 * hsSeminormSq s f + normF ^ 2 * hsSeminormSq s g)

/-! ### ¬ß11.8 Galerkin SQG closure (Phase 10) -/

/-- **Phase 10 bridge.** -/
structure HasSqgGalerkinHsClosure
    (s : ‚ĄĚ) (őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)) where
  K : ‚ĄĚ
  hK_nn : 0 ‚Č§ K
  hDerivBound : ‚ąÄ n : ‚Ąē, ‚ąÄ T : ‚ĄĚ, 0 ‚Č§ T ‚Üí ‚ąÄ x ‚ąą Set.Ico (0 : ‚ĄĚ) T,
    |deriv (fun t => trigPolyEnergyHs s (sqgBox n) (őĪ n t)) x|
      ‚Č§ K * |trigPolyEnergyHs s (sqgBox n) (őĪ n x)|
  E‚āÄ : ‚ĄĚ
  hE‚āÄ : ‚ąÄ n : ‚Ąē, trigPolyEnergyHs s (sqgBox n) (őĪ n 0) ‚Č§ E‚āÄ

/-! ### ¬ß11.9 Phase 10 ‚Üí Phase 5 bridge -/

/-- **Bridge Phase 10 ‚Üí Phase 5**. -/
noncomputable def HasGalerkinHsGronwallFamily.of_sqgClosure
    (s : ‚ĄĚ) {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (h : HasSqgGalerkinHsClosure s őĪ)
    (hODE : ‚ąÄ n : ‚Ąē, ‚ąÄ t : ‚ĄĚ,
      HasDerivAt (őĪ n) (galerkinVectorField (sqgBox n) (őĪ n t)) t) :
    HasGalerkinHsGronwallFamily s őĪ where
  level n := {
    hDeriv := hODE n
    K := h.K
    hDerivBound := h.hDerivBound n
    E‚āÄ := h.E‚āÄ
    hE‚āÄ := h.hE‚āÄ n
  }
  K_uniform := h.K
  hK_uniform := fun _ => rfl
  E‚āÄ_uniform := h.E‚āÄ
  hE‚āÄ_uniform := fun _ => rfl

/-! ### ¬ß11.10 Zero-datum exemplar (Phase 11) -/

/-- **Zero Galerkin trajectory.** -/
noncomputable def zeroGalerkin :
    ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā) :=
  fun _ _ => 0

lemma zeroGalerkin_trigPolyEnergyHs_zero (s : ‚ĄĚ) (n : ‚Ąē) (t : ‚ĄĚ) :
    trigPolyEnergyHs s (sqgBox n) (zeroGalerkin n t) = 0 := by
  unfold zeroGalerkin trigPolyEnergyHs
  simp

lemma zeroGalerkin_energyFun_const (s : ‚ĄĚ) (n : ‚Ąē) :
    (fun t : ‚ĄĚ => trigPolyEnergyHs s (sqgBox n) (zeroGalerkin n t))
      = fun _ => (0 : ‚ĄĚ) := by
  funext t
  exact zeroGalerkin_trigPolyEnergyHs_zero s n t

/-- **Zero Galerkin trajectory satisfies Phase 10 closure.** -/
noncomputable def HasSqgGalerkinHsClosure.ofZero (s : ‚ĄĚ) :
    HasSqgGalerkinHsClosure s zeroGalerkin where
  K := 0
  hK_nn := le_refl 0
  hDerivBound := by
    intro n _ _ x _
    have hE := zeroGalerkin_energyFun_const s n
    have hd : deriv (fun t : ‚ĄĚ =>
                trigPolyEnergyHs s (sqgBox n) (zeroGalerkin n t)) x = 0 := by
      rw [hE]; simp
    rw [hd, zeroGalerkin_trigPolyEnergyHs_zero]
    simp
  E‚āÄ := 0
  hE‚āÄ := fun n => (zeroGalerkin_trigPolyEnergyHs_zero s n 0).le

/-! ### ¬ß11.11 Zero-paraproduct Kato-Ponce witness

Since `paraproduct` and `paraRemainder` are both defined as the zero
operator (Phase 7 placeholders), `HasKatoPonceProductBound s 0` holds
trivially.  This demonstrates that the `HasKatoPonceProductBound`
hypothesis is instantiable without additional analytical work on the
stubs.

**In actual SQG application**, once Phase 7 replaces `paraproduct` /
`paraRemainder` with the true Littlewood‚ÄďPaley sums, a non-trivial
`HasKatoPonceProductBound s C` witness is required (classical PDE
content, ~1500-2000 LOC of paraproduct analysis). -/

/-- **Trivial Kato-Ponce product bound** on the zero-paraproduct stub.
Uses `hsSeminormSq_of_zero` to reduce the LHS to 0; RHS is non-negative. -/
noncomputable def HasKatoPonceProductBound.ofZeroStubs (s : ‚ĄĚ) :
    HasKatoPonceProductBound s 0 where
  bound := by
    intro f g normF normG hF hG
    -- paraproduct = 0 and paraRemainder = 0 by definition; both
    -- occurrences of `hsSeminormSq s 0` collapse at once via simp.
    unfold paraproduct paraRemainder
    rw [hsSeminormSq_of_zero]
    simp

/-- **Trivial Kato-Ponce commutator bound** on the zero-remainder stub. -/
noncomputable def HasKatoPonceCommutatorBound.ofZeroStubs (s : ‚ĄĚ) :
    HasKatoPonceCommutatorBound s 0 where
  bound := by
    intro f g gradNormF gradNormG hF hG
    unfold paraRemainder
    rw [hsSeminormSq_of_zero]
    simp

/-- **Trivial paraproduct ŠłĘňĘ bound** on the zero stub. -/
noncomputable def HasParaproductHsBound.ofZeroStub (s : ‚ĄĚ) :
    HasParaproductHsBound s 0 where
  bound := by
    intro f g
    unfold paraproduct
    rw [hsSeminormSq_of_zero]
    simp

/-- **Trivial paraproduct remainder ŠłĘňĘ bound** on the zero stub. -/
noncomputable def HasParaRemainderHsBound.ofZeroStub (s : ‚ĄĚ) :
    HasParaRemainderHsBound s 0 where
  bound := by
    intro f g
    unfold paraRemainder
    rw [hsSeminormSq_of_zero]
    simp

/-! ### ¬ß11.12 Phase 10 capstone ‚ÄĒ structural chain from closure to
uniform bound

Composes `HasSqgGalerkinHsClosure` + ODE witness (Phase 10) via
`HasGalerkinHsGronwallFamily.of_sqgClosure` (¬ß11.9) to produce the
compact-interval uniform `ŠłĘňĘ` bound on the Galerkin family.  This is
the direct feed into ¬ß10.174's `hBoundS` hypothesis. -/

/-- **Phase 10 capstone**: from `HasSqgGalerkinHsClosure` + ODE
witnesses, extract a single-scalar uniform `ŠłĘňĘ` bound on `[0, T]`. -/
theorem HasSqgGalerkinHsClosure.uniform_bound
    (s : ‚ĄĚ) {őĪ : ‚ąÄ n : ‚Ąē, ‚ĄĚ ‚Üí (‚Ü•(sqgBox n) ‚Üí ‚Ąā)}
    (h : HasSqgGalerkinHsClosure s őĪ)
    (hODE : ‚ąÄ n : ‚Ąē, ‚ąÄ t : ‚ĄĚ,
      HasDerivAt (őĪ n) (galerkinVectorField (sqgBox n) (őĪ n t)) t)
    (T : ‚ĄĚ) (hT : 0 ‚Č§ T) :
    ‚ąÉ M : ‚ĄĚ, ‚ąÄ n : ‚Ąē, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí t ‚Č§ T ‚Üí
      hsSeminormSq s (galerkinToLp (sqgBox n) (őĪ n t)) ‚Č§ M :=
  (HasGalerkinHsGronwallFamily.of_sqgClosure s h hODE).global_uniform_bound
    s h.hK_nn T hT

/-! ### ¬ß11.13 Zero-datum exemplar ‚ÄĒ Phase 10 ‚Üí Phase 5 uniform bound -/

/-- **Zero-datum Phase 10 uniform bound.** Exercises ¬ß11.12 on the
zero Galerkin trajectory. -/
theorem HasSqgGalerkinHsClosure.uniform_bound_ofZero
    (s : ‚ĄĚ) (T : ‚ĄĚ) (hT : 0 ‚Č§ T) :
    ‚ąÉ M : ‚ĄĚ, ‚ąÄ n : ‚Ąē, ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí t ‚Č§ T ‚Üí
      hsSeminormSq s (galerkinToLp (sqgBox n) (zeroGalerkin n t)) ‚Č§ M := by
  refine ‚ü®0, ?_‚ü©
  intro n t _ _
  rw [show galerkinToLp (sqgBox n) (zeroGalerkin n t)
        = galerkinToLp (sqgBox n) 0 from by unfold zeroGalerkin; rfl]
  rw [galerkinToLp_zero, hsSeminormSq_of_zero]

/-! ### ¬ß11.14 Low-frequency vanishing of `lpProjector` truncations

For any `m ‚ąČ dyadicAnnulus N`, the `őĒ_N` projection's `m`-mode is 0.
This is the direct consequence of `fourierTruncate_mFourierCoeff_of_not_mem`. -/

lemma lpProjector_vanishes_off_annulus
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (N : ‚Ąē) (f : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    {m : Fin 2 ‚Üí ‚Ą§} (hm : m ‚ąČ dyadicAnnulus N) :
    mFourierCoeff (lpProjector N f) m = 0 := by
  unfold lpProjector
  exact fourierTruncate_mFourierCoeff_of_not_mem _ f hm

/-! ### ¬ß11.15 Zero-function preservation

`fourierTruncate A 0 = 0`, `lpProjector N 0 = 0`. -/

lemma fourierTruncate_zero
    (A : Finset (Fin 2 ‚Üí ‚Ą§)) :
    fourierTruncate A (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) = 0 := by
  unfold fourierTruncate trigPoly
  apply Finset.sum_eq_zero
  intros n _
  show mFourierCoeff (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) n ‚ÄĘ
    (mFourierLp 2 n : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) = 0
  rw [mFourierCoeff_zero, zero_smul]

lemma lpProjector_zero
    (N : ‚Ąē) :
    lpProjector N (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2)))) = 0 := by
  unfold lpProjector
  exact fourierTruncate_zero _

/-! ### ¬ß11.16 Hs-seminorm vanishing under dyadic projection on zero

Direct specializations used by the zero-datum Kato-Ponce chain. -/

lemma hsSeminormSq_lpProjector_zero
    (s : ‚ĄĚ) (N : ‚Ąē) :
    hsSeminormSq s (lpProjector N (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) = 0 := by
  rw [lpProjector_zero, hsSeminormSq_of_zero]

lemma hsSeminormSq_fourierTruncate_zero
    (s : ‚ĄĚ) (A : Finset (Fin 2 ‚Üí ‚Ą§)) :
    hsSeminormSq s (fourierTruncate A (0 : Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))) = 0 := by
  rw [fourierTruncate_zero, hsSeminormSq_of_zero]

/-! ### ¬ß11.17 Finite-Fourier-support pointwise product ‚ÄĒ mode convolution

Classical Kato‚ÄďPonce uses pointwise multiplication of functions on `ūĚēč¬≤`.
Since `Lp ‚Ąā 2` is not a ring, we work with `trigPoly`-represented
products via the Fourier convolution formula:
  `(f ¬∑ g)Őā(n) = ‚ąĎ_{a + b = n} fŐā(a) ¬∑ ńĚ(b)`.

On finite-Fourier-support data `f = trigPoly A cf`, `g = trigPoly B cg`,
the convolution is a finite sum, and the product is itself a
trigonometric polynomial supported on the Minkowski sum `A + B`.  This
`trigPoly`-representation is the foundation for the concrete
Kato‚ÄďPonce product bound (¬ß11.20) on the finite-Fourier-support class,
which is what the Galerkin `sqgBox` provides for ¬ß10.174's `hBoundS`. -/

/-- **Minkowski sum of two finsets on `‚Ą§¬≤`.**  `sumSet A B = A + B`. -/
def sumSet
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) : Finset (Fin 2 ‚Üí ‚Ą§) :=
  (A √óňĘ B).image (fun p => p.1 + p.2)

lemma mem_sumSet_iff
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {A B : Finset (Fin 2 ‚Üí ‚Ą§)} {n : Fin 2 ‚Üí ‚Ą§} :
    n ‚ąą sumSet A B ‚ÜĒ ‚ąÉ a ‚ąą A, ‚ąÉ b ‚ąą B, a + b = n := by
  unfold sumSet
  simp only [Finset.mem_image, Finset.mem_product, Prod.exists]
  constructor
  ¬∑ rintro ‚ü®a, b, ‚ü®ha, hb‚ü©, hsum‚ü©
    exact ‚ü®a, ha, b, hb, hsum‚ü©
  ¬∑ rintro ‚ü®a, ha, b, hb, hsum‚ü©
    exact ‚ü®a, b, ‚ü®ha, hb‚ü©, hsum‚ü©

/-- **Mode convolution of two finsupp coefficient sequences on `‚Ą§¬≤`.**
Fourier-side representation of the pointwise product
`trigPoly A cf ¬∑ trigPoly B cg`. -/
noncomputable def modeConvolution
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā :=
  fun n => ‚ąĎ a ‚ąą A, ‚ąĎ b ‚ąą B, if a + b = n then cf a * cg b else 0

/-- **Modes outside `A + B` contribute 0 to the convolution.** -/
lemma modeConvolution_eq_zero_of_not_mem_sumSet
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {A B : Finset (Fin 2 ‚Üí ‚Ą§)} {cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚ąČ sumSet A B) :
    modeConvolution A B cf cg n = 0 := by
  unfold modeConvolution
  apply Finset.sum_eq_zero
  intros a ha
  apply Finset.sum_eq_zero
  intros b hb
  split_ifs with hsum
  ¬∑ exfalso
    exact hn (mem_sumSet_iff.mpr ‚ü®a, ha, b, hb, hsum‚ü©)
  ¬∑ rfl

/-- **`trigPoly`-representation of the pointwise product of two trig polys.**
Defined as `trigPoly (sumSet A B) (modeConvolution A B cf cg)`.  Its
Fourier coefficients equal the convolution everywhere (¬ß11.17.B). -/
noncomputable def trigPolyProduct
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))) :=
  trigPoly (sumSet A B) (modeConvolution A B cf cg)

/-- **¬ß11.17.A ‚ÄĒ Raw Fourier coefficients of the trig-poly product.**
Indicator form. -/
theorem mFourierCoeff_trigPolyProduct_ite
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (trigPolyProduct A B cf cg) n
      = if n ‚ąą sumSet A B then modeConvolution A B cf cg n else 0 := by
  unfold trigPolyProduct
  exact mFourierCoeff_trigPoly (sumSet A B) (modeConvolution A B cf cg) n

/-- **¬ß11.17.B ‚ÄĒ Full-range Fourier coefficients of the trig-poly product.**
For every `n : Fin 2 ‚Üí ‚Ą§`, the Fourier coefficient equals the mode
convolution.  This is the clean form used downstream. -/
theorem mFourierCoeff_trigPolyProduct
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    mFourierCoeff (trigPolyProduct A B cf cg) n
      = modeConvolution A B cf cg n := by
  rw [mFourierCoeff_trigPolyProduct_ite]
  split_ifs with hn
  ¬∑ rfl
  ¬∑ exact (modeConvolution_eq_zero_of_not_mem_sumSet hn).symm

/-- **¬ß11.17.C ‚ÄĒ Trig-poly product vanishes outside `sumSet A B`.** -/
lemma mFourierCoeff_trigPolyProduct_eq_zero_of_not_mem
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {A B : Finset (Fin 2 ‚Üí ‚Ą§)} {cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā}
    {n : Fin 2 ‚Üí ‚Ą§} (hn : n ‚ąČ sumSet A B) :
    mFourierCoeff (trigPolyProduct A B cf cg) n = 0 := by
  rw [mFourierCoeff_trigPolyProduct]
  exact modeConvolution_eq_zero_of_not_mem_sumSet hn

/-- **Mode convolution with zero left factor is zero.** -/
lemma modeConvolution_zero_left
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    modeConvolution A B (fun _ => (0 : ‚Ąā)) cg = fun _ => (0 : ‚Ąā) := by
  funext n
  unfold modeConvolution
  apply Finset.sum_eq_zero
  intros a _
  apply Finset.sum_eq_zero
  intros b _
  split_ifs
  ¬∑ rw [zero_mul]
  ¬∑ rfl

/-- **Mode convolution with zero right factor is zero.** -/
lemma modeConvolution_zero_right
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    modeConvolution A B cf (fun _ => (0 : ‚Ąā)) = fun _ => (0 : ‚Ąā) := by
  funext n
  unfold modeConvolution
  apply Finset.sum_eq_zero
  intros a _
  apply Finset.sum_eq_zero
  intros b _
  split_ifs
  ¬∑ rw [mul_zero]
  ¬∑ rfl

/-- **Trig-poly product with zero left factor is zero.** -/
lemma trigPolyProduct_zero_left
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    trigPolyProduct A B (fun _ => (0 : ‚Ąā)) cg = 0 := by
  unfold trigPolyProduct
  rw [modeConvolution_zero_left]
  unfold trigPoly
  apply Finset.sum_eq_zero
  intros n _
  rw [zero_smul]

/-- **Trig-poly product with zero right factor is zero.** -/
lemma trigPolyProduct_zero_right
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    trigPolyProduct A B cf (fun _ => (0 : ‚Ąā)) = 0 := by
  unfold trigPolyProduct
  rw [modeConvolution_zero_right]
  unfold trigPoly
  apply Finset.sum_eq_zero
  intros n _
  rw [zero_smul]

/-! ### ¬ß11.18 Parseval + Cauchy‚ÄďSchwarz on `trigPolyProduct`

Parseval identity for the `ŠłĘňĘ` seminorm of the trig-poly product, and
a Cauchy‚ÄďSchwarz bound on the mode convolution that yields a concrete
(support-dependent) `L¬≤` bound on the product. -/

/-- **¬ß11.18.A ‚ÄĒ Parseval for the trig-poly product's `ŠłĘňĘ` seminorm.**
The tsum over `Fin 2 ‚Üí ‚Ą§` collapses to a finite sum over `sumSet A B`
because the Fourier coefficients vanish off this set. -/
theorem hsSeminormSq_trigPolyProduct
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (s : ‚ĄĚ) (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      = ‚ąĎ n ‚ąą sumSet A B,
          (fracDerivSymbol s n) ^ 2 * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2 := by
  unfold hsSeminormSq
  have hZeroOff : ‚ąÄ n ‚ąČ sumSet A B,
      (fracDerivSymbol s n) ^ 2
          * ‚ÄĖmFourierCoeff (trigPolyProduct A B cf cg) n‚ÄĖ ^ 2 = 0 := by
    intros n hn
    rw [mFourierCoeff_trigPolyProduct_eq_zero_of_not_mem hn, norm_zero]
    ring
  rw [tsum_eq_sum (s := sumSet A B) (fun n hn => hZeroOff n hn)]
  apply Finset.sum_congr rfl
  intros m _
  rw [mFourierCoeff_trigPolyProduct]

/-- **¬ß11.18.B ‚ÄĒ `modeConvolution` as a single sum over `A √óňĘ B`.**
The double sum `‚ąĎ a ‚ąą A, ‚ąĎ b ‚ąą B, ...` equals the single product sum. -/
lemma modeConvolution_eq_prod_sum
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    modeConvolution A B cf cg n
      = ‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n then cf p.1 * cg p.2 else 0 := by
  unfold modeConvolution
  rw [Finset.sum_product]

/-- **¬ß11.18.C ‚ÄĒ Cauchy‚ÄďSchwarz on `modeConvolution`.**
`|‚ąĎ Ōá ¬∑ cf ¬∑ cg|¬≤ ‚Č§ (A √óňĘ B).card ¬∑ ‚ąĎ Ōá ¬∑ |cf|¬≤ ¬∑ |cg|¬≤`.  The support-
dependent factor `|A|¬∑|B|` is the coarsest Cauchy‚ÄďSchwarz constant;
¬ß11.20 refines with the Peetre inequality to replace it. -/
theorem modeConvolution_normSq_le_card_mul_sum
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (A √óňĘ B).card *
          (‚ąĎ p ‚ąą A √óňĘ B,
              if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) := by
  rw [modeConvolution_eq_prod_sum]
  -- Drop to the real-absolute-value form.
  set f : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā :=
    fun p => if p.1 + p.2 = n then cf p.1 * cg p.2 else 0 with hf_def
  have hNormSq_term : ‚ąÄ p : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§),
      ‚ÄĖf p‚ÄĖ ^ 2
        = if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0 := by
    intro p
    simp only [hf_def]
    split_ifs
    ¬∑ rw [norm_mul, mul_pow]
    ¬∑ rw [norm_zero, pow_two, zero_mul]
  -- Triangle: `‚ÄĖ‚ąĎ f p‚ÄĖ ‚Č§ ‚ąĎ ‚ÄĖf p‚ÄĖ`.
  have hTriangle : ‚ÄĖ‚ąĎ p ‚ąą A √óňĘ B, f p‚ÄĖ ‚Č§ ‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖf p‚ÄĖ :=
    norm_sum_le _ _
  -- Cauchy‚ÄďSchwarz on real sum: `(‚ąĎ ‚ÄĖf‚ÄĖ)¬≤ ‚Č§ card ¬∑ ‚ąĎ ‚ÄĖf‚ÄĖ¬≤`.
  have hCS : (‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖf p‚ÄĖ) ^ 2
      ‚Č§ (A √óňĘ B).card * ‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖf p‚ÄĖ ^ 2 := by
    have hN_nn : ‚ąÄ p ‚ąą A √óňĘ B, (0 : ‚ĄĚ) ‚Č§ ‚ÄĖf p‚ÄĖ := fun p _ => norm_nonneg _
    -- `(‚ąĎ a)¬≤ ‚Č§ card ¬∑ ‚ąĎ a¬≤` via `Finset.sum_mul_sq_le_sq_mul_sq`
    -- (discrete Cauchy‚ÄďSchwarz) applied to `a = 1, b = ‚ÄĖf‚ÄĖ`.
    have h_ones : (‚ąĎ p ‚ąą A √óňĘ B, (1 : ‚ĄĚ) * ‚ÄĖf p‚ÄĖ) ^ 2
        ‚Č§ (‚ąĎ p ‚ąą A √óňĘ B, (1 : ‚ĄĚ) ^ 2) * (‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖf p‚ÄĖ ^ 2) :=
      Finset.sum_mul_sq_le_sq_mul_sq _ _ _
    have h_simp‚āĀ : ‚ąÄ p, (1 : ‚ĄĚ) * ‚ÄĖf p‚ÄĖ = ‚ÄĖf p‚ÄĖ := fun _ => one_mul _
    have h_simp‚āā : (‚ąĎ p ‚ąą A √óňĘ B, (1 : ‚ĄĚ) ^ 2) = (A √óňĘ B).card := by
      simp
    rw [Finset.sum_congr rfl (fun p _ => h_simp‚āĀ p)] at h_ones
    rw [h_simp‚āā] at h_ones
    exact h_ones
  -- Assemble: `‚ÄĖ‚ąĎ f‚ÄĖ¬≤ ‚Č§ (‚ąĎ ‚ÄĖf‚ÄĖ)¬≤ ‚Č§ card ¬∑ ‚ąĎ ‚ÄĖf‚ÄĖ¬≤`.
  have hSumNn : (0 : ‚ĄĚ) ‚Č§ ‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖf p‚ÄĖ :=
    Finset.sum_nonneg (fun p _ => norm_nonneg _)
  have hSq : ‚ÄĖ‚ąĎ p ‚ąą A √óňĘ B, f p‚ÄĖ ^ 2 ‚Č§ (‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖf p‚ÄĖ) ^ 2 := by
    exact pow_le_pow_left‚āÄ (norm_nonneg _) hTriangle 2
  calc ‚ÄĖ‚ąĎ p ‚ąą A √óňĘ B, f p‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖf p‚ÄĖ) ^ 2 := hSq
    _ ‚Č§ (A √óňĘ B).card * ‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖf p‚ÄĖ ^ 2 := hCS
    _ = (A √óňĘ B).card * ‚ąĎ p ‚ąą A √óňĘ B,
          (if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) := by
          rw [Finset.sum_congr rfl (fun p _ => hNormSq_term p)]

/-! ### ¬ß11.19 Peetre lattice inequality on `latticeNorm` / `fracDerivSymbol`

For `s ‚Č• 1`, the Peetre inequality on `‚Ą§¬≤` gives
  `‚ÄĖa + b‚ÄĖ^s ‚Č§ 2^{s-1} ¬∑ (‚ÄĖa‚ÄĖ^s + ‚ÄĖb‚ÄĖ^s)`.
This is the pointwise Fourier-side input for Kato‚ÄďPonce: the symbol
`ŌÉ_s(m) = ‚ÄĖm‚ÄĖ^s` splits across the convolution. -/

/-- **¬ß11.19.A ‚ÄĒ Peetre lattice inequality.** For `s ‚Č• 1` and
`a, b : ‚Ą§¬≤`:
  `‚ÄĖa + b‚ÄĖ^s ‚Č§ 2^{s-1} ¬∑ (‚ÄĖa‚ÄĖ^s + ‚ÄĖb‚ÄĖ^s)`.
Proof: triangle inequality on `latticeNorm` + convexity of `t ‚Ü¶ t^s`
on `[0, ‚ąě)` (via `NNReal.rpow_add_le_mul_rpow_add_rpow`). -/
lemma latticeNorm_add_rpow_le
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) (a b : Fin 2 ‚Üí ‚Ą§) :
    (latticeNorm (a + b)) ^ s
      ‚Č§ 2 ^ (s - 1) * ((latticeNorm a) ^ s + (latticeNorm b) ^ s) := by
  have h_triangle : latticeNorm (a + b) ‚Č§ latticeNorm a + latticeNorm b :=
    latticeNorm_add_le a b
  have hs_nn : 0 ‚Č§ s := le_trans zero_le_one hs
  have h_mono : (latticeNorm (a + b)) ^ s ‚Č§ (latticeNorm a + latticeNorm b) ^ s :=
    Real.rpow_le_rpow (latticeNorm_nonneg _) h_triangle hs_nn
  -- Convexity: `(x+y)^s ‚Č§ 2^{s-1}¬∑(x^s + y^s)` for `s ‚Č• 1`, `x, y ‚Č• 0`.
  -- Lift to `NNReal` to use `NNReal.rpow_add_le_mul_rpow_add_rpow`.
  have h_jensen : (latticeNorm a + latticeNorm b) ^ s
      ‚Č§ 2 ^ (s - 1) * ((latticeNorm a) ^ s + (latticeNorm b) ^ s) := by
    set x : ‚ĄĚ := latticeNorm a with hx_def
    set y : ‚ĄĚ := latticeNorm b with hy_def
    have hx_nn : 0 ‚Č§ x := latticeNorm_nonneg _
    have hy_nn : 0 ‚Č§ y := latticeNorm_nonneg _
    lift x to NNReal using hx_nn with xN
    lift y to NNReal using hy_nn with yN
    have hNN : (xN + yN : NNReal) ^ s
        ‚Č§ (2 : NNReal) ^ (s - 1) * (xN ^ s + yN ^ s) :=
      NNReal.rpow_add_le_mul_rpow_add_rpow xN yN hs
    exact_mod_cast hNN
  linarith

/-- **¬ß11.19.B ‚ÄĒ Uniform expansion `(ŌÉ_s x)^2 = ‚ÄĖx‚ÄĖ^{2s}` for `s ‚Č• 1`.**
Both branches (`x = 0` and `x ‚Č† 0`) evaluate to `(latticeNorm x)^(2s)`
via `Real.zero_rpow` and `Real.rpow_mul`. -/
lemma fracDerivSymbol_sq_eq_latticeNorm_rpow
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) (x : Fin 2 ‚Üí ‚Ą§) :
    (fracDerivSymbol s x) ^ 2 = (latticeNorm x) ^ (2 * s) := by
  have h2s_pos : (0 : ‚ĄĚ) < 2 * s := by linarith
  have h2s_ne : (2 * s : ‚ĄĚ) ‚Č† 0 := ne_of_gt h2s_pos
  by_cases hx : x = 0
  ¬∑ rw [hx, fracDerivSymbol_zero,
        (latticeNorm_eq_zero_iff (0 : Fin 2 ‚Üí ‚Ą§)).mpr rfl]
    rw [show (0 : ‚ĄĚ) ^ 2 = 0 from by ring, Real.zero_rpow h2s_ne]
  ¬∑ rw [fracDerivSymbol_of_ne_zero s hx,
        ‚Üź Real.rpow_natCast ((latticeNorm x) ^ s) 2,
        ‚Üź Real.rpow_mul (latticeNorm_nonneg _)]
    ring_nf

/-- **¬ß11.19.C ‚ÄĒ Peetre on `fracDerivSymbol` squared.** For `s ‚Č• 1` and
any `a, b : ‚Ą§¬≤`:
  `(ŌÉ_s(a+b))^2 ‚Č§ 2^{2s-1} ¬∑ ((ŌÉ_s a)^2 + (ŌÉ_s b)^2)`. -/
lemma fracDerivSymbol_sq_add_le
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) (a b : Fin 2 ‚Üí ‚Ą§) :
    (fracDerivSymbol s (a + b)) ^ 2
      ‚Č§ 2 ^ (2 * s - 1)
          * ((fracDerivSymbol s a) ^ 2 + (fracDerivSymbol s b) ^ 2) := by
  rw [fracDerivSymbol_sq_eq_latticeNorm_rpow hs,
      fracDerivSymbol_sq_eq_latticeNorm_rpow hs,
      fracDerivSymbol_sq_eq_latticeNorm_rpow hs]
  have h_2s : 1 ‚Č§ 2 * s := by linarith
  exact latticeNorm_add_rpow_le h_2s a b

/-- **¬ß11.19.D ‚ÄĒ ŠłĘňĘ seminorm of a trig polynomial** ‚ÄĒ direct finite-sum
formula.  The tsum collapses since `mFourierCoeff (trigPoly A a) m = 0`
for `m ‚ąČ A`. -/
theorem hsSeminormSq_trigPoly
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (s : ‚ĄĚ) (A : Finset (Fin 2 ‚Üí ‚Ą§)) (a : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq s (trigPoly A a)
      = ‚ąĎ m ‚ąą A, (fracDerivSymbol s m) ^ 2 * ‚ÄĖa m‚ÄĖ ^ 2 := by
  unfold hsSeminormSq
  have hZeroOff : ‚ąÄ n ‚ąČ A,
      (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (trigPoly A a) n‚ÄĖ ^ 2 = 0 := by
    intros n hn
    rw [mFourierCoeff_trigPoly_eq_zero_of_not_mem A a hn, norm_zero]
    ring
  rw [tsum_eq_sum (s := A) (fun n hn => hZeroOff n hn)]
  apply Finset.sum_congr rfl
  intros m hm
  rw [mFourierCoeff_trigPoly, if_pos hm]

/-! ### ¬ß11.20 Concrete tame Kato‚ÄďPonce on `trigPolyProduct` (support-dependent)

Combines ¬ß11.18.C (Cauchy‚ÄďSchwarz on `modeConvolution`) with ¬ß11.19.C
(Peetre inequality) to give the first concrete tame product bound on
`trigPolyProduct`:

  `‚ÄĖfg‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ (A√óB).card ¬∑ 2^{2s-1}
                ¬∑ ((‚ąĎ_a ŌÉ_s(a)¬≤ ‚ÄĖcf a‚ÄĖ¬≤)¬∑(‚ąĎ_b ‚ÄĖcg b‚ÄĖ¬≤)
                   + (‚ąĎ_a ‚ÄĖcf a‚ÄĖ¬≤)¬∑(‚ąĎ_b ŌÉ_s(b)¬≤ ‚ÄĖcg b‚ÄĖ¬≤))`

The `(A√óB).card` factor is the support-dependent Cauchy‚ÄďSchwarz
constant; a uniform (in support) bound requires Young's ‚Ąď¬Ļ√ó‚Ąď¬≤ ‚Üí ‚Ąď¬≤
plus `‚ąĎ_{m ‚ąą ‚Ą§¬≤} ‚ÄĖm‚ÄĖ^{-2s}` summability for `s > d/2 = 1`, which is
deferred to a follow-on section. -/

/-- **¬ß11.20.A ‚ÄĒ Sum reorder on `sumSet A B √ó (A √óňĘ B)` indicator sums.**
For every function `X : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ`, summing the
indicator `Ōá(p.1 + p.2 = n)` across `n ‚ąą sumSet A B` picks the unique
`n = p.1 + p.2`, collapsing the double sum to `‚ąĎ_{p ‚ąą A √óňĘ B} X p`. -/
private lemma sum_sumSet_pair_reorder
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (X : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ) :
    ‚ąĎ n ‚ąą sumSet A B, ‚ąĎ p ‚ąą A √óňĘ B, (if p.1 + p.2 = n then X p else 0)
      = ‚ąĎ p ‚ąą A √óňĘ B, X p := by
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intros p hp
  rw [Finset.mem_product] at hp
  have hsum : p.1 + p.2 ‚ąą sumSet A B :=
    mem_sumSet_iff.mpr ‚ü®p.1, hp.1, p.2, hp.2, rfl‚ü©
  rw [Finset.sum_eq_single (p.1 + p.2)]
  ¬∑ rw [if_pos rfl]
  ¬∑ intros n _ hn_ne
    exact if_neg (Ne.symm hn_ne)
  ¬∑ intro h_nm; exact absurd hsum h_nm

/-- **¬ß11.20.B ‚ÄĒ ŠłĘňĘ seminorm of the trig-poly product: single-sum form.**
Combines Parseval (¬ß11.18.A) + Cauchy‚ÄďSchwarz on `modeConvolution`
(¬ß11.18.C) + sum reorder (¬ß11.20.A) to reduce to a single sum over
`A √óňĘ B` with weight `(ŌÉ_s(a+b))¬≤`. -/
private lemma hsSeminormSq_trigPolyProduct_le_sum_pair
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (s : ‚ĄĚ) (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      ‚Č§ (A √óňĘ B).card
          * ‚ąĎ p ‚ąą A √óňĘ B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 := by
  rw [hsSeminormSq_trigPolyProduct]
  -- Pointwise: (ŌÉ_s n)¬≤ ¬∑ ‚ÄĖmodeConv n‚ÄĖ¬≤ ‚Č§ (ŌÉ_s n)¬≤ ¬∑ (|A√óB| ¬∑ ‚ąĎ ...)
  have hPointwise : ‚ąÄ n ‚ąą sumSet A B,
      (fracDerivSymbol s n) ^ 2 * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
        ‚Č§ (fracDerivSymbol s n) ^ 2 *
            ((A √óňĘ B).card * ‚ąĎ p ‚ąą A √óňĘ B,
              if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) := fun n _ =>
    mul_le_mul_of_nonneg_left
      (modeConvolution_normSq_le_card_mul_sum A B cf cg n)
      (sq_nonneg _)
  have h_sum_step1 := Finset.sum_le_sum hPointwise
  -- Rearrange the upper bound into the target form.
  have h_rearrange :
      ‚ąĎ n ‚ąą sumSet A B, (fracDerivSymbol s n) ^ 2 *
        ((A √óňĘ B).card * ‚ąĎ p ‚ąą A √óňĘ B,
          if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0)
      = (A √óňĘ B).card *
          ‚ąĎ p ‚ąą A √óňĘ B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 := by
    calc ‚ąĎ n ‚ąą sumSet A B, (fracDerivSymbol s n) ^ 2 *
          ((A √óňĘ B).card * ‚ąĎ p ‚ąą A √óňĘ B,
            if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0)
        = ‚ąĎ n ‚ąą sumSet A B, (A √óňĘ B).card *
            ((fracDerivSymbol s n) ^ 2 *
              ‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) := by
              apply Finset.sum_congr rfl; intros n _; ring
      _ = (A √óňĘ B).card *
            ‚ąĎ n ‚ąą sumSet A B, (fracDerivSymbol s n) ^ 2 *
              ‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0 := by
              rw [‚Üź Finset.mul_sum]
      _ = (A √óňĘ B).card *
            ‚ąĎ n ‚ąą sumSet A B, ‚ąĎ p ‚ąą A √óňĘ B,
              (if p.1 + p.2 = n then
                (fracDerivSymbol s (p.1 + p.2)) ^ 2
                  * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2
               else 0) := by
              congr 1
              apply Finset.sum_congr rfl
              intros n _
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intros p _
              split_ifs with h_eq
              ¬∑ rw [h_eq]; ring
              ¬∑ ring
      _ = (A √óňĘ B).card *
            ‚ąĎ p ‚ąą A √óňĘ B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 := by
              congr 1
              exact sum_sumSet_pair_reorder A B
                (fun p => (fracDerivSymbol s (p.1 + p.2)) ^ 2 *
                  ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)
  linarith

/-- **¬ß11.20.C ‚ÄĒ Concrete tame Kato‚ÄďPonce bound on `trigPolyProduct`.**
For `s ‚Č• 1`, combining ¬ß11.20.B with ¬ß11.19.C Peetre gives
  `‚ÄĖfg‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ K ¬∑ 2^{2s-1} ¬∑ (E‚āĀ¬∑N‚āā + N‚āĀ¬∑E‚āā)`
where `K = (A √óňĘ B).card`, `E_i = ‚ąĎ ŌÉ_s¬≤ ‚ÄĖc_i‚ÄĖ¬≤`, `N_i = ‚ąĎ ‚ÄĖc_i‚ÄĖ¬≤`. -/
theorem hsSeminormSq_trigPolyProduct_le_kato_ponce
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s)
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      ‚Č§ (A √óňĘ B).card * 2 ^ (2 * s - 1) *
          ((‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
              * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2)
           + (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
              * (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2)) := by
  have h_single := hsSeminormSq_trigPolyProduct_le_sum_pair s A B cf cg
  have h_peetre_pw : ‚ąÄ p ‚ąą A √óňĘ B,
      (fracDerivSymbol s (p.1 + p.2)) ^ 2
          * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2
        ‚Č§ 2 ^ (2 * s - 1) *
            (((fracDerivSymbol s p.1) ^ 2 * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)
             + (‚ÄĖcf p.1‚ÄĖ ^ 2 * (fracDerivSymbol s p.2) ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)) := by
    intros p _
    have h_peetre := fracDerivSymbol_sq_add_le hs p.1 p.2
    have h_nn : 0 ‚Č§ ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    calc (fracDerivSymbol s (p.1 + p.2)) ^ 2 * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2
        = (fracDerivSymbol s (p.1 + p.2)) ^ 2 * (‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2) := by ring
      _ ‚Č§ (2 ^ (2 * s - 1) *
            ((fracDerivSymbol s p.1) ^ 2 + (fracDerivSymbol s p.2) ^ 2))
          * (‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2) :=
            mul_le_mul_of_nonneg_right h_peetre h_nn
      _ = 2 ^ (2 * s - 1) *
            (((fracDerivSymbol s p.1) ^ 2 * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)
             + (‚ÄĖcf p.1‚ÄĖ ^ 2 * (fracDerivSymbol s p.2) ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)) := by ring
  have h_sum_peetre := Finset.sum_le_sum h_peetre_pw
  -- Distribute and factor.
  have h_simp_sum :
      ‚ąĎ p ‚ąą A √óňĘ B, 2 ^ (2 * s - 1) *
        (((fracDerivSymbol s p.1) ^ 2 * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)
         + (‚ÄĖcf p.1‚ÄĖ ^ 2 * (fracDerivSymbol s p.2) ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2))
        = 2 ^ (2 * s - 1) *
            ((‚ąĎ p ‚ąą A √óňĘ B,
                (fracDerivSymbol s p.1) ^ 2 * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)
             + (‚ąĎ p ‚ąą A √óňĘ B,
                ‚ÄĖcf p.1‚ÄĖ ^ 2 * (fracDerivSymbol s p.2) ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)) := by
    rw [‚Üź Finset.mul_sum, Finset.sum_add_distrib]
  have h_factor‚āĀ :
      ‚ąĎ p ‚ąą A √óňĘ B,
          (fracDerivSymbol s p.1) ^ 2 * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2
        = (‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
            * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by
    calc ‚ąĎ p ‚ąą A √óňĘ B,
            (fracDerivSymbol s p.1) ^ 2 * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2
        = ‚ąĎ a ‚ąą A, ‚ąĎ b ‚ąą B,
            (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2 := by
              rw [Finset.sum_product]
      _ = ‚ąĎ a ‚ąą A,
            ((fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2) * ‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2 := by
              apply Finset.sum_congr rfl
              intros a _
              rw [‚Üź Finset.mul_sum]
      _ = (‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
            * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by
              rw [‚Üź Finset.sum_mul]
  have h_factor‚āā :
      ‚ąĎ p ‚ąą A √óňĘ B,
          ‚ÄĖcf p.1‚ÄĖ ^ 2 * (fracDerivSymbol s p.2) ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2
        = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
            * (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2) := by
    calc ‚ąĎ p ‚ąą A √óňĘ B,
            ‚ÄĖcf p.1‚ÄĖ ^ 2 * (fracDerivSymbol s p.2) ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2
        = ‚ąĎ a ‚ąą A, ‚ąĎ b ‚ąą B,
            ‚ÄĖcf a‚ÄĖ ^ 2 * (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2 := by
              rw [Finset.sum_product]
      _ = ‚ąĎ a ‚ąą A,
            ‚ÄĖcf a‚ÄĖ ^ 2 * ‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2 := by
              apply Finset.sum_congr rfl
              intros a _
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intros b _
              ring
      _ = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
            * (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2) := by
              rw [‚Üź Finset.sum_mul]
  have h_card_nn : (0 : ‚ĄĚ) ‚Č§ (A √óňĘ B).card := by exact_mod_cast Nat.zero_le _
  -- Assemble.
  calc hsSeminormSq s (trigPolyProduct A B cf cg)
      ‚Č§ (A √óňĘ B).card
          * ‚ąĎ p ‚ąą A √óňĘ B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2 := h_single
    _ ‚Č§ (A √óňĘ B).card *
          (2 ^ (2 * s - 1) *
            ((‚ąĎ p ‚ąą A √óňĘ B,
                (fracDerivSymbol s p.1) ^ 2 * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2)
             + (‚ąĎ p ‚ąą A √óňĘ B,
                ‚ÄĖcf p.1‚ÄĖ ^ 2 * (fracDerivSymbol s p.2) ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2))) := by
          apply mul_le_mul_of_nonneg_left _ h_card_nn
          calc ‚ąĎ p ‚ąą A √óňĘ B,
              (fracDerivSymbol s (p.1 + p.2)) ^ 2
                * ‚ÄĖcf p.1‚ÄĖ ^ 2 * ‚ÄĖcg p.2‚ÄĖ ^ 2
              ‚Č§ _ := h_sum_peetre
            _ = _ := h_simp_sum
    _ = (A √óňĘ B).card * 2 ^ (2 * s - 1) *
          ((‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
              * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2)
           + (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
              * (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2)) := by
          rw [h_factor‚āĀ, h_factor‚āā]; ring

/-! ### ¬ß11.21 Concrete trig-poly Kato‚ÄďPonce bound as a hypothesis type

Bundles ¬ß11.20.C into a named hypothesis structure `HasTrigPolyKatoPonceBound`
parallel to `HasKatoPonceProductBound` (¬ß11.7), but keyed on the
trig-poly pointwise product `trigPolyProduct` rather than the
paraproduct stubs.  Admits a concrete instance with `C = 2^{2s-1}`
for any `s ‚Č• 1` via ¬ß11.20.C. -/

/-- **Trig-poly Kato‚ÄďPonce bound** hypothesis.  Bounds the `ŠłĘňĘ` seminorm
of `trigPolyProduct A B cf cg` in a Leibniz-style split `ŠłĘňĘ¬∑L¬≤ + L¬≤¬∑ŠłĘňĘ`,
with the support-dependent factor `(A √óňĘ B).card` absorbed into the
bound body.  `C` is the support-INDEPENDENT constant. -/
structure HasTrigPolyKatoPonceBound (s : ‚ĄĚ) (C : ‚ĄĚ) where
  bound : ‚ąÄ (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā),
    hsSeminormSq s (trigPolyProduct A B cf cg)
      ‚Č§ C * ((A √óňĘ B).card : ‚ĄĚ) *
          ((‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
              * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2)
           + (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
              * (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2))

/-- **¬ß11.21.A ‚ÄĒ Concrete `HasTrigPolyKatoPonceBound` from ¬ß11.20.C.**
For `s ‚Č• 1`, `HasTrigPolyKatoPonceBound s (2^{2s-1})` holds. -/
noncomputable def HasTrigPolyKatoPonceBound.of_peetre
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) :
    HasTrigPolyKatoPonceBound s (2 ^ (2 * s - 1)) where
  bound := by
    intros A B cf cg
    classical
    have h := hsSeminormSq_trigPolyProduct_le_kato_ponce hs A B cf cg
    -- h : LHS ‚Č§ (A √óňĘ B).card * 2^(2s-1) * (...)
    -- Goal: LHS ‚Č§ 2^(2s-1) * ((A √óňĘ B).card : ‚ĄĚ) * (...)
    -- Same bound modulo Nat‚ÜíReal coercion + commutativity.
    calc hsSeminormSq s (trigPolyProduct A B cf cg)
        ‚Č§ (A √óňĘ B).card * 2 ^ (2 * s - 1) *
            ((‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
                * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2)
             + (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
                * (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2)) := h
      _ = 2 ^ (2 * s - 1) * ((A √óňĘ B).card : ‚ĄĚ) *
            ((‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
                * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2)
             + (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
                * (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2)) := by
            push_cast
            ring

/-! ### ¬ß11.22 Young's ‚Ąď¬Ļ √ó ‚Ąď¬≤ ‚Üí ‚Ąď¬≤ on `modeConvolution`

The finite-lattice version of Young's convolution inequality:
  `‚ąĎ_n |modeConv(A, B, cf, cg)(n)|¬≤ ‚Č§ (‚ąĎ_a |cf a|)¬≤ ¬∑ (‚ąĎ_b |cg b|¬≤)`

This is support-independent in the ‚Ąď¬Ļ norm of `cf`: the RHS does not
carry the `(A √óňĘ B).card` factor of ¬ß11.20.  Combined with the ‚Ąď¬Ļ
Cauchy‚ÄďSchwarz bound `(‚ąĎ |cf a|)¬≤ ‚Č§ C_s ¬∑ ‚ÄĖf‚ÄĖ¬≤_{H^s}` (for `s > d/2`,
via lattice summability of `‚ąĎ ‚ü®m‚ü©^{-2s}`), this delivers the genuinely
uniform-in-support Kato‚ÄďPonce bound.  This section proves the Young
half; the Cauchy‚ÄďSchwarz half is ¬ß11.23. -/

/-- **¬ß11.22.A ‚ÄĒ Triangle bound on `modeConvolution`.** -/
private lemma modeConvolution_norm_le_sum_abs
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ
      ‚Č§ ‚ąĎ p ‚ąą A √óňĘ B,
          (if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0) := by
  rw [modeConvolution_eq_prod_sum]
  refine le_trans (norm_sum_le _ _) ?_
  apply Finset.sum_le_sum
  intros p _
  by_cases h : p.1 + p.2 = n
  ¬∑ rw [if_pos h, if_pos h, norm_mul]
  ¬∑ rw [if_neg h, if_neg h, norm_zero]

/-- **¬ß11.22.B ‚ÄĒ Weighted Cauchy‚ÄďSchwarz on the indicator sum.**
`(‚ąĎ Ōá ¬∑ |cf|¬∑|cg|)¬≤ ‚Č§ (‚ąĎ Ōá ¬∑ |cf|) ¬∑ (‚ąĎ Ōá ¬∑ |cf|¬∑|cg|¬≤)`.
Applies `Finset.sum_mul_sq_le_sq_mul_sq` with `F = Ōá ¬∑ ‚ąö|cf|` and
`G = Ōá ¬∑ ‚ąö|cf|¬∑|cg|`. -/
private lemma sum_pair_indicator_sq_le_cs
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    (‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0) ^ 2
      ‚Č§ (‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ else 0)
          * (‚ąĎ p ‚ąą A √óňĘ B,
              if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) := by
  set F : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ := fun p =>
    if p.1 + p.2 = n then Real.sqrt ‚ÄĖcf p.1‚ÄĖ else 0 with hF_def
  set G : (Fin 2 ‚Üí ‚Ą§) √ó (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ := fun p =>
    if p.1 + p.2 = n then Real.sqrt ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0 with hG_def
  have h_FG : ‚ąÄ p, F p * G p
      = if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0 := by
    intro p
    simp only [hF_def, hG_def]
    by_cases h : p.1 + p.2 = n
    ¬∑ rw [if_pos h, if_pos h, if_pos h]
      rw [‚Üź mul_assoc, Real.mul_self_sqrt (norm_nonneg _)]
    ¬∑ rw [if_neg h, if_neg h, if_neg h]; ring
  have h_F_sq : ‚ąÄ p, F p ^ 2
      = if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ else 0 := by
    intro p
    simp only [hF_def]
    by_cases h : p.1 + p.2 = n
    ¬∑ rw [if_pos h, if_pos h, Real.sq_sqrt (norm_nonneg _)]
    ¬∑ rw [if_neg h, if_neg h]; ring
  have h_G_sq : ‚ąÄ p, G p ^ 2
      = if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0 := by
    intro p
    simp only [hG_def]
    by_cases h : p.1 + p.2 = n
    ¬∑ rw [if_pos h, if_pos h, mul_pow, Real.sq_sqrt (norm_nonneg _)]
    ¬∑ rw [if_neg h, if_neg h]; ring
  have hCS := Finset.sum_mul_sq_le_sq_mul_sq (A √óňĘ B) F G
  rw [Finset.sum_congr rfl (fun p _ => h_FG p),
      Finset.sum_congr rfl (fun p _ => h_F_sq p),
      Finset.sum_congr rfl (fun p _ => h_G_sq p)] at hCS
  exact hCS

/-- **¬ß11.22.C ‚ÄĒ First factor bound.** Sum of `Ōá(a+b=n) ¬∑ ‚ÄĖcf a‚ÄĖ`
across `A √óňĘ B` is bounded by `‚ąĎ_{a ‚ąą A} ‚ÄĖcf a‚ÄĖ` (independent of `n`). -/
private lemma sum_pair_indicator_first_le_‚Ąď1
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    (‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ else 0)
      ‚Č§ ‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ := by
  calc ‚ąĎ p ‚ąą A √óňĘ B, (if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ else 0)
      = ‚ąĎ a ‚ąą A, ‚ąĎ b ‚ąą B, (if a + b = n then ‚ÄĖcf a‚ÄĖ else 0) := by
          rw [Finset.sum_product]
    _ ‚Č§ ‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ := by
          apply Finset.sum_le_sum
          intros a _
          -- Inner sum: ‚ąĎ b ‚ąą B, if a + b = n then ‚ÄĖcf a‚ÄĖ else 0 ‚Č§ ‚ÄĖcf a‚ÄĖ.
          -- Either n - a ‚ąą B (one term contributes ‚ÄĖcf a‚ÄĖ) or no term contributes.
          by_cases hb : n - a ‚ąą B
          ¬∑ -- Express the sum by isolating the unique b = n - a term.
            have h_inner : ‚ąĎ b ‚ąą B, (if a + b = n then ‚ÄĖcf a‚ÄĖ else 0) = ‚ÄĖcf a‚ÄĖ := by
              rw [Finset.sum_eq_single (n - a)]
              ¬∑ have : a + (n - a) = n := by abel
                rw [if_pos this]
              ¬∑ intros b hb_mem hb_ne
                have h_not : ¬¨ (a + b = n) := by
                  intro h_eq
                  have : b = n - a := by
                    have : a + b - a = n - a := by rw [h_eq]
                    rwa [add_comm a b, add_sub_cancel_right] at this
                  exact hb_ne this
                rw [if_neg h_not]
              ¬∑ intros h_nm; exact absurd hb h_nm
            rw [h_inner]
          ¬∑ -- All terms are zero.
            have h_inner : ‚ąĎ b ‚ąą B, (if a + b = n then ‚ÄĖcf a‚ÄĖ else 0) = 0 := by
              apply Finset.sum_eq_zero
              intros b hb_mem
              have h_not : ¬¨ (a + b = n) := by
                intro h_eq
                apply hb
                have : b = n - a := by
                  have : a + b - a = n - a := by rw [h_eq]
                  rwa [add_comm a b, add_sub_cancel_right] at this
                rw [‚Üź this]; exact hb_mem
              rw [if_neg h_not]
            rw [h_inner]
            exact norm_nonneg _

/-- **¬ß11.22.D ‚ÄĒ Inner-sum swap via ¬ß11.20.A pattern.**
`‚ąĎ n ‚ąą sumSet, ‚ąĎ p, Ōá(p.1+p.2=n) ¬∑ X(p) = ‚ąĎ p, X(p)`.
Specialized form used below. -/
private lemma sum_sumSet_pair_cfcg_reorder
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąĎ n ‚ąą sumSet A B, ‚ąĎ p ‚ąą A √óňĘ B,
        (if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0)
      = ‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 :=
  sum_sumSet_pair_reorder A B (fun p => ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2)

/-- **¬ß11.22.E ‚ÄĒ Young's ‚Ąď¬Ļ √ó ‚Ąď¬≤ ‚Üí ‚Ąď¬≤ on `modeConvolution`.**
`‚ąĎ_{n ‚ąą sumSet} ‚ÄĖmodeConv(n)‚ÄĖ¬≤ ‚Č§ (‚ąĎ_a ‚ÄĖcf a‚ÄĖ)¬≤ ¬∑ (‚ąĎ_b ‚ÄĖcg b‚ÄĖ¬≤)`. -/
theorem hsSeminormSq_zero_trigPolyProduct_le_young
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) ^ 2 * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by
  -- Step 1: Pointwise bound via triangle + CS.
  have h_pointwise : ‚ąÄ n ‚ąą sumSet A B,
      ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
        ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ)
            * (‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) := by
    intros n _
    have h_tri := modeConvolution_norm_le_sum_abs A B cf cg n
    have h_tri_sq : ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
        ‚Č§ (‚ąĎ p ‚ąą A √óňĘ B,
            if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0) ^ 2 :=
      pow_le_pow_left‚āÄ (norm_nonneg _) h_tri 2
    have h_cs := sum_pair_indicator_sq_le_cs A B cf cg n
    have h_first_bound := sum_pair_indicator_first_le_‚Ąď1 A B cf n
    have h_second_nn : 0 ‚Č§ ‚ąĎ p ‚ąą A √óňĘ B,
        (if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) :=
      Finset.sum_nonneg (fun p _ => by
        split_ifs
        ¬∑ exact mul_nonneg (norm_nonneg _) (sq_nonneg _)
        ¬∑ exact le_refl _)
    calc ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
        ‚Č§ (‚ąĎ p ‚ąą A √óňĘ B,
            if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0) ^ 2 := h_tri_sq
      _ ‚Č§ (‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ else 0)
            * (‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) := h_cs
      _ ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ)
            * (‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0) :=
            mul_le_mul_of_nonneg_right h_first_bound h_second_nn
  -- Step 2: Sum over n ‚ąą sumSet A B.
  have h_sum := Finset.sum_le_sum h_pointwise
  -- Step 3: Factor (‚ąĎ ‚ÄĖcf‚ÄĖ) out + apply sum reorder (¬ß11.22.D).
  have h_factor :
      ‚ąĎ n ‚ąą sumSet A B, (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) *
          (‚ąĎ p ‚ąą A √óňĘ B,
              if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 else 0)
        = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) *
            ‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2 := by
    rw [‚Üź Finset.mul_sum]
    congr 1
    exact sum_sumSet_pair_cfcg_reorder A B cf cg
  rw [h_factor] at h_sum
  -- Step 4: Factor the product sum.
  have h_factor_prod :
      ‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2
        = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by
    calc ‚ąĎ p ‚ąą A √óňĘ B, ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ ^ 2
        = ‚ąĎ a ‚ąą A, ‚ąĎ b ‚ąą B, ‚ÄĖcf a‚ÄĖ * ‚ÄĖcg b‚ÄĖ ^ 2 := by
              rw [Finset.sum_product]
      _ = ‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ * ‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2 := by
              apply Finset.sum_congr rfl
              intros a _
              rw [‚Üź Finset.mul_sum]
      _ = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by
              rw [‚Üź Finset.sum_mul]
  rw [h_factor_prod] at h_sum
  calc ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) *
          ((‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2)) := h_sum
    _ = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) ^ 2 * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by ring

/-! ### ¬ß11.23 Cauchy‚ÄďSchwarz bridge: `‚Ąď¬Ļ` ‚Üí weighted `‚Ąď¬≤`

For `s > 0` and `0 ‚ąČ A`:
  `(‚ąĎ_{a ‚ąą A} ‚ÄĖcf a‚ÄĖ)¬≤ ‚Č§ (‚ąĎ_{a ‚ąą A} ‚ÄĖa‚ÄĖ^{-2s}) ¬∑ hsSeminormSq s (trigPoly A cf)`.

Combined with ¬ß11.22 (Young `‚Ąď¬Ļ √ó ‚Ąď¬≤ ‚Üí ‚Ąď¬≤`) this yields the genuinely
uniform-in-support Kato‚ÄďPonce bound (¬ß11.24), because
`‚ąĎ_{a ‚ąą A} ‚ÄĖa‚ÄĖ^{-2s} ‚Č§ ‚ąĎ_{a ‚ąą ‚Ą§¬≤ \ {0}} ‚ÄĖa‚ÄĖ^{-2s} = C_s^{glob} < ‚ąě`
for `s > d/2 = 1` on `ūĚēč¬≤` (lattice zeta summability, deferred). -/

/-- **¬ß11.23.A ‚ÄĒ Cauchy‚ÄďSchwarz bridge.**  For `s > 0` and `0 ‚ąČ A`,
the `‚Ąď¬Ļ` norm of `cf` is bounded by the lattice-summability constant
`‚ąĎ ‚ÄĖa‚ÄĖ^{-2s}` times `hsSeminormSq s (trigPoly A cf)`. -/
theorem sum_norm_sq_le_latticeWeight_mul_hsSeminormSq
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {A : Finset (Fin 2 ‚Üí ‚Ą§)} (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A)
    {s : ‚ĄĚ} (hs : 0 < s) (cf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf) := by
  -- Cauchy‚ÄďSchwarz on reals with F = ‚ÄĖa‚ÄĖ^{-s}, G = ‚ÄĖa‚ÄĖ^s ¬∑ ‚ÄĖcf a‚ÄĖ.
  have h_cs := Finset.sum_mul_sq_le_sq_mul_sq A
    (fun a => (latticeNorm a) ^ (-s))
    (fun a => (latticeNorm a) ^ s * ‚ÄĖcf a‚ÄĖ)
  -- Massage the CS factors.
  have h_prod : ‚ąÄ a ‚ąą A,
      (latticeNorm a) ^ (-s) * ((latticeNorm a) ^ s * ‚ÄĖcf a‚ÄĖ) = ‚ÄĖcf a‚ÄĖ := by
    intros a ha
    have h_ne : a ‚Č† 0 := fun h => hA (h ‚Ėł ha)
    have h_pos : 0 < latticeNorm a := latticeNorm_pos h_ne
    rw [‚Üź mul_assoc, ‚Üź Real.rpow_add h_pos,
        show (-s + s : ‚ĄĚ) = 0 from by ring,
        Real.rpow_zero, one_mul]
  have h_f_sq : ‚ąÄ a ‚ąą A,
      ((latticeNorm a) ^ (-s)) ^ 2 = (latticeNorm a) ^ (-(2 * s)) := by
    intros a _
    rw [‚Üź Real.rpow_natCast ((latticeNorm a) ^ (-s)) 2,
        ‚Üź Real.rpow_mul (latticeNorm_nonneg _)]
    congr 1
    push_cast
    ring
  have h_g_sq : ‚ąÄ a ‚ąą A,
      ((latticeNorm a) ^ s * ‚ÄĖcf a‚ÄĖ) ^ 2
        = (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2 := by
    intros a ha
    rw [mul_pow]
    congr 1
    have h_ne : a ‚Č† 0 := fun h => hA (h ‚Ėł ha)
    rw [fracDerivSymbol_of_ne_zero s h_ne]
  -- Rewrite h_cs to match the goal.
  rw [Finset.sum_congr rfl h_prod,
      Finset.sum_congr rfl h_f_sq,
      Finset.sum_congr rfl h_g_sq] at h_cs
  rw [hsSeminormSq_trigPoly]
  exact h_cs

/-! ### ¬ß11.24 Uniform-in-support L¬≤ product bound

Combining ¬ß11.22 (Young) + ¬ß11.23 (CS bridge) gives the uniform
finite-lattice L¬≤ product bound:

  `‚ąĎ_n ‚ÄĖmodeConv(n)‚ÄĖ¬≤ ‚Č§ C_s(A) ¬∑ hsSeminormSq s (trigPoly A cf) ¬∑ (‚ąĎ_b ‚ÄĖcg b‚ÄĖ¬≤)`

where `C_s(A) = ‚ąĎ_{a ‚ąą A} ‚ÄĖa‚ÄĖ^{-2s}` is bounded by the (lattice)
zeta `‚ąĎ_{a ‚ąą ‚Ą§¬≤ \ {0}} ‚ÄĖa‚ÄĖ^{-2s}` which is finite for `s > d/2 = 1`.
For the Galerkin scheme at `A = sqgBox n` (`0 ‚ąČ sqgBox n`), this
delivers the uniform-in-`n` `L¬≤` product bound. -/

/-- **¬ß11.24 ‚ÄĒ Uniform-in-support L¬≤ product bound.** -/
theorem l2_trigPolyProduct_le_uniform
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {A B : Finset (Fin 2 ‚Üí ‚Ą§)} (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A)
    {s : ‚ĄĚ} (hs : 0 < s) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf)
          * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by
  have h_young := hsSeminormSq_zero_trigPolyProduct_le_young A B cf cg
  have h_cs := sum_norm_sq_le_latticeWeight_mul_hsSeminormSq hA hs cf
  have h_cg_nn : 0 ‚Č§ ‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2 :=
    Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  calc ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) ^ 2 * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := h_young
    _ ‚Č§ ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf))
        * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) :=
          mul_le_mul_of_nonneg_right h_cs h_cg_nn
    _ = (‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf)
          * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by ring

/-! ### ¬ß11.25 Symmetry of `modeConvolution` + symmetric Young

The mode convolution is commutative in its two factors:
`modeConvolution A B cf cg n = modeConvolution B A cg cf n`.
Combined with `sumSet A B = sumSet B A`, this symmetry lets us apply
¬ß11.22 with factors swapped to get the symmetric Young direction:
`‚ąĎ_n ‚ÄĖmodeConv(n)‚ÄĖ¬≤ ‚Č§ (‚ąĎ_a ‚ÄĖcf a‚ÄĖ¬≤) ¬∑ (‚ąĎ_b ‚ÄĖcg b‚ÄĖ)¬≤`. -/

/-- **¬ß11.25.A‚āĀ ‚ÄĒ `sumSet` is symmetric.** -/
lemma sumSet_symm
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) :
    sumSet A B = sumSet B A := by
  ext n
  rw [mem_sumSet_iff, mem_sumSet_iff]
  constructor
  ¬∑ rintro ‚ü®a, ha, b, hb, hsum‚ü©
    exact ‚ü®b, hb, a, ha, by rw [‚Üź hsum]; abel‚ü©
  ¬∑ rintro ‚ü®b, hb, a, ha, hsum‚ü©
    exact ‚ü®a, ha, b, hb, by rw [‚Üź hsum]; abel‚ü©

/-- **¬ß11.25.A‚āā ‚ÄĒ `modeConvolution` is commutative in its factors.** -/
lemma modeConvolution_symm
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    modeConvolution A B cf cg n = modeConvolution B A cg cf n := by
  unfold modeConvolution
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intros b _
  apply Finset.sum_congr rfl
  intros a _
  by_cases h : a + b = n
  ¬∑ rw [if_pos h, if_pos (show b + a = n from by rw [add_comm]; exact h)]
    ring
  ¬∑ rw [if_neg h, if_neg (show ¬¨ (b + a = n) from fun h' => h (by rw [add_comm]; exact h'))]

/-- **¬ß11.25.B ‚ÄĒ Symmetric Young on `modeConvolution`.**  Apply ¬ß11.22
with the roles of `cf` and `cg` swapped (plus ¬ß11.25.A symmetries). -/
theorem hsSeminormSq_zero_trigPolyProduct_le_young_symm
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ) ^ 2 := by
  -- Reduce to ¬ß11.22 applied to (B, A, cg, cf).
  have h_young := hsSeminormSq_zero_trigPolyProduct_le_young B A cg cf
  -- Transform the LHS via symmetries.
  have h_lhs : ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      = ‚ąĎ n ‚ąą sumSet B A, ‚ÄĖmodeConvolution B A cg cf n‚ÄĖ ^ 2 := by
    rw [sumSet_symm A B]
    apply Finset.sum_congr rfl
    intros n _
    rw [modeConvolution_symm A B cf cg n]
  -- Transform the RHS to match ¬ß11.25.B's target form.
  have h_rhs : (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ) ^ 2 * (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
      = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ) ^ 2 := by ring
  calc ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      = ‚ąĎ n ‚ąą sumSet B A, ‚ÄĖmodeConvolution B A cg cf n‚ÄĖ ^ 2 := h_lhs
    _ ‚Č§ (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ) ^ 2 * (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2) := h_young
    _ = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ) ^ 2 := h_rhs

/-! ### ¬ß11.25.C Peetre-weighted Young via complex embedding

For the Peetre-weighted sub-convolution
`T_1'(n) = ‚ąĎ_{a+b=n} ŌÉ_s(a) ¬∑ ‚ÄĖcf(a)‚ÄĖ ¬∑ ‚ÄĖcg(b)‚ÄĖ`,
Young's inequality (¬ß11.25.B direction) delivers:
  `‚ąĎ_n T_1'(n)¬≤ ‚Č§ hsSeminormSq s (trigPoly A cf) ¬∑ (‚ąĎ_b ‚ÄĖcg b‚ÄĖ)¬≤`.

The proof embeds the real nonneg weighted sequences into `‚Ąā` via
`Complex.ofReal`, reducing to ¬ß11.25.B on the embedded data. -/

/-- **¬ß11.25.C ‚ÄĒ Peetre-weighted Young (first-factor weight on `cf`).** -/
private theorem young_peetre_weighted_left
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (s : ‚ĄĚ) (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąĎ n ‚ąą sumSet A B,
      (‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
        then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0) ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
          * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ) ^ 2 := by
  -- Embed the real nonneg weighted factors into ‚Ąā.
  set wcf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā := fun a =>
    ((fracDerivSymbol s a * ‚ÄĖcf a‚ÄĖ : ‚ĄĚ) : ‚Ąā) with hwcf_def
  set acg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā := fun b => ((‚ÄĖcg b‚ÄĖ : ‚ĄĚ) : ‚Ąā) with hacg_def
  have h_wcf_nn : ‚ąÄ a, 0 ‚Č§ fracDerivSymbol s a * ‚ÄĖcf a‚ÄĖ :=
    fun a => mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _)
  have h_wcf_norm : ‚ąÄ a, ‚ÄĖwcf a‚ÄĖ = fracDerivSymbol s a * ‚ÄĖcf a‚ÄĖ := by
    intro a
    simp only [hwcf_def, Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_nonneg (h_wcf_nn a)
  have h_acg_norm : ‚ąÄ b, ‚ÄĖacg b‚ÄĖ = ‚ÄĖcg b‚ÄĖ := by
    intro b
    simp only [hacg_def, Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_nonneg (norm_nonneg _)
  -- modeConv A B wcf acg n is real nonneg.
  have h_modeConv_eq : ‚ąÄ n,
      modeConvolution A B wcf acg n
        = ((‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
            then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0 : ‚ĄĚ) : ‚Ąā) := by
    intro n
    rw [modeConvolution_eq_prod_sum]
    rw [show ((‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
        then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0 : ‚ĄĚ) : ‚Ąā)
        = ‚ąĎ p ‚ąą A √óňĘ B, ((if p.1 + p.2 = n
          then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0 : ‚ĄĚ) : ‚Ąā) from by
      push_cast; rfl]
    apply Finset.sum_congr rfl
    intros p _
    simp only [hwcf_def, hacg_def]
    by_cases hp : p.1 + p.2 = n
    ¬∑ rw [if_pos hp, if_pos hp]
      push_cast; ring
    ¬∑ rw [if_neg hp, if_neg hp]
      push_cast; rfl
  have h_sum_nn : ‚ąÄ n, 0 ‚Č§ ‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
      then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0 := by
    intro n
    apply Finset.sum_nonneg
    intros p _
    split_ifs
    ¬∑ exact mul_nonneg (h_wcf_nn _) (norm_nonneg _)
    ¬∑ exact le_refl _
  have h_norm_eq : ‚ąÄ n,
      ‚ÄĖmodeConvolution A B wcf acg n‚ÄĖ
        = ‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
          then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0 := by
    intro n
    rw [h_modeConv_eq n, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (h_sum_nn n)]
  -- Apply ¬ß11.25.B.
  have h_young := hsSeminormSq_zero_trigPolyProduct_le_young_symm A B wcf acg
  -- Transform LHS of h_young using h_norm_eq.
  have h_lhs_eq :
      (‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B wcf acg n‚ÄĖ ^ 2)
        = ‚ąĎ n ‚ąą sumSet A B, (‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
            then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0) ^ 2 := by
    apply Finset.sum_congr rfl
    intros n _
    rw [h_norm_eq n]
  rw [h_lhs_eq] at h_young
  -- Transform RHS of h_young using h_wcf_norm, h_acg_norm.
  have h_rhs_cf :
      (‚ąĎ a ‚ąą A, ‚ÄĖwcf a‚ÄĖ ^ 2)
        = ‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2 := by
    apply Finset.sum_congr rfl
    intros a _
    rw [h_wcf_norm a, mul_pow]
  have h_rhs_cg :
      (‚ąĎ b ‚ąą B, ‚ÄĖacg b‚ÄĖ) = ‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ := by
    apply Finset.sum_congr rfl
    intros b _
    rw [h_acg_norm b]
  rw [h_rhs_cf, h_rhs_cg] at h_young
  exact h_young

/-- **¬ß11.25.C‚āā ‚ÄĒ Linear-form (sqrt) Peetre inequality.**  Taking
square roots in ¬ß11.19.C:
  `ŌÉ_s(a+b) ‚Č§ ‚ąö(2^{2s-1}) ¬∑ (ŌÉ_s a + ŌÉ_s b)` for `s ‚Č• 1`. -/
lemma fracDerivSymbol_add_le_sqrt
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) (a b : Fin 2 ‚Üí ‚Ą§) :
    fracDerivSymbol s (a + b)
      ‚Č§ Real.sqrt (2 ^ (2 * s - 1))
          * (fracDerivSymbol s a + fracDerivSymbol s b) := by
  have h_sq := fracDerivSymbol_sq_add_le hs a b
  have ha_nn := fracDerivSymbol_nonneg s a
  have hb_nn := fracDerivSymbol_nonneg s b
  have h_lhs_nn := fracDerivSymbol_nonneg s (a + b)
  have h_sum_nn : 0 ‚Č§ fracDerivSymbol s a + fracDerivSymbol s b := add_nonneg ha_nn hb_nn
  -- (ŌÉ_s a)¬≤ + (ŌÉ_s b)¬≤ ‚Č§ (ŌÉ_s a + ŌÉ_s b)¬≤
  have h_subadd : (fracDerivSymbol s a) ^ 2 + (fracDerivSymbol s b) ^ 2
      ‚Č§ (fracDerivSymbol s a + fracDerivSymbol s b) ^ 2 := by
    nlinarith [mul_nonneg ha_nn hb_nn]
  have h_pow_nn : (0 : ‚ĄĚ) ‚Č§ (2 : ‚ĄĚ) ^ (2 * s - 1) :=
    Real.rpow_nonneg (by norm_num) _
  -- (ŌÉ_s(a+b))¬≤ ‚Č§ 2^{2s-1} ¬∑ (ŌÉ_s a + ŌÉ_s b)¬≤
  have h_combined : (fracDerivSymbol s (a + b)) ^ 2
      ‚Č§ 2 ^ (2 * s - 1) * (fracDerivSymbol s a + fracDerivSymbol s b) ^ 2 := by
    calc (fracDerivSymbol s (a + b)) ^ 2
        ‚Č§ 2 ^ (2 * s - 1) *
            ((fracDerivSymbol s a) ^ 2 + (fracDerivSymbol s b) ^ 2) := h_sq
      _ ‚Č§ 2 ^ (2 * s - 1) *
            (fracDerivSymbol s a + fracDerivSymbol s b) ^ 2 :=
          mul_le_mul_of_nonneg_left h_subadd h_pow_nn
  -- Take sqrt on both sides.
  have h_rhs_sq :
      (Real.sqrt (2 ^ (2 * s - 1))
          * (fracDerivSymbol s a + fracDerivSymbol s b)) ^ 2
        = 2 ^ (2 * s - 1) * (fracDerivSymbol s a + fracDerivSymbol s b) ^ 2 := by
    rw [mul_pow, Real.sq_sqrt h_pow_nn]
  have h_rhs_nn :
      0 ‚Č§ Real.sqrt (2 ^ (2 * s - 1))
            * (fracDerivSymbol s a + fracDerivSymbol s b) :=
    mul_nonneg (Real.sqrt_nonneg _) h_sum_nn
  have h_sq_cmp :
      (fracDerivSymbol s (a + b)) ^ 2
        ‚Č§ (Real.sqrt (2 ^ (2 * s - 1))
            * (fracDerivSymbol s a + fracDerivSymbol s b)) ^ 2 := by
    rw [h_rhs_sq]; exact h_combined
  have h_sqrt_mono := Real.sqrt_le_sqrt h_sq_cmp
  rw [Real.sqrt_sq h_lhs_nn, Real.sqrt_sq h_rhs_nn] at h_sqrt_mono
  exact h_sqrt_mono

/-- **¬ß11.25.D ‚ÄĒ Peetre-weighted Young (second-factor weight on `cg`).**
Symmetric form of ¬ß11.25.C via ¬ß11.22 direction (`‚Ąď¬Ļ √ó ‚Ąď¬≤`). -/
private theorem young_peetre_weighted_right
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    (s : ‚ĄĚ) (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąĎ n ‚ąą sumSet A B,
      (‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
        then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ) else 0) ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) ^ 2
          * (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2) := by
  -- Embed the real nonneg (weighted) factors into ‚Ąā.
  set acf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā := fun a => ((‚ÄĖcf a‚ÄĖ : ‚ĄĚ) : ‚Ąā) with hacf_def
  set wcg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā := fun b =>
    ((fracDerivSymbol s b * ‚ÄĖcg b‚ÄĖ : ‚ĄĚ) : ‚Ąā) with hwcg_def
  have h_wcg_nn : ‚ąÄ b, 0 ‚Č§ fracDerivSymbol s b * ‚ÄĖcg b‚ÄĖ :=
    fun b => mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _)
  have h_acf_norm : ‚ąÄ a, ‚ÄĖacf a‚ÄĖ = ‚ÄĖcf a‚ÄĖ := by
    intro a
    simp only [hacf_def, Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_nonneg (norm_nonneg _)
  have h_wcg_norm : ‚ąÄ b, ‚ÄĖwcg b‚ÄĖ = fracDerivSymbol s b * ‚ÄĖcg b‚ÄĖ := by
    intro b
    simp only [hwcg_def, Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_nonneg (h_wcg_nn b)
  have h_modeConv_eq : ‚ąÄ n,
      modeConvolution A B acf wcg n
        = ((‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
          then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ) else 0 : ‚ĄĚ) : ‚Ąā) := by
    intro n
    rw [modeConvolution_eq_prod_sum]
    rw [show ((‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
        then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ) else 0 : ‚ĄĚ) : ‚Ąā)
        = ‚ąĎ p ‚ąą A √óňĘ B, ((if p.1 + p.2 = n
          then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ) else 0 : ‚ĄĚ) : ‚Ąā) from by
      push_cast; rfl]
    apply Finset.sum_congr rfl
    intros p _
    simp only [hacf_def, hwcg_def]
    by_cases hp : p.1 + p.2 = n
    ¬∑ rw [if_pos hp, if_pos hp]
      push_cast; ring
    ¬∑ rw [if_neg hp, if_neg hp]
      push_cast; rfl
  have h_sum_nn : ‚ąÄ n, 0 ‚Č§ ‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
      then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ) else 0 := by
    intro n
    apply Finset.sum_nonneg
    intros p _
    split_ifs
    ¬∑ exact mul_nonneg (norm_nonneg _) (h_wcg_nn _)
    ¬∑ exact le_refl _
  have h_norm_eq : ‚ąÄ n,
      ‚ÄĖmodeConvolution A B acf wcg n‚ÄĖ
        = ‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
          then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ) else 0 := by
    intro n
    rw [h_modeConv_eq n, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (h_sum_nn n)]
  have h_young := hsSeminormSq_zero_trigPolyProduct_le_young A B acf wcg
  have h_lhs_eq :
      (‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B acf wcg n‚ÄĖ ^ 2)
        = ‚ąĎ n ‚ąą sumSet A B, (‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
            then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ) else 0) ^ 2 := by
    apply Finset.sum_congr rfl
    intros n _
    rw [h_norm_eq n]
  rw [h_lhs_eq] at h_young
  have h_rhs_cf :
      (‚ąĎ a ‚ąą A, ‚ÄĖacf a‚ÄĖ) = ‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ := by
    apply Finset.sum_congr rfl
    intros a _
    rw [h_acf_norm a]
  have h_rhs_cg :
      (‚ąĎ b ‚ąą B, ‚ÄĖwcg b‚ÄĖ ^ 2)
        = ‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2 := by
    apply Finset.sum_congr rfl
    intros b _
    rw [h_wcg_norm b, mul_pow]
  rw [h_rhs_cf, h_rhs_cg] at h_young
  exact h_young

/-! ### ¬ß11.25.E Banach-algebra `ŠłĘňĘ` product bound

Final assembly of ¬ß11.25.C (Peetre-weighted Young, left) + ¬ß11.25.D
(Peetre-weighted Young, right) + ¬ß11.25.C‚āā (sqrt-Peetre) + ¬ß11.23
(Cauchy‚ÄďSchwarz bridge `‚Ąď¬Ļ ‚Üí weighted ‚Ąď¬≤`) into the full
Banach-algebra estimate:

  `‚ÄĖfg‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ 2^{2s} ¬∑ (C_s(A) + C_s(B)) ¬∑ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ} ¬∑ ‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ}`

for `s ‚Č• 1`, `0 ‚ąČ A`, `0 ‚ąČ B`, where
`C_s(A) = ‚ąĎ_{a ‚ąą A} ‚ÄĖa‚ÄĖ^{-2s}`.

Combined with global lattice zeta summability
`‚ąĎ_{a ‚ąą ‚Ą§¬≤ \ {0}} ‚ÄĖa‚ÄĖ^{-2s} < ‚ąě` for `s > d/2 = 1` on `ūĚēč¬≤`
(standard, deferred), the weights `C_s(A)`, `C_s(B)` are uniformly
bounded, delivering the support-independent Banach-algebra product
bound.  For the Galerkin scheme at `A = B = sqgBox n`, this is
uniform in `n` and discharges `hBoundS` in ¬ß10.174's Aubin‚ÄďLions
interpolation.

**Proof strategy:**
1. Pointwise sqrt-Peetre: `ŌÉ_s(n) ¬∑ ‚ÄĖmodeConv(n)‚ÄĖ ‚Č§ ‚ąö(2^{2s-1})¬∑(T‚āĀ'(n) + T‚āā'(n))`
   where `T‚āĀ'(n), T‚āā'(n)` are the indicator sums on `A √óňĘ B` that
   ¬ß11.25.C and ¬ß11.25.D bound.
2. Square and use `(x+y)¬≤ ‚Č§ 2¬∑(x¬≤ + y¬≤)` to get
   `(ŌÉ_s n)¬≤ ¬∑ ‚ÄĖmodeConv‚ÄĖ¬≤ ‚Č§ 2^{2s} ¬∑ (T‚āĀ'(n)¬≤ + T‚āā'(n)¬≤)`.
3. Sum over `n ‚ąą sumSet A B`, apply ¬ß11.25.C + ¬ß11.25.D.
4. Discharge the `‚Ąď¬Ļ` factors via ¬ß11.23 (Cauchy‚ÄďSchwarz bridge).
-/

/-- **¬ß11.25.E‚āĀ ‚ÄĒ Linear sqrt-Peetre bound on `ŌÉ_s ¬∑ ‚ÄĖmodeConv‚ÄĖ`.**
From the triangle inequality for `modeConvolution` (¬ß11.22.A),
the replacement `ŌÉ_s(n) = ŌÉ_s(p.1 + p.2)` under the indicator, and
¬ß11.25.C‚āā (sqrt-Peetre on `ŌÉ_s(a+b)`):

  `ŌÉ_s(n) ¬∑ ‚ÄĖmodeConv A B cf cg n‚ÄĖ
    ‚Č§ ‚ąö(2^{2s-1}) ¬∑ (T‚āĀ'(n) + T‚āā'(n))`

where

  `T‚āĀ'(n) = ‚ąĎ_{(a,b) ‚ąą A√óB, a+b=n} ŌÉ_s(a) ¬∑ ‚ÄĖcf a‚ÄĖ ¬∑ ‚ÄĖcg b‚ÄĖ`
  `T‚āā'(n) = ‚ąĎ_{(a,b) ‚ąą A√óB, a+b=n} ‚ÄĖcf a‚ÄĖ ¬∑ (ŌÉ_s(b) ¬∑ ‚ÄĖcg b‚ÄĖ)`. -/
private lemma fracDerivSymbol_mul_modeConvolution_norm_le_sqrt_peetre
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) (A B : Finset (Fin 2 ‚Üí ‚Ą§))
    (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) (n : Fin 2 ‚Üí ‚Ą§) :
    fracDerivSymbol s n * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ
      ‚Č§ Real.sqrt (2 ^ (2 * s - 1))
          * ((‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n
                  then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
                  else 0)
             + (‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n
                  then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ)
                  else 0)) := by
  have h_tri := modeConvolution_norm_le_sum_abs A B cf cg n
  have h_sigma_nn : 0 ‚Č§ fracDerivSymbol s n := fracDerivSymbol_nonneg _ _
  have h_mul : fracDerivSymbol s n * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ
      ‚Č§ fracDerivSymbol s n
          * ‚ąĎ p ‚ąą A √óňĘ B,
              (if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0) :=
    mul_le_mul_of_nonneg_left h_tri h_sigma_nn
  -- Distribute ŌÉ_s n into the sum, and use ŌÉ_s n = ŌÉ_s(p.1 + p.2) inside Ōá.
  have h_rewrite : fracDerivSymbol s n
      * ‚ąĎ p ‚ąą A √óňĘ B,
          (if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0)
      = ‚ąĎ p ‚ąą A √óňĘ B,
          (if p.1 + p.2 = n
             then fracDerivSymbol s (p.1 + p.2) * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
             else 0) := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intros p _
    by_cases hp : p.1 + p.2 = n
    ¬∑ rw [if_pos hp, if_pos hp, ‚Üź hp]; ring
    ¬∑ rw [if_neg hp, if_neg hp, mul_zero]
  -- Elementwise sqrt-Peetre via ¬ß11.25.C‚āā.
  have h_peetre : ‚ąÄ p ‚ąą A √óňĘ B,
      (if p.1 + p.2 = n
         then fracDerivSymbol s (p.1 + p.2) * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
         else 0)
        ‚Č§ Real.sqrt (2 ^ (2 * s - 1))
            * (if p.1 + p.2 = n
                 then (fracDerivSymbol s p.1 + fracDerivSymbol s p.2)
                        * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
                 else 0) := by
    intros p _
    by_cases hp : p.1 + p.2 = n
    ¬∑ rw [if_pos hp, if_pos hp]
      have h_peetre_pt := fracDerivSymbol_add_le_sqrt hs p.1 p.2
      have h_prod_nn : 0 ‚Č§ ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ :=
        mul_nonneg (norm_nonneg _) (norm_nonneg _)
      calc fracDerivSymbol s (p.1 + p.2) * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
          = fracDerivSymbol s (p.1 + p.2) * (‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ) := by ring
        _ ‚Č§ (Real.sqrt (2 ^ (2 * s - 1))
              * (fracDerivSymbol s p.1 + fracDerivSymbol s p.2))
            * (‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ) :=
              mul_le_mul_of_nonneg_right h_peetre_pt h_prod_nn
        _ = Real.sqrt (2 ^ (2 * s - 1))
              * ((fracDerivSymbol s p.1 + fracDerivSymbol s p.2)
                  * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ) := by ring
    ¬∑ rw [if_neg hp, if_neg hp, mul_zero]
  have h_sum_peetre := Finset.sum_le_sum h_peetre
  -- Factor ‚ąö(2^{2s-1}) out and split the (ŌÉ_s p.1 + ŌÉ_s p.2) term.
  have h_split : ‚ąĎ p ‚ąą A √óňĘ B,
        Real.sqrt (2 ^ (2 * s - 1))
          * (if p.1 + p.2 = n
               then (fracDerivSymbol s p.1 + fracDerivSymbol s p.2)
                      * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
               else 0)
      = Real.sqrt (2 ^ (2 * s - 1))
          * ((‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n
                  then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
                  else 0)
             + (‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n
                  then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ)
                  else 0)) := by
    rw [‚Üź Finset.mul_sum]
    congr 1
    rw [‚Üź Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intros p _
    by_cases hp : p.1 + p.2 = n
    ¬∑ rw [if_pos hp, if_pos hp, if_pos hp]; ring
    ¬∑ rw [if_neg hp, if_neg hp, if_neg hp]; ring
  calc fracDerivSymbol s n * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ
      ‚Č§ fracDerivSymbol s n
          * ‚ąĎ p ‚ąą A √óňĘ B,
              (if p.1 + p.2 = n then ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0) := h_mul
    _ = ‚ąĎ p ‚ąą A √óňĘ B,
          (if p.1 + p.2 = n
             then fracDerivSymbol s (p.1 + p.2) * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
             else 0) := h_rewrite
    _ ‚Č§ ‚ąĎ p ‚ąą A √óňĘ B,
          Real.sqrt (2 ^ (2 * s - 1))
            * (if p.1 + p.2 = n
                 then (fracDerivSymbol s p.1 + fracDerivSymbol s p.2)
                        * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
                 else 0) := h_sum_peetre
    _ = Real.sqrt (2 ^ (2 * s - 1))
          * ((‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n
                  then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ
                  else 0)
             + (‚ąĎ p ‚ąą A √óňĘ B,
                if p.1 + p.2 = n
                  then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ)
                  else 0)) := h_split

/-- **¬ß11.25.E ‚ÄĒ Banach-algebra `ŠłĘňĘ` product bound on `trigPolyProduct`.**
For `s ‚Č• 1`, `0 ‚ąČ A`, `0 ‚ąČ B`:

  `hsSeminormSq s (trigPolyProduct A B cf cg)
    ‚Č§ 2^{2s} ¬∑ (C_s(A) + C_s(B))
        ¬∑ hsSeminormSq s (trigPoly A cf)
        ¬∑ hsSeminormSq s (trigPoly B cg)`

where `C_s(A) = ‚ąĎ_{a ‚ąą A} ‚ÄĖa‚ÄĖ^{-2s}`.  Assembly of the ¬ß11.25.A‚ÄďD +
C‚āā + ¬ß11.23 building blocks. -/
theorem hsSeminormSq_trigPolyProduct_le_banach_algebra
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) {A B : Finset (Fin 2 ‚Üí ‚Ą§)}
    (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A) (hB : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ B)
    (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      ‚Č§ 2 ^ (2 * s)
          * ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
              + (‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by
  have hs_pos : 0 < s := lt_of_lt_of_le one_pos hs
  -- Abbreviations for the T_i'(n) indicator sums.
  set T1 : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ := fun n =>
    ‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
      then fracDerivSymbol s p.1 * ‚ÄĖcf p.1‚ÄĖ * ‚ÄĖcg p.2‚ÄĖ else 0 with hT1_def
  set T2 : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚ĄĚ := fun n =>
    ‚ąĎ p ‚ąą A √óňĘ B, if p.1 + p.2 = n
      then ‚ÄĖcf p.1‚ÄĖ * (fracDerivSymbol s p.2 * ‚ÄĖcg p.2‚ÄĖ) else 0 with hT2_def
  have h_T1_nn : ‚ąÄ n, 0 ‚Č§ T1 n := fun n => by
    apply Finset.sum_nonneg
    intros p _
    split_ifs
    ¬∑ exact mul_nonneg (mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _))
        (norm_nonneg _)
    ¬∑ exact le_refl _
  have h_T2_nn : ‚ąÄ n, 0 ‚Č§ T2 n := fun n => by
    apply Finset.sum_nonneg
    intros p _
    split_ifs
    ¬∑ exact mul_nonneg (norm_nonneg _)
        (mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _))
    ¬∑ exact le_refl _
  -- Step 1: Pointwise bound.
  have h_pow_2s_1_nn : (0 : ‚ĄĚ) ‚Č§ (2 : ‚ĄĚ) ^ (2 * s - 1) :=
    Real.rpow_nonneg (by norm_num) _
  have h_pow_2s_nn : (0 : ‚ĄĚ) ‚Č§ (2 : ‚ĄĚ) ^ (2 * s) :=
    Real.rpow_nonneg (by norm_num) _
  have h_sqrt_sq : (Real.sqrt (2 ^ (2 * s - 1))) ^ 2 = 2 ^ (2 * s - 1) := by
    rw [sq, Real.mul_self_sqrt h_pow_2s_1_nn]
  have h_2s_eq : (2 : ‚ĄĚ) ^ (2 * s) = 2 * 2 ^ (2 * s - 1) := by
    have h2 : (2 : ‚ĄĚ) ^ (2 * s) = 2 ^ (2 * s - 1 + 1) := by
      congr 1; ring
    rw [h2, Real.rpow_add (by norm_num : (2 : ‚ĄĚ) > 0), Real.rpow_one]
    ring
  have h_pointwise : ‚ąÄ n ‚ąą sumSet A B,
      (fracDerivSymbol s n) ^ 2 * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
        ‚Č§ 2 ^ (2 * s) * (T1 n ^ 2 + T2 n ^ 2) := by
    intros n _
    have h_linbound :=
      fracDerivSymbol_mul_modeConvolution_norm_le_sqrt_peetre hs A B cf cg n
    have h_lhs_nn : 0 ‚Č§ fracDerivSymbol s n * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ :=
      mul_nonneg (fracDerivSymbol_nonneg _ _) (norm_nonneg _)
    have h_sum_nn : 0 ‚Č§ T1 n + T2 n := add_nonneg (h_T1_nn n) (h_T2_nn n)
    have h_rhs_nn : 0 ‚Č§ Real.sqrt (2 ^ (2 * s - 1)) * (T1 n + T2 n) :=
      mul_nonneg (Real.sqrt_nonneg _) h_sum_nn
    have h_sq : (fracDerivSymbol s n * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ) ^ 2
        ‚Č§ (Real.sqrt (2 ^ (2 * s - 1)) * (T1 n + T2 n)) ^ 2 :=
      pow_le_pow_left‚āÄ h_lhs_nn h_linbound 2
    have h_sq_expand :
        (Real.sqrt (2 ^ (2 * s - 1)) * (T1 n + T2 n)) ^ 2
          = 2 ^ (2 * s - 1) * (T1 n + T2 n) ^ 2 := by
      rw [mul_pow, h_sqrt_sq]
    have h_T_sq_le : (T1 n + T2 n) ^ 2 ‚Č§ 2 * (T1 n ^ 2 + T2 n ^ 2) := by
      nlinarith [sq_nonneg (T1 n - T2 n)]
    calc (fracDerivSymbol s n) ^ 2 * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
        = (fracDerivSymbol s n * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ) ^ 2 := by ring
      _ ‚Č§ (Real.sqrt (2 ^ (2 * s - 1)) * (T1 n + T2 n)) ^ 2 := h_sq
      _ = 2 ^ (2 * s - 1) * (T1 n + T2 n) ^ 2 := h_sq_expand
      _ ‚Č§ 2 ^ (2 * s - 1) * (2 * (T1 n ^ 2 + T2 n ^ 2)) :=
            mul_le_mul_of_nonneg_left h_T_sq_le h_pow_2s_1_nn
      _ = 2 ^ (2 * s) * (T1 n ^ 2 + T2 n ^ 2) := by rw [h_2s_eq]; ring
  -- Step 2: Sum over n ‚ąą sumSet A B.
  rw [hsSeminormSq_trigPolyProduct]
  have h_sum := Finset.sum_le_sum h_pointwise
  -- Factor 2^{2s} out.
  have h_factor_2s :
      ‚ąĎ n ‚ąą sumSet A B, 2 ^ (2 * s) * (T1 n ^ 2 + T2 n ^ 2)
        = 2 ^ (2 * s) *
            ((‚ąĎ n ‚ąą sumSet A B, T1 n ^ 2)
              + (‚ąĎ n ‚ąą sumSet A B, T2 n ^ 2)) := by
    rw [‚Üź Finset.mul_sum, Finset.sum_add_distrib]
  rw [h_factor_2s] at h_sum
  -- Step 3: Apply ¬ß11.25.C and ¬ß11.25.D.
  have h_T1_bound := young_peetre_weighted_left s A B cf cg
  have h_T2_bound := young_peetre_weighted_right s A B cf cg
  -- Rewrite h_T1/T2 bound's RHS via hsSeminormSq_trigPoly.
  have h_hsA : (‚ąĎ a ‚ąą A, (fracDerivSymbol s a) ^ 2 * ‚ÄĖcf a‚ÄĖ ^ 2)
      = hsSeminormSq s (trigPoly A cf) := (hsSeminormSq_trigPoly s A cf).symm
  have h_hsB : (‚ąĎ b ‚ąą B, (fracDerivSymbol s b) ^ 2 * ‚ÄĖcg b‚ÄĖ ^ 2)
      = hsSeminormSq s (trigPoly B cg) := (hsSeminormSq_trigPoly s B cg).symm
  -- Rephrase in terms of T1, T2, and hsSeminormSq.
  have h_T1_rephrased : (‚ąĎ n ‚ąą sumSet A B, T1 n ^ 2)
        ‚Č§ hsSeminormSq s (trigPoly A cf) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ) ^ 2 := by
    simp only [hT1_def] at h_T1_bound ‚äĘ
    rw [‚Üź h_hsA]
    exact h_T1_bound
  have h_T2_rephrased : (‚ąĎ n ‚ąą sumSet A B, T2 n ^ 2)
        ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) ^ 2 * hsSeminormSq s (trigPoly B cg) := by
    simp only [hT2_def] at h_T2_bound ‚äĘ
    rw [‚Üź h_hsB]
    exact h_T2_bound
  -- Step 4: Apply ¬ß11.23 CS bridge to ‚Ąď¬Ļ factors.
  have h_CS_A := sum_norm_sq_le_latticeWeight_mul_hsSeminormSq hA hs_pos cf
  have h_CS_B := sum_norm_sq_le_latticeWeight_mul_hsSeminormSq hB hs_pos cg
  -- Combine.
  have h_hsA_nn : 0 ‚Č§ hsSeminormSq s (trigPoly A cf) := hsSeminormSq_nonneg_any _ _
  have h_hsB_nn : 0 ‚Č§ hsSeminormSq s (trigPoly B cg) := hsSeminormSq_nonneg_any _ _
  have h_T1_final : (‚ąĎ n ‚ąą sumSet A B, T1 n ^ 2)
      ‚Č§ hsSeminormSq s (trigPoly A cf)
          * ((‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s)))
              * hsSeminormSq s (trigPoly B cg)) :=
    le_trans h_T1_rephrased (mul_le_mul_of_nonneg_left h_CS_B h_hsA_nn)
  have h_T2_final : (‚ąĎ n ‚ąą sumSet A B, T2 n ^ 2)
      ‚Č§ ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf))
          * hsSeminormSq s (trigPoly B cg) :=
    le_trans h_T2_rephrased (mul_le_mul_of_nonneg_right h_CS_A h_hsB_nn)
  have h_sum_final :
      (‚ąĎ n ‚ąą sumSet A B, T1 n ^ 2) + (‚ąĎ n ‚ąą sumSet A B, T2 n ^ 2)
        ‚Č§ ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
            + (‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by
    have h_combined :
        (‚ąĎ n ‚ąą sumSet A B, T1 n ^ 2) + (‚ąĎ n ‚ąą sumSet A B, T2 n ^ 2)
          ‚Č§ hsSeminormSq s (trigPoly A cf)
              * ((‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s)))
                  * hsSeminormSq s (trigPoly B cg))
            + ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
                * hsSeminormSq s (trigPoly A cf))
              * hsSeminormSq s (trigPoly B cg) :=
      add_le_add h_T1_final h_T2_final
    have h_rearrange :
        hsSeminormSq s (trigPoly A cf)
            * ((‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s)))
                * hsSeminormSq s (trigPoly B cg))
          + ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
              * hsSeminormSq s (trigPoly A cf))
            * hsSeminormSq s (trigPoly B cg)
        = ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
            + (‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by ring
    linarith [h_combined, h_rearrange.le, h_rearrange.ge]
  calc ‚ąĎ n ‚ąą sumSet A B,
          (fracDerivSymbol s n) ^ 2 * ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ 2 ^ (2 * s) *
          ((‚ąĎ n ‚ąą sumSet A B, T1 n ^ 2)
            + (‚ąĎ n ‚ąą sumSet A B, T2 n ^ 2)) := h_sum
    _ ‚Č§ 2 ^ (2 * s) *
          (((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
              + (‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s))))
            * hsSeminormSq s (trigPoly A cf)
            * hsSeminormSq s (trigPoly B cg)) :=
          mul_le_mul_of_nonneg_left h_sum_final h_pow_2s_nn
    _ = 2 ^ (2 * s)
          * ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
              + (‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by ring

/-! ### ¬ß11.25.F Lattice zeta bound hypothesis + support-independent form

Parametrises ¬ß11.25.E on a uniform lattice zeta bound so the final
`ŠłĘňĘ` Banach-algebra estimate carries a support-INDEPENDENT constant,
matching the Galerkin need (uniform in `n` for `A = B = sqgBox n`).

The hypothesis type `HasLatticeZetaBound s C` packages the claim
"every nonzero-lattice finset `A ‚äÜ ‚Ą§¬≤ \ {0}` has `‚ąĎ_a ‚ÄĖa‚ÄĖ^{-2s} ‚Č§ C`."
A concrete witness requires the global summability
`Summable (fun a : ‚Ą§¬≤ \ {0} ‚Ü¶ ‚ÄĖa‚ÄĖ^{-2s})` for `s > d/2 = 1` ‚ÄĒ a
standard 2D real-analysis fact, deferred to a follow-on section
(or mathlib contribution). -/

/-- **¬ß11.25.F‚āĀ ‚ÄĒ Lattice zeta bound hypothesis.**  The uniform bound
on nonzero-lattice finite sums `‚ąĎ_{a ‚ąą A} ‚ÄĖa‚ÄĖ^{-2s} ‚Č§ C` for every
`A ‚äÜ ‚Ą§¬≤ \ {0}` (finite).  Concrete instance for `s > 1` uses global
lattice zeta summability on `‚Ą§¬≤ \ {0}`. -/
structure HasLatticeZetaBound (s : ‚ĄĚ) (C : ‚ĄĚ) : Prop where
  nonneg : 0 ‚Č§ C
  bound : ‚ąÄ (A : Finset (Fin 2 ‚Üí ‚Ą§)),
    (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A ‚Üí
      (‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s))) ‚Č§ C

/-- **¬ß11.25.F ‚ÄĒ Support-independent Banach-algebra `ŠłĘňĘ` bound.**  For
`s ‚Č• 1` with `HasLatticeZetaBound s C`, the finite-lattice Banach-
algebra bound has constant `2C` (uniform in `A, B ‚äÜ ‚Ą§¬≤ \ {0}`):

  `‚ÄĖfg‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ 2^{2s} ¬∑ 2C ¬∑ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ} ¬∑ ‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ}`

Composes ¬ß11.25.E with the lattice-zeta hypothesis to discharge the
support-dependent `C_s(A) + C_s(B)` factor. -/
theorem hsSeminormSq_trigPolyProduct_le_uniform_banach_algebra
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) {A B : Finset (Fin 2 ‚Üí ‚Ą§)}
    (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A) (hB : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ B)
    {C : ‚ĄĚ} (hC : HasLatticeZetaBound s C)
    (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq s (trigPolyProduct A B cf cg)
      ‚Č§ 2 ^ (2 * s) * (2 * C)
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by
  have h_E := hsSeminormSq_trigPolyProduct_le_banach_algebra hs hA hB cf cg
  have h_A := hC.bound A hA
  have h_B := hC.bound B hB
  have h_sum : (‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
      + (‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s))) ‚Č§ 2 * C := by linarith
  have h_pow_2s_nn : (0 : ‚ĄĚ) ‚Č§ (2 : ‚ĄĚ) ^ (2 * s) :=
    Real.rpow_nonneg (by norm_num) _
  have h_hsA_nn : 0 ‚Č§ hsSeminormSq s (trigPoly A cf) := hsSeminormSq_nonneg_any _ _
  have h_hsB_nn : 0 ‚Č§ hsSeminormSq s (trigPoly B cg) := hsSeminormSq_nonneg_any _ _
  have h_prod_nn : 0 ‚Č§ hsSeminormSq s (trigPoly A cf)
      * hsSeminormSq s (trigPoly B cg) :=
    mul_nonneg h_hsA_nn h_hsB_nn
  have h_factor_nn : 0 ‚Č§ 2 ^ (2 * s)
      * (hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg)) :=
    mul_nonneg h_pow_2s_nn h_prod_nn
  calc hsSeminormSq s (trigPolyProduct A B cf cg)
      ‚Č§ 2 ^ (2 * s)
          * ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
              + (‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s))))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := h_E
    _ = 2 ^ (2 * s)
          * (hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg))
          * ((‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
              + (‚ąĎ b ‚ąą B, (latticeNorm b) ^ (-(2 * s)))) := by ring
    _ ‚Č§ 2 ^ (2 * s)
          * (hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg))
          * (2 * C) :=
          mul_le_mul_of_nonneg_left h_sum h_factor_nn
    _ = 2 ^ (2 * s) * (2 * C)
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by ring

/-! ### ¬ß11.25.G Banach-algebra bound packaged as hypothesis structure

Parallels `HasTrigPolyKatoPonceBound` (¬ß11.21, Leibniz split form) but
carries the Banach-algebra form `C ¬∑ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ} ¬∑ ‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ}` directly.
Built via `¬ß11.25.F` + `HasLatticeZetaBound`. -/

/-- **¬ß11.25.G‚āĀ ‚ÄĒ `HasTrigPolyBanachAlgebraBound` hypothesis.**
Bundles `‚ÄĖfg‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ C ¬∑ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ} ¬∑ ‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ}` for every finite
support `A, B ‚äÜ ‚Ą§¬≤ \ {0}` into a structural hypothesis.  Constructed
via ¬ß11.25.F from `HasLatticeZetaBound` (¬ß11.25.F‚āĀ). -/
structure HasTrigPolyBanachAlgebraBound (s : ‚ĄĚ) (C : ‚ĄĚ) : Prop where
  nonneg : 0 ‚Č§ C
  bound : ‚ąÄ (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā),
    (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A ‚Üí (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ B ‚Üí
    hsSeminormSq s (trigPolyProduct A B cf cg)
      ‚Č§ C * hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly B cg)

/-- **¬ß11.25.G ‚ÄĒ `HasTrigPolyBanachAlgebraBound` from `HasLatticeZetaBound`.**
Concrete instance at `C = 2^{2s} ¬∑ (2¬∑C_z)` for `s ‚Č• 1`.

**Note on `DecidableEq`:** earlier attempts carried an explicit
`[DecidableEq (Fin 2 ‚Üí ‚Ą§)]` hypothesis and then invoked ¬ß11.25.F
inside the body, but the structure `HasTrigPolyBanachAlgebraBound`
has its `bound` field elaborated with the DEFAULT `decidablePiFintype`
instance (synthesized at structure-declaration time), whereas an
explicit class parameter injects a fresh `inst‚úĚ`.  The resulting
`@trigPolyProduct inst‚úĚ A B cf cg` vs
`@trigPolyProduct decidablePiFintype A B cf cg` mismatch triggered
`isDefEq` timeout, then `linarith failure`, then `type mismatch` as
we tried various workarounds.  Removing the class parameter lets
instance synthesis pick `decidablePiFintype` uniformly, matching the
structure's field type exactly. -/
theorem HasTrigPolyBanachAlgebraBound.of_latticeZeta
    {s : ‚ĄĚ} (hs : 1 ‚Č§ s) {C_z : ‚ĄĚ} (hC : HasLatticeZetaBound s C_z) :
    HasTrigPolyBanachAlgebraBound s (2 ^ (2 * s) * (2 * C_z)) := by
  have h_pow_nn : (0 : ‚ĄĚ) ‚Č§ (2 : ‚ĄĚ) ^ (2 * s) :=
    Real.rpow_nonneg (by norm_num) _
  have h_2c_nn : (0 : ‚ĄĚ) ‚Č§ 2 * C_z := by linarith [hC.nonneg]
  have h_nonneg : (0 : ‚ĄĚ) ‚Č§ 2 ^ (2 * s) * (2 * C_z) := mul_nonneg h_pow_nn h_2c_nn
  refine ‚ü®h_nonneg, ?_‚ü©
  intros A B cf cg hA hB
  exact hsSeminormSq_trigPolyProduct_le_uniform_banach_algebra hs hA hB hC cf cg

/-! ### ¬ß11.25.H Zero-coefficient exemplar

Whenever one factor's coefficient sequence is zero, `trigPolyProduct`
vanishes and so does its `ŠłĘňĘ` seminorm.  Uses the SAME default
`decidablePiFintype` instance as the structure-field elaboration to
avoid the class-parameter mismatch diagnosed in ¬ß11.25.G. -/

/-- **¬ß11.25.H‚āĀ ‚ÄĒ Zero left-factor trig-poly product has zero `ŠłĘňĘ`
seminorm.** -/
theorem hsSeminormSq_trigPolyProduct_zero_left
    (s : ‚ĄĚ) (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq s (trigPolyProduct A B (fun _ => (0 : ‚Ąā)) cg) = 0 := by
  rw [trigPolyProduct_zero_left]
  exact hsSeminormSq_of_zero s

/-- **¬ß11.25.H‚āā ‚ÄĒ Zero right-factor trig-poly product has zero `ŠłĘňĘ`
seminorm.** -/
theorem hsSeminormSq_trigPolyProduct_zero_right
    (s : ‚ĄĚ) (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq s (trigPolyProduct A B cf (fun _ => (0 : ‚Ąā))) = 0 := by
  rw [trigPolyProduct_zero_right]
  exact hsSeminormSq_of_zero s

/-! ### ¬ß11.25.I Monotonicity of `HasLatticeZetaBound` in the constant

Utility lemma: if `HasLatticeZetaBound s C` holds and `C ‚Č§ C'`, then
`HasLatticeZetaBound s C'` also holds.  Useful for combining witnesses
from different sources. -/

/-- **¬ß11.25.I ‚ÄĒ Monotonicity of `HasLatticeZetaBound` in C.** -/
theorem HasLatticeZetaBound.mono
    {s : ‚ĄĚ} {C C' : ‚ĄĚ} (hC : HasLatticeZetaBound s C) (hCC' : C ‚Č§ C') :
    HasLatticeZetaBound s C' where
  nonneg := le_trans hC.nonneg hCC'
  bound := fun A hA => le_trans (hC.bound A hA) hCC'

/-! ### ¬ß11.26 Prerequisites for the concrete lattice zeta bound

Building up the ingredients needed for an explicit `HasLatticeZetaBound
s C` witness at `s > 1` (i.e., `s > d/2 = 1` on `ūĚēč¬≤`).

**Strategy:** partition `‚Ą§¬≤ \ {0}` by `‚Ąď‚ąě`-radius into annular shells.
On shell `k` (radius-k `‚Ąď‚ąě`-boundary), `|shell| ‚Č§ 8k` and `‚ÄĖa‚ÄĖ_{‚Ąď¬≤} ‚Č• k`,
so `‚ąĎ_{a ‚ąą shell_k} ‚ÄĖa‚ÄĖ^{-2s} ‚Č§ 8k ¬∑ k^{-2s} = 8 k^{1-2s}`.  Sum over
`k ‚Č• 1`: `8 ‚ąĎ_{k ‚Č• 1} k^{1-2s}`, summable for `s > 1` via mathlib's
`Real.summable_one_div_nat_rpow` at `p = 2s - 1`. -/

/-- **¬ß11.26.A ‚ÄĒ 1D p-series for shell-weighted lattice zeta.**
`Summable (fun n : ‚Ąē => 1 / (n : ‚ĄĚ) ^ (2 * s - 1))` for `s > 1`.
Direct application of mathlib's `Real.summable_one_div_nat_rpow` at
`p = 2s - 1`.  Used in ¬ß11.26 downstream for the annular-shell
lattice-zeta bound. -/
theorem summable_one_div_nat_rpow_at_two_s_sub_one
    {s : ‚ĄĚ} (hs : 1 < s) :
    Summable (fun n : ‚Ąē => 1 / (n : ‚ĄĚ) ^ (2 * s - 1)) := by
  rw [Real.summable_one_div_nat_rpow]
  linarith

/-- **¬ß11.26.B ‚ÄĒ Coordinate absolute value bounded by lattice norm.**
For every index `j`, `|(n j : ‚ĄĚ)| ‚Č§ latticeNorm n`.  Follows from
`sq_le_latticeNorm_sq` (componentwise square bound) by taking sqrt. -/
lemma abs_coord_le_latticeNorm {d : Type*} [Fintype d]
    (n : d ‚Üí ‚Ą§) (j : d) :
    |(n j : ‚ĄĚ)| ‚Č§ latticeNorm n := by
  have h_sq := sq_le_latticeNorm_sq n j
  have h_nn : 0 ‚Č§ latticeNorm n := latticeNorm_nonneg n
  rw [show |(n j : ‚ĄĚ)| = Real.sqrt ((n j : ‚ĄĚ) ^ 2) from (Real.sqrt_sq_eq_abs _).symm]
  calc Real.sqrt ((n j : ‚ĄĚ) ^ 2)
      ‚Č§ Real.sqrt ((latticeNorm n) ^ 2) := Real.sqrt_le_sqrt h_sq
    _ = latticeNorm n := Real.sqrt_sq h_nn

/-- **¬ß11.26.B‚āā ‚ÄĒ `‚Ąď‚ąě` ‚Č§ `‚Ąď¬≤` on `Fin 2 ‚Üí ‚Ą§`.**  The maximum of
`|m 0|` and `|m 1|` is bounded by `latticeNorm m`. -/
lemma max_abs_coord_le_latticeNorm (m : Fin 2 ‚Üí ‚Ą§) :
    max (|(m 0 : ‚ĄĚ)|) (|(m 1 : ‚ĄĚ)|) ‚Č§ latticeNorm m :=
  max_le (abs_coord_le_latticeNorm m 0) (abs_coord_le_latticeNorm m 1)

/-! ### ¬ß11.26.C Annular shell on `‚Ą§¬≤` -/

/-- **¬ß11.26.C ‚ÄĒ Annular shell at `‚Ąď‚ąě`-radius `k`.**  Subset of `‚Ą§¬≤`
with `max |m 0| |m 1| = k` and `m ‚Č† 0`.  For `k = 0` this is empty
(only `m = 0` has `max = 0`, excluded by nonzero constraint).  For
`k ‚Č• 1`, contains at most `8k + 4` points. -/
noncomputable def annularShell (k : ‚Ąē) : Finset (Fin 2 ‚Üí ‚Ą§) :=
  (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§)).filter
    (fun m => m ‚Č† 0 ‚ąß (|m 0| = (k : ‚Ą§) ‚ą® |m 1| = (k : ‚Ą§)))

/-- **¬ß11.26.C‚āĀ ‚ÄĒ Shell membership characterization.** -/
lemma mem_annularShell_iff (k : ‚Ąē) (m : Fin 2 ‚Üí ‚Ą§) :
    m ‚ąą annularShell k ‚ÜĒ
      (‚ąÄ i : Fin 2, |m i| ‚Č§ (k : ‚Ą§)) ‚ąß m ‚Č† 0
        ‚ąß (|m 0| = (k : ‚Ą§) ‚ą® |m 1| = (k : ‚Ą§)) := by
  unfold annularShell
  simp only [Finset.mem_filter, Fintype.mem_piFinset, Finset.mem_Icc]
  constructor
  ¬∑ rintro ‚ü®h_Icc, h_ne, h_max‚ü©
    refine ‚ü®fun i => abs_le.mpr (h_Icc i), h_ne, h_max‚ü©
  ¬∑ rintro ‚ü®h_max, h_ne, h_eq‚ü©
    refine ‚ü®fun i => ?_, h_ne, h_eq‚ü©
    have := h_max i
    exact ‚ü®(abs_le.mp this).1, (abs_le.mp this).2‚ü©

/-- **¬ß11.26.C‚āā ‚ÄĒ On shell at level `k`, `latticeNorm m ‚Č• k`.**  Each
shell member has one coordinate with `|m i| = k`, so by ¬ß11.26.B
`latticeNorm m ‚Č• |m i| = k`. -/
lemma latticeNorm_ge_of_mem_annularShell (k : ‚Ąē) (m : Fin 2 ‚Üí ‚Ą§)
    (hm : m ‚ąą annularShell k) :
    (k : ‚ĄĚ) ‚Č§ latticeNorm m := by
  rw [mem_annularShell_iff] at hm
  rcases hm.2.2 with h0 | h1
  ¬∑ have h_abs : |(m 0 : ‚ĄĚ)| = (k : ‚ĄĚ) := by
      have h_cast : ((|m 0| : ‚Ą§) : ‚ĄĚ) = ((k : ‚Ą§) : ‚ĄĚ) := by exact_mod_cast h0
      simpa [Int.cast_abs] using h_cast
    calc (k : ‚ĄĚ) = |(m 0 : ‚ĄĚ)| := h_abs.symm
      _ ‚Č§ latticeNorm m := abs_coord_le_latticeNorm m 0
  ¬∑ have h_abs : |(m 1 : ‚ĄĚ)| = (k : ‚ĄĚ) := by
      have h_cast : ((|m 1| : ‚Ą§) : ‚ĄĚ) = ((k : ‚Ą§) : ‚ĄĚ) := by exact_mod_cast h1
      simpa [Int.cast_abs] using h_cast
    calc (k : ‚ĄĚ) = |(m 1 : ‚ĄĚ)| := h_abs.symm
      _ ‚Č§ latticeNorm m := abs_coord_le_latticeNorm m 1

/-- **¬ß11.26.C‚āÉ ‚ÄĒ Shell at level `0` is empty.**  Only `m = 0` has
`max |m 0| |m 1| = 0`, and the shell definition excludes `m = 0`.
Sanity check on the annular shell partition. -/
lemma annularShell_zero : annularShell 0 = ‚ąÖ := by
  unfold annularShell
  apply Finset.eq_empty_of_forall_notMem
  intros m hm
  rw [Finset.mem_filter, Fintype.mem_piFinset] at hm
  obtain ‚ü®h_Icc, h_ne, _‚ü© := hm
  apply h_ne
  funext i
  have h := h_Icc i
  rw [Finset.mem_Icc, Nat.cast_zero, neg_zero] at h
  exact le_antisymm h.2 h.1

/-- **¬ß11.26.D ‚ÄĒ Cardinality bound: `|shell k| ‚Č§ 8k + 4`.**

Bound via the union-of-filters decomposition:
`annularShell k ‚äÜ {m | |m 0| = k} ‚ą™ {m | |m 1| = k}` in the piFinset.
Each side has cardinality `‚Č§ 2 ¬∑ (2k+1) = 4k+2` via
`Fintype.card_filter_piFinset_eq_of_mem` + `abs_eq`-split into
`m i = k` and `m i = -k`.  Sum: `(4k+2) + (4k+2) = 8k+4`.

Tight bound (`8k` exact) requires inclusion-exclusion; the loose
`8k+4` bound suffices for lattice zeta summability at `s > 1`. -/
lemma card_annularShell_le (k : ‚Ąē) :
    (annularShell k).card ‚Č§ 8 * k + 4 := by
  classical
  unfold annularShell
  -- Step 1: drop m ‚Č† 0 (enlarges set)
  have h_sub :
      (Finset.filter (fun m : Fin 2 ‚Üí ‚Ą§ => m ‚Č† 0 ‚ąß (|m 0| = (k : ‚Ą§) ‚ą® |m 1| = (k : ‚Ą§)))
        (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§))).card
      ‚Č§ (Finset.filter (fun m : Fin 2 ‚Üí ‚Ą§ => |m 0| = (k : ‚Ą§) ‚ą® |m 1| = (k : ‚Ą§))
          (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§))).card := by
    apply Finset.card_le_card
    intro m hm
    simp only [Finset.mem_filter] at hm ‚äĘ
    exact ‚ü®hm.1, hm.2.2‚ü©
  refine le_trans h_sub ?_
  -- Step 2: split (P ‚ą® Q) filter via filter_or
  rw [Finset.filter_or]
  refine le_trans (Finset.card_union_le _ _) ?_
  -- Step 3: each sub-filter ‚Č§ 4k+2
  have h_each : ‚ąÄ (i : Fin 2),
      (Finset.filter (fun m : Fin 2 ‚Üí ‚Ą§ => |m i| = (k : ‚Ą§))
        (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§))).card
        ‚Č§ 4 * k + 2 := by
    intro i
    -- |m i| = k ‚ÜĒ m i = k ‚ą® m i = -k (since k ‚Č• 0)
    have h_filter_split :
        Finset.filter (fun m : Fin 2 ‚Üí ‚Ą§ => |m i| = (k : ‚Ą§))
          (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§))
        = Finset.filter (fun m : Fin 2 ‚Üí ‚Ą§ => m i = (k : ‚Ą§) ‚ą® m i = -(k : ‚Ą§))
          (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§)) := by
      apply Finset.filter_congr
      intros m _
      rw [abs_eq (by positivity : (0 : ‚Ą§) ‚Č§ (k : ‚Ą§))]
    rw [h_filter_split, Finset.filter_or]
    refine le_trans (Finset.card_union_le _ _) ?_
    -- Each inner (m i = a) filter: card ‚Č§ 2k+1 via card_filter_piFinset_eq_of_mem
    have h_card_pt : ‚ąÄ a : ‚Ą§,
        (Finset.filter (fun m : Fin 2 ‚Üí ‚Ą§ => m i = a)
          (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§))).card
          ‚Č§ 2 * k + 1 := by
      intro a
      by_cases ha : a ‚ąą Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§)
      ¬∑ rw [Fintype.card_filter_piFinset_eq_of_mem
          (s := fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§)) i ha]
        rw [Finset.prod_const]
        have h_erase_card : ((Finset.univ : Finset (Fin 2)).erase i).card = 1 := by
          rw [Finset.card_erase_of_mem (Finset.mem_univ i), Finset.card_univ,
              Fintype.card_fin]
        rw [h_erase_card, pow_one, Int.card_Icc]
        omega
      ¬∑ have h_empty : Finset.filter (fun m : Fin 2 ‚Üí ‚Ą§ => m i = a)
            (Fintype.piFinset fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§)) = ‚ąÖ :=
          Fintype.filter_piFinset_of_notMem
            (fun _ : Fin 2 => Finset.Icc (-(k : ‚Ą§)) (k : ‚Ą§)) i a ha
        rw [h_empty, Finset.card_empty]
        omega
    have h_k := h_card_pt (k : ‚Ą§)
    have h_neg_k := h_card_pt (-(k : ‚Ą§))
    linarith
  linarith [h_each 0, h_each 1]

/-- **¬ß11.26.E ‚ÄĒ Shell-sum bound.**  For `k ‚Č• 1` and `s > 0`:
`‚ąĎ_{m ‚ąą annularShell k} ‚ÄĖm‚ÄĖ^{-2s} ‚Č§ (8k + 4) ¬∑ k^{-2s}`.  Combines
`latticeNorm_ge_of_mem_annularShell` (`‚ÄĖm‚ÄĖ ‚Č• k`) with the cardinality
bound (`|shell| ‚Č§ 8k + 4`).  Sum over `k ‚Č• 1`: `(8k+4) ¬∑ k^{-2s} =
8 k^{1-2s} + 4 k^{-2s}`, both summable for `s > 1` via
`Real.summable_one_div_nat_rpow`. -/
lemma sum_annularShell_rpow_le {s : ‚ĄĚ} (hs_pos : 0 < s) {k : ‚Ąē} (hk : 1 ‚Č§ k) :
    ‚ąĎ m ‚ąą annularShell k, (latticeNorm m) ^ (-(2 * s))
      ‚Č§ ((8 * k + 4 : ‚Ąē) : ‚ĄĚ) * ((k : ‚ĄĚ) ^ (-(2 * s))) := by
  have h_k_pos : 0 < (k : ‚ĄĚ) := by exact_mod_cast hk
  have h_k_nn : 0 ‚Č§ (k : ‚ĄĚ) := le_of_lt h_k_pos
  have h_2s_nn : 0 ‚Č§ 2 * s := by linarith
  -- Pointwise bound: for m ‚ąą shell k, (latticeNorm m)^{-2s} ‚Č§ k^{-2s}
  have h_pointwise : ‚ąÄ m ‚ąą annularShell k,
      (latticeNorm m) ^ (-(2 * s)) ‚Č§ ((k : ‚ĄĚ) ^ (-(2 * s))) := by
    intros m hm
    have h_lb : (k : ‚ĄĚ) ‚Č§ latticeNorm m := latticeNorm_ge_of_mem_annularShell k m hm
    have h_m_pos : 0 < latticeNorm m := lt_of_lt_of_le h_k_pos h_lb
    -- latticeNorm m ‚Č• k > 0, so (latticeNorm m)^{2s} ‚Č• k^{2s}, hence
    -- (latticeNorm m)^{-2s} = 1/(latticeNorm m)^{2s} ‚Č§ 1/k^{2s} = k^{-2s}
    rw [Real.rpow_neg h_k_nn, Real.rpow_neg (le_of_lt h_m_pos)]
    apply inv_anti‚āÄ (Real.rpow_pos_of_pos h_k_pos _)
    exact Real.rpow_le_rpow h_k_nn h_lb h_2s_nn
  -- Sum over shell.
  calc ‚ąĎ m ‚ąą annularShell k, (latticeNorm m) ^ (-(2 * s))
      ‚Č§ ‚ąĎ _ ‚ąą annularShell k, ((k : ‚ĄĚ) ^ (-(2 * s))) := Finset.sum_le_sum h_pointwise
    _ = (annularShell k).card * ((k : ‚ĄĚ) ^ (-(2 * s))) := by
        rw [Finset.sum_const, nsmul_eq_mul]
    _ ‚Č§ ((8 * k + 4 : ‚Ąē) : ‚ĄĚ) * ((k : ‚ĄĚ) ^ (-(2 * s))) := by
        apply mul_le_mul_of_nonneg_right
        ¬∑ exact_mod_cast card_annularShell_le k
        ¬∑ exact Real.rpow_nonneg h_k_nn _

/-! ### ¬ß11.26.F Concrete lattice-zeta constant

Define the ambient lattice-zeta constant as the tsum of the shell-
bounded series over `k ‚Č• 1`:
`latticeZetaConst s := 8¬∑‚ąĎ_{k ‚Č• 1} k^{1-2s} + 4¬∑‚ąĎ_{k ‚Č• 1} k^{-2s}`.

For `s > 1`, both tsums are finite via `Real.summable_one_div_nat_rpow`.
The full `HasLatticeZetaBound s (latticeZetaConst s)` proof is deferred
(requires shell-partition of arbitrary `A ‚äÜ ‚Ą§¬≤ \ {0}` + disjoint
biUnion + partial-sum ‚Č§ tsum bookkeeping; see ¬ß11.26.F next-session
entry).  Infrastructure in-tree for downstream use. -/

/-- **¬ß11.26.F‚āĀ ‚ÄĒ Lattice-zeta constant `latticeZetaConst s`.**
Tsum of the shell-bounded series: `8¬∑ő∂(2s-1) + 4¬∑ő∂(2s)` over `k : ‚Ąē`.
The `k = 0` terms vanish (since `1/0^p = 0` for `p > 0`), so this
matches the Riemann zeta summation from `k = 1`.  For `s > 1`, both
tsums are finite via `Real.summable_one_div_nat_rpow` and this
provides a uniform upper bound on `‚ąĎ_{a ‚ąą A} ‚ÄĖa‚ÄĖ^{-2s}` for every
finite `A ‚äÜ ‚Ą§¬≤ \ {0}` (see ¬ß11.26.H). -/
noncomputable def latticeZetaConst (s : ‚ĄĚ) : ‚ĄĚ :=
  8 * ‚ąĎ' (k : ‚Ąē), 1 / ((k : ‚ĄĚ) ^ (2 * s - 1)) +
  4 * ‚ąĎ' (k : ‚Ąē), 1 / ((k : ‚ĄĚ) ^ (2 * s))

/-- **¬ß11.26.F‚āā ‚ÄĒ `latticeZetaConst s ‚Č• 0`.** -/
lemma latticeZetaConst_nonneg (s : ‚ĄĚ) : 0 ‚Č§ latticeZetaConst s := by
  unfold latticeZetaConst
  apply add_nonneg
  ¬∑ apply mul_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 8)
    apply tsum_nonneg
    intros k
    apply div_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1)
    exact Real.rpow_nonneg (Nat.cast_nonneg _) _
  ¬∑ apply mul_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 4)
    apply tsum_nonneg
    intros k
    apply div_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1)
    exact Real.rpow_nonneg (Nat.cast_nonneg _) _

/-! ### ¬ß11.26.G Shell-index preliminaries

The `‚Ąď‚ąě`-radius `shellOf m := max(|m 0|.toNat, |m 1|.toNat)` gives
the annular-shell level of `m ‚Č† 0`.  Three facts for the main bound:
1. `shellOf m ‚Č• 1` for `m ‚Č† 0` (¬ß11.26.G‚āĀ).
2. `m ‚ąą annularShell (shellOf m)` for `m ‚Č† 0` (¬ß11.26.G‚āā).
3. Distinct shells are disjoint (¬ß11.26.G‚āÉ). -/

/-- **¬ß11.26.G ‚ÄĒ Shell-index function.** -/
def shellOf (m : Fin 2 ‚Üí ‚Ą§) : ‚Ąē := max (|m 0|).toNat (|m 1|).toNat

/-- **¬ß11.26.G‚āĀ ‚ÄĒ Positivity of `shellOf` on nonzero lattice points.** -/
lemma shellOf_pos_of_ne_zero (m : Fin 2 ‚Üí ‚Ą§) (hm : m ‚Č† 0) :
    1 ‚Č§ shellOf m := by
  unfold shellOf
  by_cases h0 : m 0 = 0
  ¬∑ by_cases h1 : m 1 = 0
    ¬∑ exact absurd (funext fun i => by fin_cases i <;> [exact h0; exact h1]) hm
    ¬∑ have ha : 0 < |m 1| := abs_pos.mpr h1
      have hb : 1 ‚Č§ (|m 1|).toNat := by omega
      exact le_trans hb (le_max_right _ _)
  ¬∑ have ha : 0 < |m 0| := abs_pos.mpr h0
    have hb : 1 ‚Č§ (|m 0|).toNat := by omega
    exact le_trans hb (le_max_left _ _)

/-- **¬ß11.26.G‚āā ‚ÄĒ Each `m ‚Č† 0` lies in `annularShell (shellOf m)`.** -/
lemma mem_annularShell_shellOf (m : Fin 2 ‚Üí ‚Ą§) (hm : m ‚Č† 0) :
    m ‚ąą annularShell (shellOf m) := by
  rw [mem_annularShell_iff]
  refine ‚ü®?_, hm, ?_‚ü©
  ¬∑ intro i
    fin_cases i
    ¬∑ have h_cast : ((|m 0|).toNat : ‚Ą§) = |m 0| :=
        Int.toNat_of_nonneg (abs_nonneg _)
      have h_le : (|m 0|).toNat ‚Č§ shellOf m := le_max_left _ _
      calc |m 0| = ((|m 0|).toNat : ‚Ą§) := h_cast.symm
        _ ‚Č§ ((shellOf m : ‚Ąē) : ‚Ą§) := by exact_mod_cast h_le
    ¬∑ have h_cast : ((|m 1|).toNat : ‚Ą§) = |m 1| :=
        Int.toNat_of_nonneg (abs_nonneg _)
      have h_le : (|m 1|).toNat ‚Č§ shellOf m := le_max_right _ _
      calc |m 1| = ((|m 1|).toNat : ‚Ą§) := h_cast.symm
        _ ‚Č§ ((shellOf m : ‚Ąē) : ‚Ą§) := by exact_mod_cast h_le
  ¬∑ rcases max_choice (|m 0|).toNat (|m 1|).toNat with h | h
    ¬∑ left
      have h_cast : ((|m 0|).toNat : ‚Ą§) = |m 0| :=
        Int.toNat_of_nonneg (abs_nonneg _)
      unfold shellOf
      calc |m 0| = ((|m 0|).toNat : ‚Ą§) := h_cast.symm
        _ = ((max (|m 0|).toNat (|m 1|).toNat : ‚Ąē) : ‚Ą§) := by
            exact_mod_cast h.symm
    ¬∑ right
      have h_cast : ((|m 1|).toNat : ‚Ą§) = |m 1| :=
        Int.toNat_of_nonneg (abs_nonneg _)
      unfold shellOf
      calc |m 1| = ((|m 1|).toNat : ‚Ą§) := h_cast.symm
        _ = ((max (|m 0|).toNat (|m 1|).toNat : ‚Ąē) : ‚Ą§) := by
            exact_mod_cast h.symm

/-- **¬ß11.26.G‚āÉ ‚ÄĒ Annular shells at distinct indices are disjoint.** -/
lemma annularShell_disjoint {k‚āĀ k‚āā : ‚Ąē} (hne : k‚āĀ ‚Č† k‚āā) :
    Disjoint (annularShell k‚āĀ) (annularShell k‚āā) := by
  rw [Finset.disjoint_left]
  intros m hm1 hm2
  rw [mem_annularShell_iff] at hm1 hm2
  obtain ‚ü®h_Icc1, _, h_max1‚ü© := hm1
  obtain ‚ü®h_Icc2, _, h_max2‚ü© := hm2
  apply hne
  have h1_0 : |m 0| ‚Č§ (k‚āĀ : ‚Ą§) := h_Icc1 0
  have h1_1 : |m 1| ‚Č§ (k‚āĀ : ‚Ą§) := h_Icc1 1
  have h2_0 : |m 0| ‚Č§ (k‚āā : ‚Ą§) := h_Icc2 0
  have h2_1 : |m 1| ‚Č§ (k‚āā : ‚Ą§) := h_Icc2 1
  rcases h_max1 with h‚āĀ | h‚āĀ <;> rcases h_max2 with h‚āā | h‚āā <;>
    ¬∑ have h_int : (k‚āĀ : ‚Ą§) = (k‚āā : ‚Ą§) := by omega
      exact_mod_cast h_int

/-! ### ¬ß11.26.H Concrete lattice-zeta bound

Unconditional witness of `HasLatticeZetaBound s (latticeZetaConst s)`
for `s > 1`.  Partition any finite `A ‚äÜ ‚Ą§¬≤ \ {0}` by `shellOf`,
decompose via disjoint `biUnion`, bound each shell sum via ¬ß11.26.E,
then bridge the finite shell sum to the `tsum` defining
`latticeZetaConst` via `Summable.sum_le_tsum` on the two p-series. -/

/-- **¬ß11.26.H ‚ÄĒ Concrete `HasLatticeZetaBound s (latticeZetaConst s)`
for `s > 1`.**  This closes the lattice-zeta leg of Route A Item 5.A
(¬ß11.25.F/F‚āĀ/G/G‚āĀ composed with this witness gives the full
support-independent Banach-algebra `ŠłĘňĘ` bound). -/
theorem hasLatticeZetaBound_latticeZetaConst {s : ‚ĄĚ} (hs : 1 < s) :
    HasLatticeZetaBound s (latticeZetaConst s) := by
  refine ‚ü®latticeZetaConst_nonneg s, ?_‚ü©
  classical
  intros A hA0
  -- Index set: image of A under shellOf.
  set K : Finset ‚Ąē := A.image shellOf with hK_def
  -- Step 1 (cover): A ‚äÜ K.biUnion annularShell
  have h_sub : A ‚äÜ K.biUnion annularShell := by
    intros m hm
    have hm_ne : m ‚Č† 0 := fun h => hA0 (h ‚Ėł hm)
    rw [Finset.mem_biUnion]
    exact ‚ü®shellOf m, Finset.mem_image.mpr ‚ü®m, hm, rfl‚ü©,
      mem_annularShell_shellOf m hm_ne‚ü©
  -- Step 2: extend sum to biUnion (non-neg summands).
  have h_nn_term : ‚ąÄ a : Fin 2 ‚Üí ‚Ą§, 0 ‚Č§ (latticeNorm a) ^ (-(2 * s)) :=
    fun a => Real.rpow_nonneg (latticeNorm_nonneg a) _
  have h_ext : ‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s))
      ‚Č§ ‚ąĎ a ‚ąą K.biUnion annularShell, (latticeNorm a) ^ (-(2 * s)) :=
    Finset.sum_le_sum_of_subset_of_nonneg h_sub
      (fun a _ _ => h_nn_term a)
  -- Step 3: decompose biUnion via pairwise-disjoint shells.
  have h_pairwise : (‚ÜĎK : Set ‚Ąē).PairwiseDisjoint annularShell :=
    fun _ _ _ _ hne => annularShell_disjoint hne
  have h_biUnion :
      ‚ąĎ a ‚ąą K.biUnion annularShell, (latticeNorm a) ^ (-(2 * s))
        = ‚ąĎ k ‚ąą K, ‚ąĎ a ‚ąą annularShell k, (latticeNorm a) ^ (-(2 * s)) :=
    Finset.sum_biUnion h_pairwise
  rw [h_biUnion] at h_ext
  -- Step 4: k ‚Č• 1 for k ‚ąą K.
  have h_k_pos : ‚ąÄ k ‚ąą K, 1 ‚Č§ k := by
    intros k hk
    rw [hK_def, Finset.mem_image] at hk
    obtain ‚ü®m, hm, rfl‚ü© := hk
    exact shellOf_pos_of_ne_zero m (fun h => hA0 (h ‚Ėł hm))
  -- Step 5: per-shell bound via ¬ß11.26.E.
  have h_shell_bd : ‚ąÄ k ‚ąą K,
      ‚ąĎ a ‚ąą annularShell k, (latticeNorm a) ^ (-(2 * s))
        ‚Č§ ((8 * k + 4 : ‚Ąē) : ‚ĄĚ) * ((k : ‚ĄĚ) ^ (-(2 * s))) :=
    fun k hk => sum_annularShell_rpow_le (by linarith : (0 : ‚ĄĚ) < s)
      (h_k_pos k hk)
  have h_shell_sum :
      ‚ąĎ k ‚ąą K, ‚ąĎ a ‚ąą annularShell k, (latticeNorm a) ^ (-(2 * s))
        ‚Č§ ‚ąĎ k ‚ąą K, ((8 * k + 4 : ‚Ąē) : ‚ĄĚ) * ((k : ‚ĄĚ) ^ (-(2 * s))) :=
    Finset.sum_le_sum h_shell_bd
  -- Step 6: algebraic split (8k+4)¬∑k^{-2s} = 8¬∑k^{1-2s} + 4¬∑k^{-2s}.
  have h_term_split : ‚ąÄ k ‚ąą K,
      ((8 * k + 4 : ‚Ąē) : ‚ĄĚ) * ((k : ‚ĄĚ) ^ (-(2 * s)))
        = 8 * ((k : ‚ĄĚ) ^ (1 - 2 * s)) + 4 * ((k : ‚ĄĚ) ^ (-(2 * s))) := by
    intros k hk
    have hk_pos : (0 : ‚ĄĚ) < k := by exact_mod_cast h_k_pos k hk
    have h_rpow : (k : ‚ĄĚ) ^ (1 - 2 * s) = (k : ‚ĄĚ) * (k : ‚ĄĚ) ^ (-(2 * s)) := by
      rw [show (1 - 2 * s) = (1 : ‚ĄĚ) + (-(2 * s)) from by ring,
          Real.rpow_add hk_pos, Real.rpow_one]
    push_cast
    rw [h_rpow]
    ring
  have h_split_sum :
      ‚ąĎ k ‚ąą K, ((8 * k + 4 : ‚Ąē) : ‚ĄĚ) * ((k : ‚ĄĚ) ^ (-(2 * s)))
        = 8 * (‚ąĎ k ‚ąą K, ((k : ‚ĄĚ) ^ (1 - 2 * s)))
          + 4 * (‚ąĎ k ‚ąą K, ((k : ‚ĄĚ) ^ (-(2 * s)))) := by
    calc ‚ąĎ k ‚ąą K, ((8 * k + 4 : ‚Ąē) : ‚ĄĚ) * ((k : ‚ĄĚ) ^ (-(2 * s)))
        = ‚ąĎ k ‚ąą K, (8 * ((k : ‚ĄĚ) ^ (1 - 2 * s))
            + 4 * ((k : ‚ĄĚ) ^ (-(2 * s)))) := Finset.sum_congr rfl h_term_split
      _ = (‚ąĎ k ‚ąą K, 8 * ((k : ‚ĄĚ) ^ (1 - 2 * s)))
            + (‚ąĎ k ‚ąą K, 4 * ((k : ‚ĄĚ) ^ (-(2 * s)))) := Finset.sum_add_distrib
      _ = 8 * (‚ąĎ k ‚ąą K, ((k : ‚ĄĚ) ^ (1 - 2 * s)))
            + 4 * (‚ąĎ k ‚ąą K, ((k : ‚ĄĚ) ^ (-(2 * s)))) := by
            rw [‚Üź Finset.mul_sum, ‚Üź Finset.mul_sum]
  -- Step 7: bridge (k:‚ĄĚ)^p form to 1/(k:‚ĄĚ)^p form on K.
  have h_rw1 : ‚ąÄ k ‚ąą K,
      ((k : ‚ĄĚ) ^ (1 - 2 * s)) = 1 / ((k : ‚ĄĚ) ^ (2 * s - 1)) := by
    intros k hk
    have hk_pos : (0 : ‚ĄĚ) < k := by exact_mod_cast h_k_pos k hk
    rw [show (1 - 2 * s) = -(2 * s - 1) from by ring,
        Real.rpow_neg (le_of_lt hk_pos), inv_eq_one_div]
  have h_rw2 : ‚ąÄ k ‚ąą K,
      ((k : ‚ĄĚ) ^ (-(2 * s))) = 1 / ((k : ‚ĄĚ) ^ (2 * s)) := by
    intros k hk
    have hk_pos : (0 : ‚ĄĚ) < k := by exact_mod_cast h_k_pos k hk
    rw [Real.rpow_neg (le_of_lt hk_pos), inv_eq_one_div]
  have h_sum_eq1 : ‚ąĎ k ‚ąą K, ((k : ‚ĄĚ) ^ (1 - 2 * s))
      = ‚ąĎ k ‚ąą K, 1 / ((k : ‚ĄĚ) ^ (2 * s - 1)) :=
    Finset.sum_congr rfl h_rw1
  have h_sum_eq2 : ‚ąĎ k ‚ąą K, ((k : ‚ĄĚ) ^ (-(2 * s)))
      = ‚ąĎ k ‚ąą K, 1 / ((k : ‚ĄĚ) ^ (2 * s)) :=
    Finset.sum_congr rfl h_rw2
  -- Step 8: finite sums bounded by tsum via summability.
  have h_summ1 : Summable (fun k : ‚Ąē => 1 / ((k : ‚ĄĚ) ^ (2 * s - 1))) := by
    rw [Real.summable_one_div_nat_rpow]; linarith
  have h_summ2 : Summable (fun k : ‚Ąē => 1 / ((k : ‚ĄĚ) ^ (2 * s))) := by
    rw [Real.summable_one_div_nat_rpow]; linarith
  have h_nn_f1 : ‚ąÄ k : ‚Ąē, 0 ‚Č§ 1 / ((k : ‚ĄĚ) ^ (2 * s - 1)) := fun k =>
    div_nonneg zero_le_one (Real.rpow_nonneg (Nat.cast_nonneg _) _)
  have h_nn_f2 : ‚ąÄ k : ‚Ąē, 0 ‚Č§ 1 / ((k : ‚ĄĚ) ^ (2 * s)) := fun k =>
    div_nonneg zero_le_one (Real.rpow_nonneg (Nat.cast_nonneg _) _)
  have h_tsum1 : ‚ąĎ k ‚ąą K, 1 / ((k : ‚ĄĚ) ^ (2 * s - 1))
      ‚Č§ ‚ąĎ' (k : ‚Ąē), 1 / ((k : ‚ĄĚ) ^ (2 * s - 1)) :=
    h_summ1.sum_le_tsum K (fun k _ => h_nn_f1 k)
  have h_tsum2 : ‚ąĎ k ‚ąą K, 1 / ((k : ‚ĄĚ) ^ (2 * s))
      ‚Č§ ‚ąĎ' (k : ‚Ąē), 1 / ((k : ‚ĄĚ) ^ (2 * s)) :=
    h_summ2.sum_le_tsum K (fun k _ => h_nn_f2 k)
  -- Step 9: assemble.
  calc ‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s))
      ‚Č§ ‚ąĎ k ‚ąą K, ‚ąĎ a ‚ąą annularShell k, (latticeNorm a) ^ (-(2 * s)) := h_ext
    _ ‚Č§ ‚ąĎ k ‚ąą K, ((8 * k + 4 : ‚Ąē) : ‚ĄĚ) * ((k : ‚ĄĚ) ^ (-(2 * s))) := h_shell_sum
    _ = 8 * (‚ąĎ k ‚ąą K, ((k : ‚ĄĚ) ^ (1 - 2 * s)))
        + 4 * (‚ąĎ k ‚ąą K, ((k : ‚ĄĚ) ^ (-(2 * s)))) := h_split_sum
    _ = 8 * (‚ąĎ k ‚ąą K, 1 / ((k : ‚ĄĚ) ^ (2 * s - 1)))
        + 4 * (‚ąĎ k ‚ąą K, 1 / ((k : ‚ĄĚ) ^ (2 * s))) := by
          rw [h_sum_eq1, h_sum_eq2]
    _ ‚Č§ 8 * (‚ąĎ' (k : ‚Ąē), 1 / ((k : ‚ĄĚ) ^ (2 * s - 1)))
        + 4 * (‚ąĎ' (k : ‚Ąē), 1 / ((k : ‚ĄĚ) ^ (2 * s))) := by
          apply add_le_add
          ¬∑ exact mul_le_mul_of_nonneg_left h_tsum1 (by norm_num : (0 : ‚ĄĚ) ‚Č§ 8)
          ¬∑ exact mul_le_mul_of_nonneg_left h_tsum2 (by norm_num : (0 : ‚ĄĚ) ‚Č§ 4)
    _ = latticeZetaConst s := by rw [latticeZetaConst]

/-! ### ¬ß11.27 Fully unconditional Banach-algebra `ŠłĘňĘ` product bound

Composition of ¬ß11.26.H (concrete `HasLatticeZetaBound s (latticeZetaConst s)`
for `s > 1`) with ¬ß11.25.G `HasTrigPolyBanachAlgebraBound.of_latticeZeta`
(concrete Banach-algebra bound from a lattice-zeta witness) yields an
**unconditional** `HasTrigPolyBanachAlgebraBound` witness for every
`s > 1` with concrete constant `2^{2s}¬∑(2¬∑latticeZetaConst s)`.

This is the first Banach-algebra product bound in the project with
zero open hypotheses ‚ÄĒ the entire lattice-zeta leg of Route A
Item 5.A is now unconditional. -/

/-- **¬ß11.27 ‚ÄĒ Unconditional `HasTrigPolyBanachAlgebraBound` for `s > 1`.**
Concrete witness with constant `2^{2s}¬∑(2¬∑latticeZetaConst s)`.
Compose ¬ß11.25.G `.of_latticeZeta` with ¬ß11.26.H
`hasLatticeZetaBound_latticeZetaConst`. -/
theorem hasTrigPolyBanachAlgebraBound_of_gt_one {s : ‚ĄĚ} (hs : 1 < s) :
    HasTrigPolyBanachAlgebraBound s
      (2 ^ (2 * s) * (2 * latticeZetaConst s)) :=
  HasTrigPolyBanachAlgebraBound.of_latticeZeta (le_of_lt hs)
    (hasLatticeZetaBound_latticeZetaConst hs)

/-- **¬ß11.27.A ‚ÄĒ Explicit zero-coefficient exemplar on the
unconditional bound.**  Exercises ¬ß11.27 on the zero left factor:
`hsSeminormSq s (trigPolyProduct A B 0 cg) = 0 ‚Č§ 2^{2s}¬∑(2¬∑latticeZetaConst s)
    ¬∑ hsSeminormSq s (trigPoly A 0) ¬∑ hsSeminormSq s (trigPoly B cg)`.

Since the LHS is zero (via ¬ß11.25.H‚āĀ) and the RHS is a product of
non-negative reals, the inequality holds trivially.  Sanity check
that the unconditional bound reduces correctly on zero factors. -/
theorem hasTrigPolyBanachAlgebraBound_of_gt_one_zero_left
    {s : ‚ĄĚ} (hs : 1 < s)
    (A B : Finset (Fin 2 ‚Üí ‚Ą§)) (cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A) (hB : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ B) :
    hsSeminormSq s (trigPolyProduct A B (fun _ => (0 : ‚Ąā)) cg)
      ‚Č§ (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * hsSeminormSq s (trigPoly A (fun _ => (0 : ‚Ąā)))
          * hsSeminormSq s (trigPoly B cg) := by
  exact (hasTrigPolyBanachAlgebraBound_of_gt_one hs).bound A B _ cg hA hB

/-! ### ¬ß11.28 Self-product specialization

When `A = B` and `cf = cg`, ¬ß11.27 reduces to a bound on the ŠłĘňĘ norm
of the self-square `‚ÄĖf¬≤‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ C ¬∑ (‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ})¬≤`.  This is the
natural form used in Gronwall energy estimates for quadratic
nonlinearities (e.g., Burgers `‚ąā_t őł + őł ¬∑ ‚ąā_x őł = 0`). -/

/-- **¬ß11.28 ‚ÄĒ Self-product Banach-algebra bound.**
For `s > 1` and `0 ‚ąČ A`:
  `‚ÄĖf¬≤‚ÄĖ¬≤_{ŠłĘňĘ} ‚Č§ 2^{2s}¬∑(2¬∑latticeZetaConst s) ¬∑ (‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ})¬≤`
where `f = trigPoly A cf` and `f¬≤ = trigPolyProduct A A cf cf`. -/
theorem hsSeminormSq_trigPolyProduct_self_le {s : ‚ĄĚ} (hs : 1 < s)
    (A : Finset (Fin 2 ‚Üí ‚Ą§)) (cf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā)
    (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A) :
    hsSeminormSq s (trigPolyProduct A A cf cf)
      ‚Č§ (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * (hsSeminormSq s (trigPoly A cf)) ^ 2 := by
  have h := (hasTrigPolyBanachAlgebraBound_of_gt_one hs).bound A A cf cf hA hA
  calc hsSeminormSq s (trigPolyProduct A A cf cf)
      ‚Č§ (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * hsSeminormSq s (trigPoly A cf) * hsSeminormSq s (trigPoly A cf) := h
    _ = (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * (hsSeminormSq s (trigPoly A cf)) ^ 2 := by ring

/-! ### ¬ß11.30 Unconditional `‚Ąď¬Ļ ‚Üí ŠłĘňĘ` Cauchy‚ÄďSchwarz bound (`s > 1`)

Direct composition of ¬ß11.23 (`‚Ąď¬Ļ` Cauchy‚ÄďSchwarz with lattice weight)
and ¬ß11.26.H (concrete `HasLatticeZetaBound`) gives an unconditional
bound

  `(‚ąĎ_a ‚ÄĖcf a‚ÄĖ)¬≤ ‚Č§ latticeZetaConst s ¬∑ hsSeminormSq s (trigPoly A cf)`

for `s > 1`, `0 ‚ąČ A`.  This is the Fourier-side form of the classical
Sobolev embedding `ŠłĘňĘ ‚äā L‚ąě` on `ūĚēč¬≤` for `s > d/2 = 1`: the `‚Ąď¬Ļ`
coefficient norm bounds the `L‚ąě` norm of the trig polynomial
(`|trigPoly A cf (x)| ‚Č§ ‚ąĎ_a ‚ÄĖcf a‚ÄĖ`), and this lemma bounds the
`‚Ąď¬Ļ` coefficient norm by the `ŠłĘňĘ` seminorm with an explicit
(uniform-in-support) constant. -/

/-- **¬ß11.30 ‚ÄĒ Unconditional `‚Ąď¬Ļ` Cauchy‚ÄďSchwarz bound on trig polys.**
For `s > 1`, `0 ‚ąČ A`: `(‚ąĎ_a ‚ÄĖcf a‚ÄĖ)¬≤ ‚Č§ latticeZetaConst s ¬∑ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ}`
where `f = trigPoly A cf`.  Composition of ¬ß11.23.A with ¬ß11.26.H. -/
theorem sum_norm_sq_le_latticeZeta_mul_hsSeminormSq
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {s : ‚ĄĚ} (hs : 1 < s) {A : Finset (Fin 2 ‚Üí ‚Ą§)}
    (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A) (cf : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) ^ 2
      ‚Č§ latticeZetaConst s * hsSeminormSq s (trigPoly A cf) := by
  have h_cs := sum_norm_sq_le_latticeWeight_mul_hsSeminormSq
    hA (by linarith : (0 : ‚ĄĚ) < s) cf
  have h_zeta := (hasLatticeZetaBound_latticeZetaConst hs).bound A hA
  have h_seminorm_nn : 0 ‚Č§ hsSeminormSq s (trigPoly A cf) :=
    hsSeminormSq_nonneg_any _ _
  calc (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ) ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf) := h_cs
    _ ‚Č§ latticeZetaConst s * hsSeminormSq s (trigPoly A cf) :=
        mul_le_mul_of_nonneg_right h_zeta h_seminorm_nn

/-! ### ¬ß11.31 Unconditional uniform `L¬≤` product bound (`s > 1`)

Composition of ¬ß11.24 (uniform-in-support L¬≤ product bound,
parametrised on the lattice weight `C_s(A) = ‚ąĎ_a ‚ÄĖa‚ÄĖ^{-2s}`) with
¬ß11.26.H (concrete `HasLatticeZetaBound` witness at `s > 1`) gives
the unconditional bound

  `‚ąĎ_n ‚ÄĖmodeConv(n)‚ÄĖ¬≤ ‚Č§ latticeZetaConst s ¬∑ ‚ÄĖf‚ÄĖ¬≤_{ŠłĘňĘ} ¬∑ (‚ąĎ_b ‚ÄĖcg b‚ÄĖ¬≤)`

for every finite `A ‚äÜ ‚Ą§¬≤ \ {0}`, `B ‚äÜ ‚Ą§¬≤`, `s > 1`.  The constant
`latticeZetaConst s` is uniform in `A` and `B`.  On the SQG Galerkin
scheme at `A = sqgBox n`, this delivers the uniform-in-`n`
`L¬≤ √ó ŠłĘňĘ ‚Üí L¬≤` product bound. -/

/-- **¬ß11.31 ‚ÄĒ Unconditional uniform L¬≤ product bound for `s > 1`.**
Direct composition of ¬ß11.24 with ¬ß11.26.H. -/
theorem l2_trigPolyProduct_le_latticeZeta
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {s : ‚ĄĚ} (hs : 1 < s) {A B : Finset (Fin 2 ‚Üí ‚Ą§)}
    (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ latticeZetaConst s * hsSeminormSq s (trigPoly A cf)
          * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by
  have h_u := l2_trigPolyProduct_le_uniform (A := A) (B := B) hA
    (by linarith : (0 : ‚ĄĚ) < s) cf cg
  have h_zeta := (hasLatticeZetaBound_latticeZetaConst hs).bound A hA
  have h_seminorm_nn : 0 ‚Č§ hsSeminormSq s (trigPoly A cf) :=
    hsSeminormSq_nonneg_any _ _
  have h_cg_nn : 0 ‚Č§ ‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2 :=
    Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  have h_nn_prod : 0 ‚Č§ hsSeminormSq s (trigPoly A cf) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) :=
    mul_nonneg h_seminorm_nn h_cg_nn
  calc ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
          * hsSeminormSq s (trigPoly A cf)
          * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := h_u
    _ = (‚ąĎ a ‚ąą A, (latticeNorm a) ^ (-(2 * s)))
          * (hsSeminormSq s (trigPoly A cf) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2)) := by ring
    _ ‚Č§ latticeZetaConst s
          * (hsSeminormSq s (trigPoly A cf) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2)) :=
          mul_le_mul_of_nonneg_right h_zeta h_nn_prod
    _ = latticeZetaConst s * hsSeminormSq s (trigPoly A cf)
          * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ ^ 2) := by ring

/-! ### ¬ß11.32 Symmetric unconditional uniform `L¬≤` product bound

Swapped variant of ¬ß11.31 via ¬ß11.25.B (symmetric Young): ‚Ąď¬≤ on `cf`,
‚Ąď¬Ļ on `cg` (instead of ¬ß11.22's ‚Ąď¬Ļ on `cf`, ‚Ąď¬≤ on `cg`).  Combined
with ¬ß11.30 applied to `B` gives the unconditional

  `‚ąĎ_n ‚ÄĖmodeConv(n)‚ÄĖ¬≤ ‚Č§ (‚ąĎ_a ‚ÄĖcf a‚ÄĖ¬≤) ¬∑ latticeZetaConst s ¬∑ ‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ}`

for `s > 1`, `0 ‚ąČ B`.  This is the `L¬≤ √ó ŠłĘňĘ ‚Üí L¬≤` bound with ŠłĘňĘ
control on the SECOND factor rather than the first. -/

/-- **¬ß11.32 ‚ÄĒ Symmetric form of ¬ß11.31.**  For `s > 1`, `0 ‚ąČ B`:
`‚ąĎ_n ‚ÄĖmodeConv(n)‚ÄĖ¬≤ ‚Č§ (‚ąĎ_a ‚ÄĖcf a‚ÄĖ¬≤) ¬∑ latticeZetaConst s ¬∑ ‚ÄĖg‚ÄĖ¬≤_{ŠłĘňĘ}`
via ¬ß11.25.B (swapped Young) + ¬ß11.30 on `B`. -/
theorem l2_trigPolyProduct_le_latticeZeta_symm
    [DecidableEq (Fin 2 ‚Üí ‚Ą§)]
    {s : ‚ĄĚ} (hs : 1 < s) {A B : Finset (Fin 2 ‚Üí ‚Ą§)}
    (hB : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ B) (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2) * latticeZetaConst s
          * hsSeminormSq s (trigPoly B cg) := by
  have h_young :=
    hsSeminormSq_zero_trigPolyProduct_le_young_symm A B cf cg
  have h_cs_B :=
    sum_norm_sq_le_latticeZeta_mul_hsSeminormSq hs hB cg
  have h_cf_nn : 0 ‚Č§ ‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2 :=
    Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  calc ‚ąĎ n ‚ąą sumSet A B, ‚ÄĖmodeConvolution A B cf cg n‚ÄĖ ^ 2
      ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2) * (‚ąĎ b ‚ąą B, ‚ÄĖcg b‚ÄĖ) ^ 2 := h_young
    _ ‚Č§ (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2)
          * (latticeZetaConst s * hsSeminormSq s (trigPoly B cg)) :=
          mul_le_mul_of_nonneg_left h_cs_B h_cf_nn
    _ = (‚ąĎ a ‚ąą A, ‚ÄĖcf a‚ÄĖ ^ 2) * latticeZetaConst s
          * hsSeminormSq s (trigPoly B cg) := by ring

/-! ### ¬ß11.33 ŠłĘŠĶó interpolation form of the Banach-algebra bound

The ¬ß11.27 bound at exponent `s > 1` implies a ŠłĘŠĶó bound at every
`t ‚ąą [0, s]` via `hsSeminormSq_mono_of_le` (monotonicity in the
exponent).  Useful when the consumer needs the product's `ŠłĘŠĶó`
seminorm controlled by the factors' `ŠłĘňĘ` seminorms at a lower
regularity `t`, e.g. `t = 1` with `s = 3/2` for SQG energy. -/

/-- **¬ß11.33 ‚ÄĒ Banach-algebra `ŠłĘŠĶó` bound for `t ‚ąą [0, s]`, `s > 1`.**
  Interpolation of ¬ß11.27 via `hsSeminormSq_mono_of_le`.

  **Note:** `[DecidableEq (Fin 2 ‚Üí ‚Ą§)]` is OMITTED from the signature
  (uses the structure's default `decidablePiFintype`), matching the
  diagnostic pattern codified in ¬ß11.25.G ‚ÄĒ an explicit class parameter
  creates a fresh `inst‚úĚ` that mismatches the structure field's
  default-synthesized instance, triggering an `isDefEq`/`whnf` timeout. -/
theorem hsSeminormSq_trigPolyProduct_le_latticeZeta_interp
    {s t : ‚ĄĚ} (hs : 1 < s) (hts : t ‚Č§ s)
    {A B : Finset (Fin 2 ‚Üí ‚Ą§)}
    (hA : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ A) (hB : (0 : Fin 2 ‚Üí ‚Ą§) ‚ąČ B)
    (cf cg : (Fin 2 ‚Üí ‚Ą§) ‚Üí ‚Ąā) :
    hsSeminormSq t (trigPolyProduct A B cf cg)
      ‚Č§ (2 ^ (2 * s) * (2 * latticeZetaConst s))
          * hsSeminormSq s (trigPoly A cf)
          * hsSeminormSq s (trigPoly B cg) := by
  classical
  -- Summability at s via finite-support of trigPolyProduct on sumSet A B.
  have h_supp : ‚ąÄ n ‚ąČ sumSet A B,
      mFourierCoeff (trigPolyProduct A B cf cg) n = 0 :=
    fun n hn => mFourierCoeff_trigPolyProduct_eq_zero_of_not_mem hn
  have h_summable_s : Summable (fun n : Fin 2 ‚Üí ‚Ą§ =>
      (fracDerivSymbol s n) ^ 2 * ‚ÄĖmFourierCoeff (trigPolyProduct A B cf cg) n‚ÄĖ ^ 2) :=
    hsSeminormSq_summable_of_finite_support s _ (sumSet A B) h_supp
  have h_mono : hsSeminormSq t (trigPolyProduct A B cf cg)
      ‚Č§ hsSeminormSq s (trigPolyProduct A B cf cg) :=
    hsSeminormSq_mono_of_le hts _ h_summable_s
  have h_prod := (hasTrigPolyBanachAlgebraBound_of_gt_one hs).bound A B cf cg hA hB
  exact le_trans h_mono h_prod

