theorem BKMCriterionS2.of_L2_limit_uniform_Hs
    (őł : ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (f‚āô : ‚Ąē ‚Üí ‚ĄĚ ‚Üí Lp ‚Ąā 2 (volume : Measure (UnitAddTorus (Fin 2))))
    (hConv : ‚ąÄ t : ‚ĄĚ, 0 ‚Č§ t ‚Üí
